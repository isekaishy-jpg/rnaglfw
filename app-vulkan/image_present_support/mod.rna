        select self.device_local_surface_vulkan_image_plan :: :: method:
            when Result.Ok(plan) => return self.image_from_plan_with_image :: plan, source :: method
            when Result.Err(err) => return Result.Err :: err :: call

    fn present_vulkan_image(edit self, edit image: VulkanImage) -> Result[Unit, VulkanPresentError]:
        select validate_surface_present_image :: self, image :: call:
            when Result.Ok(_) =>
                let request = PresentSurfaceCopyImageRequest :: :: call
                    image = image.image_handle :: :: method
                    source_layout = image.layout_code :: :: method
                    source_width = image.width :: :: method
                    source_height = image.height :: :: method
                    source_format = image.format :: :: method
                select present_surface_copy_image_raw :: self, request :: call:
                    when Result.Ok(_) =>
                        image.layout = VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL
                        return Result.Ok :: () :: call
                    when Result.Err(err) => return Result.Err :: err :: call
            when Result.Err(err) => return Result.Err :: err :: call

