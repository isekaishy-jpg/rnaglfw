            image => return Result.Err :: err :: call

    fn surface_vulkan_image_from_pixels(edit self, memory_type_index: CUInt, take pixels: ByteBuffer) -> Result[VulkanImage, VulkanPresentError]:
        select either:
            when plan: Result.Ok(plan) <- self.surface_vulkan_image_plan :: memory_type_index :: method
            when image: Result.Ok(image) <- self.image_from_plan_with_pixels :: plan, pixels :: method =>
                return Result.Ok :: image :: call

        with Result.Err(err):
            plan => return Result.Err :: err :: call
            image => return Result.Err :: err :: call

