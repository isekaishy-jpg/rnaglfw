    fn destroy(take self) -> Result[Unit, VulkanPresentError]:
        select self.context.destroy :: :: method:
            when Result.Ok(_) =>
                self.app.terminate :: :: method
                return Result.Ok :: () :: call
            when Result.Err(err) =>
                self.app.terminate :: :: method
                return Result.Err :: err :: call

impl VulkanPresentContext:
    fn destroy_present_resources(read self, read resources: PresentResources) -> Unit:
        select:
            when resources.render_complete != 0U64 => #unsafe self.destroy_semaphore :: self.device, resources.render_complete, null :: call
            else => ()
        select:
            when resources.image_available != 0U64 => #unsafe self.destroy_semaphore :: self.device, resources.image_available, null :: call
            else => ()
        select:
            when resources.command_pool != 0U64 => #unsafe self.destroy_command_pool :: self.device, resources.command_pool, null :: call
            else => ()
        return

    fn prepare_present_resources(edit self) -> Result[PresentResources, VulkanPresentError]:
        let resources = PresentResources :: :: call
            command_pool = 0U64
            command_buffer = null
            image_available = 0U64
            render_complete = 0U64
            image_index = 0
            target_image = 0U64

        let command_pool_info = VkCommandPoolCreateInfo :: :: call
            stype = VK_STRUCTURE_TYPE_COMMAND_POOL_CREATE_INFO
            pnext = null
            flags = 0
            queuefamily_index = self.queuefamily
        let command_pool_ptr: *edit VkCommandPool = #unsafe &raw edit resources.command_pool
        let command_pool_info_ptr: *read VkCommandPoolCreateInfo = #unsafe &raw read command_pool_info
        let command_pool_result = #unsafe self.create_command_pool :: self.device, command_pool_info_ptr, null, command_pool_ptr :: call
        select:
            when command_pool_result != VK_SUCCESS || resources.command_pool == 0U64 =>
                let error = VulkanPresentError.CommandPoolCreateFailed :: command_pool_result :: call
                return Result.Err :: error :: call
            else => ()

        let command_buffer_info = VkCommandBufferAllocateInfo :: :: call
            stype = VK_STRUCTURE_TYPE_COMMAND_BUFFER_ALLOCATE_INFO
            pnext = null
            command_pool = resources.command_pool
            level = VK_COMMAND_BUFFER_LEVEL_PRIMARY
            command_buffer_count = 1
        let command_buffer_ptr: *edit VkCommandBuffer = #unsafe &raw edit resources.command_buffer
        let command_buffer_info_ptr: *read VkCommandBufferAllocateInfo = #unsafe &raw read command_buffer_info
        let command_buffer_result = #unsafe self.allocate_command_buffers :: self.device, command_buffer_info_ptr, command_buffer_ptr :: call
        select:
            when command_buffer_result != VK_SUCCESS || resources.command_buffer.is_null :: :: method =>
                self.destroy_present_resources :: resources :: method
                let error = VulkanPresentError.CommandBufferAllocateFailed :: command_buffer_result :: call
                return Result.Err :: error :: call
            else => ()

        let semaphore_info = VkSemaphoreCreateInfo :: :: call
            stype = VK_STRUCTURE_TYPE_SEMAPHORE_CREATE_INFO
            pnext = null
            flags = 0
        let semaphore_info_ptr: *read VkSemaphoreCreateInfo = #unsafe &raw read semaphore_info
        let image_available_ptr: *edit VkSemaphore = #unsafe &raw edit resources.image_available
        let image_available_result = #unsafe self.create_semaphore :: self.device, semaphore_info_ptr, null, image_available_ptr :: call
        select:
            when image_available_result != VK_SUCCESS || resources.image_available == 0U64 =>
                self.destroy_present_resources :: resources :: method
                let error = VulkanPresentError.SemaphoreCreateFailed :: image_available_result :: call
                return Result.Err :: error :: call
            else => ()
        let render_complete_ptr: *edit VkSemaphore = #unsafe &raw edit resources.render_complete
        let render_complete_result = #unsafe self.create_semaphore :: self.device, semaphore_info_ptr, null, render_complete_ptr :: call
        select:
            when render_complete_result != VK_SUCCESS || resources.render_complete == 0U64 =>
                self.destroy_present_resources :: resources :: method
                let error = VulkanPresentError.SemaphoreCreateFailed :: render_complete_result :: call
                return Result.Err :: error :: call
            else => ()

        let image_index_ptr: *edit CUInt = #unsafe &raw edit resources.image_index
        let acquire_result = #unsafe self.acquire_next_image :: self.device, self.swapchain, VK_TIMEOUT_FOREVER, resources.image_available, 0U64, image_index_ptr :: call
        select:
            when acquire_result != VK_SUCCESS && acquire_result != VK_SUBOPTIMAL_KHR =>
                self.destroy_present_resources :: resources :: method
                let error = VulkanPresentError.AcquireFailed :: acquire_result :: call
                return Result.Err :: error :: call
            else => ()
        let Result.Ok(image_slot) = resources.image_index as Maybe[Index] else =>
            self.destroy_present_resources :: resources :: method
            let error = VulkanPresentError.NoSwapchainImages :: :: call
            return Result.Err :: error :: call
        resources.target_image = self.swapchain_images[image_slot]
        return Result.Ok :: resources :: call

    fn transfer_source_buffer_requirements(read self, byte_count: Index) -> Result[VkMemoryRequirements, VulkanPresentError]:
        let Result.Ok(byte_count_u64) = byte_count as Maybe[U64] else =>
            let error = VulkanPresentError.StagingSizeOutOfRange :: byte_count :: call
            return Result.Err :: error :: call
        let buffer: VkBuffer = 0U64
        let buffer_info = VkBufferCreateInfo :: :: call
            stype = VK_STRUCTURE_TYPE_BUFFER_CREATE_INFO
            pnext = null
            flags = 0
            size = byte_count_u64
            usage = VK_BUFFER_USAGE_TRANSFER_SRC_BIT | VK_BUFFER_USAGE_TRANSFER_DST_BIT
            sharing_mode = VK_SHARING_MODE_EXCLUSIVE
            queuefamily_index_count = 0
            queuefamily_indices = null
        let buffer_ptr: *edit VkBuffer = #unsafe &raw edit buffer
        let buffer_info_ptr: *read VkBufferCreateInfo = #unsafe &raw read buffer_info
        let buffer_result = #unsafe self.create_buffer :: self.device, buffer_info_ptr, null, buffer_ptr :: call
        select:
            when buffer_result != VK_SUCCESS || buffer == 0U64 =>
                let error = VulkanPresentError.StagingBufferCreateFailed :: buffer_result :: call
                return Result.Err :: error :: call
            else => ()
        let requirements = VkMemoryRequirements :: :: call
            size = 0U64
            alignment = 0U64
            memory_type_bits = 0
        let requirements_ptr: *edit VkMemoryRequirements = #unsafe &raw edit requirements
        #unsafe self.get_buffer_memory_requirements :: self.device, buffer, requirements_ptr :: call
        #unsafe self.destroy_buffer :: self.device, buffer, null :: call
        return Result.Ok :: requirements :: call

    fn surface_transfer_destination_image_requirements(read self) -> Result[VkMemoryRequirements, VulkanPresentError]:
        let image: VkImage = 0U64
        let image_extent = VkExtent3D :: :: call
            width = self.extent.width
            height = self.extent.height
            depth = 1
        let image_info = VkImageCreateInfo :: :: call
            stype = VK_STRUCTURE_TYPE_IMAGE_CREATE_INFO
            pnext = null
            flags = 0
            image_type = VK_IMAGE_TYPE_2D
            format = self.surface_format.format
            extent = image_extent
            mip_levels = 1
            array_layers = 1
            samples = VK_SAMPLE_COUNT_1_BIT
            tiling = VK_IMAGE_TILING_OPTIMAL
            usage = VK_IMAGE_USAGE_TRANSFER_SRC_BIT | VK_IMAGE_USAGE_TRANSFER_DST_BIT
            sharing_mode = VK_SHARING_MODE_EXCLUSIVE
            queuefamily_index_count = 0
            queuefamily_indices = null
            initial_layout = VK_IMAGE_LAYOUT_UNDEFINED
        let image_ptr: *edit VkImage = #unsafe &raw edit image
        let image_info_ptr: *read VkImageCreateInfo = #unsafe &raw read image_info
        let image_result = #unsafe self.create_image :: self.device, image_info_ptr, null, image_ptr :: call
        select:
            when image_result != VK_SUCCESS || image == 0U64 =>
                let error = VulkanPresentError.TransferDestinationImageCreateFailed :: image_result :: call
                return Result.Err :: error :: call
            else => ()

        let requirements = VkMemoryRequirements :: :: call
            size = 0U64
            alignment = 0U64
            memory_type_bits = 0
        let requirements_ptr: *edit VkMemoryRequirements = #unsafe &raw edit requirements
        #unsafe self.get_image_memory_requirements :: self.device, image, requirements_ptr :: call
        #unsafe self.destroy_image :: self.device, image, null :: call
        return Result.Ok :: requirements :: call

    fn find_staging_memory_type(read self, memory_type_bits: CUInt) -> Result[CUInt, VulkanPresentError]:
        select self.memory_properties.staging_memory_type_index :: memory_type_bits :: method:
            when Option.Some(index) => return Result.Ok :: index :: call
            when Option.None =>
                let error = VulkanPresentError.StagingMemoryTypeUnavailable :: memory_type_bits :: call
                return Result.Err :: error :: call

    fn destroy_surface_transfer_destination_image(read self, take image: VulkanSurfaceTransferDestinationImage) -> Unit:
        select:
            when image.image != 0U64 => #unsafe self.destroy_image :: self.device, image.image, null :: call
            else => ()
        select:
            when image.memory != 0U64 => #unsafe self.free_memory :: self.device, image.memory, null :: call
            else => ()
        return

    fn surface_transfer_destination_image_from_plan(read self, read plan: VulkanSurfaceTransferDestinationImagePlan) -> Result[VulkanSurfaceTransferDestinationImage, VulkanPresentError]:
        let image: VkImage = 0U64
        let memory: VkDeviceMemory = 0U64
        let image_extent = VkExtent3D :: :: call
            width = plan.extent.width
            height = plan.extent.height
            depth = 1
        let image_info = VkImageCreateInfo :: :: call
            stype = VK_STRUCTURE_TYPE_IMAGE_CREATE_INFO
            pnext = null
            flags = 0
            image_type = VK_IMAGE_TYPE_2D
            format = plan.surface_format.format
            extent = image_extent
            mip_levels = 1
            array_layers = 1
            samples = VK_SAMPLE_COUNT_1_BIT
            tiling = VK_IMAGE_TILING_OPTIMAL
            usage = VK_IMAGE_USAGE_TRANSFER_SRC_BIT | VK_IMAGE_USAGE_TRANSFER_DST_BIT
            sharing_mode = VK_SHARING_MODE_EXCLUSIVE
            queuefamily_index_count = 0
            queuefamily_indices = null
            initial_layout = VK_IMAGE_LAYOUT_UNDEFINED
        let image_ptr: *edit VkImage = #unsafe &raw edit image
        let image_info_ptr: *read VkImageCreateInfo = #unsafe &raw read image_info
        let image_result = #unsafe self.create_image :: self.device, image_info_ptr, null, image_ptr :: call
        select:
            when image_result != VK_SUCCESS || image == 0U64 =>
                let error = VulkanPresentError.TransferDestinationImageCreateFailed :: image_result :: call
                return Result.Err :: error :: call
            else => ()

        let allocation_info = VkMemoryAllocateInfo :: :: call
            stype = VK_STRUCTURE_TYPE_MEMORY_ALLOCATE_INFO
            pnext = null
            allocation_size = plan.requirements.size
            memory_type_index = plan.allocation_plan.memory_type_index
        let allocation_info_ptr: *read VkMemoryAllocateInfo = #unsafe &raw read allocation_info
        let memory_ptr: *edit VkDeviceMemory = #unsafe &raw edit memory
        let allocate_result = #unsafe self.allocate_memory :: self.device, allocation_info_ptr, null, memory_ptr :: call
        select:
            when allocate_result != VK_SUCCESS || memory == 0U64 =>
                select:
                    when image != 0U64 => #unsafe self.destroy_image :: self.device, image, null :: call
                    else => ()
                let error = VulkanPresentError.TransferDestinationImageMemoryAllocateFailed :: allocate_result :: call
                return Result.Err :: error :: call
            else => ()

        let bind_result = #unsafe self.bind_image_memory :: self.device, image, memory, 0U64 :: call
        select:
            when bind_result != VK_SUCCESS =>
                select:
                    when image != 0U64 => #unsafe self.destroy_image :: self.device, image, null :: call
                    else => ()
                select:
                    when memory != 0U64 => #unsafe self.free_memory :: self.device, memory, null :: call
                    else => ()
                let error = VulkanPresentError.TransferDestinationImageBindFailed :: bind_result :: call
                return Result.Err :: error :: call
            else => ()

        let resource = VulkanSurfaceTransferDestinationImage :: :: call
            image = image
            memory = memory
            plan = plan
            layout = VK_IMAGE_LAYOUT_UNDEFINED
        return Result.Ok :: resource :: call

    fn destroy_transfer_source_buffer(read self, take upload: VulkanTransferSourceBuffer) -> Unit:
        select:
            when upload.buffer != 0U64 => #unsafe self.destroy_buffer :: self.device, upload.buffer, null :: call
            else => ()
        select:
            when upload.memory != 0U64 => #unsafe self.free_memory :: self.device, upload.memory, null :: call
            else => ()
        return

    fn transfer_source_buffer(read self, take pixels: ByteBuffer) -> Result[VulkanTransferSourceBuffer, VulkanPresentError]:
        let byte_count = pixels.byte_count :: :: method
        let Result.Ok(byte_count_u64) = byte_count as Maybe[U64] else =>
            let error = VulkanPresentError.StagingSizeOutOfRange :: byte_count :: call
            return Result.Err :: error :: call

        let buffer: VkBuffer = 0U64
        let memory: VkDeviceMemory = 0U64

        let buffer_info = VkBufferCreateInfo :: :: call
            stype = VK_STRUCTURE_TYPE_BUFFER_CREATE_INFO
            pnext = null
            flags = 0
            size = byte_count_u64
            usage = VK_BUFFER_USAGE_TRANSFER_SRC_BIT | VK_BUFFER_USAGE_TRANSFER_DST_BIT
            sharing_mode = VK_SHARING_MODE_EXCLUSIVE
            queuefamily_index_count = 0
            queuefamily_indices = null
        let buffer_ptr: *edit VkBuffer = #unsafe &raw edit buffer
        let buffer_info_ptr: *read VkBufferCreateInfo = #unsafe &raw read buffer_info
        let buffer_result = #unsafe self.create_buffer :: self.device, buffer_info_ptr, null, buffer_ptr :: call
        select:
            when buffer_result != VK_SUCCESS || buffer == 0U64 =>
                let error = VulkanPresentError.StagingBufferCreateFailed :: buffer_result :: call
                return Result.Err :: error :: call
            else => ()

        let requirements = VkMemoryRequirements :: :: call
            size = 0U64
            alignment = 0U64
            memory_type_bits = 0
        let requirements_ptr: *edit VkMemoryRequirements = #unsafe &raw edit requirements
        #unsafe self.get_buffer_memory_requirements :: self.device, buffer, requirements_ptr :: call

        select self.memory_properties.staging_allocation_plan :: requirements :: method:
            when Option.Some(allocation_plan) =>
                let allocation_info = VkMemoryAllocateInfo :: :: call
                    stype = VK_STRUCTURE_TYPE_MEMORY_ALLOCATE_INFO
                    pnext = null
                    allocation_size = requirements.size
                    memory_type_index = allocation_plan.memory_type_index
                let allocation_info_ptr: *read VkMemoryAllocateInfo = #unsafe &raw read allocation_info
                let memory_ptr: *edit VkDeviceMemory = #unsafe &raw edit memory
                let allocate_result = #unsafe self.allocate_memory :: self.device, allocation_info_ptr, null, memory_ptr :: call
                select:
                    when allocate_result != VK_SUCCESS || memory == 0U64 =>
                        select:
                            when buffer != 0U64 => #unsafe self.destroy_buffer :: self.device, buffer, null :: call
                            else => ()
                        let error = VulkanPresentError.StagingMemoryAllocateFailed :: allocate_result :: call
                        return Result.Err :: error :: call
                    else => ()
            when Option.None =>
                select:
                    when buffer != 0U64 => #unsafe self.destroy_buffer :: self.device, buffer, null :: call
                    else => ()
                let error = VulkanPresentError.StagingMemoryTypeUnavailable :: requirements.memory_type_bits :: call
                return Result.Err :: error :: call

        let bind_result = #unsafe self.bind_buffer_memory :: self.device, buffer, memory, 0U64 :: call
        select:
            when bind_result != VK_SUCCESS =>
                select:
                    when buffer != 0U64 => #unsafe self.destroy_buffer :: self.device, buffer, null :: call
                    else => ()
                select:
                    when memory != 0U64 => #unsafe self.free_memory :: self.device, memory, null :: call
                    else => ()
                let error = VulkanPresentError.StagingBufferBindFailed :: bind_result :: call
                return Result.Err :: error :: call
            else => ()

        let mapped_memory: *edit CVoid = null
        let mapped_memory_ptr: *edit *edit CVoid = #unsafe &raw edit mapped_memory
        let map_result = #unsafe self.map_memory :: self.device, memory, 0U64, byte_count_u64, 0, mapped_memory_ptr :: call
        select:
            when map_result != VK_SUCCESS || mapped_memory.is_null :: :: method =>
                select:
                    when buffer != 0U64 => #unsafe self.destroy_buffer :: self.device, buffer, null :: call
                    else => ()
                select:
                    when memory != 0U64 => #unsafe self.free_memory :: self.device, memory, null :: call
                    else => ()
                let error = VulkanPresentError.StagingMemoryMapFailed :: map_result :: call
                return Result.Err :: error :: call
            else => ()
        let mapped_address = #unsafe raw_pointer_address_edit :: mapped_memory :: call
        let mapped_bytes = #unsafe raw_pointer_from_address_edit[U8] :: mapped_address :: call
        let source_ptr: *read U8 = #unsafe &raw read pixels[0]
        let Result.Ok(scan_limit) = byte_count as Maybe[USize] else =>
            #unsafe self.unmap_memory :: self.device, memory :: call
            select:
                when buffer != 0U64 => #unsafe self.destroy_buffer :: self.device, buffer, null :: call
                else => ()
            select:
                when memory != 0U64 => #unsafe self.free_memory :: self.device, memory, null :: call
                else => ()
            let error = VulkanPresentError.StagingSizeOutOfRange :: byte_count :: call
            return Result.Err :: error :: call
        let scan: USize = 0
        repeat while scan < scan_limit:
            let Result.Ok(offset) = scan as Maybe[ISize] else =>
                #unsafe self.unmap_memory :: self.device, memory :: call
                select:
                    when buffer != 0U64 => #unsafe self.destroy_buffer :: self.device, buffer, null :: call
                    else => ()
                select:
                    when memory != 0U64 => #unsafe self.free_memory :: self.device, memory, null :: call
                    else => ()
                let error = VulkanPresentError.StagingSizeOutOfRange :: byte_count :: call
                return Result.Err :: error :: call
            let source_slot = #unsafe source_ptr.offset :: offset :: method
            let raw: U8 = #unsafe source_slot.load :: :: method
            let slot = #unsafe mapped_bytes.offset :: offset :: method
            #unsafe slot.store :: raw :: method
            scan = scan + 1
        #unsafe self.unmap_memory :: self.device, memory :: call
        select self.transfer_source_buffer_plan :: byte_count :: method:
            when Result.Ok(plan) =>
                let upload = VulkanTransferSourceBuffer :: :: call
                    buffer = buffer
                    memory = memory
                    byte_count = byte_count
                    plan = plan
                return Result.Ok :: upload :: call
            when Result.Err(err) =>
                select:
                    when buffer != 0U64 => #unsafe self.destroy_buffer :: self.device, buffer, null :: call
                    else => ()
                select:
                    when memory != 0U64 => #unsafe self.free_memory :: self.device, memory, null :: call
                    else => ()
                return Result.Err :: err :: call

    fn queuefamily_index(read self) -> CUInt:
        return self.queuefamily

    fn memory_properties(read self) -> VkPhysicalDeviceMemoryProperties:
        return self.memory_properties

    fn memory_type_count(read self) -> CUInt:
        return self.memory_properties.memory_type_count

    fn memory_heap_count(read self) -> CUInt:
        return self.memory_properties.memory_heap_count

    fn memory_type(read self, index: CUInt) -> Option[VkMemoryType]:
        return self.memory_properties.memory_type :: index :: method

    fn memory_heap(read self, index: CUInt) -> Option[VkMemoryHeap]:
        return self.memory_properties.memory_heap :: index :: method

    fn host_visible_memory_type_count(read self) -> CUInt:
        return self.memory_properties.host_visible_memory_type_count :: :: method

    fn host_coherent_memory_type_count(read self) -> CUInt:
        return self.memory_properties.host_coherent_memory_type_count :: :: method

    fn staging_memory_type_count(read self) -> CUInt:
        return self.memory_properties.staging_memory_type_count :: :: method

    fn device_local_memory_type_count(read self) -> CUInt:
        return self.memory_properties.device_local_memory_type_count :: :: method

    fn device_local_memory_heap_count(read self) -> CUInt:
        return self.memory_properties.device_local_memory_heap_count :: :: method

    fn has_staging_memory_type(read self) -> Bool:
        return self.memory_properties.has_staging_memory_type :: :: method

    fn first_staging_memory_type_index(read self) -> Option[CUInt]:
        return self.memory_properties.first_staging_memory_type_index :: :: method

    fn memory_type_supported(read self, index: CUInt, memory_type_bits: CUInt) -> Bool:
        return self.memory_properties.memory_type_supported :: index, memory_type_bits :: method

    fn compatible_memory_type_indices(read self, memory_type_bits: CUInt) -> List[CUInt]:
        return self.memory_properties.compatible_memory_type_indices :: memory_type_bits :: method

    fn host_visible_memory_type_index(read self, memory_type_bits: CUInt) -> Option[CUInt]:
        return self.memory_properties.host_visible_memory_type_index :: memory_type_bits :: method

    fn host_coherent_memory_type_index(read self, memory_type_bits: CUInt) -> Option[CUInt]:
        return self.memory_properties.host_coherent_memory_type_index :: memory_type_bits :: method

    fn staging_memory_type_index(read self, memory_type_bits: CUInt) -> Option[CUInt]:
        return self.memory_properties.staging_memory_type_index :: memory_type_bits :: method

    fn device_local_memory_type_index(read self, memory_type_bits: CUInt) -> Option[CUInt]:
        return self.memory_properties.device_local_memory_type_index :: memory_type_bits :: method

    fn surface_capabilities(read self) -> VkSurfaceCapabilitiesKHR:
        return self.surface_capabilities

    fn chosen_surface_format(read self) -> VkSurfaceFormatKHR:
        return self.surface_format

    fn chosen_present_mode(read self) -> CInt:
        return self.present_mode

    fn swapchain_image_count(read self) -> CUInt:
        return self.swapchain_image_count

    fn surface_extent(read self) -> VkExtent2D:
        return self.extent

    fn preferred_image_count(read self) -> CUInt:
        return choose_image_count :: self.surface_capabilities :: call

    fn surface_pixel_format(read self) -> Result[VulkanPixelFormat, VulkanPresentError]:
        return self.surface_format.surface_pixel_format :: :: method

    fn surface_pixel_count(read self) -> Result[Index, VulkanPresentError]:
        let raw_width = self.extent.width
        let raw_height = self.extent.height
        select surface_image_shape_from_extent :: self.extent :: call:
            when Result.Ok(shape) =>
                let Result.Ok(pixel_width) = raw_width as Maybe[CInt] else =>
                    let error = VulkanPresentError.SurfaceExtentOutOfRange :: raw_width, raw_height :: call
                    return Result.Err :: error :: call
                let Result.Ok(pixel_height) = raw_height as Maybe[CInt] else =>
                    let error = VulkanPresentError.SurfaceExtentOutOfRange :: raw_width, raw_height :: call
                    return Result.Err :: error :: call
                let Result.Ok(width_wide) = shape.width as Maybe[USize] else =>
                    let error = VulkanPresentError.PixelExtentOutOfRange :: pixel_width, pixel_height :: call
                    return Result.Err :: error :: call
                let Result.Ok(height_wide) = shape.height as Maybe[USize] else =>
                    let error = VulkanPresentError.PixelExtentOutOfRange :: pixel_width, pixel_height :: call
                    return Result.Err :: error :: call
                let pixel_count_wide: USize = width_wide * height_wide
                let Result.Ok(pixel_count) = pixel_count_wide as Maybe[Index] else =>
                    let error = VulkanPresentError.PixelExtentOutOfRange :: pixel_width, pixel_height :: call
                    return Result.Err :: error :: call
                return Result.Ok :: pixel_count :: call
            when Result.Err(err) => return Result.Err :: err :: call

    fn surface_tight_stride(read self) -> Result[Index, VulkanPresentError]:
        select surface_image_shape_from_extent :: self.extent :: call:
            when Result.Ok(shape) => return Result.Ok :: shape.tight_stride :: call
            when Result.Err(err) => return Result.Err :: err :: call

    fn surface_rgba_byte_count(read self) -> Result[Index, VulkanPresentError]:
        select surface_image_shape_from_extent :: self.extent :: call:
            when Result.Ok(shape) => return Result.Ok :: shape.rgba_byte_count :: call
            when Result.Err(err) => return Result.Err :: err :: call

    fn surface_pixel_frame(read self, read fill: RgbaColor) -> Result[VulkanPixelFrame, VulkanPresentError]:
        select self.surface_pixel_format :: :: method:
            when Result.Ok(format) => return self.surface_pixel_frame_with_color :: format, fill :: method
            when Result.Err(err) => return Result.Err :: err :: call

    fn surface_pixel_frame_with_color(read self, format: VulkanPixelFormat, read fill: RgbaColor) -> Result[VulkanPixelFrame, VulkanPresentError]:
        return surface_pixel_frame_with_color :: self.extent, format, fill :: call

    fn surface_pixel_frame_from_surface_bytes(read self, take pixels: ByteBuffer) -> Result[VulkanPixelFrame, VulkanPresentError]:
        select self.surface_pixel_format :: :: method:
            when Result.Ok(format) => return surface_pixel_frame_from_extent :: self.extent, format, pixels :: call
            when Result.Err(err) => return Result.Err :: err :: call

    fn surface_pixel_frame_from_image(read self, read image: RgbaImage) -> Result[VulkanPixelFrame, VulkanPresentError]:
        select image.width_index :: :: method:
            when Result.Ok(image_width) =>
                select image.height_index :: :: method:
                    when Result.Ok(image_height) =>
                        select surface_image_shape_from_extent :: self.extent :: call:
                            when Result.Ok(shape) =>
                                select:
                                    when image_width != shape.width || image_height != shape.height =>
                                        let error = VulkanPresentError.PixelFrameExtentMismatch :: image_width, image_height, self.extent.width, self.extent.height :: call
                                        return Result.Err :: error :: call
                                    else => ()
                            when Result.Err(err) => return Result.Err :: err :: call
                        select self.surface_pixel_format :: :: method:
                            when Result.Ok(format) => return vulkan_pixel_frame_from_image :: image, format :: call
                            when Result.Err(err) => return Result.Err :: err :: call
                    when Result.Err(err) =>
                        let error = VulkanPresentError.ImageAccess :: err :: call
                        return Result.Err :: error :: call
            when Result.Err(err) =>
                let error = VulkanPresentError.ImageAccess :: err :: call
                return Result.Err :: error :: call

    fn surface_pixel_frame_from_pixels(read self, width: Index, height: Index, stride: Index, format: VulkanPixelFormat, take pixels: ByteBuffer) -> Result[VulkanPixelFrame, VulkanPresentError]:
        select surface_image_shape_from_extent :: self.extent :: call:
            when Result.Ok(shape) =>
                select:
                    when width != shape.width || height != shape.height =>
                        let error = VulkanPresentError.PixelFrameExtentMismatch :: width, height, self.extent.width, self.extent.height :: call
                        return Result.Err :: error :: call
                    else => return vulkan_pixel_frame :: width, height, stride, format, pixels :: call
            when Result.Err(err) => return Result.Err :: err :: call

    fn surface_image(read self, read fill: RgbaColor) -> Result[RgbaImage, VulkanPresentError]:
        select self.surface_pixel_frame_with_color :: VulkanPixelFormat.Rgba8, fill :: method:
            when Result.Ok(frame) => return frame.to_rgba_image :: :: method
            when Result.Err(err) => return Result.Err :: err :: call

    fn surface_image_from_pixels(read self, take pixels: ByteBuffer) -> Result[RgbaImage, VulkanPresentError]:
        select surface_pixel_frame_from_extent :: self.extent, VulkanPixelFormat.Rgba8, pixels :: call:
            when Result.Ok(frame) => return frame.to_rgba_image :: :: method
            when Result.Err(err) => return Result.Err :: err :: call

    fn present_solid_rgba(edit self, read fill: RgbaColor) -> Result[Unit, VulkanPresentError]:
        select self.surface_pixel_frame_with_color :: VulkanPixelFormat.Rgba8, fill :: method:
            when Result.Ok(frame) => return self.present_pixel_frame :: frame :: method
            when Result.Err(err) => return Result.Err :: err :: call

    fn present_pixels(edit self, take pixels: ByteBuffer) -> Result[Unit, VulkanPresentError]:
        select surface_pixel_frame_from_extent :: self.extent, VulkanPixelFormat.Rgba8, pixels :: call:
            when Result.Ok(frame) => return self.present_pixel_frame :: frame :: method
            when Result.Err(err) => return Result.Err :: err :: call

    fn present_surface_pixels(edit self, take pixels: ByteBuffer) -> Result[Unit, VulkanPresentError]:
        return self.present_surface_bytes :: pixels :: method

    fn present_transfer_source_buffer(edit self, read upload: VulkanTransferSourceBuffer) -> Result[Unit, VulkanPresentError]:
        select self.surface_rgba_byte_count :: :: method:
            when Result.Ok(required_byte_count) =>
                select:
                    when upload.byte_count != required_byte_count =>
                        let error = VulkanPresentError.PixelByteCountMismatch :: upload.byte_count, required_byte_count :: call
                        return Result.Err :: error :: call
                    else => ()
            when Result.Err(err) => return Result.Err :: err :: call
        select self.prepare_present_resources :: :: method:
            when Result.Ok(resources) =>
                let begin_info = VkCommandBufferBeginInfo :: :: call
                    stype = VK_STRUCTURE_TYPE_COMMAND_BUFFER_BEGIN_INFO
                    pnext = null
                    flags = VK_COMMAND_BUFFER_USAGE_ONE_TIME_SUBMIT_BIT
                    inheritance_info = null
                let begin_info_ptr: *read VkCommandBufferBeginInfo = #unsafe &raw read begin_info
                let begin_result = #unsafe self.begin_command_buffer :: resources.command_buffer, begin_info_ptr :: call
                select:
                    when begin_result != VK_SUCCESS =>
                        self.destroy_present_resources :: resources :: method
                        let error = VulkanPresentError.CommandBufferBeginFailed :: begin_result :: call
                        return Result.Err :: error :: call
                    else => ()
                let before_barrier = VkImageMemoryBarrier :: :: call
                    stype = VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER
                    pnext = null
                    src_access_mask = 0
                    dst_access_mask = VK_ACCESS_TRANSFER_WRITE_BIT
                    old_layout = VK_IMAGE_LAYOUT_UNDEFINED
                    new_layout = VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL
                    src_queuefamily_index = VK_QUEUE_FAMILY_IGNORED
                    dst_queuefamily_index = VK_QUEUE_FAMILY_IGNORED
                    image = resources.target_image
                    subresource_range = CLEAR_RANGE
                select:
                    when self.presented_once =>
                        before_barrier.src_access_mask = VK_ACCESS_MEMORY_READ_BIT
                        before_barrier.old_layout = VK_IMAGE_LAYOUT_PRESENT_SRC_KHR
                    else => ()
                let before_barrier_ptr: *read VkImageMemoryBarrier = #unsafe &raw read before_barrier
                let before_stage: CUInt = VK_PIPELINE_STAGE_TOP_OF_PIPE_BIT
                select:
                    when self.presented_once => before_stage = VK_PIPELINE_STAGE_BOTTOM_OF_PIPE_BIT
                    else => ()
                #unsafe self.cmd_pipeline_barrier :: resources.command_buffer, before_stage, VK_PIPELINE_STAGE_TRANSFER_BIT, 0, 0, null, 0, null, 1, before_barrier_ptr :: call
                let copy_region = VkBufferImageCopy :: :: call
                    buffer_offset = 0U64
                    buffer_row_length = 0
                    buffer_image_height = 0
                    image_subresource = IMAGE_COPY_SUBRESOURCE
                    image_offset = ZERO_OFFSET3D
                    image_extent = VkExtent3D :: :: call
                        width = self.extent.width
                        height = self.extent.height
                        depth = 1
                let copy_region_ptr: *read VkBufferImageCopy = #unsafe &raw read copy_region
                #unsafe self.cmd_copy_buffer_to_image :: resources.command_buffer, upload.buffer, resources.target_image, VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL, 1, copy_region_ptr :: call
                let after_barrier = VkImageMemoryBarrier :: :: call
                    stype = VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER
                    pnext = null
                    src_access_mask = VK_ACCESS_TRANSFER_WRITE_BIT
                    dst_access_mask = VK_ACCESS_MEMORY_READ_BIT
                    old_layout = VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL
                    new_layout = VK_IMAGE_LAYOUT_PRESENT_SRC_KHR
                    src_queuefamily_index = VK_QUEUE_FAMILY_IGNORED
                    dst_queuefamily_index = VK_QUEUE_FAMILY_IGNORED
                    image = resources.target_image
                    subresource_range = CLEAR_RANGE
                let after_barrier_ptr: *read VkImageMemoryBarrier = #unsafe &raw read after_barrier
                #unsafe self.cmd_pipeline_barrier :: resources.command_buffer, VK_PIPELINE_STAGE_TRANSFER_BIT, VK_PIPELINE_STAGE_BOTTOM_OF_PIPE_BIT, 0, 0, null, 0, null, 1, after_barrier_ptr :: call
                let end_result = #unsafe self.end_command_buffer :: resources.command_buffer :: call
                select:
                    when end_result != VK_SUCCESS =>
                        self.destroy_present_resources :: resources :: method
                        let error = VulkanPresentError.CommandBufferEndFailed :: end_result :: call
                        return Result.Err :: error :: call
                    else => ()
                let wait_stage_masks: [CUInt; 1] = [VK_PIPELINE_STAGE_TRANSFER_BIT]
                let wait_stage_ptr: *read CUInt = #unsafe &raw read wait_stage_masks[0]
                let wait_semaphores: [VkSemaphore; 1] = [resources.image_available]
                let signal_semaphores: [VkSemaphore; 1] = [resources.render_complete]
                let command_buffers: [VkCommandBuffer; 1] = [resources.command_buffer]
                let wait_semaphore_ptr: *read VkSemaphore = #unsafe &raw read wait_semaphores[0]
                let signal_semaphore_ptr: *read VkSemaphore = #unsafe &raw read signal_semaphores[0]
                let command_buffer_submit_ptr: *read VkCommandBuffer = #unsafe &raw read command_buffers[0]
                let submit_info = VkSubmitInfo :: :: call
                    stype = VK_STRUCTURE_TYPE_SUBMIT_INFO
                    pnext = null
                    wait_semaphore_count = 1
                    wait_semaphores = wait_semaphore_ptr
                    wait_dst_stage_mask = wait_stage_ptr
                    command_buffer_count = 1
                    command_buffers = command_buffer_submit_ptr
                    signal_semaphore_count = 1
                    signal_semaphores = signal_semaphore_ptr
                let submit_info_ptr: *read VkSubmitInfo = #unsafe &raw read submit_info
                let submit_result = #unsafe self.queue_submit :: self.queue, 1, submit_info_ptr, 0U64 :: call
                select:
                    when submit_result != VK_SUCCESS =>
                        self.destroy_present_resources :: resources :: method
                        let error = VulkanPresentError.SubmitFailed :: submit_result :: call
                        return Result.Err :: error :: call
                    else => ()
                let swapchains: [VkSwapchain; 1] = [self.swapchain]
                let swapchain_ptr: *read VkSwapchain = #unsafe &raw read swapchains[0]
                let image_index_ptr: *read CUInt = #unsafe &raw read resources.image_index
                let present_info = VkPresentInfoKHR :: :: call
                    stype = VK_STRUCTURE_TYPE_PRESENT_INFO_KHR
                    pnext = null
                    wait_semaphore_count = 1
                    wait_semaphores = signal_semaphore_ptr
                    swapchain_count = 1
                    swapchains = swapchain_ptr
                    image_indices = image_index_ptr
                    results = null
                let present_info_ptr: *read VkPresentInfoKHR = #unsafe &raw read present_info
                let present_result = #unsafe self.queue_present :: self.queue, present_info_ptr :: call
                let idle_result = #unsafe self.queue_wait_idle :: self.queue :: call
                self.destroy_present_resources :: resources :: method
                select:
                    when present_result != VK_SUCCESS && present_result != VK_SUBOPTIMAL_KHR =>
                        let error = VulkanPresentError.PresentFailed :: present_result :: call
                        return Result.Err :: error :: call
                    when idle_result != VK_SUCCESS =>
                        let error = VulkanPresentError.QueueWaitIdleFailed :: idle_result :: call
                        return Result.Err :: error :: call
                    else => ()
                self.presented_once = true
                return Result.Ok :: () :: call
            when Result.Err(err) => return Result.Err :: err :: call

    fn present_surface_bytes(edit self, take pixels: ByteBuffer) -> Result[Unit, VulkanPresentError]:
        select self.surface_transfer_source_buffer :: pixels :: method:
            when Result.Ok(upload) =>
                select self.present_transfer_source_buffer :: upload :: method:
                    when Result.Ok(_) =>
                        self.destroy_transfer_source_buffer :: upload :: method
                        return Result.Ok :: () :: call
                    when Result.Err(err) =>
                        self.destroy_transfer_source_buffer :: upload :: method
                        return Result.Err :: err :: call
            when Result.Err(err) => return Result.Err :: err :: call

    fn present_pixel_frame(edit self, take frame: VulkanPixelFrame) -> Result[Unit, VulkanPresentError]:
        select surface_image_shape_from_extent :: self.extent :: call:
            when Result.Ok(shape) =>
                select:
                    when frame.width :: :: method != shape.width || frame.height :: :: method != shape.height =>
                        let error = VulkanPresentError.PixelFrameExtentMismatch :: frame.width :: :: method, frame.height :: :: method, self.extent.width, self.extent.height :: call
                        return Result.Err :: error :: call
                    else => ()
            when Result.Err(err) => return Result.Err :: err :: call
        let surface_format = self.chosen_surface_format :: :: method
        select frame.to_surface_bytes :: surface_format :: method:
            when Result.Ok(surface_pixels) => return self.present_surface_bytes :: surface_pixels :: method
            when Result.Err(err) => return Result.Err :: err :: call

    fn present_image(edit self, take image: RgbaImage) -> Result[Unit, VulkanPresentError]:
        let raw_width = image.width :: :: method
        let raw_height = image.height :: :: method
        let Result.Ok(image_width) = raw_width as Maybe[Index] else =>
            let error = VulkanPresentError.PixelExtentOutOfRange :: raw_width, raw_height :: call
            return Result.Err :: error :: call
        let Result.Ok(image_height) = raw_height as Maybe[Index] else =>
            let error = VulkanPresentError.PixelExtentOutOfRange :: raw_width, raw_height :: call
            return Result.Err :: error :: call
        let pixels = image.take_pixels :: :: method
        select self.surface_tight_stride :: :: method:
            when Result.Ok(tight_stride) =>
                select self.surface_pixel_frame_from_pixels :: image_width, image_height, tight_stride, VulkanPixelFormat.Rgba8, pixels :: method:
                    when Result.Ok(frame) => return self.present_pixel_frame :: frame :: method
                    when Result.Err(err) => return Result.Err :: err :: call
            when Result.Err(err) => return Result.Err :: err :: call

    fn present(edit self, read color: PresentColor) -> Result[Unit, VulkanPresentError]:
        let command_pool: VkCommandPool = 0U64
        let command_buffer: VkCommandBuffer = null
        let image_available: VkSemaphore = 0U64
        let render_complete: VkSemaphore = 0U64

        let command_pool_info = VkCommandPoolCreateInfo :: :: call
            stype = VK_STRUCTURE_TYPE_COMMAND_POOL_CREATE_INFO
            pnext = null
            flags = 0
            queuefamily_index = self.queuefamily
        let command_pool_ptr: *edit VkCommandPool = #unsafe &raw edit command_pool
        let command_pool_info_ptr: *read VkCommandPoolCreateInfo = #unsafe &raw read command_pool_info
        let command_pool_result = #unsafe self.create_command_pool :: self.device, command_pool_info_ptr, null, command_pool_ptr :: call
        select:
            when command_pool_result != VK_SUCCESS || command_pool == 0U64 =>
                let error = VulkanPresentError.CommandPoolCreateFailed :: command_pool_result :: call
                return Result.Err :: error :: call
            else => ()

        let command_buffer_info = VkCommandBufferAllocateInfo :: :: call
            stype = VK_STRUCTURE_TYPE_COMMAND_BUFFER_ALLOCATE_INFO
            pnext = null
            command_pool = command_pool
            level = VK_COMMAND_BUFFER_LEVEL_PRIMARY
            command_buffer_count = 1
        let command_buffer_ptr: *edit VkCommandBuffer = #unsafe &raw edit command_buffer
        let command_buffer_info_ptr: *read VkCommandBufferAllocateInfo = #unsafe &raw read command_buffer_info
        let command_buffer_result = #unsafe self.allocate_command_buffers :: self.device, command_buffer_info_ptr, command_buffer_ptr :: call
        select:
            when command_buffer_result != VK_SUCCESS || command_buffer.is_null :: :: method =>
                #unsafe self.destroy_command_pool :: self.device, command_pool, null :: call
                let error = VulkanPresentError.CommandBufferAllocateFailed :: command_buffer_result :: call
                return Result.Err :: error :: call
            else => ()

        let semaphore_info = VkSemaphoreCreateInfo :: :: call
            stype = VK_STRUCTURE_TYPE_SEMAPHORE_CREATE_INFO
            pnext = null
            flags = 0
        let semaphore_info_ptr: *read VkSemaphoreCreateInfo = #unsafe &raw read semaphore_info
        let image_available_ptr: *edit VkSemaphore = #unsafe &raw edit image_available
        let image_available_result = #unsafe self.create_semaphore :: self.device, semaphore_info_ptr, null, image_available_ptr :: call
        select:
            when image_available_result != VK_SUCCESS || image_available == 0U64 =>
                #unsafe self.destroy_command_pool :: self.device, command_pool, null :: call
                let error = VulkanPresentError.SemaphoreCreateFailed :: image_available_result :: call
                return Result.Err :: error :: call
            else => ()
        let render_complete_ptr: *edit VkSemaphore = #unsafe &raw edit render_complete
        let render_complete_result = #unsafe self.create_semaphore :: self.device, semaphore_info_ptr, null, render_complete_ptr :: call
        select:
            when render_complete_result != VK_SUCCESS || render_complete == 0U64 =>
                #unsafe self.destroy_semaphore :: self.device, image_available, null :: call
                #unsafe self.destroy_command_pool :: self.device, command_pool, null :: call
                let error = VulkanPresentError.SemaphoreCreateFailed :: render_complete_result :: call
                return Result.Err :: error :: call
            else => ()

        let image_index: CUInt = 0
        let image_index_ptr: *edit CUInt = #unsafe &raw edit image_index
        let acquire_result = #unsafe self.acquire_next_image :: self.device, self.swapchain, VK_TIMEOUT_FOREVER, image_available, 0U64, image_index_ptr :: call
        select:
            when acquire_result != VK_SUCCESS && acquire_result != VK_SUBOPTIMAL_KHR =>
                #unsafe self.destroy_semaphore :: self.device, render_complete, null :: call
                #unsafe self.destroy_semaphore :: self.device, image_available, null :: call
                #unsafe self.destroy_command_pool :: self.device, command_pool, null :: call
                let error = VulkanPresentError.AcquireFailed :: acquire_result :: call
                return Result.Err :: error :: call
            else => ()
        let Result.Ok(image_slot) = image_index as Maybe[Index] else =>
            #unsafe self.destroy_semaphore :: self.device, render_complete, null :: call
            #unsafe self.destroy_semaphore :: self.device, image_available, null :: call
            #unsafe self.destroy_command_pool :: self.device, command_pool, null :: call
            let error = VulkanPresentError.NoSwapchainImages :: :: call
            return Result.Err :: error :: call
        let target_image = self.swapchain_images[image_slot]

        let begin_info = VkCommandBufferBeginInfo :: :: call
            stype = VK_STRUCTURE_TYPE_COMMAND_BUFFER_BEGIN_INFO
            pnext = null
            flags = VK_COMMAND_BUFFER_USAGE_ONE_TIME_SUBMIT_BIT
            inheritance_info = null
        let begin_info_ptr: *read VkCommandBufferBeginInfo = #unsafe &raw read begin_info
        let begin_result = #unsafe self.begin_command_buffer :: command_buffer, begin_info_ptr :: call
        select:
            when begin_result != VK_SUCCESS =>
                #unsafe self.destroy_semaphore :: self.device, render_complete, null :: call
                #unsafe self.destroy_semaphore :: self.device, image_available, null :: call
                #unsafe self.destroy_command_pool :: self.device, command_pool, null :: call
                let error = VulkanPresentError.CommandBufferBeginFailed :: begin_result :: call
                return Result.Err :: error :: call
            else => ()

        let before_barrier = VkImageMemoryBarrier :: :: call
            stype = VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER
            pnext = null
            src_access_mask = 0
            dst_access_mask = VK_ACCESS_TRANSFER_WRITE_BIT
            old_layout = VK_IMAGE_LAYOUT_UNDEFINED
            new_layout = VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL
            src_queuefamily_index = VK_QUEUE_FAMILY_IGNORED
            dst_queuefamily_index = VK_QUEUE_FAMILY_IGNORED
            image = target_image
            subresource_range = CLEAR_RANGE
        select:
            when self.presented_once =>
                before_barrier.stype = VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER
                before_barrier.src_access_mask = VK_ACCESS_MEMORY_READ_BIT
                before_barrier.old_layout = VK_IMAGE_LAYOUT_PRESENT_SRC_KHR
            else => ()
        let before_barrier_ptr: *read VkImageMemoryBarrier = #unsafe &raw read before_barrier
        let before_stage: CUInt = VK_PIPELINE_STAGE_TOP_OF_PIPE_BIT
        select:
            when self.presented_once => before_stage = VK_PIPELINE_STAGE_BOTTOM_OF_PIPE_BIT
            else => ()
        #unsafe self.cmd_pipeline_barrier :: command_buffer, before_stage, VK_PIPELINE_STAGE_TRANSFER_BIT, 0, 0, null, 0, null, 1, before_barrier_ptr :: call

        let clear_color = VkClearColorValue :: :: call
            float32_values = [color.red, color.green, color.blue, color.alpha]
        let clear_color_ptr: *read VkClearColorValue = #unsafe &raw read clear_color
        let clear_range = CLEAR_RANGE
        let clear_range_ptr: *read VkImageSubresourceRange = #unsafe &raw read clear_range
        #unsafe self.cmd_clear_color_image :: command_buffer, target_image, VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL, clear_color_ptr, 1, clear_range_ptr :: call

        let after_barrier = VkImageMemoryBarrier :: :: call
            stype = VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER
            pnext = null
            src_access_mask = VK_ACCESS_TRANSFER_WRITE_BIT
            dst_access_mask = VK_ACCESS_MEMORY_READ_BIT
            old_layout = VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL
            new_layout = VK_IMAGE_LAYOUT_PRESENT_SRC_KHR
            src_queuefamily_index = VK_QUEUE_FAMILY_IGNORED
            dst_queuefamily_index = VK_QUEUE_FAMILY_IGNORED
            image = target_image
            subresource_range = CLEAR_RANGE
        let after_barrier_ptr: *read VkImageMemoryBarrier = #unsafe &raw read after_barrier
        #unsafe self.cmd_pipeline_barrier :: command_buffer, VK_PIPELINE_STAGE_TRANSFER_BIT, VK_PIPELINE_STAGE_BOTTOM_OF_PIPE_BIT, 0, 0, null, 0, null, 1, after_barrier_ptr :: call

        let end_result = #unsafe self.end_command_buffer :: command_buffer :: call
        select:
            when end_result != VK_SUCCESS =>
                #unsafe self.destroy_semaphore :: self.device, render_complete, null :: call
                #unsafe self.destroy_semaphore :: self.device, image_available, null :: call
                #unsafe self.destroy_command_pool :: self.device, command_pool, null :: call
                let error = VulkanPresentError.CommandBufferEndFailed :: end_result :: call
                return Result.Err :: error :: call
            else => ()

        let wait_stage_masks: [CUInt; 1] = [VK_PIPELINE_STAGE_TRANSFER_BIT]
        let wait_stage_ptr: *read CUInt = #unsafe &raw read wait_stage_masks[0]
        let wait_semaphores: [VkSemaphore; 1] = [image_available]
        let signal_semaphores: [VkSemaphore; 1] = [render_complete]
        let command_buffers: [VkCommandBuffer; 1] = [command_buffer]
        let wait_semaphore_ptr: *read VkSemaphore = #unsafe &raw read wait_semaphores[0]
        let signal_semaphore_ptr: *read VkSemaphore = #unsafe &raw read signal_semaphores[0]
        let command_buffer_submit_ptr: *read VkCommandBuffer = #unsafe &raw read command_buffers[0]
        let submit_info = VkSubmitInfo :: :: call
            stype = VK_STRUCTURE_TYPE_SUBMIT_INFO
            pnext = null
            wait_semaphore_count = 1
            wait_semaphores = wait_semaphore_ptr
            wait_dst_stage_mask = wait_stage_ptr
            command_buffer_count = 1
            command_buffers = command_buffer_submit_ptr
            signal_semaphore_count = 1
            signal_semaphores = signal_semaphore_ptr
        let submit_info_ptr: *read VkSubmitInfo = #unsafe &raw read submit_info
        let submit_result = #unsafe self.queue_submit :: self.queue, 1, submit_info_ptr, 0U64 :: call
        select:
            when submit_result != VK_SUCCESS =>
                #unsafe self.destroy_semaphore :: self.device, render_complete, null :: call
                #unsafe self.destroy_semaphore :: self.device, image_available, null :: call
                #unsafe self.destroy_command_pool :: self.device, command_pool, null :: call
                let error = VulkanPresentError.SubmitFailed :: submit_result :: call
                return Result.Err :: error :: call
            else => ()

        let swapchains: [VkSwapchain; 1] = [self.swapchain]
        let swapchain_ptr: *read VkSwapchain = #unsafe &raw read swapchains[0]
        let image_index_read_ptr: *read CUInt = #unsafe &raw read image_index
        let present_info = VkPresentInfoKHR :: :: call
            stype = VK_STRUCTURE_TYPE_PRESENT_INFO_KHR
            pnext = null
            wait_semaphore_count = 1
            wait_semaphores = signal_semaphore_ptr
            swapchain_count = 1
            swapchains = swapchain_ptr
            image_indices = image_index_read_ptr
            results = null
        let present_info_ptr: *read VkPresentInfoKHR = #unsafe &raw read present_info
        let present_result = #unsafe self.queue_present :: self.queue, present_info_ptr :: call
        select:
            when present_result != VK_SUCCESS && present_result != VK_SUBOPTIMAL_KHR =>
                #unsafe self.destroy_semaphore :: self.device, render_complete, null :: call
                #unsafe self.destroy_semaphore :: self.device, image_available, null :: call
                #unsafe self.destroy_command_pool :: self.device, command_pool, null :: call
                let error = VulkanPresentError.PresentFailed :: present_result :: call
                return Result.Err :: error :: call
            else => ()

        let idle_result = #unsafe self.queue_wait_idle :: self.queue :: call
        #unsafe self.destroy_semaphore :: self.device, render_complete, null :: call
        #unsafe self.destroy_semaphore :: self.device, image_available, null :: call
        #unsafe self.destroy_command_pool :: self.device, command_pool, null :: call
        select:
            when idle_result != VK_SUCCESS =>
                let error = VulkanPresentError.QueueWaitIdleFailed :: idle_result :: call
                return Result.Err :: error :: call
            else => ()
        self.presented_once = true
        return Result.Ok :: () :: call

    fn destroy(take self) -> Result[Unit, VulkanPresentError]:
        let wait_result = #unsafe self.device_wait_idle :: self.device :: call
        #unsafe self.destroy_swapchain :: self.device, self.swapchain, null :: call
        #unsafe self.destroy_device :: self.device, null :: call
        #unsafe self.destroy_surface :: self.instance, self.surface, null :: call
        #unsafe self.destroy_instance :: self.instance, null :: call
        let close_result = #unsafe close_library :: self.library :: call
        select close_result:
            when Result.Ok(_) =>
                select:
                    when wait_result != VK_SUCCESS =>
                        let error = VulkanPresentError.DeviceWaitIdleFailed :: wait_result :: call
                        return Result.Err :: error :: call
                    else => return Result.Ok :: () :: call
            when Result.Err(err) =>
                let error = VulkanPresentError.LibraryClose :: err :: call
                return Result.Err :: error :: call
