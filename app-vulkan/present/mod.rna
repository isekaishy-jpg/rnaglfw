fn close_library_quiet(take library: DynamicLibrary) -> Unit:
    let _ = #unsafe close_library :: library :: call
    return

fn cleanup_surface_context(take library: DynamicLibrary, take cleanup: SurfaceCleanup) -> Unit:
    select:
        when cleanup.surface != 0U64 => #unsafe cleanup.destroy_surface :: cleanup.instance, cleanup.surface, null :: call
        else => ()
    select:
        when !cleanup.instance.is_null :: :: method => #unsafe cleanup.destroy_instance :: cleanup.instance, null :: call
        else => ()
    close_library_quiet :: library :: call
    return

fn cleanup_device_context(take library: DynamicLibrary, take cleanup: DeviceCleanup) -> Unit:
    select:
        when !cleanup.device.is_null :: :: method => #unsafe cleanup.destroy_device :: cleanup.device, null :: call
        else => ()
    select:
        when cleanup.surface != 0U64 => #unsafe cleanup.destroy_surface :: cleanup.instance, cleanup.surface, null :: call
        else => ()
    select:
        when !cleanup.instance.is_null :: :: method => #unsafe cleanup.destroy_instance :: cleanup.instance, null :: call
        else => ()
    close_library_quiet :: library :: call
    return

fn cleanup_swapchain_context(take library: DynamicLibrary, take cleanup: SwapchainCleanup) -> Unit:
    select:
        when cleanup.swapchain != 0U64 => #unsafe cleanup.destroy_swapchain :: cleanup.device, cleanup.swapchain, null :: call
        else => ()
    select:
        when !cleanup.device.is_null :: :: method => #unsafe cleanup.destroy_device :: cleanup.device, null :: call
        else => ()
    select:
        when cleanup.surface != 0U64 => #unsafe cleanup.destroy_surface :: cleanup.instance, cleanup.surface, null :: call
        else => ()
    select:
        when !cleanup.instance.is_null :: :: method => #unsafe cleanup.destroy_instance :: cleanup.instance, null :: call
        else => ()
    close_library_quiet :: library :: call
    return

fn find_graphics_present_device(enumerate_physical_devices: VkEnumeratePhysicalDevicesFn, queue_family_properties: VkGetPhysicalDeviceQueueFamilyPropertiesFn, surface_support: VkGetPhysicalDeviceSurfaceSupportFn, instance: GlfwVkInstance, surface: GlfwVkSurface) -> Result[VulkanDeviceCandidate, VulkanPresentError]:
    let device_count: CUInt = 0
    let device_count_ptr: *edit CUInt = #unsafe &raw edit device_count
    let query_result = #unsafe enumerate_physical_devices :: instance, device_count_ptr, null :: call
    select:
        when query_result != VK_SUCCESS =>
            let error = VulkanPresentError.PhysicalDeviceQueryFailed :: query_result :: call
            return Result.Err :: error :: call
        when device_count == 0 =>
            let error = VulkanPresentError.NoGraphicsPresentDevice :: :: call
            return Result.Err :: error :: call
        when device_count > MAX_PHYSICAL_DEVICES_RAW =>
            let error = VulkanPresentError.PhysicalDeviceOverflow :: device_count :: call
            return Result.Err :: error :: call
        else => ()
    let devices: [GlfwVkPhysicalDevice; MAX_PHYSICAL_DEVICES] = [null; MAX_PHYSICAL_DEVICES]
    let device_ptr: *edit GlfwVkPhysicalDevice = #unsafe &raw edit devices[0]
    let fill_result = #unsafe enumerate_physical_devices :: instance, device_count_ptr, device_ptr :: call
    select:
        when fill_result != VK_SUCCESS =>
            let error = VulkanPresentError.PhysicalDeviceQueryFailed :: fill_result :: call
            return Result.Err :: error :: call
        else => ()
    let device_scan: CUInt = 0
    repeat while device_scan < device_count:
        let Result.Ok(device_index) = device_scan as Maybe[Index] else =>
            let error = VulkanPresentError.NoGraphicsPresentDevice :: :: call
            return Result.Err :: error :: call
        let device = devices[device_index]
        let queue_count: CUInt = 0
        let queue_count_ptr: *edit CUInt = #unsafe &raw edit queue_count
        #unsafe queue_family_properties :: device, queue_count_ptr, null :: call
        select:
            when queue_count > MAX_QUEUE_FAMILIES_RAW =>
                let error = VulkanPresentError.QueueFamilyOverflow :: queue_count :: call
                return Result.Err :: error :: call
            else => ()
        let properties: [VkQueueFamilyProperties; MAX_QUEUE_FAMILIES] = [ZERO_QUEUE_FAMILY_PROPERTIES; MAX_QUEUE_FAMILIES]
        select:
            when queue_count == 0 => ()
            else =>
                let properties_ptr: *edit VkQueueFamilyProperties = #unsafe &raw edit properties[0]
                #unsafe queue_family_properties :: device, queue_count_ptr, properties_ptr :: call
        let family_scan: CUInt = 0
        repeat while family_scan < queue_count:
            let Result.Ok(family_index) = family_scan as Maybe[Index] else =>
                let error = VulkanPresentError.NoGraphicsPresentDevice :: :: call
                return Result.Err :: error :: call
            let family = properties[family_index]
            let supported: CUInt = 0
            let supported_ptr: *edit CUInt = #unsafe &raw edit supported
            let support_result = #unsafe surface_support :: device, family_scan, surface, supported_ptr :: call
            select:
                when support_result != VK_SUCCESS =>
                    let error = VulkanPresentError.SurfaceCapabilitiesFailed :: support_result :: call
                    return Result.Err :: error :: call
                when family.queue_count != 0 && (family.queue_flags & VK_QUEUE_GRAPHICS_BIT) != 0 && supported != 0 =>
                    let candidate = VulkanDeviceCandidate :: :: call
                        device = device
                        queuefamily = family_scan
                    return Result.Ok :: candidate :: call
                else => ()
            family_scan = family_scan + 1
        device_scan = device_scan + 1
    let error = VulkanPresentError.NoGraphicsPresentDevice :: :: call
    return Result.Err :: error :: call

pub(package) fn finish_vulkan_present_app(take app: App, take window: Window, app_name: Str) -> Result[VulkanPresentApp, VulkanPresentAppError]:
    select bootstrap_vulkan_present :: window, app_name :: call:
        when Result.Ok(context) =>
            let present_app = VulkanPresentApp :: :: call
                app = app
                window = window
                context = context
            return Result.Ok :: present_app :: call
        when Result.Err(err) =>
            app.terminate :: :: method
            let error = VulkanPresentAppError.PresentBootstrap :: err :: call
            return Result.Err :: error :: call

pub fn bootstrap_vulkan_present(read window: Window, app_name: Str) -> Result[VulkanPresentContext, VulkanPresentError]:
    select:
        when !vulkan_supported :: :: call =>
            let error = VulkanPresentError.NotSupported :: :: call
            return Result.Err :: error :: call
        else => ()
    select either:
        when library: Result.Ok(library) <- open_library :: VULKAN_LIBRARY_PATH :: call
        when create_instance: Result.Ok(create_instance) <- lookup_loader_symbol[VkCreateInstanceFn] :: library, "vkCreateInstance" :: call
        when required_extensions: Result.Ok((extension_pointers, extension_names)) <- copy_required_extension_array :: :: call
        when application_name: Result.Ok(application_name) <- maybe_c_string_local :: app_name :: call
        when engine_name: Result.Ok(engine_name) <- maybe_c_string_local :: ENGINE_NAME :: call =>
            let application_info = VkApplicationInfo :: :: call
                stype = VK_STRUCTURE_TYPE_APPLICATION_INFO
                pnext = null
                application_name = application_name.as_ptr :: :: method
                application_version = 0
                engine_name = engine_name.as_ptr :: :: method
                engine_version = 0
                api_version = VK_API_VERSION_1_0
            let application_info_ptr: *read VkApplicationInfo = #unsafe &raw read application_info
            let extension_ptr: *read *read CChar = #unsafe &raw read extension_pointers[0]
            let create_info = VkInstanceCreateInfo :: :: call
                stype = VK_STRUCTURE_TYPE_INSTANCE_CREATE_INFO
                pnext = null
                flags = 0
                application_info = application_info_ptr
                enabled_layer_count = 0
                enabled_layer_names = null
                enabled_extension_count = 2
                enabled_extension_names = extension_ptr
            let instance: GlfwVkInstance = null
            let create_info_ptr: *read VkInstanceCreateInfo = #unsafe &raw read create_info
            let instance_ptr: *edit GlfwVkInstance = #unsafe &raw edit instance
            let create_result = #unsafe create_instance :: create_info_ptr, null, instance_ptr :: call
            let _ = extension_names
            select:
                when create_result != VK_SUCCESS || instance.is_null :: :: method =>
                    close_library_quiet :: library :: call
                    let error = VulkanPresentError.InstanceCreateFailed :: create_result :: call
                    return Result.Err :: error :: call
                else => ()
            select either:
                when destroy_instance: Result.Ok(destroy_instance) <- lookup_instance_symbol[VkDestroyInstanceFn] :: library, instance, "vkDestroyInstance", "vkDestroyInstance" :: call
                when instance_fns: Result.Ok(instance_fns) <- lookup_vulkan_instance_fns :: library, instance, destroy_instance :: call =>
                    return bootstrap_vulkan_present_with_instance :: window, library, instance, instance_fns :: call

            with Result.Err(err):
                destroy_instance =>
                    close_library_quiet :: library :: call
                    return Result.Err :: err :: call
                instance_fns =>
                    #unsafe destroy_instance :: instance, null :: call
                    close_library_quiet :: library :: call
                    return Result.Err :: err :: call

    with Result.Err(err):
        library =>
            let error = VulkanPresentError.LibraryOpen :: err :: call
            return Result.Err :: error :: call
        create_instance =>
            close_library_quiet :: library :: call
            return Result.Err :: err :: call
        required_extensions =>
            close_library_quiet :: library :: call
            return Result.Err :: err :: call
        application_name =>
            close_library_quiet :: library :: call
            return Result.Err :: err :: call
        engine_name =>
            close_library_quiet :: library :: call
            return Result.Err :: err :: call

fn bootstrap_vulkan_present_with_instance(read window: Window, take library: DynamicLibrary, instance: GlfwVkInstance, read instance_fns: VulkanInstanceFns) -> Result[VulkanPresentContext, VulkanPresentError]:
    let surface_report = window.vulkan_surface :: instance, null :: method
    select:
        when surface_report.result != VK_SUCCESS || surface_report.surface == 0U64 =>
            #unsafe instance_fns.destroy_instance :: instance, null :: call
            close_library_quiet :: library :: call
            let error = VulkanPresentError.SurfaceCreateFailed :: surface_report.result :: call
            return Result.Err :: error :: call
        else => ()
    let surface_cleanup = SurfaceCleanup :: :: call
        destroy_instance = instance_fns.destroy_instance
        destroy_surface = instance_fns.destroy_surface
        instance = instance
        surface = surface_report.surface
    select find_graphics_present_device :: instance_fns.enumerate_physical_devices, instance_fns.queue_family_properties, instance_fns.surface_support, instance, surface_report.surface :: call:
        when Result.Ok(candidate) =>
            let queue_priority_values: [F32; 1] = [1.0; 1]
            let queue_priority_ptr: *read F32 = #unsafe &raw read queue_priority_values[0]
            let queue_create_info = VkDeviceQueueCreateInfo :: :: call
                stype = VK_STRUCTURE_TYPE_DEVICE_QUEUE_CREATE_INFO
                pnext = null
                flags = 0
                queuefamily_index = candidate.queuefamily
                queue_count = 1
                queue_priorities = queue_priority_ptr
            select maybe_c_string_local :: SWAPCHAIN_EXTENSION_NAME :: call:
                when Result.Ok(swapchain_extension_name) =>
                    let swapchain_extension_names: [MaybeStr; 1] = [swapchain_extension_name]
                    let swapchain_extension_pointers: [*read CChar; 1] = [swapchain_extension_names[0].as_ptr :: :: method]
                    let queue_create_info_ptr: *read VkDeviceQueueCreateInfo = #unsafe &raw read queue_create_info
                    let extension_names_ptr: *read *read CChar = #unsafe &raw read swapchain_extension_pointers[0]
                    let device_create_info = VkDeviceCreateInfo :: :: call
                        stype = VK_STRUCTURE_TYPE_DEVICE_CREATE_INFO
                        pnext = null
                        flags = 0
                        queue_create_info_count = 1
                        queue_create_infos = queue_create_info_ptr
                        enabled_layer_count = 0
                        enabled_layer_names = null
                        enabled_extension_count = 1
                        enabled_extension_names = extension_names_ptr
                        enabled_features = null
                    let device: VkDevice = null
                    let device_create_info_ptr: *read VkDeviceCreateInfo = #unsafe &raw read device_create_info
                    let device_ptr: *edit VkDevice = #unsafe &raw edit device
                    let device_create_result = #unsafe instance_fns.create_device :: candidate.device, device_create_info_ptr, null, device_ptr :: call
                    select:
                        when device_create_result != VK_SUCCESS || device.is_null :: :: method =>
                            cleanup_surface_context :: library, surface_cleanup :: call
                            let error = VulkanPresentError.DeviceCreateFailed :: device_create_result :: call
                            return Result.Err :: error :: call
                        else => ()
                    select lookup_instance_symbol[VkDestroyDeviceFn] :: library, instance, "vkDestroyDevice", "vkDestroyDevice" :: call:
                        when Result.Ok(destroy_device) =>
                            let device_cleanup = DeviceCleanup :: :: call
                                destroy_instance = instance_fns.destroy_instance
                                destroy_device = destroy_device
                                destroy_surface = instance_fns.destroy_surface
                                instance = instance
                                device = device
                                surface = surface_report.surface
                            select lookup_vulkan_device_fns :: library, device, destroy_device :: call:
                                when Result.Ok(device_fns) =>
                                    let queue: VkQueue = null
                                    let queue_ptr: *edit VkQueue = #unsafe &raw edit queue
                                    #unsafe device_fns.get_device_queue :: device, candidate.queuefamily, 0, queue_ptr :: call
                                    select:
                                        when queue.is_null :: :: method =>
                                            cleanup_device_context :: library, device_cleanup :: call
                                            let error = VulkanPresentError.NoQueue :: :: call
                                            return Result.Err :: error :: call
                                        else => ()
                                    let memory_properties = ZERO_MEMORY_PROPERTIES
                                    let memory_properties_ptr: *edit VkPhysicalDeviceMemoryProperties = #unsafe &raw edit memory_properties
                                    #unsafe instance_fns.memory_properties :: candidate.device, memory_properties_ptr :: call
                                    let capabilities = ZERO_SURFACE_CAPABILITIES
                                    let capabilities_ptr: *edit VkSurfaceCapabilitiesKHR = #unsafe &raw edit capabilities
                                    let capabilities_result = #unsafe instance_fns.surface_capabilities :: candidate.device, surface_report.surface, capabilities_ptr :: call
                                    select:
                                        when capabilities_result != VK_SUCCESS =>
                                            cleanup_device_context :: library, device_cleanup :: call
                                            let error = VulkanPresentError.SurfaceCapabilitiesFailed :: capabilities_result :: call
                                            return Result.Err :: error :: call
                                        when (capabilities.supported_usage_flags & VK_IMAGE_USAGE_TRANSFER_DST_BIT) == 0 =>
                                            cleanup_device_context :: library, device_cleanup :: call
                                            let error = VulkanPresentError.SurfaceTransferUnsupported :: capabilities.supported_usage_flags :: call
                                            return Result.Err :: error :: call
                                        else => ()
                                    let format_count: CUInt = 0
                                    let format_count_ptr: *edit CUInt = #unsafe &raw edit format_count
                                    let format_count_result = #unsafe instance_fns.surface_formats :: candidate.device, surface_report.surface, format_count_ptr, null :: call
                                    select:
                                        when format_count_result != VK_SUCCESS =>
                                            cleanup_device_context :: library, device_cleanup :: call
                                            let error = VulkanPresentError.SurfaceFormatsFailed :: format_count_result :: call
                                            return Result.Err :: error :: call
                                        when format_count == 0 =>
                                            cleanup_device_context :: library, device_cleanup :: call
                                            let error = VulkanPresentError.NoSurfaceFormats :: :: call
                                            return Result.Err :: error :: call
                                        when format_count > MAX_SURFACE_FORMATS_RAW =>
                                            cleanup_device_context :: library, device_cleanup :: call
                                            let error = VulkanPresentError.SurfaceFormatOverflow :: format_count :: call
                                            return Result.Err :: error :: call
                                        else => ()
                                    let formats: [VkSurfaceFormatKHR; MAX_SURFACE_FORMATS] = [ZERO_SURFACE_FORMAT; MAX_SURFACE_FORMATS]
                                    let formats_ptr: *edit VkSurfaceFormatKHR = #unsafe &raw edit formats[0]
                                    let formats_result = #unsafe instance_fns.surface_formats :: candidate.device, surface_report.surface, format_count_ptr, formats_ptr :: call
                                    select:
                                        when formats_result != VK_SUCCESS =>
                                            cleanup_device_context :: library, device_cleanup :: call
                                            let error = VulkanPresentError.SurfaceFormatsFailed :: formats_result :: call
                                            return Result.Err :: error :: call
                                        else => ()
                                    let present_mode_count: CUInt = 0
                                    let present_mode_count_ptr: *edit CUInt = #unsafe &raw edit present_mode_count
                                    let present_mode_count_result = #unsafe instance_fns.surface_present_modes :: candidate.device, surface_report.surface, present_mode_count_ptr, null :: call
                                    select:
                                        when present_mode_count_result != VK_SUCCESS =>
                                            cleanup_device_context :: library, device_cleanup :: call
                                            let error = VulkanPresentError.PresentModesFailed :: present_mode_count_result :: call
                                            return Result.Err :: error :: call
                                        when present_mode_count == 0 =>
                                            cleanup_device_context :: library, device_cleanup :: call
                                            let error = VulkanPresentError.NoPresentModes :: :: call
                                            return Result.Err :: error :: call
                                        when present_mode_count > MAX_PRESENT_MODES_RAW =>
                                            cleanup_device_context :: library, device_cleanup :: call
                                            let error = VulkanPresentError.PresentModeOverflow :: present_mode_count :: call
                                            return Result.Err :: error :: call
                                        else => ()
                                    let present_modes: [CInt; MAX_PRESENT_MODES] = [0; MAX_PRESENT_MODES]
                                    let present_modes_ptr: *edit CInt = #unsafe &raw edit present_modes[0]
                                    let present_modes_result = #unsafe instance_fns.surface_present_modes :: candidate.device, surface_report.surface, present_mode_count_ptr, present_modes_ptr :: call
                                    select:
                                        when present_modes_result != VK_SUCCESS =>
                                            cleanup_device_context :: library, device_cleanup :: call
                                            let error = VulkanPresentError.PresentModesFailed :: present_modes_result :: call
                                            return Result.Err :: error :: call
                                        else => ()
                                    select either:
                                        when chosen_surface_format: Result.Ok(chosen_surface_format) <- choose_surface_format :: formats, format_count :: call
                                        when chosen_present_mode: Result.Ok(chosen_present_mode) <- choose_present_mode :: present_modes, present_mode_count :: call
                                        when chosen_extent: Result.Ok(chosen_extent) <- choose_window_extent :: window, capabilities :: call =>
                                            let swapchain: VkSwapchain = 0U64
                                            let swapchain_info = VkSwapchainCreateInfoKHR :: :: call
                                                stype = VK_STRUCTURE_TYPE_SWAPCHAIN_CREATE_INFO_KHR
                                                pnext = null
                                                flags = 0
                                                surface = surface_report.surface
                                                min_image_count = choose_image_count :: capabilities :: call
                                                image_format = chosen_surface_format.format
                                                image_color_space = chosen_surface_format.color_space
                                                image_extent = chosen_extent
                                                image_array_layers = 1
                                                image_usage = VK_IMAGE_USAGE_TRANSFER_DST_BIT
                                                image_sharing_mode = VK_SHARING_MODE_EXCLUSIVE
                                                queuefamily_index_count = 0
                                                queuefamily_indices = null
                                                pre_transform = capabilities.current_transform
                                                composite_alpha = VK_COMPOSITE_ALPHA_OPAQUE_BIT_KHR
                                                present_mode = chosen_present_mode
                                                clipped = VK_TRUE
                                                old_swapchain = 0U64
                                            let swapchain_ptr: *edit VkSwapchain = #unsafe &raw edit swapchain
                                            let swapchain_info_ptr: *read VkSwapchainCreateInfoKHR = #unsafe &raw read swapchain_info
                                            let swapchain_create_result = #unsafe device_fns.create_swapchain :: device, swapchain_info_ptr, null, swapchain_ptr :: call
                                            select:
                                                when swapchain_create_result != VK_SUCCESS || swapchain == 0U64 =>
                                                    cleanup_device_context :: library, device_cleanup :: call
                                                    let error = VulkanPresentError.SwapchainCreateFailed :: swapchain_create_result :: call
                                                    return Result.Err :: error :: call
                                                else => ()
                                            let cleanup_with_swapchain = SwapchainCleanup :: :: call
                                                destroy_instance = instance_fns.destroy_instance
                                                destroy_device = device_fns.destroy_device
                                                destroy_surface = instance_fns.destroy_surface
                                                destroy_swapchain = device_fns.destroy_swapchain
                                                instance = instance
                                                device = device
                                                surface = surface_report.surface
                                                swapchain = swapchain
                                            let swapchain_image_count: CUInt = 0
                                            let swapchain_image_count_ptr: *edit CUInt = #unsafe &raw edit swapchain_image_count
                                            let image_count_result = #unsafe device_fns.get_swapchain_images :: device, swapchain, swapchain_image_count_ptr, null :: call
                                            select:
                                                when image_count_result != VK_SUCCESS =>
                                                    cleanup_swapchain_context :: library, cleanup_with_swapchain :: call
                                                    let error = VulkanPresentError.SwapchainImagesFailed :: image_count_result :: call
                                                    return Result.Err :: error :: call
                                                when swapchain_image_count == 0 =>
                                                    cleanup_swapchain_context :: library, cleanup_with_swapchain :: call
                                                    let error = VulkanPresentError.NoSwapchainImages :: :: call
                                                    return Result.Err :: error :: call
                                                when swapchain_image_count > MAX_SWAPCHAIN_IMAGES_RAW =>
                                                    cleanup_swapchain_context :: library, cleanup_with_swapchain :: call
                                                    let error = VulkanPresentError.SwapchainImageOverflow :: swapchain_image_count :: call
                                                    return Result.Err :: error :: call
                                                else => ()
                                            let swapchain_images: [VkImage; MAX_SWAPCHAIN_IMAGES] = [0U64; MAX_SWAPCHAIN_IMAGES]
                                            let swapchain_images_ptr: *edit VkImage = #unsafe &raw edit swapchain_images[0]
                                            let swapchain_images_result = #unsafe device_fns.get_swapchain_images :: device, swapchain, swapchain_image_count_ptr, swapchain_images_ptr :: call
                                            select:
                                                when swapchain_images_result != VK_SUCCESS =>
                                                    cleanup_swapchain_context :: library, cleanup_with_swapchain :: call
                                                    let error = VulkanPresentError.SwapchainImagesFailed :: swapchain_images_result :: call
                                                    return Result.Err :: error :: call
                                                else => ()
                                            let context = VulkanPresentContext :: :: call
                                                library = library
                                                destroy_instance = instance_fns.destroy_instance
                                                destroy_device = device_fns.destroy_device
                                                destroy_surface = instance_fns.destroy_surface
                                                destroy_swapchain = device_fns.destroy_swapchain
                                                create_image = device_fns.create_image
                                                destroy_image = device_fns.destroy_image
                                                get_image_memory_requirements = device_fns.get_image_memory_requirements
                                                bind_image_memory = device_fns.bind_image_memory
                                                create_buffer = device_fns.create_buffer
                                                destroy_buffer = device_fns.destroy_buffer
                                                get_buffer_memory_requirements = device_fns.get_buffer_memory_requirements
                                                allocate_memory = device_fns.allocate_memory
                                                free_memory = device_fns.free_memory
                                                bind_buffer_memory = device_fns.bind_buffer_memory
                                                map_memory = device_fns.map_memory
                                                unmap_memory = device_fns.unmap_memory
                                                flush_mapped_memory_ranges = device_fns.flush_mapped_memory_ranges
                                                invalidate_mapped_memory_ranges = device_fns.invalidate_mapped_memory_ranges
                                                create_command_pool = device_fns.create_command_pool
                                                destroy_command_pool = device_fns.destroy_command_pool
                                                allocate_command_buffers = device_fns.allocate_command_buffers
                                                begin_command_buffer = device_fns.begin_command_buffer
                                                end_command_buffer = device_fns.end_command_buffer
                                                cmd_pipeline_barrier = device_fns.cmd_pipeline_barrier
                                                cmd_clear_color_image = device_fns.cmd_clear_color_image
                                                cmd_copy_buffer = device_fns.cmd_copy_buffer
                                                cmd_copy_buffer_to_image = device_fns.cmd_copy_buffer_to_image
                                                cmd_copy_image = device_fns.cmd_copy_image
                                                cmd_copy_image_to_buffer = device_fns.cmd_copy_image_to_buffer
                                                create_fence = device_fns.create_fence
                                                destroy_fence = device_fns.destroy_fence
                                                reset_fences = device_fns.reset_fences
                                                wait_for_fences = device_fns.wait_for_fences
                                                get_fence_status = device_fns.get_fence_status
                                                create_semaphore = device_fns.create_semaphore
                                                destroy_semaphore = device_fns.destroy_semaphore
                                                acquire_next_image = device_fns.acquire_next_image
                                                queue_submit = device_fns.queue_submit
                                                queue_present = device_fns.queue_present
                                                queue_wait_idle = device_fns.queue_wait_idle
                                                device_wait_idle = device_fns.device_wait_idle
                                                instance = instance
                                                device = device
                                                queue = queue
                                                surface = surface_report.surface
                                                physical_device = candidate.device
                                                queuefamily = candidate.queuefamily
                                                surface_format = chosen_surface_format
                                                surface_capabilities = capabilities
                                                memory_properties = memory_properties
                                                present_mode = chosen_present_mode
                                                extent = chosen_extent
                                                swapchain = swapchain
                                                swapchain_images = swapchain_images
                                                swapchain_image_count = swapchain_image_count
                                                presented_once = false
                                            return Result.Ok :: context :: call

                                    with Result.Err(err):
                                        chosen_surface_format =>
                                            cleanup_device_context :: library, device_cleanup :: call
                                            return Result.Err :: err :: call
                                        chosen_present_mode =>
                                            cleanup_device_context :: library, device_cleanup :: call
                                            return Result.Err :: err :: call
                                        chosen_extent =>
                                            cleanup_device_context :: library, device_cleanup :: call
                                            return Result.Err :: err :: call
                                when Result.Err(err) =>
                                    cleanup_device_context :: library, device_cleanup :: call
                                    return Result.Err :: err :: call
                        when Result.Err(err) =>
                            cleanup_surface_context :: library, surface_cleanup :: call
                            return Result.Err :: err :: call
                when Result.Err(err) =>
                    cleanup_surface_context :: library, surface_cleanup :: call
                    return Result.Err :: err :: call
        when Result.Err(err) =>
            cleanup_surface_context :: library, surface_cleanup :: call
            return Result.Err :: err :: call

fn collect_swapchain_images(read source: [VkImage; MAX_SWAPCHAIN_IMAGES], count: CUInt) -> List[VkImage]:
    let copied = List[VkImage] :: :: call
    select:
        when count > 0 => copied.push :: source[0] :: method
        else => ()
    select:
        when count > 1 => copied.push :: source[1] :: method
        else => ()
    select:
        when count > 2 => copied.push :: source[2] :: method
        else => ()
    select:
        when count > 3 => copied.push :: source[3] :: method
        else => ()
    select:
        when count > 4 => copied.push :: source[4] :: method
        else => ()
    select:
        when count > 5 => copied.push :: source[5] :: method
        else => ()
    select:
        when count > 6 => copied.push :: source[6] :: method
        else => ()
    select:
        when count > 7 => copied.push :: source[7] :: method
        else => ()
    return copied

fn copy_swapchain_image_list(read source: List[VkImage]) -> List[VkImage]:
    let copied = List[VkImage] :: :: call
    let count = source.count :: :: method
    select:
        when count > 0 => copied.push :: source[0] :: method
        else => ()
    select:
        when count > 1 => copied.push :: source[1] :: method
        else => ()
    select:
        when count > 2 => copied.push :: source[2] :: method
        else => ()
    select:
        when count > 3 => copied.push :: source[3] :: method
        else => ()
    select:
        when count > 4 => copied.push :: source[4] :: method
        else => ()
    select:
        when count > 5 => copied.push :: source[5] :: method
        else => ()
    select:
        when count > 6 => copied.push :: source[6] :: method
        else => ()
    select:
        when count > 7 => copied.push :: source[7] :: method
        else => ()
    return copied

fn copy_vulkan_present_bindings(read source: VulkanPresentBindings) -> VulkanPresentBindings:
    let copied_images = copy_swapchain_image_list :: source.swapchain_images :: call
    let copied = VulkanPresentBindings :: :: call
        instance = source.instance
        physical_device = source.physical_device
        device = source.device
        queue = source.queue
        surface = source.surface
        swapchain = source.swapchain
        queuefamily_index = source.queuefamily_index
        swapchain_image_count = source.swapchain_image_count
        swapchain_images = copied_images
    return copied

impl VulkanPresentBindings:
    fn instance_valid(read self) -> Bool:
        return !self.instance.is_null :: :: method

    fn physical_device_valid(read self) -> Bool:
        return !self.physical_device.is_null :: :: method

    fn device_valid(read self) -> Bool:
        return !self.device.is_null :: :: method

    fn queue_valid(read self) -> Bool:
        return !self.queue.is_null :: :: method

    fn surface_valid(read self) -> Bool:
        return self.surface != 0U64

    fn swapchain_valid(read self) -> Bool:
        return self.swapchain != 0U64

    fn has_swapchain_images(read self) -> Bool:
        return self.swapchain_image_count != 0

    fn ready_for_interop(read self) -> Bool:
        select:
            when !self.instance_valid :: :: method => return false
            when !self.physical_device_valid :: :: method => return false
            when !self.device_valid :: :: method => return false
            when !self.queue_valid :: :: method => return false
            when !self.surface_valid :: :: method => return false
            when !self.swapchain_valid :: :: method => return false
            when !self.has_swapchain_images :: :: method => return false
            else => return true

    fn swapchain_image(read self, index: CUInt) -> Option[VkImage]:
        select:
            when index >= self.swapchain_image_count => return Option.None
            else => ()
        let Result.Ok(slot) = index as Maybe[Index] else => return Option.None
        return Option.Some :: self.swapchain_images[slot] :: call

    fn first_swapchain_image(read self) -> Option[VkImage]:
        return self.swapchain_image :: 0 :: method

    fn active_swapchain_images(read self) -> List[VkImage]:
        return copy_swapchain_image_list :: self.swapchain_images :: call

impl VulkanPresentSnapshot:
    fn bindings(read self) -> VulkanPresentBindings:
        return copy_vulkan_present_bindings :: self.bindings :: call

impl VulkanSemaphoreResource:
    fn semaphore_handle(read self) -> VkSemaphore:
        return self.semaphore

    fn valid(read self) -> Bool:
        return self.semaphore != 0U64

impl VulkanPresentContext:
    fn bindings(read self) -> VulkanPresentBindings:
        let swapchain_images = collect_swapchain_images :: self.swapchain_images, self.swapchain_image_count :: call
        let bindings = VulkanPresentBindings :: :: call
            instance = self.instance
            physical_device = self.physical_device
            device = self.device
            queue = self.queue
            surface = self.surface
            swapchain = self.swapchain
            queuefamily_index = self.queuefamily
            swapchain_image_count = self.swapchain_image_count
            swapchain_images = swapchain_images
        return bindings

    fn present_snapshot(read self, window_id: WindowId) -> VulkanPresentSnapshot:
        let snapshot = VulkanPresentSnapshot :: :: call
            bindings = self.bindings :: :: method
            window_id = window_id
            queuefamily_index = self.queuefamily
            surface_capabilities = self.surface_capabilities
            surface_format = self.surface_format
            memory_properties = self.memory_properties
            present_mode = self.present_mode
            swapchain_image_count = self.swapchain_image_count
            preferred_image_count = self.preferred_image_count :: :: method
            surface_extent = self.extent
            presented_once = self.presented_once
        return snapshot

    fn semaphore_resource(read self) -> Result[VulkanSemaphoreResource, VulkanPresentError]:
        let semaphore: VkSemaphore = 0U64
        let semaphore_info = VkSemaphoreCreateInfo :: :: call
            stype = VK_STRUCTURE_TYPE_SEMAPHORE_CREATE_INFO
            pnext = null
            flags = 0
        let semaphore_ptr: *edit VkSemaphore = #unsafe &raw edit semaphore
        let semaphore_info_ptr: *read VkSemaphoreCreateInfo = #unsafe &raw read semaphore_info
        let semaphore_result = #unsafe self.create_semaphore :: self.device, semaphore_info_ptr, null, semaphore_ptr :: call
        select:
            when semaphore_result != VK_SUCCESS =>
                let error = VulkanPresentError.SemaphoreCreateFailed :: semaphore_result :: call
                return Result.Err :: error :: call
            when semaphore == 0U64 =>
                let error = VulkanPresentError.SemaphoreCreateFailed :: semaphore_result :: call
                return Result.Err :: error :: call
            else => ()
        let resource = VulkanSemaphoreResource :: :: call
            semaphore = semaphore
        return Result.Ok :: resource :: call

    fn destroy_semaphore_resource(read self, take semaphore: VulkanSemaphoreResource) -> Unit:
        select:
            when semaphore.semaphore != 0U64 => #unsafe self.destroy_semaphore :: self.device, semaphore.semaphore, null :: call
            else => ()
        return

impl VulkanPresentApp:
    fn present_snapshot(read self) -> VulkanPresentSnapshot:
        return self.context.present_snapshot :: self.window.id :: method

    fn bindings(read self) -> VulkanPresentBindings:
        return self.context.bindings :: :: method

    fn semaphore_resource(read self) -> Result[VulkanSemaphoreResource, VulkanPresentError]:
        return self.context.semaphore_resource :: :: method

    fn destroy_semaphore_resource(read self, take semaphore: VulkanSemaphoreResource) -> Unit:
        return self.context.destroy_semaphore_resource :: semaphore :: method

    fn present(edit self, read color: PresentColor) -> Result[Unit, VulkanPresentError]:
        return self.context.present :: color :: method

    fn destroy(take self) -> Result[Unit, VulkanPresentError]:
        select self.context.destroy :: :: method:
            when Result.Ok(_) =>
                self.app.terminate :: :: method
                return Result.Ok :: () :: call
            when Result.Err(err) =>
                self.app.terminate :: :: method
                return Result.Err :: err :: call

impl VulkanPresentContext:
    fn queuefamily_index(read self) -> CUInt:
        return self.queuefamily

    fn present(edit self, read color: PresentColor) -> Result[Unit, VulkanPresentError]:
        let command_pool: VkCommandPool = 0U64
        let command_buffer: VkCommandBuffer = null
        let image_available: VkSemaphore = 0U64
        let render_complete: VkSemaphore = 0U64

        let command_pool_info = VkCommandPoolCreateInfo :: :: call
            stype = VK_STRUCTURE_TYPE_COMMAND_POOL_CREATE_INFO
            pnext = null
            flags = 0
            queuefamily_index = self.queuefamily
        let command_pool_ptr: *edit VkCommandPool = #unsafe &raw edit command_pool
        let command_pool_info_ptr: *read VkCommandPoolCreateInfo = #unsafe &raw read command_pool_info
        let command_pool_result = #unsafe self.create_command_pool :: self.device, command_pool_info_ptr, null, command_pool_ptr :: call
        select:
            when command_pool_result != VK_SUCCESS || command_pool == 0U64 =>
                let error = VulkanPresentError.CommandPoolCreateFailed :: command_pool_result :: call
                return Result.Err :: error :: call
            else => ()

        let command_buffer_info = VkCommandBufferAllocateInfo :: :: call
            stype = VK_STRUCTURE_TYPE_COMMAND_BUFFER_ALLOCATE_INFO
            pnext = null
            command_pool = command_pool
            level = VK_COMMAND_BUFFER_LEVEL_PRIMARY
            command_buffer_count = 1
        let command_buffer_ptr: *edit VkCommandBuffer = #unsafe &raw edit command_buffer
        let command_buffer_info_ptr: *read VkCommandBufferAllocateInfo = #unsafe &raw read command_buffer_info
        let command_buffer_result = #unsafe self.allocate_command_buffers :: self.device, command_buffer_info_ptr, command_buffer_ptr :: call
        select:
            when command_buffer_result != VK_SUCCESS || command_buffer.is_null :: :: method =>
                #unsafe self.destroy_command_pool :: self.device, command_pool, null :: call
                let error = VulkanPresentError.CommandBufferAllocateFailed :: command_buffer_result :: call
                return Result.Err :: error :: call
            else => ()

        let semaphore_info = VkSemaphoreCreateInfo :: :: call
            stype = VK_STRUCTURE_TYPE_SEMAPHORE_CREATE_INFO
            pnext = null
            flags = 0
        let semaphore_info_ptr: *read VkSemaphoreCreateInfo = #unsafe &raw read semaphore_info
        let image_available_ptr: *edit VkSemaphore = #unsafe &raw edit image_available
        let image_available_result = #unsafe self.create_semaphore :: self.device, semaphore_info_ptr, null, image_available_ptr :: call
        select:
            when image_available_result != VK_SUCCESS || image_available == 0U64 =>
                #unsafe self.destroy_command_pool :: self.device, command_pool, null :: call
                let error = VulkanPresentError.SemaphoreCreateFailed :: image_available_result :: call
                return Result.Err :: error :: call
            else => ()
        let render_complete_ptr: *edit VkSemaphore = #unsafe &raw edit render_complete
        let render_complete_result = #unsafe self.create_semaphore :: self.device, semaphore_info_ptr, null, render_complete_ptr :: call
        select:
            when render_complete_result != VK_SUCCESS || render_complete == 0U64 =>
                #unsafe self.destroy_semaphore :: self.device, image_available, null :: call
                #unsafe self.destroy_command_pool :: self.device, command_pool, null :: call
                let error = VulkanPresentError.SemaphoreCreateFailed :: render_complete_result :: call
                return Result.Err :: error :: call
            else => ()

        let image_index: CUInt = 0
        let image_index_ptr: *edit CUInt = #unsafe &raw edit image_index
        let acquire_result = #unsafe self.acquire_next_image :: self.device, self.swapchain, VK_TIMEOUT_FOREVER, image_available, 0U64, image_index_ptr :: call
        select:
            when acquire_result != VK_SUCCESS && acquire_result != VK_SUBOPTIMAL_KHR =>
                #unsafe self.destroy_semaphore :: self.device, render_complete, null :: call
                #unsafe self.destroy_semaphore :: self.device, image_available, null :: call
                #unsafe self.destroy_command_pool :: self.device, command_pool, null :: call
                let error = VulkanPresentError.AcquireFailed :: acquire_result :: call
                return Result.Err :: error :: call
            else => ()
        let Result.Ok(image_slot) = image_index as Maybe[Index] else =>
            #unsafe self.destroy_semaphore :: self.device, render_complete, null :: call
            #unsafe self.destroy_semaphore :: self.device, image_available, null :: call
            #unsafe self.destroy_command_pool :: self.device, command_pool, null :: call
            let error = VulkanPresentError.NoSwapchainImages :: :: call
            return Result.Err :: error :: call
        let target_image = self.swapchain_images[image_slot]

        let begin_info = VkCommandBufferBeginInfo :: :: call
            stype = VK_STRUCTURE_TYPE_COMMAND_BUFFER_BEGIN_INFO
            pnext = null
            flags = VK_COMMAND_BUFFER_USAGE_ONE_TIME_SUBMIT_BIT
            inheritance_info = null
        let begin_info_ptr: *read VkCommandBufferBeginInfo = #unsafe &raw read begin_info
        let begin_result = #unsafe self.begin_command_buffer :: command_buffer, begin_info_ptr :: call
        select:
            when begin_result != VK_SUCCESS =>
                #unsafe self.destroy_semaphore :: self.device, render_complete, null :: call
                #unsafe self.destroy_semaphore :: self.device, image_available, null :: call
                #unsafe self.destroy_command_pool :: self.device, command_pool, null :: call
                let error = VulkanPresentError.CommandBufferBeginFailed :: begin_result :: call
                return Result.Err :: error :: call
            else => ()

        let before_barrier = VkImageMemoryBarrier :: :: call
            stype = VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER
            pnext = null
            src_access_mask = 0
            dst_access_mask = VK_ACCESS_TRANSFER_WRITE_BIT
            old_layout = VK_IMAGE_LAYOUT_UNDEFINED
            new_layout = VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL
            src_queuefamily_index = VK_QUEUE_FAMILY_IGNORED
            dst_queuefamily_index = VK_QUEUE_FAMILY_IGNORED
            image = target_image
            subresource_range = CLEAR_RANGE
        select:
            when self.presented_once =>
                before_barrier.stype = VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER
                before_barrier.src_access_mask = VK_ACCESS_MEMORY_READ_BIT
                before_barrier.old_layout = VK_IMAGE_LAYOUT_PRESENT_SRC_KHR
            else => ()
        let before_barrier_ptr: *read VkImageMemoryBarrier = #unsafe &raw read before_barrier
        let before_stage: CUInt = VK_PIPELINE_STAGE_TOP_OF_PIPE_BIT
        select:
            when self.presented_once => before_stage = VK_PIPELINE_STAGE_BOTTOM_OF_PIPE_BIT
            else => ()
        #unsafe self.cmd_pipeline_barrier :: command_buffer, before_stage, VK_PIPELINE_STAGE_TRANSFER_BIT, 0, 0, null, 0, null, 1, before_barrier_ptr :: call

        let clear_color = VkClearColorValue :: :: call
            float32_values = [color.red, color.green, color.blue, color.alpha]
        let clear_color_ptr: *read VkClearColorValue = #unsafe &raw read clear_color
        let clear_range = CLEAR_RANGE
        let clear_range_ptr: *read VkImageSubresourceRange = #unsafe &raw read clear_range
        #unsafe self.cmd_clear_color_image :: command_buffer, target_image, VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL, clear_color_ptr, 1, clear_range_ptr :: call

        let after_barrier = VkImageMemoryBarrier :: :: call
            stype = VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER
            pnext = null
            src_access_mask = VK_ACCESS_TRANSFER_WRITE_BIT
            dst_access_mask = VK_ACCESS_MEMORY_READ_BIT
            old_layout = VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL
            new_layout = VK_IMAGE_LAYOUT_PRESENT_SRC_KHR
            src_queuefamily_index = VK_QUEUE_FAMILY_IGNORED
            dst_queuefamily_index = VK_QUEUE_FAMILY_IGNORED
            image = target_image
            subresource_range = CLEAR_RANGE
        let after_barrier_ptr: *read VkImageMemoryBarrier = #unsafe &raw read after_barrier
        #unsafe self.cmd_pipeline_barrier :: command_buffer, VK_PIPELINE_STAGE_TRANSFER_BIT, VK_PIPELINE_STAGE_BOTTOM_OF_PIPE_BIT, 0, 0, null, 0, null, 1, after_barrier_ptr :: call

        let end_result = #unsafe self.end_command_buffer :: command_buffer :: call
        select:
            when end_result != VK_SUCCESS =>
                #unsafe self.destroy_semaphore :: self.device, render_complete, null :: call
                #unsafe self.destroy_semaphore :: self.device, image_available, null :: call
                #unsafe self.destroy_command_pool :: self.device, command_pool, null :: call
                let error = VulkanPresentError.CommandBufferEndFailed :: end_result :: call
                return Result.Err :: error :: call
            else => ()

        let wait_stage_masks: [CUInt; 1] = [VK_PIPELINE_STAGE_TRANSFER_BIT]
        let wait_stage_ptr: *read CUInt = #unsafe &raw read wait_stage_masks[0]
        let wait_semaphores: [VkSemaphore; 1] = [image_available]
        let signal_semaphores: [VkSemaphore; 1] = [render_complete]
        let command_buffers: [VkCommandBuffer; 1] = [command_buffer]
        let wait_semaphore_ptr: *read VkSemaphore = #unsafe &raw read wait_semaphores[0]
        let signal_semaphore_ptr: *read VkSemaphore = #unsafe &raw read signal_semaphores[0]
        let command_buffer_submit_ptr: *read VkCommandBuffer = #unsafe &raw read command_buffers[0]
        let submit_info = VkSubmitInfo :: :: call
            stype = VK_STRUCTURE_TYPE_SUBMIT_INFO
            pnext = null
            wait_semaphore_count = 1
            wait_semaphores = wait_semaphore_ptr
            wait_dst_stage_mask = wait_stage_ptr
            command_buffer_count = 1
            command_buffers = command_buffer_submit_ptr
            signal_semaphore_count = 1
            signal_semaphores = signal_semaphore_ptr
        let submit_info_ptr: *read VkSubmitInfo = #unsafe &raw read submit_info
        let submit_result = #unsafe self.queue_submit :: self.queue, 1, submit_info_ptr, 0U64 :: call
        select:
            when submit_result != VK_SUCCESS =>
                #unsafe self.destroy_semaphore :: self.device, render_complete, null :: call
                #unsafe self.destroy_semaphore :: self.device, image_available, null :: call
                #unsafe self.destroy_command_pool :: self.device, command_pool, null :: call
                let error = VulkanPresentError.SubmitFailed :: submit_result :: call
                return Result.Err :: error :: call
            else => ()

        let swapchains: [VkSwapchain; 1] = [self.swapchain]
        let swapchain_ptr: *read VkSwapchain = #unsafe &raw read swapchains[0]
        let image_index_read_ptr: *read CUInt = #unsafe &raw read image_index
        let present_info = VkPresentInfoKHR :: :: call
            stype = VK_STRUCTURE_TYPE_PRESENT_INFO_KHR
            pnext = null
            wait_semaphore_count = 1
            wait_semaphores = signal_semaphore_ptr
            swapchain_count = 1
            swapchains = swapchain_ptr
            image_indices = image_index_read_ptr
            results = null
        let present_info_ptr: *read VkPresentInfoKHR = #unsafe &raw read present_info
        let present_result = #unsafe self.queue_present :: self.queue, present_info_ptr :: call
        select:
            when present_result != VK_SUCCESS && present_result != VK_SUBOPTIMAL_KHR =>
                #unsafe self.destroy_semaphore :: self.device, render_complete, null :: call
                #unsafe self.destroy_semaphore :: self.device, image_available, null :: call
                #unsafe self.destroy_command_pool :: self.device, command_pool, null :: call
                let error = VulkanPresentError.PresentFailed :: present_result :: call
                return Result.Err :: error :: call
            else => ()

        let idle_result = #unsafe self.queue_wait_idle :: self.queue :: call
        #unsafe self.destroy_semaphore :: self.device, render_complete, null :: call
        #unsafe self.destroy_semaphore :: self.device, image_available, null :: call
        #unsafe self.destroy_command_pool :: self.device, command_pool, null :: call
        select:
            when idle_result != VK_SUCCESS =>
                let error = VulkanPresentError.QueueWaitIdleFailed :: idle_result :: call
                return Result.Err :: error :: call
            else => ()
        self.presented_once = true
        return Result.Ok :: () :: call

    fn destroy(take self) -> Result[Unit, VulkanPresentError]:
        let wait_result = #unsafe self.device_wait_idle :: self.device :: call
        #unsafe self.destroy_swapchain :: self.device, self.swapchain, null :: call
        #unsafe self.destroy_device :: self.device, null :: call
        #unsafe self.destroy_surface :: self.instance, self.surface, null :: call
        #unsafe self.destroy_instance :: self.instance, null :: call
        let close_result = #unsafe close_library :: self.library :: call
        select close_result:
            when Result.Ok(_) =>
                select:
                    when wait_result != VK_SUCCESS =>
                        let error = VulkanPresentError.DeviceWaitIdleFailed :: wait_result :: call
                        return Result.Err :: error :: call
                    else => return Result.Ok :: () :: call
            when Result.Err(err) =>
                let error = VulkanPresentError.LibraryClose :: err :: call
                return Result.Err :: error :: call
