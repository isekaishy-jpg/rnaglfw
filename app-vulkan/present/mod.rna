pub enum VulkanPresentError:
    NotSupported
    LibraryOpen(DynamicLibraryError)
    LibraryClose(DynamicLibraryError)
    SymbolLookup(SymbolLookupError)
    ProcUnavailable(Str)
    TextDecode(TextDecodeError)
    UnsupportedRequiredInstanceExtensionCount(CUInt)
    PhysicalDeviceOverflow(CUInt)
    QueueFamilyOverflow(CUInt)
    SurfaceFormatOverflow(CUInt)
    PresentModeOverflow(CUInt)
    SwapchainImageOverflow(CUInt)
    WindowExtentOutOfRange
    SurfaceExtentOutOfRange(CUInt, CUInt)
    SurfaceTransferUnsupported(CUInt)
    ImageCreate(RgbaImageError)
    ImageAccess(RgbaImageError)
    ColorBlend(RgbaImageError)
    PixelExtentOutOfRange(CInt, CInt)
    PixelByteCountOutOfRange(CUInt, CUInt)
    PixelExtentMismatch(CInt, CInt, CUInt, CUInt)
    PixelByteCountMismatch(Index, Index)
    BufferByteCountMismatch(Index, Index)
    BufferSizeOutOfRange(Index)
    PixelFrameZeroSize
    PixelFrameStrideTooSmall(Index, Index)
    PixelFrameBufferTooSmall(Index, Index)
    PixelFrameByteCountOutOfRange(Index, Index, Index)
    PixelFrameCoordOutOfRange(Index, Index, Index, Index)
    PixelFrameRectZeroSize
    PixelFrameExtentMismatch(Index, Index, CUInt, CUInt)
    SurfaceFormatUnsupported(CInt)
    StagingSizeOutOfRange(Index)
    VulkanImageExtentOutOfRange(CUInt, CUInt)
    InstanceCreateFailed(GlfwVkResult)
    SurfaceCreateFailed(GlfwVkResult)
    PhysicalDeviceQueryFailed(GlfwVkResult)
    SurfaceCapabilitiesFailed(GlfwVkResult)
    SurfaceFormatsFailed(GlfwVkResult)
    PresentModesFailed(GlfwVkResult)
    DeviceCreateFailed(GlfwVkResult)
    SwapchainCreateFailed(GlfwVkResult)
    SwapchainImagesFailed(GlfwVkResult)
    CommandPoolCreateFailed(GlfwVkResult)
    CommandBufferAllocateFailed(GlfwVkResult)
    CommandBufferBeginFailed(GlfwVkResult)
    CommandBufferEndFailed(GlfwVkResult)
    SemaphoreCreateFailed(GlfwVkResult)
    BufferCreateFailed(GlfwVkResult)
    BufferMemoryTypeUnavailable(CUInt)
    BufferMemoryAllocateFailed(GlfwVkResult)
    BufferBindFailed(GlfwVkResult)
    BufferMemoryMapFailed(GlfwVkResult)
    StagingBufferCreateFailed(GlfwVkResult)
    StagingMemoryTypeUnavailable(CUInt)
    StagingMemoryAllocateFailed(GlfwVkResult)
    StagingBufferBindFailed(GlfwVkResult)
    StagingMemoryMapFailed(GlfwVkResult)
    VulkanImageCreateFailed(GlfwVkResult)
    VulkanImageMemoryTypeUnavailable(CUInt)
    VulkanImageMemoryAllocateFailed(GlfwVkResult)
    VulkanImageBindFailed(GlfwVkResult)
    TransferDestinationImageCreateFailed(GlfwVkResult)
    TransferDestinationImageMemoryTypeUnavailable(CUInt)
    TransferDestinationImageMemoryAllocateFailed(GlfwVkResult)
    TransferDestinationImageBindFailed(GlfwVkResult)
    TransferDestinationImageUninitialized
    AcquireFailed(GlfwVkResult)
    SubmitFailed(GlfwVkResult)
    PresentFailed(GlfwVkResult)
    QueueWaitIdleFailed(GlfwVkResult)
    DeviceWaitIdleFailed(GlfwVkResult)
    NoGraphicsPresentDevice
    NoSurfaceFormats
    NoPresentModes
    NoSwapchainImages
    NoQueue

pub opaque type VkDeviceRaw
pub opaque type VkQueueRaw
pub opaque type VkCommandBufferRaw
pub opaque type VkPhysicalDeviceFeaturesRaw

pub type VkDevice = *edit VkDeviceRaw
pub type VkQueue = *edit VkQueueRaw
pub type VkCommandBuffer = *edit VkCommandBufferRaw
pub type VkCommandPool = U64
pub type VkFormat = CInt
pub type VkImage = U64
pub type VkBuffer = U64
pub type VkDeviceMemory = U64
pub type VkSwapchain = U64
pub type VkSemaphore = U64
pub type VkFence = U64

pub type VkCreateInstanceFn = extern["system"] fn(*read VkInstanceCreateInfo, *read GlfwVkAllocationCallbacksRaw, *edit GlfwVkInstance) -> GlfwVkResult
pub type VkDestroyInstanceFn = extern["system"] fn(GlfwVkInstance, *read GlfwVkAllocationCallbacksRaw) -> CVoid
pub type VkEnumeratePhysicalDevicesFn = extern["system"] fn(GlfwVkInstance, *edit CUInt, *edit GlfwVkPhysicalDevice) -> GlfwVkResult
pub type VkGetPhysicalDeviceQueueFamilyPropertiesFn = extern["system"] fn(GlfwVkPhysicalDevice, *edit CUInt, *edit VkQueueFamilyProperties) -> CVoid
pub type VkGetPhysicalDeviceMemoryPropertiesFn = extern["system"] fn(GlfwVkPhysicalDevice, *edit VkPhysicalDeviceMemoryProperties) -> CVoid
pub type VkGetPhysicalDeviceSurfaceSupportFn = extern["system"] fn(GlfwVkPhysicalDevice, CUInt, GlfwVkSurface, *edit CUInt) -> GlfwVkResult
pub type VkGetPhysicalDeviceSurfaceCapabilitiesFn = extern["system"] fn(GlfwVkPhysicalDevice, GlfwVkSurface, *edit VkSurfaceCapabilitiesKHR) -> GlfwVkResult
pub type VkGetPhysicalDeviceSurfaceFormatsFn = extern["system"] fn(GlfwVkPhysicalDevice, GlfwVkSurface, *edit CUInt, *edit VkSurfaceFormatKHR) -> GlfwVkResult
pub type VkGetPhysicalDeviceSurfacePresentModesFn = extern["system"] fn(GlfwVkPhysicalDevice, GlfwVkSurface, *edit CUInt, *edit CInt) -> GlfwVkResult
pub type VkCreateDeviceFn = extern["system"] fn(GlfwVkPhysicalDevice, *read VkDeviceCreateInfo, *read GlfwVkAllocationCallbacksRaw, *edit VkDevice) -> GlfwVkResult
pub type VkDestroyDeviceFn = extern["system"] fn(VkDevice, *read GlfwVkAllocationCallbacksRaw) -> CVoid
pub type VkDestroySurfaceFn = extern["system"] fn(GlfwVkInstance, GlfwVkSurface, *read GlfwVkAllocationCallbacksRaw) -> CVoid
pub type VkGetDeviceQueueFn = extern["system"] fn(VkDevice, CUInt, CUInt, *edit VkQueue) -> CVoid
pub type VkCreateSwapchainFn = extern["system"] fn(VkDevice, *read VkSwapchainCreateInfoKHR, *read GlfwVkAllocationCallbacksRaw, *edit VkSwapchain) -> GlfwVkResult
pub type VkDestroySwapchainFn = extern["system"] fn(VkDevice, VkSwapchain, *read GlfwVkAllocationCallbacksRaw) -> CVoid
pub type VkGetSwapchainImagesFn = extern["system"] fn(VkDevice, VkSwapchain, *edit CUInt, *edit VkImage) -> GlfwVkResult
pub type VkCreateImageFn = extern["system"] fn(VkDevice, *read VkImageCreateInfo, *read GlfwVkAllocationCallbacksRaw, *edit VkImage) -> GlfwVkResult
pub type VkDestroyImageFn = extern["system"] fn(VkDevice, VkImage, *read GlfwVkAllocationCallbacksRaw) -> CVoid
pub type VkGetImageMemoryRequirementsFn = extern["system"] fn(VkDevice, VkImage, *edit VkMemoryRequirements) -> CVoid
pub type VkBindImageMemoryFn = extern["system"] fn(VkDevice, VkImage, VkDeviceMemory, U64) -> GlfwVkResult
pub type VkCreateBufferFn = extern["system"] fn(VkDevice, *read VkBufferCreateInfo, *read GlfwVkAllocationCallbacksRaw, *edit VkBuffer) -> GlfwVkResult
pub type VkDestroyBufferFn = extern["system"] fn(VkDevice, VkBuffer, *read GlfwVkAllocationCallbacksRaw) -> CVoid
pub type VkGetBufferMemoryRequirementsFn = extern["system"] fn(VkDevice, VkBuffer, *edit VkMemoryRequirements) -> CVoid
pub type VkAllocateMemoryFn = extern["system"] fn(VkDevice, *read VkMemoryAllocateInfo, *read GlfwVkAllocationCallbacksRaw, *edit VkDeviceMemory) -> GlfwVkResult
pub type VkFreeMemoryFn = extern["system"] fn(VkDevice, VkDeviceMemory, *read GlfwVkAllocationCallbacksRaw) -> CVoid
pub type VkBindBufferMemoryFn = extern["system"] fn(VkDevice, VkBuffer, VkDeviceMemory, U64) -> GlfwVkResult
pub type VkMapMemoryFn = extern["system"] fn(VkDevice, VkDeviceMemory, U64, U64, CUInt, *edit *edit CVoid) -> GlfwVkResult
pub type VkUnmapMemoryFn = extern["system"] fn(VkDevice, VkDeviceMemory) -> CVoid
pub type VkCreateCommandPoolFn = extern["system"] fn(VkDevice, *read VkCommandPoolCreateInfo, *read GlfwVkAllocationCallbacksRaw, *edit VkCommandPool) -> GlfwVkResult
pub type VkDestroyCommandPoolFn = extern["system"] fn(VkDevice, VkCommandPool, *read GlfwVkAllocationCallbacksRaw) -> CVoid
pub type VkAllocateCommandBuffersFn = extern["system"] fn(VkDevice, *read VkCommandBufferAllocateInfo, *edit VkCommandBuffer) -> GlfwVkResult
pub type VkBeginCommandBufferFn = extern["system"] fn(VkCommandBuffer, *read VkCommandBufferBeginInfo) -> GlfwVkResult
pub type VkEndCommandBufferFn = extern["system"] fn(VkCommandBuffer) -> GlfwVkResult
pub type VkCmdPipelineBarrierFn = extern["system"] fn(VkCommandBuffer, CUInt, CUInt, CUInt, CUInt, *read CVoid, CUInt, *read CVoid, CUInt, *read VkImageMemoryBarrier) -> CVoid
pub type VkCmdClearColorImageFn = extern["system"] fn(VkCommandBuffer, VkImage, CInt, *read VkClearColorValue, CUInt, *read VkImageSubresourceRange) -> CVoid
pub type VkCmdCopyBufferToImageFn = extern["system"] fn(VkCommandBuffer, VkBuffer, VkImage, CInt, CUInt, *read VkBufferImageCopy) -> CVoid
pub type VkCmdCopyImageFn = extern["system"] fn(VkCommandBuffer, VkImage, CInt, VkImage, CInt, CUInt, *read VkImageCopy) -> CVoid
pub type VkCmdCopyImageToBufferFn = extern["system"] fn(VkCommandBuffer, VkImage, CInt, VkBuffer, CUInt, *read VkBufferImageCopy) -> CVoid
pub type VkCreateSemaphoreFn = extern["system"] fn(VkDevice, *read VkSemaphoreCreateInfo, *read GlfwVkAllocationCallbacksRaw, *edit VkSemaphore) -> GlfwVkResult
pub type VkDestroySemaphoreFn = extern["system"] fn(VkDevice, VkSemaphore, *read GlfwVkAllocationCallbacksRaw) -> CVoid
pub type VkAcquireNextImageFn = extern["system"] fn(VkDevice, VkSwapchain, U64, VkSemaphore, VkFence, *edit CUInt) -> GlfwVkResult
pub type VkQueueSubmitFn = extern["system"] fn(VkQueue, CUInt, *read VkSubmitInfo, VkFence) -> GlfwVkResult
pub type VkQueuePresentFn = extern["system"] fn(VkQueue, *read VkPresentInfoKHR) -> GlfwVkResult
pub type VkQueueWaitIdleFn = extern["system"] fn(VkQueue) -> GlfwVkResult
pub type VkDeviceWaitIdleFn = extern["system"] fn(VkDevice) -> GlfwVkResult


