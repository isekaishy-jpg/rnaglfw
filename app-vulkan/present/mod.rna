fn close_library_quiet(take library: DynamicLibrary) -> Unit:
    let _ = #unsafe close_library :: library :: call
    return

fn cleanup_surface_context(take library: DynamicLibrary, take cleanup: SurfaceCleanup) -> Unit:
    select:
        when cleanup.surface != 0U64 => #unsafe cleanup.destroy_surface :: cleanup.instance, cleanup.surface, null :: call
        else => ()
    select:
        when !cleanup.instance.is_null :: :: method => #unsafe cleanup.destroy_instance :: cleanup.instance, null :: call
        else => ()
    close_library_quiet :: library :: call
    return

fn cleanup_device_context(take library: DynamicLibrary, take cleanup: DeviceCleanup) -> Unit:
    select:
        when !cleanup.device.is_null :: :: method => #unsafe cleanup.destroy_device :: cleanup.device, null :: call
        else => ()
    select:
        when cleanup.surface != 0U64 => #unsafe cleanup.destroy_surface :: cleanup.instance, cleanup.surface, null :: call
        else => ()
    select:
        when !cleanup.instance.is_null :: :: method => #unsafe cleanup.destroy_instance :: cleanup.instance, null :: call
        else => ()
    close_library_quiet :: library :: call
    return

fn cleanup_swapchain_context(take library: DynamicLibrary, take cleanup: SwapchainCleanup) -> Unit:
    select:
        when cleanup.swapchain != 0U64 => #unsafe cleanup.destroy_swapchain :: cleanup.device, cleanup.swapchain, null :: call
        else => ()
    select:
        when !cleanup.device.is_null :: :: method => #unsafe cleanup.destroy_device :: cleanup.device, null :: call
        else => ()
    select:
        when cleanup.surface != 0U64 => #unsafe cleanup.destroy_surface :: cleanup.instance, cleanup.surface, null :: call
        else => ()
    select:
        when !cleanup.instance.is_null :: :: method => #unsafe cleanup.destroy_instance :: cleanup.instance, null :: call
        else => ()
    close_library_quiet :: library :: call
    return

fn find_graphics_present_device(enumerate_physical_devices: VkEnumeratePhysicalDevicesFn, queue_family_properties: VkGetPhysicalDeviceQueueFamilyPropertiesFn, surface_support: VkGetPhysicalDeviceSurfaceSupportFn, instance: GlfwVkInstance, surface: GlfwVkSurface) -> Result[VulkanDeviceCandidate, VulkanPresentError]:
    let device_count: CUInt = 0
    let device_count_ptr: *edit CUInt = #unsafe &raw edit device_count
    let query_result = #unsafe enumerate_physical_devices :: instance, device_count_ptr, null :: call
    select:
        when query_result != VK_SUCCESS =>
            let error = VulkanPresentError.PhysicalDeviceQueryFailed :: query_result :: call
            return Result.Err :: error :: call
        when device_count == 0 =>
            let error = VulkanPresentError.NoGraphicsPresentDevice :: :: call
            return Result.Err :: error :: call
        when device_count > MAX_PHYSICAL_DEVICES_RAW =>
            let error = VulkanPresentError.PhysicalDeviceOverflow :: device_count :: call
            return Result.Err :: error :: call
        else => ()
    let devices: [GlfwVkPhysicalDevice; MAX_PHYSICAL_DEVICES] = [null; MAX_PHYSICAL_DEVICES]
    let device_ptr: *edit GlfwVkPhysicalDevice = #unsafe &raw edit devices[0]
    let fill_result = #unsafe enumerate_physical_devices :: instance, device_count_ptr, device_ptr :: call
    select:
        when fill_result != VK_SUCCESS =>
            let error = VulkanPresentError.PhysicalDeviceQueryFailed :: fill_result :: call
            return Result.Err :: error :: call
        else => ()
    let device_scan: CUInt = 0
    repeat while device_scan < device_count:
        let Result.Ok(device_index) = device_scan as Maybe[Index] else =>
            let error = VulkanPresentError.NoGraphicsPresentDevice :: :: call
            return Result.Err :: error :: call
        let device = devices[device_index]
        let queue_count: CUInt = 0
        let queue_count_ptr: *edit CUInt = #unsafe &raw edit queue_count
        #unsafe queue_family_properties :: device, queue_count_ptr, null :: call
        select:
            when queue_count > MAX_QUEUE_FAMILIES_RAW =>
                let error = VulkanPresentError.QueueFamilyOverflow :: queue_count :: call
                return Result.Err :: error :: call
            else => ()
        let properties: [VkQueueFamilyProperties; MAX_QUEUE_FAMILIES] = [ZERO_QUEUE_FAMILY_PROPERTIES; MAX_QUEUE_FAMILIES]
        select:
            when queue_count == 0 => ()
            else =>
                let properties_ptr: *edit VkQueueFamilyProperties = #unsafe &raw edit properties[0]
                #unsafe queue_family_properties :: device, queue_count_ptr, properties_ptr :: call
        let family_scan: CUInt = 0
        repeat while family_scan < queue_count:
            let Result.Ok(family_index) = family_scan as Maybe[Index] else =>
                let error = VulkanPresentError.NoGraphicsPresentDevice :: :: call
                return Result.Err :: error :: call
            let family = properties[family_index]
            let supported: CUInt = 0
            let supported_ptr: *edit CUInt = #unsafe &raw edit supported
            let support_result = #unsafe surface_support :: device, family_scan, surface, supported_ptr :: call
            select:
                when support_result != VK_SUCCESS =>
                    let error = VulkanPresentError.SurfaceCapabilitiesFailed :: support_result :: call
                    return Result.Err :: error :: call
                when family.queue_count != 0 && (family.queue_flags & VK_QUEUE_GRAPHICS_BIT) != 0 && supported != 0 =>
                    let candidate = VulkanDeviceCandidate :: :: call
                        device = device
                        queuefamily = family_scan
                    return Result.Ok :: candidate :: call
                else => ()
            family_scan = family_scan + 1
        device_scan = device_scan + 1
    let error = VulkanPresentError.NoGraphicsPresentDevice :: :: call
    return Result.Err :: error :: call

pub(package) fn finish_vulkan_present_app(take app: App, take window: Window, app_name: Str) -> Result[VulkanPresentApp, VulkanPresentAppError]:
    select bootstrap_vulkan_present :: window, app_name :: call:
        when Result.Ok(context) =>
            let present_app = VulkanPresentApp :: :: call
                app = app
                window = window
                context = context
            return Result.Ok :: present_app :: call
        when Result.Err(err) =>
            app.terminate :: :: method
            let error = VulkanPresentAppError.PresentBootstrap :: err :: call
            return Result.Err :: error :: call

pub fn bootstrap_vulkan_present(read window: Window, app_name: Str) -> Result[VulkanPresentContext, VulkanPresentError]:
    select:
        when !vulkan_supported :: :: call =>
            let error = VulkanPresentError.NotSupported :: :: call
            return Result.Err :: error :: call
        else => ()
    select open_library :: VULKAN_LIBRARY_PATH :: call:
        when Result.Ok(library) =>
            select lookup_loader_symbol[VkCreateInstanceFn] :: library, "vkCreateInstance" :: call:
                when Result.Ok(create_instance) =>
                    select copy_required_extension_array :: :: call:
                        when Result.Ok((extension_pointers, extension_names)) =>
                            select maybe_c_string_local :: app_name :: call:
                                when Result.Ok(application_name) =>
                                    select maybe_c_string_local :: ENGINE_NAME :: call:
                                        when Result.Ok(engine_name) =>
                                            let application_info = VkApplicationInfo :: :: call
                                                stype = VK_STRUCTURE_TYPE_APPLICATION_INFO
                                                pnext = null
                                                application_name = application_name.as_ptr :: :: method
                                                application_version = 0
                                                engine_name = engine_name.as_ptr :: :: method
                                                engine_version = 0
                                                api_version = VK_API_VERSION_1_0
                                            let application_info_ptr: *read VkApplicationInfo = #unsafe &raw read application_info
                                            let extension_ptr: *read *read CChar = #unsafe &raw read extension_pointers[0]
                                            let create_info = VkInstanceCreateInfo :: :: call
                                                stype = VK_STRUCTURE_TYPE_INSTANCE_CREATE_INFO
                                                pnext = null
                                                flags = 0
                                                application_info = application_info_ptr
                                                enabled_layer_count = 0
                                                enabled_layer_names = null
                                                enabled_extension_count = 2
                                                enabled_extension_names = extension_ptr
                                            let instance: GlfwVkInstance = null
                                            let create_info_ptr: *read VkInstanceCreateInfo = #unsafe &raw read create_info
                                            let instance_ptr: *edit GlfwVkInstance = #unsafe &raw edit instance
                                            let create_result = #unsafe create_instance :: create_info_ptr, null, instance_ptr :: call
                                            let _ = extension_names
                                            select:
                                                when create_result != VK_SUCCESS || instance.is_null :: :: method =>
                                                    close_library_quiet :: library :: call
                                                    let error = VulkanPresentError.InstanceCreateFailed :: create_result :: call
                                                    return Result.Err :: error :: call
                                                else => ()
                                            select lookup_instance_symbol[VkDestroyInstanceFn] :: library, instance, "vkDestroyInstance", "vkDestroyInstance" :: call:
                                                when Result.Ok(destroy_instance) =>
                                                    select lookup_vulkan_instance_fns :: library, instance, destroy_instance :: call:
                                                        when Result.Ok(instance_fns) =>
                                                            return bootstrap_vulkan_present_with_instance :: window, library, instance, instance_fns :: call
                                                        when Result.Err(err) =>
                                                            #unsafe destroy_instance :: instance, null :: call
                                                            close_library_quiet :: library :: call
                                                            return Result.Err :: err :: call
                                                when Result.Err(err) =>
                                                    close_library_quiet :: library :: call
                                                    return Result.Err :: err :: call
                                        when Result.Err(err) =>
                                            close_library_quiet :: library :: call
                                            return Result.Err :: err :: call
                                when Result.Err(err) =>
                                    close_library_quiet :: library :: call
                                    return Result.Err :: err :: call
                        when Result.Err(err) =>
                            close_library_quiet :: library :: call
                            return Result.Err :: err :: call
                when Result.Err(err) =>
                    close_library_quiet :: library :: call
                    return Result.Err :: err :: call
        when Result.Err(err) =>
            let error = VulkanPresentError.LibraryOpen :: err :: call
            return Result.Err :: error :: call

fn bootstrap_vulkan_present_with_instance(read window: Window, take library: DynamicLibrary, instance: GlfwVkInstance, read instance_fns: VulkanInstanceFns) -> Result[VulkanPresentContext, VulkanPresentError]:
    let surface_report = window.vulkan_surface :: instance, null :: method
    select:
        when surface_report.result != VK_SUCCESS || surface_report.surface == 0U64 =>
            #unsafe instance_fns.destroy_instance :: instance, null :: call
            close_library_quiet :: library :: call
            let error = VulkanPresentError.SurfaceCreateFailed :: surface_report.result :: call
            return Result.Err :: error :: call
        else => ()
    let surface_cleanup = SurfaceCleanup :: :: call
        destroy_instance = instance_fns.destroy_instance
        destroy_surface = instance_fns.destroy_surface
        instance = instance
        surface = surface_report.surface
    select find_graphics_present_device :: instance_fns.enumerate_physical_devices, instance_fns.queue_family_properties, instance_fns.surface_support, instance, surface_report.surface :: call:
        when Result.Ok(candidate) =>
            let queue_priority_values: [F32; 1] = [1.0; 1]
            let queue_priority_ptr: *read F32 = #unsafe &raw read queue_priority_values[0]
            let queue_create_info = VkDeviceQueueCreateInfo :: :: call
                stype = VK_STRUCTURE_TYPE_DEVICE_QUEUE_CREATE_INFO
                pnext = null
                flags = 0
                queuefamily_index = candidate.queuefamily
                queue_count = 1
                queue_priorities = queue_priority_ptr
            select maybe_c_string_local :: SWAPCHAIN_EXTENSION_NAME :: call:
                when Result.Ok(swapchain_extension_name) =>
                    let swapchain_extension_names: [MaybeStr; 1] = [swapchain_extension_name]
                    let swapchain_extension_pointers: [*read CChar; 1] = [swapchain_extension_names[0].as_ptr :: :: method]
                    let queue_create_info_ptr: *read VkDeviceQueueCreateInfo = #unsafe &raw read queue_create_info
                    let extension_names_ptr: *read *read CChar = #unsafe &raw read swapchain_extension_pointers[0]
                    let device_create_info = VkDeviceCreateInfo :: :: call
                        stype = VK_STRUCTURE_TYPE_DEVICE_CREATE_INFO
                        pnext = null
                        flags = 0
                        queue_create_info_count = 1
                        queue_create_infos = queue_create_info_ptr
                        enabled_layer_count = 0
                        enabled_layer_names = null
                        enabled_extension_count = 1
                        enabled_extension_names = extension_names_ptr
                        enabled_features = null
                    let device: VkDevice = null
                    let device_create_info_ptr: *read VkDeviceCreateInfo = #unsafe &raw read device_create_info
                    let device_ptr: *edit VkDevice = #unsafe &raw edit device
                    let device_create_result = #unsafe instance_fns.create_device :: candidate.device, device_create_info_ptr, null, device_ptr :: call
                    select:
                        when device_create_result != VK_SUCCESS || device.is_null :: :: method =>
                            cleanup_surface_context :: library, surface_cleanup :: call
                            let error = VulkanPresentError.DeviceCreateFailed :: device_create_result :: call
                            return Result.Err :: error :: call
                        else => ()
                    select lookup_instance_symbol[VkDestroyDeviceFn] :: library, instance, "vkDestroyDevice", "vkDestroyDevice" :: call:
                        when Result.Ok(destroy_device) =>
                            let device_cleanup = DeviceCleanup :: :: call
                                destroy_instance = instance_fns.destroy_instance
                                destroy_device = destroy_device
                                destroy_surface = instance_fns.destroy_surface
                                instance = instance
                                device = device
                                surface = surface_report.surface
                            select lookup_vulkan_device_fns :: library, device, destroy_device :: call:
                                when Result.Ok(device_fns) =>
                                    let queue: VkQueue = null
                                    let queue_ptr: *edit VkQueue = #unsafe &raw edit queue
                                    #unsafe device_fns.get_device_queue :: device, candidate.queuefamily, 0, queue_ptr :: call
                                    select:
                                        when queue.is_null :: :: method =>
                                            cleanup_device_context :: library, device_cleanup :: call
                                            let error = VulkanPresentError.NoQueue :: :: call
                                            return Result.Err :: error :: call
                                        else => ()
                                    let memory_properties = ZERO_MEMORY_PROPERTIES
                                    let memory_properties_ptr: *edit VkPhysicalDeviceMemoryProperties = #unsafe &raw edit memory_properties
                                    #unsafe instance_fns.memory_properties :: candidate.device, memory_properties_ptr :: call
                                    let capabilities = ZERO_SURFACE_CAPABILITIES
                                    let capabilities_ptr: *edit VkSurfaceCapabilitiesKHR = #unsafe &raw edit capabilities
                                    let capabilities_result = #unsafe instance_fns.surface_capabilities :: candidate.device, surface_report.surface, capabilities_ptr :: call
                                    select:
                                        when capabilities_result != VK_SUCCESS =>
                                            cleanup_device_context :: library, device_cleanup :: call
                                            let error = VulkanPresentError.SurfaceCapabilitiesFailed :: capabilities_result :: call
                                            return Result.Err :: error :: call
                                        when (capabilities.supported_usage_flags & VK_IMAGE_USAGE_TRANSFER_DST_BIT) == 0 =>
                                            cleanup_device_context :: library, device_cleanup :: call
                                            let error = VulkanPresentError.SurfaceTransferUnsupported :: capabilities.supported_usage_flags :: call
                                            return Result.Err :: error :: call
                                        else => ()
                                    let format_count: CUInt = 0
                                    let format_count_ptr: *edit CUInt = #unsafe &raw edit format_count
                                    let format_count_result = #unsafe instance_fns.surface_formats :: candidate.device, surface_report.surface, format_count_ptr, null :: call
                                    select:
                                        when format_count_result != VK_SUCCESS =>
                                            cleanup_device_context :: library, device_cleanup :: call
                                            let error = VulkanPresentError.SurfaceFormatsFailed :: format_count_result :: call
                                            return Result.Err :: error :: call
                                        when format_count == 0 =>
                                            cleanup_device_context :: library, device_cleanup :: call
                                            let error = VulkanPresentError.NoSurfaceFormats :: :: call
                                            return Result.Err :: error :: call
                                        when format_count > MAX_SURFACE_FORMATS_RAW =>
                                            cleanup_device_context :: library, device_cleanup :: call
                                            let error = VulkanPresentError.SurfaceFormatOverflow :: format_count :: call
                                            return Result.Err :: error :: call
                                        else => ()
                                    let formats: [VkSurfaceFormatKHR; MAX_SURFACE_FORMATS] = [ZERO_SURFACE_FORMAT; MAX_SURFACE_FORMATS]
                                    let formats_ptr: *edit VkSurfaceFormatKHR = #unsafe &raw edit formats[0]
                                    let formats_result = #unsafe instance_fns.surface_formats :: candidate.device, surface_report.surface, format_count_ptr, formats_ptr :: call
                                    select:
                                        when formats_result != VK_SUCCESS =>
                                            cleanup_device_context :: library, device_cleanup :: call
                                            let error = VulkanPresentError.SurfaceFormatsFailed :: formats_result :: call
                                            return Result.Err :: error :: call
                                        else => ()
                                    let present_mode_count: CUInt = 0
                                    let present_mode_count_ptr: *edit CUInt = #unsafe &raw edit present_mode_count
                                    let present_mode_count_result = #unsafe instance_fns.surface_present_modes :: candidate.device, surface_report.surface, present_mode_count_ptr, null :: call
                                    select:
                                        when present_mode_count_result != VK_SUCCESS =>
                                            cleanup_device_context :: library, device_cleanup :: call
                                            let error = VulkanPresentError.PresentModesFailed :: present_mode_count_result :: call
                                            return Result.Err :: error :: call
                                        when present_mode_count == 0 =>
                                            cleanup_device_context :: library, device_cleanup :: call
                                            let error = VulkanPresentError.NoPresentModes :: :: call
                                            return Result.Err :: error :: call
                                        when present_mode_count > MAX_PRESENT_MODES_RAW =>
                                            cleanup_device_context :: library, device_cleanup :: call
                                            let error = VulkanPresentError.PresentModeOverflow :: present_mode_count :: call
                                            return Result.Err :: error :: call
                                        else => ()
                                    let present_modes: [CInt; MAX_PRESENT_MODES] = [0; MAX_PRESENT_MODES]
                                    let present_modes_ptr: *edit CInt = #unsafe &raw edit present_modes[0]
                                    let present_modes_result = #unsafe instance_fns.surface_present_modes :: candidate.device, surface_report.surface, present_mode_count_ptr, present_modes_ptr :: call
                                    select:
                                        when present_modes_result != VK_SUCCESS =>
                                            cleanup_device_context :: library, device_cleanup :: call
                                            let error = VulkanPresentError.PresentModesFailed :: present_modes_result :: call
                                            return Result.Err :: error :: call
                                        else => ()
                                    select choose_surface_format :: formats, format_count :: call:
                                        when Result.Ok(chosen_surface_format) =>
                                            select choose_present_mode :: present_modes, present_mode_count :: call:
                                                when Result.Ok(chosen_present_mode) =>
                                                    select choose_window_extent :: window, capabilities :: call:
                                                        when Result.Ok(chosen_extent) =>
                                                            let swapchain: VkSwapchain = 0U64
                                                            let swapchain_info = VkSwapchainCreateInfoKHR :: :: call
                                                                stype = VK_STRUCTURE_TYPE_SWAPCHAIN_CREATE_INFO_KHR
                                                                pnext = null
                                                                flags = 0
                                                                surface = surface_report.surface
                                                                min_image_count = choose_image_count :: capabilities :: call
                                                                image_format = chosen_surface_format.format
                                                                image_color_space = chosen_surface_format.color_space
                                                                image_extent = chosen_extent
                                                                image_array_layers = 1
                                                                image_usage = VK_IMAGE_USAGE_TRANSFER_DST_BIT
                                                                image_sharing_mode = VK_SHARING_MODE_EXCLUSIVE
                                                                queuefamily_index_count = 0
                                                                queuefamily_indices = null
                                                                pre_transform = capabilities.current_transform
                                                                composite_alpha = VK_COMPOSITE_ALPHA_OPAQUE_BIT_KHR
                                                                present_mode = chosen_present_mode
                                                                clipped = VK_TRUE
                                                                old_swapchain = 0U64
                                                            let swapchain_ptr: *edit VkSwapchain = #unsafe &raw edit swapchain
                                                            let swapchain_info_ptr: *read VkSwapchainCreateInfoKHR = #unsafe &raw read swapchain_info
                                                            let swapchain_create_result = #unsafe device_fns.create_swapchain :: device, swapchain_info_ptr, null, swapchain_ptr :: call
                                                            select:
                                                                when swapchain_create_result != VK_SUCCESS || swapchain == 0U64 =>
                                                                    cleanup_device_context :: library, device_cleanup :: call
                                                                    let error = VulkanPresentError.SwapchainCreateFailed :: swapchain_create_result :: call
                                                                    return Result.Err :: error :: call
                                                                else => ()
                                                            let cleanup_with_swapchain = SwapchainCleanup :: :: call
                                                                destroy_instance = instance_fns.destroy_instance
                                                                destroy_device = device_fns.destroy_device
                                                                destroy_surface = instance_fns.destroy_surface
                                                                destroy_swapchain = device_fns.destroy_swapchain
                                                                instance = instance
                                                                device = device
                                                                surface = surface_report.surface
                                                                swapchain = swapchain
                                                            let swapchain_image_count: CUInt = 0
                                                            let swapchain_image_count_ptr: *edit CUInt = #unsafe &raw edit swapchain_image_count
                                                            let image_count_result = #unsafe device_fns.get_swapchain_images :: device, swapchain, swapchain_image_count_ptr, null :: call
                                                            select:
                                                                when image_count_result != VK_SUCCESS =>
                                                                    cleanup_swapchain_context :: library, cleanup_with_swapchain :: call
                                                                    let error = VulkanPresentError.SwapchainImagesFailed :: image_count_result :: call
                                                                    return Result.Err :: error :: call
                                                                when swapchain_image_count == 0 =>
                                                                    cleanup_swapchain_context :: library, cleanup_with_swapchain :: call
                                                                    let error = VulkanPresentError.NoSwapchainImages :: :: call
                                                                    return Result.Err :: error :: call
                                                                when swapchain_image_count > MAX_SWAPCHAIN_IMAGES_RAW =>
                                                                    cleanup_swapchain_context :: library, cleanup_with_swapchain :: call
                                                                    let error = VulkanPresentError.SwapchainImageOverflow :: swapchain_image_count :: call
                                                                    return Result.Err :: error :: call
                                                                else => ()
                                                            let swapchain_images: [VkImage; MAX_SWAPCHAIN_IMAGES] = [0U64; MAX_SWAPCHAIN_IMAGES]
                                                            let swapchain_images_ptr: *edit VkImage = #unsafe &raw edit swapchain_images[0]
                                                            let swapchain_images_result = #unsafe device_fns.get_swapchain_images :: device, swapchain, swapchain_image_count_ptr, swapchain_images_ptr :: call
                                                            select:
                                                                when swapchain_images_result != VK_SUCCESS =>
                                                                    cleanup_swapchain_context :: library, cleanup_with_swapchain :: call
                                                                    let error = VulkanPresentError.SwapchainImagesFailed :: swapchain_images_result :: call
                                                                    return Result.Err :: error :: call
                                                                else => ()
                                                            let context = VulkanPresentContext :: :: call
                                                                library = library
                                                                destroy_instance = instance_fns.destroy_instance
                                                                destroy_device = device_fns.destroy_device
                                                                destroy_surface = instance_fns.destroy_surface
                                                                destroy_swapchain = device_fns.destroy_swapchain
                                                                create_image = device_fns.create_image
                                                                destroy_image = device_fns.destroy_image
                                                                get_image_memory_requirements = device_fns.get_image_memory_requirements
                                                                bind_image_memory = device_fns.bind_image_memory
                                                                create_buffer = device_fns.create_buffer
                                                                destroy_buffer = device_fns.destroy_buffer
                                                                get_buffer_memory_requirements = device_fns.get_buffer_memory_requirements
                                                                allocate_memory = device_fns.allocate_memory
                                                                free_memory = device_fns.free_memory
                                                                bind_buffer_memory = device_fns.bind_buffer_memory
                                                                map_memory = device_fns.map_memory
                                                                unmap_memory = device_fns.unmap_memory
                                                                create_command_pool = device_fns.create_command_pool
                                                                destroy_command_pool = device_fns.destroy_command_pool
                                                                allocate_command_buffers = device_fns.allocate_command_buffers
                                                                begin_command_buffer = device_fns.begin_command_buffer
                                                                end_command_buffer = device_fns.end_command_buffer
                                                                cmd_pipeline_barrier = device_fns.cmd_pipeline_barrier
                                                                cmd_clear_color_image = device_fns.cmd_clear_color_image
                                                                cmd_copy_buffer_to_image = device_fns.cmd_copy_buffer_to_image
                                                                cmd_copy_image = device_fns.cmd_copy_image
                                                                cmd_copy_image_to_buffer = device_fns.cmd_copy_image_to_buffer
                                                                create_semaphore = device_fns.create_semaphore
                                                                destroy_semaphore = device_fns.destroy_semaphore
                                                                acquire_next_image = device_fns.acquire_next_image
                                                                queue_submit = device_fns.queue_submit
                                                                queue_present = device_fns.queue_present
                                                                queue_wait_idle = device_fns.queue_wait_idle
                                                                device_wait_idle = device_fns.device_wait_idle
                                                                instance = instance
                                                                device = device
                                                                queue = queue
                                                                surface = surface_report.surface
                                                                physical_device = candidate.device
                                                                queuefamily = candidate.queuefamily
                                                                surface_format = chosen_surface_format
                                                                surface_capabilities = capabilities
                                                                memory_properties = memory_properties
                                                                present_mode = chosen_present_mode
                                                                extent = chosen_extent
                                                                swapchain = swapchain
                                                                swapchain_images = swapchain_images
                                                                swapchain_image_count = swapchain_image_count
                                                                presented_once = false
                                                            return Result.Ok :: context :: call
                                                        when Result.Err(err) =>
                                                            cleanup_device_context :: library, device_cleanup :: call
                                                            return Result.Err :: err :: call
                                                when Result.Err(err) =>
                                                    cleanup_device_context :: library, device_cleanup :: call
                                                    return Result.Err :: err :: call
                                        when Result.Err(err) =>
                                            cleanup_device_context :: library, device_cleanup :: call
                                            return Result.Err :: err :: call
                                when Result.Err(err) =>
                                    cleanup_device_context :: library, device_cleanup :: call
                                    return Result.Err :: err :: call
                        when Result.Err(err) =>
                            cleanup_surface_context :: library, surface_cleanup :: call
                            return Result.Err :: err :: call
                when Result.Err(err) =>
                    cleanup_surface_context :: library, surface_cleanup :: call
                    return Result.Err :: err :: call
        when Result.Err(err) =>
            cleanup_surface_context :: library, surface_cleanup :: call
            return Result.Err :: err :: call

impl VulkanPresentApp:
