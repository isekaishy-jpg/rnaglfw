const ZERO_EXTENT2D: VkExtent2D = VkExtent2D :: :: call
    width = 0
    height = 0

const ZERO_EXTENT3D: VkExtent3D = VkExtent3D :: :: call
    width = 0
    height = 0
    depth = 0

const ZERO_QUEUE_FAMILY_PROPERTIES: VkQueueFamilyProperties = VkQueueFamilyProperties :: :: call
    queue_flags = 0
    queue_count = 0
    timestamp_valid_bits = 0
    min_image_transfer_granularity = ZERO_EXTENT3D

const ZERO_SURFACE_CAPABILITIES: VkSurfaceCapabilitiesKHR = VkSurfaceCapabilitiesKHR :: :: call
    min_image_count = 0
    max_image_count = 0
    current_extent = ZERO_EXTENT2D
    min_image_extent = ZERO_EXTENT2D
    max_image_extent = ZERO_EXTENT2D
    max_image_array_layers = 0
    supported_transforms = 0
    current_transform = 0
    supported_composite_alpha = 0
    supported_usage_flags = 0

const ZERO_SURFACE_FORMAT: VkSurfaceFormatKHR = VkSurfaceFormatKHR :: :: call
    format = 0
    color_space = 0

const ZERO_MEMORY_TYPE: VkMemoryType = VkMemoryType :: :: call
    property_flags = 0
    heap_index = 0

const ZERO_MEMORY_HEAP: VkMemoryHeap = VkMemoryHeap :: :: call
    size = 0U64
    flags = 0

const ZERO_MEMORY_PROPERTIES: VkPhysicalDeviceMemoryProperties = VkPhysicalDeviceMemoryProperties :: :: call
    memory_type_count = 0
    memory_types = [ZERO_MEMORY_TYPE; VK_MAX_MEMORY_TYPES]
    memory_heap_count = 0
    memory_heaps = [ZERO_MEMORY_HEAP; VK_MAX_MEMORY_HEAPS]

pub(package) const CLEAR_RANGE: VkImageSubresourceRange = VkImageSubresourceRange :: :: call
    aspect_mask = VK_IMAGE_ASPECT_COLOR_BIT
    base_mip_level = 0
    level_count = 1
    base_array_layer = 0
    layer_count = 1

pub(package) const ZERO_OFFSET3D: VkOffset3D = VkOffset3D :: :: call
    x = 0
    y = 0
    z = 0

pub(package) const IMAGE_COPY_SUBRESOURCE: VkImageSubresourceLayers = VkImageSubresourceLayers :: :: call
    aspect_mask = VK_IMAGE_ASPECT_COLOR_BIT
    mip_level = 0
    base_array_layer = 0
    layer_count = 1

