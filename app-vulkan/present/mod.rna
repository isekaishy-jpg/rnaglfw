pub type VkCmdCopyImageToBufferFn = extern["system"] fn(VkCommandBuffer, VkImage, CInt, VkBuffer, CUInt, *read VkBufferImageCopy) -> CVoid
pub type VkCreateFenceFn = extern["system"] fn(VkDevice, *read VkFenceCreateInfo, *read GlfwVkAllocationCallbacksRaw, *edit VkFence) -> GlfwVkResult
pub type VkDestroyFenceFn = extern["system"] fn(VkDevice, VkFence, *read GlfwVkAllocationCallbacksRaw) -> CVoid
