        return self.context.write_surface_transfer_source_buffer_from_image :: upload, image :: method

    fn present_transfer_source_buffer(edit self, read upload: VulkanTransferSourceBuffer) -> Result[Unit, VulkanPresentError]:
        return self.context.present_transfer_source_buffer :: upload :: method

    fn destroy_transfer_source_buffer(read self, take upload: VulkanTransferSourceBuffer) -> Unit:
        self.context.destroy_transfer_source_buffer :: upload :: method
        return

impl VulkanPresentContext:
    fn destroy_transfer_source_buffer(read self, take upload: VulkanTransferSourceBuffer) -> Unit:
        select:
            when upload.buffer != 0U64 => #unsafe self.destroy_buffer :: self.device, upload.buffer, null :: call
            else => ()
        select:
            when upload.memory != 0U64 => #unsafe self.free_memory :: self.device, upload.memory, null :: call
            else => ()
        return
