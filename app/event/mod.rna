pub enum MonitorEventKind:
    Connected
    Disconnected
pub enum MonitorEvent:
    Connected:
        pub id: MonitorId
    Disconnected:
        pub id: MonitorId
pub enum JoystickEventKind:
    Connected
    Disconnected
pub enum JoystickEvent:
    Connected:
        pub id: JoystickId
        pub gamepad: Bool
    Disconnected:
        pub id: JoystickId
pub enum UserEventKind:
    Signaled
pub enum UserEvent:
    Signaled:
        pub id: UserEventId
pub enum AppEventKind:
    Window
    Monitor
    Joystick
    User
pub enum AppEvent:
    Window(WindowEvent)
    Monitor(MonitorEvent)
    Joystick(JoystickEvent)
    User(UserEvent)
pub fn app_event_batch() -> AppEventBatch:
    let events = List[AppEvent] :: :: call
    return AppEventBatch :: :: call
        events = events
pub fn app_event_batch_from_events(take events: List[AppEvent]) -> AppEventBatch:
    return split_app_events :: events :: call
pub(package) fn split_app_events(take events: List[AppEvent]) -> AppEventBatch:
    return AppEventBatch :: :: call
        events = events
fn batch_push_window(edit events: List[AppEvent], event: WindowEvent) -> Unit:
    let wrapped = AppEvent.Window :: event :: call
    events.push :: wrapped :: method
    return
fn batch_push_monitor(edit events: List[AppEvent], event: MonitorEvent) -> Unit:
    let wrapped = AppEvent.Monitor :: event :: call
    events.push :: wrapped :: method
    return
fn batch_push_joystick(edit events: List[AppEvent], event: JoystickEvent) -> Unit:
    let wrapped = AppEvent.Joystick :: event :: call
    events.push :: wrapped :: method
    return
fn batch_push_user(edit events: List[AppEvent], event: UserEvent) -> Unit:
    let wrapped = AppEvent.User :: event :: call
    events.push :: wrapped :: method
    return
fn copy_monitor_event(read event: MonitorEvent) -> MonitorEvent:
    select event:
        when MonitorEvent.Connected(id = id) =>
            return MonitorEvent.Connected :: :: call
                id = id
        when MonitorEvent.Disconnected(id = id) =>
            return MonitorEvent.Disconnected :: :: call
                id = id
fn copy_joystick_event(read event: JoystickEvent) -> JoystickEvent:
    select event:
        when JoystickEvent.Connected(id = id, gamepad = gamepad) =>
            return JoystickEvent.Connected :: :: call
                id = id
                gamepad = gamepad
        when JoystickEvent.Disconnected(id = id) =>
            return JoystickEvent.Disconnected :: :: call
                id = id

fn copy_user_event(read event: UserEvent) -> UserEvent:
    select event:
        when UserEvent.Signaled(id = id) =>
            return UserEvent.Signaled :: :: call
                id = id

fn copy_window_lifecycle_event_by_kind(read event: WindowEvent, read kind: WindowEventKind) -> Option[WindowEvent]:
    select kind:
        when WindowEventKind.Created =>
            select event:
                when WindowEvent.Created(id = id) =>
                    let copied = WindowEvent.Created :: :: call
                        id = id
                    return Option.Some :: copied :: call
                when _ => return Option.None
        when WindowEventKind.Destroyed =>
            select event:
                when WindowEvent.Destroyed(id = id) =>
                    let copied = WindowEvent.Destroyed :: :: call
                        id = id
                    return Option.Some :: copied :: call
                when _ => return Option.None
        when WindowEventKind.CloseRequested =>
            select event:
                when WindowEvent.CloseRequested(id = id) =>
                    let copied = WindowEvent.CloseRequested :: :: call
                        id = id
                    return Option.Some :: copied :: call
                when _ => return Option.None
        when _ => return Option.None
    return Option.None

fn monitor_event_matches_connected_filter(read event: MonitorEvent, read connected_filter: Option[Bool]) -> Bool:
    select connected_filter:
        when Option.Some(expected) => return event.connected :: :: method == expected
        when Option.None => return true
    return true

fn joystick_event_matches_connected_filter(read event: JoystickEvent, read connected_filter: Option[Bool]) -> Bool:
    select connected_filter:
        when Option.Some(expected) => return event.connected :: :: method == expected
        when Option.None => return true
    return true

fn user_event_matches_id_filter(read event: UserEvent, read id_filter: Option[UserEventId]) -> Bool:
    select id_filter:
        when Option.Some(expected) => return event.user_id :: :: method == expected
        when Option.None => return true
    return true

fn collect_window_ids_by_kind(edit batch: AppEventBatch, read kind: WindowEventKind) -> List[WindowId]:
    let staged = batch_support.take_batch_events_reversed :: batch :: call
    let ids = List[WindowId] :: :: call
    let remaining = List[AppEvent] :: :: call
    let id_filter: Option[WindowId] = Option.None
    repeat while !staged.is_empty :: :: method:
        select staged.pop :: :: method:
            when Option.Some(event) =>
                select event:
                    when AppEvent.Window(window_event) =>
                        select:
                            when batch_support.window_event_matches_filter :: window_event, kind, id_filter :: call =>
                                let id = window_event.window_id :: :: method
                                ids.push :: id :: method
                            else => ()
                        batch_push_window :: remaining, window_event :: call
                    when AppEvent.Monitor(monitor_event) => batch_push_monitor :: remaining, monitor_event :: call
                    when AppEvent.Joystick(joystick_event) => batch_push_joystick :: remaining, joystick_event :: call
                    when AppEvent.User(user_event) => batch_push_user :: remaining, user_event :: call
            when Option.None => break
    batch.events = remaining
    return ids

fn collect_window_lifecycle_events_by_kind(edit batch: AppEventBatch, read kind: WindowEventKind) -> List[WindowEvent]:
    let staged = batch_support.take_batch_events_reversed :: batch :: call
    let matched = List[WindowEvent] :: :: call
    let remaining = List[AppEvent] :: :: call
    repeat while !staged.is_empty :: :: method:
        select staged.pop :: :: method:
            when Option.Some(event) =>
                select event:
                    when AppEvent.Window(window_event) =>
                        select copy_window_lifecycle_event_by_kind :: window_event, kind :: call:
                            when Option.Some(copied) =>
                                matched.push :: copied :: method
                                batch_push_window :: remaining, window_event :: call
                            when Option.None => batch_push_window :: remaining, window_event :: call
                    when AppEvent.Monitor(monitor_event) => batch_push_monitor :: remaining, monitor_event :: call
                    when AppEvent.Joystick(joystick_event) => batch_push_joystick :: remaining, joystick_event :: call
                    when AppEvent.User(user_event) => batch_push_user :: remaining, user_event :: call
            when Option.None => break
    batch.events = remaining
    return matched

fn collect_monitor_ids(edit batch: AppEventBatch, read connected_filter: Option[Bool]) -> List[MonitorId]:
    let staged = batch_support.take_batch_events_reversed :: batch :: call
    let ids = List[MonitorId] :: :: call
    let remaining = List[AppEvent] :: :: call
    repeat while !staged.is_empty :: :: method:
        select staged.pop :: :: method:
            when Option.Some(event) =>
                select event:
                    when AppEvent.Window(window_event) => batch_push_window :: remaining, window_event :: call
                    when AppEvent.Monitor(monitor_event) =>
                        select monitor_event_matches_connected_filter :: monitor_event, connected_filter :: call:
                            when true =>
                                let id = monitor_event.monitor_id :: :: method
                                ids.push :: id :: method
                            when false => ()
                        batch_push_monitor :: remaining, monitor_event :: call
                    when AppEvent.Joystick(joystick_event) => batch_push_joystick :: remaining, joystick_event :: call
                    when AppEvent.User(user_event) => batch_push_user :: remaining, user_event :: call
            when Option.None => break
    batch.events = remaining
    return ids

fn collect_joystick_ids(edit batch: AppEventBatch, read connected_filter: Option[Bool]) -> List[JoystickId]:
    let staged = batch_support.take_batch_events_reversed :: batch :: call
    let ids = List[JoystickId] :: :: call
    let remaining = List[AppEvent] :: :: call
    repeat while !staged.is_empty :: :: method:
        select staged.pop :: :: method:
            when Option.Some(event) =>
                select event:
                    when AppEvent.Window(window_event) => batch_push_window :: remaining, window_event :: call
                    when AppEvent.Monitor(monitor_event) => batch_push_monitor :: remaining, monitor_event :: call
                    when AppEvent.Joystick(joystick_event) =>
                        select joystick_event_matches_connected_filter :: joystick_event, connected_filter :: call:
                            when true =>
                                let id = joystick_event.joystick_id :: :: method
                                ids.push :: id :: method
                            when false => ()
                        batch_push_joystick :: remaining, joystick_event :: call
                    when AppEvent.User(user_event) => batch_push_user :: remaining, user_event :: call
            when Option.None => break
    batch.events = remaining
    return ids

fn collect_user_ids(edit batch: AppEventBatch) -> List[UserEventId]:
    let staged = batch_support.take_batch_events_reversed :: batch :: call
    let ids = List[UserEventId] :: :: call
    let remaining = List[AppEvent] :: :: call
    repeat while !staged.is_empty :: :: method:
        select staged.pop :: :: method:
            when Option.Some(event) =>
                select event:
                    when AppEvent.Window(window_event) => batch_push_window :: remaining, window_event :: call
                    when AppEvent.Monitor(monitor_event) => batch_push_monitor :: remaining, monitor_event :: call
                    when AppEvent.Joystick(joystick_event) => batch_push_joystick :: remaining, joystick_event :: call
                    when AppEvent.User(user_event) =>
                        let id = user_event.user_id :: :: method
                        ids.push :: id :: method
                        batch_push_user :: remaining, user_event :: call
            when Option.None => break
    batch.events = remaining
    return ids

fn collect_monitor_events(edit batch: AppEventBatch, read connected_filter: Option[Bool], read id_filter: Option[MonitorId]) -> List[MonitorEvent]:
    let staged = batch_support.take_batch_events_reversed :: batch :: call
    let matched = List[MonitorEvent] :: :: call
    let remaining = List[AppEvent] :: :: call
    repeat while !staged.is_empty :: :: method:
        select staged.pop :: :: method:
            when Option.Some(event) =>
                select event:
                    when AppEvent.Window(window_event) => batch_push_window :: remaining, window_event :: call
                    when AppEvent.Monitor(monitor_event) =>
                        let event_id = monitor_event.monitor_id :: :: method
                        select:
                            when monitor_event_matches_connected_filter :: monitor_event, connected_filter :: call =>
                                select id_filter:
                                    when Option.Some(expected) =>
                                        select:
                                            when event_id == expected =>
                                                let copied = copy_monitor_event :: monitor_event :: call
                                                matched.push :: copied :: method
                                            else => ()
                                    when Option.None =>
                                        let copied = copy_monitor_event :: monitor_event :: call
                                        matched.push :: copied :: method
                            else => ()
                        batch_push_monitor :: remaining, monitor_event :: call
                    when AppEvent.Joystick(joystick_event) => batch_push_joystick :: remaining, joystick_event :: call
                    when AppEvent.User(user_event) => batch_push_user :: remaining, user_event :: call
            when Option.None => break
    batch.events = remaining
    return matched

fn collect_joystick_events(edit batch: AppEventBatch, read connected_filter: Option[Bool], read id_filter: Option[JoystickId]) -> List[JoystickEvent]:
    let staged = batch_support.take_batch_events_reversed :: batch :: call
    let matched = List[JoystickEvent] :: :: call
    let remaining = List[AppEvent] :: :: call
    repeat while !staged.is_empty :: :: method:
        select staged.pop :: :: method:
            when Option.Some(event) =>
                select event:
                    when AppEvent.Window(window_event) => batch_push_window :: remaining, window_event :: call
                    when AppEvent.Monitor(monitor_event) => batch_push_monitor :: remaining, monitor_event :: call
                    when AppEvent.Joystick(joystick_event) =>
                        let event_id = joystick_event.joystick_id :: :: method
                        select:
                            when joystick_event_matches_connected_filter :: joystick_event, connected_filter :: call =>
                                select id_filter:
                                    when Option.Some(expected) =>
                                        select:
                                            when event_id == expected =>
                                                let copied = copy_joystick_event :: joystick_event :: call
                                                matched.push :: copied :: method
                                            else => ()
                                    when Option.None =>
                                        let copied = copy_joystick_event :: joystick_event :: call
                                        matched.push :: copied :: method
                            else => ()
                        batch_push_joystick :: remaining, joystick_event :: call
                    when AppEvent.User(user_event) => batch_push_user :: remaining, user_event :: call
            when Option.None => break
    batch.events = remaining
    return matched

fn collect_user_events(edit batch: AppEventBatch, read id_filter: Option[UserEventId]) -> List[UserEvent]:
    let staged = batch_support.take_batch_events_reversed :: batch :: call
    let matched = List[UserEvent] :: :: call
    let remaining = List[AppEvent] :: :: call
    repeat while !staged.is_empty :: :: method:
        select staged.pop :: :: method:
            when Option.Some(event) =>
                select event:
                    when AppEvent.Window(window_event) => batch_push_window :: remaining, window_event :: call
                    when AppEvent.Monitor(monitor_event) => batch_push_monitor :: remaining, monitor_event :: call
                    when AppEvent.Joystick(joystick_event) => batch_push_joystick :: remaining, joystick_event :: call
                    when AppEvent.User(user_event) =>
                        select user_event_matches_id_filter :: user_event, id_filter :: call:
                            when true =>
                                let copied = copy_user_event :: user_event :: call
                                matched.push :: copied :: method
                            when false => ()
                        batch_push_user :: remaining, user_event :: call
            when Option.None => break
    batch.events = remaining
    return matched

fn take_window_cursor_data_from_events(take events: List[WindowEvent]) -> List[WindowCursorData]:
    let data = List[WindowCursorData] :: :: call
    repeat while !events.is_empty :: :: method:
        select events.pop :: :: method:
            when Option.Some(event) =>
                select event.cursor_data :: :: method:
                    when Option.Some(value) => data.push :: value :: method
                    when Option.None => ()
            when Option.None => break
    return data

