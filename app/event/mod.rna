                        when _ => batch_push_joystick :: remaining, joystick_event :: call
                when AppEvent.User(user_event) => batch_push_user :: remaining, user_event :: call
        self.events = remaining
        return ids

    fn take_disconnected_joystick_ids(edit self) -> List[JoystickId]:
        let ids = List[JoystickId] :: :: call
        let remaining = List[AppEvent] :: :: call
        repeat while !self.events.is_empty :: :: method:
            let event = self.events.remove :: 0 :: method
            select event:
                when AppEvent.Window(window_event) => batch_push_window :: remaining, window_event :: call
                when AppEvent.Monitor(monitor_event) => batch_push_monitor :: remaining, monitor_event :: call
                when AppEvent.Joystick(joystick_event) =>
                    select joystick_event:
                        when JoystickEvent.Disconnected(id = id) => ids.push :: id :: method
                        when _ => batch_push_joystick :: remaining, joystick_event :: call
                when AppEvent.User(user_event) => batch_push_user :: remaining, user_event :: call
        self.events = remaining
        return ids

    fn take_disconnected_joystick_events(edit self) -> List[JoystickEvent]:
        let matched = List[JoystickEvent] :: :: call
        let remaining = List[AppEvent] :: :: call
        repeat while !self.events.is_empty :: :: method:
            let event = self.events.remove :: 0 :: method
            select event:
                when AppEvent.Window(window_event) => batch_push_window :: remaining, window_event :: call
                when AppEvent.Monitor(monitor_event) => batch_push_monitor :: remaining, monitor_event :: call
                when AppEvent.Joystick(joystick_event) =>
                    select joystick_event:
                        when JoystickEvent.Disconnected(id = _) => matched.push :: joystick_event :: method
                        when _ => batch_push_joystick :: remaining, joystick_event :: call
                when AppEvent.User(user_event) => batch_push_user :: remaining, user_event :: call
        self.events = remaining
        return matched

    fn take_user_ids(edit self) -> List[UserEventId]:
        let ids = List[UserEventId] :: :: call
