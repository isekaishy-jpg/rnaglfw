fn copy_modifiers(read mods: Modifiers) -> Modifiers:
    let raw = modifiers_raw :: mods :: call
    return modifiers_from_raw :: raw :: call

fn build_cursor_moved_window_event(id: WindowId, x: F64, y: F64) -> WindowEvent:
    return WindowEvent.CursorMoved :: :: call
        id = id
        x = x
        y = y

fn build_scrolled_window_event(id: WindowId, x: F64, y: F64) -> WindowEvent:
    return WindowEvent.Scrolled :: :: call
        id = id
        x = x
        y = y

fn build_modifiers_changed_window_event(id: WindowId, read mods: Modifiers) -> WindowEvent:
    let copied_mods = copy_modifiers :: mods :: call
    return WindowEvent.ModifiersChanged :: :: call
        id = id
        mods = copied_mods

fn build_key_changed_window_event(id: WindowId, raw_key: RawKeyCode, scancode: ScanCode, raw_action: CInt, read mods: Modifiers) -> WindowEvent:
    let copied_mods = copy_modifiers :: mods :: call
    return WindowEvent.KeyChanged :: :: call
        id = id
        key = key_from_raw :: raw_key :: call
        scancode = scancode
        action = input_action_from_raw :: raw_action :: call
        mods = copied_mods

fn build_raw_key_changed_window_event(id: WindowId, raw_key: RawKeyCode, scancode: ScanCode, raw_action: CInt, extended: Bool) -> WindowEvent:
    return WindowEvent.RawKeyChanged :: :: call
        id = id
        raw_key = raw_key
        scancode = scancode
        action = input_action_from_raw :: raw_action :: call
        extended = extended

fn build_character_window_event(id: WindowId, codepoint: CUInt) -> WindowEvent:
    return WindowEvent.Character :: :: call
        id = id
        codepoint = codepoint

fn build_character_mods_window_event(id: WindowId, codepoint: CUInt, read mods: Modifiers) -> WindowEvent:
    let copied_mods = copy_modifiers :: mods :: call
    return WindowEvent.CharacterMods :: :: call
        id = id
        codepoint = codepoint
        mods = copied_mods

fn build_mouse_button_changed_window_event(id: WindowId, raw_button: CInt, raw_action: CInt, read mods: Modifiers) -> WindowEvent:
    let copied_mods = copy_modifiers :: mods :: call
    return WindowEvent.MouseButtonChanged :: :: call
        id = id
        button = mouse_button_from_raw :: raw_button :: call
        action = input_action_from_raw :: raw_action :: call
        mods = copied_mods

fn copy_window_cursor_data(read event: WindowEvent) -> Option[WindowCursorData]:
    select event:
        when WindowEvent.CursorMoved(id = _, x = x, y = y) =>
            let data = WindowCursorData :: :: call
                x = x
                y = y
            return Option.Some :: data :: call
        when _ => return Option.None

fn copy_window_scroll_data(read event: WindowEvent) -> Option[WindowScrollData]:
    select event:
        when WindowEvent.Scrolled(id = _, x = x, y = y) =>
            let data = WindowScrollData :: :: call
                x = x
                y = y
            return Option.Some :: data :: call
        when _ => return Option.None

fn copy_window_character_data(read event: WindowEvent) -> Option[WindowCharacterData]:
    select event:
        when WindowEvent.Character(id = _, codepoint = codepoint) =>
            let data = WindowCharacterData :: :: call
                codepoint = codepoint
            return Option.Some :: data :: call
        when _ => return Option.None

impl WindowEvent:
    fn kind(read self) -> WindowEventKind:
        select self:
            when WindowEvent.Created(id = _) => return WindowEventKind.Created
            when WindowEvent.Destroyed(id = _) => return WindowEventKind.Destroyed
            when WindowEvent.CloseRequested(id = _) => return WindowEventKind.CloseRequested
            when WindowEvent.RedrawRequested(id = _) => return WindowEventKind.RedrawRequested
            when WindowEvent.Moved(id = _, x = _, y = _) => return WindowEventKind.Moved
            when WindowEvent.Resized(id = _, width = _, height = _) => return WindowEventKind.Resized
            when WindowEvent.FramebufferResized(id = _, width = _, height = _) => return WindowEventKind.FramebufferResized
            when WindowEvent.ContentScaleChanged(id = _, x = _, y = _) => return WindowEventKind.ContentScaleChanged
            when WindowEvent.FocusChanged(id = _, focused = _) => return WindowEventKind.FocusChanged
            when WindowEvent.Iconified(id = _, iconified = _) => return WindowEventKind.Iconified
            when WindowEvent.Maximized(id = _, maximized = _) => return WindowEventKind.Maximized
