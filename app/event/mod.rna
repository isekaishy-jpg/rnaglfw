impl AppEventBatch:
    fn event_count(read self) -> Index:
        return self.events.count :: :: method

    fn window_count(read self) -> Index:
        let total: CInt = 0
        let count = self.events.count :: :: method
        let Result.Ok(limit) = count as Maybe[CInt] else => return 0
        let scan: CInt = 0
        repeat while scan < limit:
            let Result.Ok(index) = scan as Maybe[Index] else => break
            select self.events[index].kind :: :: method:
                when AppEventKind.Window => total = total + 1
                when _ => ()
            scan = scan + 1
        let Result.Ok(result) = total as Maybe[Index] else => return 0
        return result

    fn monitor_count(read self) -> Index:
        let total: CInt = 0
        let count = self.events.count :: :: method
        let Result.Ok(limit) = count as Maybe[CInt] else => return 0
        let scan: CInt = 0
        repeat while scan < limit:
            let Result.Ok(index) = scan as Maybe[Index] else => break
            select self.events[index].kind :: :: method:
                when AppEventKind.Monitor => total = total + 1
                when _ => ()
            scan = scan + 1
        let Result.Ok(result) = total as Maybe[Index] else => return 0
        return result

    fn joystick_count(read self) -> Index:
        let total: CInt = 0
        let count = self.events.count :: :: method
        let Result.Ok(limit) = count as Maybe[CInt] else => return 0
        let scan: CInt = 0
        repeat while scan < limit:
            let Result.Ok(index) = scan as Maybe[Index] else => break
            select self.events[index].kind :: :: method:
                when AppEventKind.Joystick => total = total + 1
                when _ => ()
            scan = scan + 1
        let Result.Ok(result) = total as Maybe[Index] else => return 0
        return result

    fn user_count(read self) -> Index:
        let total: CInt = 0
        let count = self.events.count :: :: method
        let Result.Ok(limit) = count as Maybe[CInt] else => return 0
        let scan: CInt = 0
        repeat while scan < limit:
            let Result.Ok(index) = scan as Maybe[Index] else => break
            select self.events[index].kind :: :: method:
                when AppEventKind.User => total = total + 1
                when _ => ()
            scan = scan + 1
        let Result.Ok(result) = total as Maybe[Index] else => return 0
        return result

    fn is_empty(read self) -> Bool:
        return self.events.is_empty :: :: method

    fn has_window_events(read self) -> Bool:
        return self.window_count :: :: method != 0

    fn has_monitor_events(read self) -> Bool:
        return self.monitor_count :: :: method != 0

    fn has_joystick_events(read self) -> Bool:
        return self.joystick_count :: :: method != 0

    fn has_user_events(read self) -> Bool:
        return self.user_count :: :: method != 0

    fn window_ids(edit self) -> List[WindowId]:
        let staged = batch_support.take_batch_events_reversed :: self :: call
        let ids = List[WindowId] :: :: call
        let remaining = List[AppEvent] :: :: call
        repeat while !staged.is_empty :: :: method:
            select staged.pop :: :: method:
                when Option.Some(event) =>
                    select event:
                        when AppEvent.Window(window_event) =>
                            let id = window_event.window_id :: :: method
                            ids.push :: id :: method
