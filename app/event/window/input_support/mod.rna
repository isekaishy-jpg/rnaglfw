        return batch_support.pop_window_event_matching :: self, WindowEventKind.Scrolled, id_filter :: call

    fn pop_dropped_path_event_for(edit self, id: WindowId) -> Option[WindowEvent]:
        let id_filter = Option.Some :: id :: call
        return batch_support.pop_window_event_matching :: self, WindowEventKind.DroppedPaths, id_filter :: call
