use std.{List, Option, Str}
use event.{AppEvent, AppEventBatch, WindowCharacterData, WindowCharacterModsData}
use event.{WindowCursorData, WindowEvent, WindowEventKind, WindowKeyData}
use event.{WindowRawKeyData, WindowRawMouseButtonData, WindowRawMouseMotionData}
use event.batch_support
use event.WindowRawMouseWheelData
use event.WindowMouseButtonData
use event.WindowScrollData
use input.{input_action_from_raw, input_action_raw, key_from_raw, key_raw}
use input.{modifiers_from_raw, modifiers_raw, mouse_button_from_raw, mouse_button_raw}
use window.WindowId

fn push_window(edit events: List[AppEvent], window_event: WindowEvent) -> Unit:
    let wrapped = AppEvent.Window :: window_event :: call
    events.push :: wrapped :: method

fn push_passthrough(edit events: List[AppEvent], event: AppEvent) -> Unit:
    events.push :: event :: method

fn copy_modifiers(read mods: input.Modifiers) -> input.Modifiers:
    let raw = modifiers_raw :: mods :: call
    return modifiers_from_raw :: raw :: call

fn build_cursor_moved_window_event(id: WindowId, x: F64, y: F64) -> WindowEvent:
    return WindowEvent.CursorMoved :: :: call
        id = id
        x = x
        y = y

fn build_scrolled_window_event(id: WindowId, x: F64, y: F64) -> WindowEvent:
    return WindowEvent.Scrolled :: :: call
        id = id
        x = x
        y = y

fn build_key_changed_window_event(id: WindowId, raw_key: input.RawKeyCode, scancode: input.ScanCode, raw_action: CInt, read mods: input.Modifiers) -> WindowEvent:
    let copied_mods = copy_modifiers :: mods :: call
    return WindowEvent.KeyChanged :: :: call
        id = id
        key = key_from_raw :: raw_key :: call
        scancode = scancode
        action = input_action_from_raw :: raw_action :: call
        mods = copied_mods

fn build_character_window_event(id: WindowId, codepoint: CUInt) -> WindowEvent:
    return WindowEvent.Character :: :: call
        id = id
        codepoint = codepoint

fn build_character_mods_window_event(id: WindowId, codepoint: CUInt, read mods: input.Modifiers) -> WindowEvent:
    let copied_mods = copy_modifiers :: mods :: call
    return WindowEvent.CharacterMods :: :: call
        id = id
        codepoint = codepoint
        mods = copied_mods

fn build_mouse_button_changed_window_event(id: WindowId, raw_button: CInt, raw_action: CInt, read mods: input.Modifiers) -> WindowEvent:
    let copied_mods = copy_modifiers :: mods :: call
    return WindowEvent.MouseButtonChanged :: :: call
        id = id
        button = mouse_button_from_raw :: raw_button :: call
        action = input_action_from_raw :: raw_action :: call
        mods = copied_mods

impl AppEventBatch:
    fn key_changed_events(edit self) -> List[WindowEvent]:
        let staged = batch_support.take_batch_events_reversed :: self :: call
        let matched = List[WindowEvent] :: :: call
        let remaining = List[AppEvent] :: :: call
        repeat while !staged.is_empty :: :: method:
            select staged.pop :: :: method:
                when Option.Some(event) =>
                    select event:
                        when AppEvent.Window(window_event) =>
                            select window_event:
                                when WindowEvent.KeyChanged(id = id, key = key, scancode = scancode, action = action, mods = mods) =>
                                    let raw_key = key_raw :: key :: call
                                    let raw_action = input_action_raw :: action :: call
                                    let copied = build_key_changed_window_event :: id, raw_key, scancode, raw_action, mods :: call
                                    let restored = build_key_changed_window_event :: id, raw_key, scancode, raw_action, mods :: call
                                    matched.push :: copied :: method
                                    push_window :: remaining, restored :: call
                                when _ => push_window :: remaining, window_event :: call
                        when _ => push_passthrough :: remaining, event :: call
                when Option.None => break
        self.events = remaining
        return matched

    fn character_events(edit self) -> List[WindowEvent]:
        let staged = batch_support.take_batch_events_reversed :: self :: call
        let matched = List[WindowEvent] :: :: call
        let remaining = List[AppEvent] :: :: call
        repeat while !staged.is_empty :: :: method:
            select staged.pop :: :: method:
                when Option.Some(event) =>
                    select event:
                        when AppEvent.Window(window_event) =>
                            select window_event:
                                when WindowEvent.Character(id = id, codepoint = codepoint) =>
                                    let copied = build_character_window_event :: id, codepoint :: call
                                    let restored = build_character_window_event :: id, codepoint :: call
                                    matched.push :: copied :: method
                                    push_window :: remaining, restored :: call
                                when _ => push_window :: remaining, window_event :: call
                        when _ => push_passthrough :: remaining, event :: call
                when Option.None => break
        self.events = remaining
        return matched

