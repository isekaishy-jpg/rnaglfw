                            select window_event:
                                when WindowEvent.Character(id = event_id, codepoint = codepoint) =>
                                    select:
                                        when event_id == id =>
                                            let copied = build_character_window_event :: event_id, codepoint :: call
                                            matched.push :: copied :: method
                                        else => ()
                                    let restored = build_character_window_event :: event_id, codepoint :: call
                                    push_window :: remaining, restored :: call
                                when _ => push_window :: remaining, window_event :: call
                        when _ => push_passthrough :: remaining, event :: call
