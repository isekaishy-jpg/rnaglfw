    fn key_changed_events_for(edit self, id: WindowId) -> List[WindowEvent]:
        let staged = batch_support.take_batch_events_reversed :: self :: call
        let matched = List[WindowEvent] :: :: call
        let remaining = List[AppEvent] :: :: call
        repeat while !staged.is_empty :: :: method:
            select staged.pop :: :: method:
                when Option.Some(event) =>
                    select event:
                        when AppEvent.Window(window_event) =>
                            select window_event:
                                when WindowEvent.KeyChanged(id = event_id, key = key, scancode = scancode, action = action, mods = mods) =>
                                    let raw_key = key_raw :: key :: call
                                    let raw_action = input_action_raw :: action :: call
                                    select:
                                        when event_id == id =>
                                            let copied = build_key_changed_window_event :: event_id, raw_key, scancode, raw_action, mods :: call
                                            matched.push :: copied :: method
                                        else => ()
                                    let restored = build_key_changed_window_event :: event_id, raw_key, scancode, raw_action, mods :: call
                                    push_window :: remaining, restored :: call
                                when _ => push_window :: remaining, window_event :: call
                        when _ => push_passthrough :: remaining, event :: call
                when Option.None => break
        self.events = remaining
        return matched

