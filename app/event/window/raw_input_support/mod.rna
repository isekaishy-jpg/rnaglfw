impl AppEventBatch:
    fn raw_key_changed_events(edit self) -> List[WindowEvent]:
        let staged = batch_support.take_batch_events_reversed :: self :: call
        let matched = List[WindowEvent] :: :: call
        let remaining = List[AppEvent] :: :: call
        repeat while !staged.is_empty :: :: method:
            select staged.pop :: :: method:
                when Option.Some(event) =>
                    select event:
                        when AppEvent.Window(window_event) =>
                            select window_event:
                                when WindowEvent.RawKeyChanged(id = id, raw_key = raw_key, scancode = scancode, action = action, extended = extended) =>
                                    let raw_action = input_action_raw :: action :: call
                                    let copied = build_raw_key_changed_window_event :: id, raw_key, scancode, raw_action, extended :: call
                                    let restored = build_raw_key_changed_window_event :: id, raw_key, scancode, raw_action, extended :: call
                                    matched.push :: copied :: method
                                    push_window :: remaining, restored :: call
                                when _ => push_window :: remaining, window_event :: call
                        when AppEvent.Monitor(monitor_event) => push_monitor :: remaining, monitor_event :: call
                        when AppEvent.Joystick(joystick_event) => push_joystick :: remaining, joystick_event :: call
                        when AppEvent.User(user_event) => push_user :: remaining, user_event :: call
                when Option.None => break
        self.events = remaining
        return matched

    fn raw_key_changed_events_for(edit self, id: WindowId) -> List[WindowEvent]:
        let staged = batch_support.take_batch_events_reversed :: self :: call
        let matched = List[WindowEvent] :: :: call
        let remaining = List[AppEvent] :: :: call
        repeat while !staged.is_empty :: :: method:
            select staged.pop :: :: method:
                when Option.Some(event) =>
                    select event:
                        when AppEvent.Window(window_event) =>
                            select window_event:
                                when WindowEvent.RawKeyChanged(id = event_id, raw_key = raw_key, scancode = scancode, action = action, extended = extended) =>
                                    let raw_action = input_action_raw :: action :: call
                                    select:
                                        when event_id == id =>
                                            let copied = build_raw_key_changed_window_event :: event_id, raw_key, scancode, raw_action, extended :: call
                                            matched.push :: copied :: method
                                        else => ()
                                    let restored = build_raw_key_changed_window_event :: event_id, raw_key, scancode, raw_action, extended :: call
                                    push_window :: remaining, restored :: call
                                when _ => push_window :: remaining, window_event :: call
                        when AppEvent.Monitor(monitor_event) => push_monitor :: remaining, monitor_event :: call
                        when AppEvent.Joystick(joystick_event) => push_joystick :: remaining, joystick_event :: call
                        when AppEvent.User(user_event) => push_user :: remaining, user_event :: call
                when Option.None => break
        self.events = remaining
        return matched

    fn raw_mouse_motion_events(edit self) -> List[WindowEvent]:
        let staged = batch_support.take_batch_events_reversed :: self :: call
        let matched = List[WindowEvent] :: :: call
        let remaining = List[AppEvent] :: :: call
        repeat while !staged.is_empty :: :: method:
            select staged.pop :: :: method:
                when Option.Some(event) =>
                    select event:
                        when AppEvent.Window(window_event) =>
                            select window_event:
                                when WindowEvent.RawMouseMotion(id = id, delta_x = delta_x, delta_y = delta_y) =>
                                    let copied = build_raw_mouse_motion_window_event :: id, delta_x, delta_y :: call
                                    let restored = build_raw_mouse_motion_window_event :: id, delta_x, delta_y :: call
                                    matched.push :: copied :: method
                                    push_window :: remaining, restored :: call
                                when _ => push_window :: remaining, window_event :: call
                        when AppEvent.Monitor(monitor_event) => push_monitor :: remaining, monitor_event :: call
                        when AppEvent.Joystick(joystick_event) => push_joystick :: remaining, joystick_event :: call
                        when AppEvent.User(user_event) => push_user :: remaining, user_event :: call
                when Option.None => break
        self.events = remaining
        return matched

    fn raw_mouse_motion_events_for(edit self, id: WindowId) -> List[WindowEvent]:
        let staged = batch_support.take_batch_events_reversed :: self :: call
