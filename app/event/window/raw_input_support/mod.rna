    fn raw_mouse_motion_data(edit self) -> List[WindowRawMouseMotionData]:
        return take_raw_mouse_motion_data_from_events :: (self.raw_mouse_motion_events :: :: method) :: call

    fn raw_mouse_button_data(edit self) -> List[WindowRawMouseButtonData]:
        return take_raw_mouse_button_data_from_events :: (self.raw_mouse_button_changed_events :: :: method) :: call

    fn raw_mouse_wheel_data(edit self) -> List[WindowRawMouseWheelData]:
        return take_raw_mouse_wheel_data_from_events :: (self.raw_mouse_wheel_events :: :: method) :: call

    fn raw_key_data(edit self) -> List[WindowRawKeyData]:
        return take_raw_key_data_from_events :: (self.raw_key_changed_events :: :: method) :: call

    fn raw_mouse_motion_data_for(edit self, id: WindowId) -> List[WindowRawMouseMotionData]:
        return take_raw_mouse_motion_data_from_events :: (self.raw_mouse_motion_events_for :: id :: method) :: call

    fn raw_mouse_button_data_for(edit self, id: WindowId) -> List[WindowRawMouseButtonData]:
        return take_raw_mouse_button_data_from_events :: (self.raw_mouse_button_changed_events_for :: id :: method) :: call

