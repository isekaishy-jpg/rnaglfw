        return batch_support.take_window_events_matching :: self, WindowEventKind.RawMouseWheel, id_filter :: call

    fn take_raw_mouse_motion_data(edit self) -> List[WindowRawMouseMotionData]:
        return take_raw_mouse_motion_data_from_events :: (self.take_raw_mouse_motion_events :: :: method) :: call

    fn take_raw_key_data(edit self) -> List[WindowRawKeyData]:
        return take_raw_key_data_from_events :: (self.take_raw_key_changed_events :: :: method) :: call

