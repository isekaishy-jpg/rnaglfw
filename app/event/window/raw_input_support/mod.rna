    fn raw_key_data_for(edit self, id: WindowId) -> List[WindowRawKeyData]:
        return take_raw_key_data_from_events :: (self.raw_key_changed_events_for :: id :: method) :: call

    fn take_raw_mouse_motion_events(edit self) -> List[WindowEvent]:
        let id_filter: Option[WindowId] = Option.None
        return batch_support.take_window_events_matching :: self, WindowEventKind.RawMouseMotion, id_filter :: call

    fn take_raw_key_changed_events(edit self) -> List[WindowEvent]:
        let id_filter: Option[WindowId] = Option.None
        return batch_support.take_window_events_matching :: self, WindowEventKind.RawKeyChanged, id_filter :: call

