use std.{List, Option}
use event.{AppEvent, AppEventBatch, JoystickEvent, MonitorEvent, UserEvent, WindowEvent}
use event.WindowEventKind
use event.{WindowMoveData, WindowScaleData, WindowSizeData}
use window.{Theme, WindowId, theme_from_raw, theme_raw}

fn push_window(edit events: List[AppEvent], event: WindowEvent) -> Unit:
    let wrapped = AppEvent.Window :: event :: call
    events.push :: wrapped :: method
    return

fn push_monitor(edit events: List[AppEvent], event: MonitorEvent) -> Unit:
    let wrapped = AppEvent.Monitor :: event :: call
    events.push :: wrapped :: method
    return

fn push_joystick(edit events: List[AppEvent], event: JoystickEvent) -> Unit:
    let wrapped = AppEvent.Joystick :: event :: call
    events.push :: wrapped :: method
    return

fn push_user(edit events: List[AppEvent], event: UserEvent) -> Unit:
    let wrapped = AppEvent.User :: event :: call
    events.push :: wrapped :: method
    return

fn build_redraw_requested_window_event(id: WindowId) -> WindowEvent:
    return WindowEvent.RedrawRequested :: :: call
        id = id

fn build_moved_window_event(id: WindowId, x: CInt, y: CInt) -> WindowEvent:
    return WindowEvent.Moved :: :: call
        id = id
        x = x
        y = y

fn build_resized_window_event(id: WindowId, width: CInt, height: CInt) -> WindowEvent:
    return WindowEvent.Resized :: :: call
        id = id
        width = width
        height = height

fn build_framebuffer_resized_window_event(id: WindowId, width: CInt, height: CInt) -> WindowEvent:
    return WindowEvent.FramebufferResized :: :: call
        id = id
        width = width
        height = height

fn build_content_scale_changed_window_event(id: WindowId, x: F32, y: F32) -> WindowEvent:
    return WindowEvent.ContentScaleChanged :: :: call
        id = id
        x = x
        y = y

fn build_focus_changed_window_event(id: WindowId, focused: Bool) -> WindowEvent:
    return WindowEvent.FocusChanged :: :: call
        id = id
        focused = focused

fn build_iconified_window_event(id: WindowId, iconified: Bool) -> WindowEvent:
    return WindowEvent.Iconified :: :: call
        id = id
        iconified = iconified

fn build_maximized_window_event(id: WindowId, maximized: Bool) -> WindowEvent:
    return WindowEvent.Maximized :: :: call
        id = id
        maximized = maximized

fn build_cursor_entered_window_event(id: WindowId, entered: Bool) -> WindowEvent:
    return WindowEvent.CursorEntered :: :: call
        id = id
        entered = entered

fn build_theme_changed_window_event(id: WindowId, read theme: Theme) -> WindowEvent:
    let raw = theme_raw :: theme :: call
    let copied = theme_from_raw :: raw :: call
    return WindowEvent.ThemeChanged :: :: call
        id = id
        theme = copied

impl AppEventBatch:
    fn redraw_requested_events(edit self) -> List[WindowEvent]:
        let matched = List[WindowEvent] :: :: call
        let remaining = List[AppEvent] :: :: call
        repeat while !self.events.is_empty :: :: method:
            let event = self.events.remove :: 0 :: method
            select event:
                when AppEvent.Window(window_event) =>
                    select window_event:
                        when WindowEvent.RedrawRequested(id = id) =>
                            let copied = build_redraw_requested_window_event :: id :: call
                            matched.push :: copied :: method
                            push_window :: remaining, window_event :: call
                        when _ => push_window :: remaining, window_event :: call
                when AppEvent.Monitor(monitor_event) => push_monitor :: remaining, monitor_event :: call
                when AppEvent.Joystick(joystick_event) => push_joystick :: remaining, joystick_event :: call
                when AppEvent.User(user_event) => push_user :: remaining, user_event :: call
        self.events = remaining
        return matched

    fn moved_events(edit self) -> List[WindowEvent]:
        let matched = List[WindowEvent] :: :: call
        let remaining = List[AppEvent] :: :: call
