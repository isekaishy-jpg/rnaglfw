use std.{List, Option}

use event.{AppEvent, AppEventBatch, WindowEvent, WindowEventKind}
use event.{WindowMoveData, WindowScaleData, WindowSizeData}
use event.batch_support
use window.{Theme, WindowId, theme_from_raw, theme_raw}

fn push_window(edit events: List[AppEvent], event: WindowEvent) -> Unit:
    let wrapped = AppEvent.Window :: event :: call
    events.push :: wrapped :: method
    return

fn push_passthrough(edit events: List[AppEvent], event: AppEvent) -> Unit:
    events.push :: event :: method
    return

fn build_redraw_requested_window_event(id: WindowId) -> WindowEvent:
    return WindowEvent.RedrawRequested :: :: call
        id = id

fn build_moved_window_event(id: WindowId, x: CInt, y: CInt) -> WindowEvent:
    return WindowEvent.Moved :: :: call
        id = id
        x = x
        y = y

fn build_resized_window_event(id: WindowId, width: CInt, height: CInt) -> WindowEvent:
    return WindowEvent.Resized :: :: call
        id = id
        width = width
        height = height

fn build_framebuffer_resized_window_event(id: WindowId, width: CInt, height: CInt) -> WindowEvent:
    return WindowEvent.FramebufferResized :: :: call
        id = id
        width = width
        height = height

fn build_content_scale_changed_window_event(id: WindowId, x: F32, y: F32) -> WindowEvent:
    return WindowEvent.ContentScaleChanged :: :: call
        id = id
        x = x
        y = y

fn build_focus_changed_window_event(id: WindowId, focused: Bool) -> WindowEvent:
    return WindowEvent.FocusChanged :: :: call
        id = id
        focused = focused

fn build_iconified_window_event(id: WindowId, iconified: Bool) -> WindowEvent:
    return WindowEvent.Iconified :: :: call
        id = id
        iconified = iconified

fn build_maximized_window_event(id: WindowId, maximized: Bool) -> WindowEvent:
    return WindowEvent.Maximized :: :: call
        id = id
        maximized = maximized

fn build_cursor_entered_window_event(id: WindowId, entered: Bool) -> WindowEvent:
    return WindowEvent.CursorEntered :: :: call
        id = id
        entered = entered

fn build_theme_changed_window_event(id: WindowId, read theme: Theme) -> WindowEvent:
    let raw = theme_raw :: theme :: call
    let copied = theme_from_raw :: raw :: call
    return WindowEvent.ThemeChanged :: :: call
        id = id
        theme = copied

fn collect_state_events(edit batch: AppEventBatch, read kind: WindowEventKind, read id_filter: Option[WindowId]) -> List[WindowEvent]:
    let staged = batch_support.take_batch_events_reversed :: batch :: call
    let matched = List[WindowEvent] :: :: call
    let remaining = List[AppEvent] :: :: call
    repeat while !staged.is_empty :: :: method:
        select staged.pop :: :: method:
            when Option.Some(event) =>
                select event:
                    when AppEvent.Window(window_event) =>
                        select kind:
                            when WindowEventKind.RedrawRequested =>
                                select window_event:
                                    when WindowEvent.RedrawRequested(id = id) =>
                                        select id_filter:
                                            when Option.Some(expected) =>
                                                select:
                                                    when id == expected =>
                                                        let copied = build_redraw_requested_window_event :: id :: call
                                                        let restored = build_redraw_requested_window_event :: id :: call
                                                        matched.push :: copied :: method
                                                        push_window :: remaining, restored :: call
                                                    else =>
                                                        let restored = build_redraw_requested_window_event :: id :: call
                                                        push_window :: remaining, restored :: call
                                            when Option.None =>
                                                let copied = build_redraw_requested_window_event :: id :: call
                                                let restored = build_redraw_requested_window_event :: id :: call
                                                matched.push :: copied :: method
                                                push_window :: remaining, restored :: call
                                    when _ => push_window :: remaining, window_event :: call
                            when WindowEventKind.Moved =>
                                select window_event:
                                    when WindowEvent.Moved(id = id, x = x, y = y) =>
                                        select id_filter:
                                            when Option.Some(expected) =>
                                                select:
                                                    when id == expected =>
                                                        let copied = build_moved_window_event :: id, x, y :: call
                                                        let restored = build_moved_window_event :: id, x, y :: call
                                                        matched.push :: copied :: method
                                                        push_window :: remaining, restored :: call
                                                    else =>
                                                        let restored = build_moved_window_event :: id, x, y :: call
                                                        push_window :: remaining, restored :: call
                                            when Option.None =>
                                                let copied = build_moved_window_event :: id, x, y :: call
                                                let restored = build_moved_window_event :: id, x, y :: call
                                                matched.push :: copied :: method
                                                push_window :: remaining, restored :: call
                                    when _ => push_window :: remaining, window_event :: call
                            when WindowEventKind.Resized =>
                                select window_event:
                                    when WindowEvent.Resized(id = id, width = width, height = height) =>
                                        select id_filter:
                                            when Option.Some(expected) =>
                                                select:
                                                    when id == expected =>
                                                        let copied = build_resized_window_event :: id, width, height :: call
                                                        let restored = build_resized_window_event :: id, width, height :: call
                                                        matched.push :: copied :: method
                                                        push_window :: remaining, restored :: call
                                                    else =>
                                                        let restored = build_resized_window_event :: id, width, height :: call
                                                        push_window :: remaining, restored :: call
                                            when Option.None =>
                                                let copied = build_resized_window_event :: id, width, height :: call
                                                let restored = build_resized_window_event :: id, width, height :: call
                                                matched.push :: copied :: method
                                                push_window :: remaining, restored :: call
                                    when _ => push_window :: remaining, window_event :: call
                            when WindowEventKind.FramebufferResized =>
                                select window_event:
                                    when WindowEvent.FramebufferResized(id = id, width = width, height = height) =>
                                        select id_filter:
                                            when Option.Some(expected) =>
                                                select:
                                                    when id == expected =>
                                                        let copied = build_framebuffer_resized_window_event :: id, width, height :: call
                                                        let restored = build_framebuffer_resized_window_event :: id, width, height :: call
                                                        matched.push :: copied :: method
                                                        push_window :: remaining, restored :: call
                                                    else =>
                                                        let restored = build_framebuffer_resized_window_event :: id, width, height :: call
                                                        push_window :: remaining, restored :: call
                                            when Option.None =>
                                                let copied = build_framebuffer_resized_window_event :: id, width, height :: call
                                                let restored = build_framebuffer_resized_window_event :: id, width, height :: call
                                                matched.push :: copied :: method
                                                push_window :: remaining, restored :: call
                                    when _ => push_window :: remaining, window_event :: call
                            when WindowEventKind.ContentScaleChanged =>
                                select window_event:
                                    when WindowEvent.ContentScaleChanged(id = id, x = x, y = y) =>
                                        select id_filter:
                                            when Option.Some(expected) =>
                                                select:
                                                    when id == expected =>
                                                        let copied = build_content_scale_changed_window_event :: id, x, y :: call
                                                        let restored = build_content_scale_changed_window_event :: id, x, y :: call
                                                        matched.push :: copied :: method
                                                        push_window :: remaining, restored :: call
                                                    else =>
                                                        let restored = build_content_scale_changed_window_event :: id, x, y :: call
                                                        push_window :: remaining, restored :: call
                                            when Option.None =>
                                                let copied = build_content_scale_changed_window_event :: id, x, y :: call
                                                let restored = build_content_scale_changed_window_event :: id, x, y :: call
                                                matched.push :: copied :: method
                                                push_window :: remaining, restored :: call
                                    when _ => push_window :: remaining, window_event :: call
                            when WindowEventKind.FocusChanged =>
                                select window_event:
                                    when WindowEvent.FocusChanged(id = id, focused = focused) =>
                                        select id_filter:
                                            when Option.Some(expected) =>
                                                select:
                                                    when id == expected =>
                                                        let copied = build_focus_changed_window_event :: id, focused :: call
                                                        let restored = build_focus_changed_window_event :: id, focused :: call
                                                        matched.push :: copied :: method
                                                        push_window :: remaining, restored :: call
                                                    else =>
                                                        let restored = build_focus_changed_window_event :: id, focused :: call
                                                        push_window :: remaining, restored :: call
                                            when Option.None =>
                                                let copied = build_focus_changed_window_event :: id, focused :: call
                                                let restored = build_focus_changed_window_event :: id, focused :: call
                                                matched.push :: copied :: method
                                                push_window :: remaining, restored :: call
                                    when _ => push_window :: remaining, window_event :: call
                            when WindowEventKind.Iconified =>
                                select window_event:
                                    when WindowEvent.Iconified(id = id, iconified = iconified) =>
                                        select id_filter:
                                            when Option.Some(expected) =>
                                                select:
                                                    when id == expected =>
                                                        let copied = build_iconified_window_event :: id, iconified :: call
                                                        let restored = build_iconified_window_event :: id, iconified :: call
                                                        matched.push :: copied :: method
                                                        push_window :: remaining, restored :: call
                                                    else =>
                                                        let restored = build_iconified_window_event :: id, iconified :: call
                                                        push_window :: remaining, restored :: call
                                            when Option.None =>
                                                let copied = build_iconified_window_event :: id, iconified :: call
                                                let restored = build_iconified_window_event :: id, iconified :: call
                                                matched.push :: copied :: method
                                                push_window :: remaining, restored :: call
                                    when _ => push_window :: remaining, window_event :: call
                            when WindowEventKind.Maximized =>
                                select window_event:
                                    when WindowEvent.Maximized(id = id, maximized = maximized) =>
                                        select id_filter:
                                            when Option.Some(expected) =>
                                                select:
                                                    when id == expected =>
                                                        let copied = build_maximized_window_event :: id, maximized :: call
                                                        let restored = build_maximized_window_event :: id, maximized :: call
                                                        matched.push :: copied :: method
                                                        push_window :: remaining, restored :: call
                                                    else =>
                                                        let restored = build_maximized_window_event :: id, maximized :: call
                                                        push_window :: remaining, restored :: call
                                            when Option.None =>
                                                let copied = build_maximized_window_event :: id, maximized :: call
                                                let restored = build_maximized_window_event :: id, maximized :: call
                                                matched.push :: copied :: method
                                                push_window :: remaining, restored :: call
                                    when _ => push_window :: remaining, window_event :: call
                            when WindowEventKind.CursorEntered =>
                                select window_event:
                                    when WindowEvent.CursorEntered(id = id, entered = entered) =>
                                        select id_filter:
                                            when Option.Some(expected) =>
                                                select:
                                                    when id == expected =>
                                                        let copied = build_cursor_entered_window_event :: id, entered :: call
                                                        let restored = build_cursor_entered_window_event :: id, entered :: call
                                                        matched.push :: copied :: method
                                                        push_window :: remaining, restored :: call
                                                    else =>
                                                        let restored = build_cursor_entered_window_event :: id, entered :: call
                                                        push_window :: remaining, restored :: call
                                            when Option.None =>
                                                let copied = build_cursor_entered_window_event :: id, entered :: call
                                                let restored = build_cursor_entered_window_event :: id, entered :: call
                                                matched.push :: copied :: method
                                                push_window :: remaining, restored :: call
                                    when _ => push_window :: remaining, window_event :: call
                            when WindowEventKind.ThemeChanged =>
                                select window_event:
                                    when WindowEvent.ThemeChanged(id = id, theme = theme) =>
                                        select id_filter:
                                            when Option.Some(expected) =>
                                                select:
                                                    when id == expected =>
                                                        let copied = build_theme_changed_window_event :: id, theme :: call
                                                        let restored = build_theme_changed_window_event :: id, theme :: call
                                                        matched.push :: copied :: method
                                                        push_window :: remaining, restored :: call
                                                    else =>
                                                        let restored = build_theme_changed_window_event :: id, theme :: call
                                                        push_window :: remaining, restored :: call
                                            when Option.None =>
                                                let copied = build_theme_changed_window_event :: id, theme :: call
                                                let restored = build_theme_changed_window_event :: id, theme :: call
                                                matched.push :: copied :: method
                                                push_window :: remaining, restored :: call
                                    when _ => push_window :: remaining, window_event :: call
                            when _ => push_window :: remaining, window_event :: call
                    when other => push_passthrough :: remaining, other :: call
            when Option.None => break
    batch.events = remaining
    return matched

fn take_moved_data_from_events(take events: List[WindowEvent]) -> List[WindowMoveData]:
    let data = List[WindowMoveData] :: :: call
    repeat while !events.is_empty :: :: method:
        select events.pop :: :: method:
            when Option.Some(event) =>
                select event.moved_data :: :: method:
                    when Option.Some(value) => data.push :: value :: method
                    when Option.None => ()
            when Option.None => break
    return data

fn take_resized_data_from_events(take events: List[WindowEvent]) -> List[WindowSizeData]:
    let data = List[WindowSizeData] :: :: call
    repeat while !events.is_empty :: :: method:
        select events.pop :: :: method:
            when Option.Some(event) =>
                select event.resized_data :: :: method:
                    when Option.Some(value) => data.push :: value :: method
                    when Option.None => ()
            when Option.None => break
    return data

