            when Option.None => break
    return themes

impl AppEventBatch:
    fn redraw_requested_events(edit self) -> List[WindowEvent]:
        let id_filter: Option[WindowId] = Option.None
        return collect_state_events :: self, WindowEventKind.RedrawRequested, id_filter :: call

    fn moved_events(edit self) -> List[WindowEvent]:
        let id_filter: Option[WindowId] = Option.None
        return collect_state_events :: self, WindowEventKind.Moved, id_filter :: call

    fn resized_events(edit self) -> List[WindowEvent]:
        let id_filter: Option[WindowId] = Option.None
        return collect_state_events :: self, WindowEventKind.Resized, id_filter :: call

    fn framebuffer_resized_events(edit self) -> List[WindowEvent]:
        let id_filter: Option[WindowId] = Option.None
        return collect_state_events :: self, WindowEventKind.FramebufferResized, id_filter :: call

    fn content_scale_changed_events(edit self) -> List[WindowEvent]:
        let id_filter: Option[WindowId] = Option.None
        return collect_state_events :: self, WindowEventKind.ContentScaleChanged, id_filter :: call

    fn focus_changed_events(edit self) -> List[WindowEvent]:
        let id_filter: Option[WindowId] = Option.None
        return collect_state_events :: self, WindowEventKind.FocusChanged, id_filter :: call

    fn iconified_events(edit self) -> List[WindowEvent]:
        let id_filter: Option[WindowId] = Option.None
        return collect_state_events :: self, WindowEventKind.Iconified, id_filter :: call

    fn maximized_events(edit self) -> List[WindowEvent]:
        let id_filter: Option[WindowId] = Option.None
        return collect_state_events :: self, WindowEventKind.Maximized, id_filter :: call

    fn cursor_entered_events(edit self) -> List[WindowEvent]:
        let id_filter: Option[WindowId] = Option.None
        return collect_state_events :: self, WindowEventKind.CursorEntered, id_filter :: call

    fn theme_changed_events(edit self) -> List[WindowEvent]:
        let id_filter: Option[WindowId] = Option.None
        return collect_state_events :: self, WindowEventKind.ThemeChanged, id_filter :: call

    fn redraw_requested_events_for(edit self, id: WindowId) -> List[WindowEvent]:
        let id_filter = Option.Some :: id :: call
        return collect_state_events :: self, WindowEventKind.RedrawRequested, id_filter :: call

    fn moved_events_for(edit self, id: WindowId) -> List[WindowEvent]:
        let id_filter = Option.Some :: id :: call
        return collect_state_events :: self, WindowEventKind.Moved, id_filter :: call

    fn resized_events_for(edit self, id: WindowId) -> List[WindowEvent]:
        let id_filter = Option.Some :: id :: call
        return collect_state_events :: self, WindowEventKind.Resized, id_filter :: call

    fn framebuffer_resized_events_for(edit self, id: WindowId) -> List[WindowEvent]:
        let id_filter = Option.Some :: id :: call
        return collect_state_events :: self, WindowEventKind.FramebufferResized, id_filter :: call

    fn content_scale_changed_events_for(edit self, id: WindowId) -> List[WindowEvent]:
        let id_filter = Option.Some :: id :: call
        return collect_state_events :: self, WindowEventKind.ContentScaleChanged, id_filter :: call

    fn focus_changed_events_for(edit self, id: WindowId) -> List[WindowEvent]:
        let id_filter = Option.Some :: id :: call
        return collect_state_events :: self, WindowEventKind.FocusChanged, id_filter :: call

    fn iconified_events_for(edit self, id: WindowId) -> List[WindowEvent]:
        let id_filter = Option.Some :: id :: call
        return collect_state_events :: self, WindowEventKind.Iconified, id_filter :: call

    fn maximized_events_for(edit self, id: WindowId) -> List[WindowEvent]:
        let id_filter = Option.Some :: id :: call
        return collect_state_events :: self, WindowEventKind.Maximized, id_filter :: call

    fn cursor_entered_events_for(edit self, id: WindowId) -> List[WindowEvent]:
        let id_filter = Option.Some :: id :: call
        return collect_state_events :: self, WindowEventKind.CursorEntered, id_filter :: call

    fn theme_changed_events_for(edit self, id: WindowId) -> List[WindowEvent]:
        let id_filter = Option.Some :: id :: call
        return collect_state_events :: self, WindowEventKind.ThemeChanged, id_filter :: call

    fn pop_redraw_requested_event(edit self) -> Option[WindowEvent]:
        let id_filter: Option[WindowId] = Option.None
        return batch_support.pop_window_event_matching :: self, WindowEventKind.RedrawRequested, id_filter :: call

    fn pop_moved_event(edit self) -> Option[WindowEvent]:
        let id_filter: Option[WindowId] = Option.None
        return batch_support.pop_window_event_matching :: self, WindowEventKind.Moved, id_filter :: call

    fn pop_resized_event(edit self) -> Option[WindowEvent]:
        let id_filter: Option[WindowId] = Option.None
        return batch_support.pop_window_event_matching :: self, WindowEventKind.Resized, id_filter :: call

    fn pop_framebuffer_resized_event(edit self) -> Option[WindowEvent]:
        let id_filter: Option[WindowId] = Option.None
        return batch_support.pop_window_event_matching :: self, WindowEventKind.FramebufferResized, id_filter :: call

    fn pop_content_scale_changed_event(edit self) -> Option[WindowEvent]:
        let id_filter: Option[WindowId] = Option.None
        return batch_support.pop_window_event_matching :: self, WindowEventKind.ContentScaleChanged, id_filter :: call

    fn pop_focus_changed_event(edit self) -> Option[WindowEvent]:
        let id_filter: Option[WindowId] = Option.None
        return batch_support.pop_window_event_matching :: self, WindowEventKind.FocusChanged, id_filter :: call

    fn pop_iconified_event(edit self) -> Option[WindowEvent]:
        let id_filter: Option[WindowId] = Option.None
        return batch_support.pop_window_event_matching :: self, WindowEventKind.Iconified, id_filter :: call

    fn pop_maximized_event(edit self) -> Option[WindowEvent]:
        let id_filter: Option[WindowId] = Option.None
        return batch_support.pop_window_event_matching :: self, WindowEventKind.Maximized, id_filter :: call

    fn pop_cursor_entered_event(edit self) -> Option[WindowEvent]:
        let id_filter: Option[WindowId] = Option.None
        return batch_support.pop_window_event_matching :: self, WindowEventKind.CursorEntered, id_filter :: call

    fn pop_theme_changed_event(edit self) -> Option[WindowEvent]:
        let id_filter: Option[WindowId] = Option.None
        return batch_support.pop_window_event_matching :: self, WindowEventKind.ThemeChanged, id_filter :: call

    fn pop_redraw_requested_event_for(edit self, id: WindowId) -> Option[WindowEvent]:
        let id_filter = Option.Some :: id :: call
        return batch_support.pop_window_event_matching :: self, WindowEventKind.RedrawRequested, id_filter :: call

    fn pop_moved_event_for(edit self, id: WindowId) -> Option[WindowEvent]:
        let id_filter = Option.Some :: id :: call
        return batch_support.pop_window_event_matching :: self, WindowEventKind.Moved, id_filter :: call

    fn pop_resized_event_for(edit self, id: WindowId) -> Option[WindowEvent]:
        let id_filter = Option.Some :: id :: call
        return batch_support.pop_window_event_matching :: self, WindowEventKind.Resized, id_filter :: call

    fn pop_framebuffer_resized_event_for(edit self, id: WindowId) -> Option[WindowEvent]:
        let id_filter = Option.Some :: id :: call
        return batch_support.pop_window_event_matching :: self, WindowEventKind.FramebufferResized, id_filter :: call

    fn pop_content_scale_changed_event_for(edit self, id: WindowId) -> Option[WindowEvent]:
        let id_filter = Option.Some :: id :: call
        return batch_support.pop_window_event_matching :: self, WindowEventKind.ContentScaleChanged, id_filter :: call

    fn pop_focus_changed_event_for(edit self, id: WindowId) -> Option[WindowEvent]:
        let id_filter = Option.Some :: id :: call
        return batch_support.pop_window_event_matching :: self, WindowEventKind.FocusChanged, id_filter :: call

    fn pop_iconified_event_for(edit self, id: WindowId) -> Option[WindowEvent]:
        let id_filter = Option.Some :: id :: call
        return batch_support.pop_window_event_matching :: self, WindowEventKind.Iconified, id_filter :: call

    fn pop_maximized_event_for(edit self, id: WindowId) -> Option[WindowEvent]:
        let id_filter = Option.Some :: id :: call
        return batch_support.pop_window_event_matching :: self, WindowEventKind.Maximized, id_filter :: call

    fn pop_cursor_entered_event_for(edit self, id: WindowId) -> Option[WindowEvent]:
        let id_filter = Option.Some :: id :: call
        return batch_support.pop_window_event_matching :: self, WindowEventKind.CursorEntered, id_filter :: call

    fn pop_theme_changed_event_for(edit self, id: WindowId) -> Option[WindowEvent]:
        let id_filter = Option.Some :: id :: call
        return batch_support.pop_window_event_matching :: self, WindowEventKind.ThemeChanged, id_filter :: call

    fn moved_data(edit self) -> List[WindowMoveData]:
        return take_moved_data_from_events :: (self.moved_events :: :: method) :: call

    fn resized_data(edit self) -> List[WindowSizeData]:
        return take_resized_data_from_events :: (self.resized_events :: :: method) :: call

    fn framebuffer_resized_data(edit self) -> List[WindowSizeData]:
        return take_framebuffer_resized_data_from_events :: (self.framebuffer_resized_events :: :: method) :: call

    fn content_scale_data(edit self) -> List[WindowScaleData]:
        return take_content_scale_data_from_events :: (self.content_scale_changed_events :: :: method) :: call

    fn focus_states(edit self) -> List[Bool]:
        return take_focus_states_from_events :: (self.focus_changed_events :: :: method) :: call

    fn iconified_states(edit self) -> List[Bool]:
        return take_iconified_states_from_events :: (self.iconified_events :: :: method) :: call

