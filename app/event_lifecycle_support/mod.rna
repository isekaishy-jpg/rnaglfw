                        when Option.None =>
                            select window_event.kind :: :: method:
                                when WindowEventKind.CloseRequested => found = Option.Some :: window_event :: call
                                else => push_window :: remaining, window_event :: call
                        when Option.Some(_) => push_window :: remaining, window_event :: call
                when AppEvent.Monitor(monitor_event) => push_monitor :: remaining, monitor_event :: call
                when AppEvent.Joystick(joystick_event) => push_joystick :: remaining, joystick_event :: call
                when AppEvent.User(user_event) => push_user :: remaining, user_event :: call
        self.events = remaining
        return found

    fn pop_created_window_event_for(edit self, id: WindowId) -> Option[WindowEvent]:
        let remaining = List[AppEvent] :: :: call
        let found: Option[WindowEvent] = Option.None
        repeat while !self.events.is_empty :: :: method:
            let event = self.events.remove :: 0 :: method
            select event:
                when AppEvent.Window(window_event) =>
                    select found:
                        when Option.None =>
                            select window_event.kind :: :: method:
                                when WindowEventKind.Created =>
                                    select:
                                        when window_event.window_id :: :: method == id => found = Option.Some :: window_event :: call
                                        else => push_window :: remaining, window_event :: call
                                else => push_window :: remaining, window_event :: call
                        when Option.Some(_) => push_window :: remaining, window_event :: call
                when AppEvent.Monitor(monitor_event) => push_monitor :: remaining, monitor_event :: call
                when AppEvent.Joystick(joystick_event) => push_joystick :: remaining, joystick_event :: call
                when AppEvent.User(user_event) => push_user :: remaining, user_event :: call
        self.events = remaining
        return found

