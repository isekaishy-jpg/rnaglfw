        let remaining = List[AppEvent] :: :: call
        repeat while !self.events.is_empty :: :: method:
            let event = self.events.remove :: 0 :: method
            select event:
                when AppEvent.Window(window_event) => push_window :: remaining, window_event :: call
                when AppEvent.Monitor(monitor_event) =>
                    select monitor_event:
                        when MonitorEvent.Connected(id = event_id) =>
                            select:
                                when event_id == id => matched.push :: monitor_event :: method
                                else => push_monitor :: remaining, monitor_event :: call
                        when _ => push_monitor :: remaining, monitor_event :: call
                when AppEvent.Joystick(joystick_event) => push_joystick :: remaining, joystick_event :: call
                when AppEvent.User(user_event) => push_user :: remaining, user_event :: call
        self.events = remaining
        return matched

    fn take_disconnected_monitor_events_for(edit self, id: MonitorId) -> List[MonitorEvent]:
        let matched = List[MonitorEvent] :: :: call
        let remaining = List[AppEvent] :: :: call
