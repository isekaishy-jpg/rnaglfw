    fn take_connected_joystick_events_for(edit self, id: JoystickId) -> List[JoystickEvent]:
        let matched = List[JoystickEvent] :: :: call
        let remaining = List[AppEvent] :: :: call
        repeat while !self.events.is_empty :: :: method:
            let event = self.events.remove :: 0 :: method
            select event:
                when AppEvent.Window(window_event) => push_window :: remaining, window_event :: call
                when AppEvent.Monitor(monitor_event) => push_monitor :: remaining, monitor_event :: call
                when AppEvent.Joystick(joystick_event) =>
                    select joystick_event:
                        when JoystickEvent.Connected(id = event_id, gamepad = _) =>
                            select:
                                when event_id == id => matched.push :: joystick_event :: method
                                else => push_joystick :: remaining, joystick_event :: call
                        when _ => push_joystick :: remaining, joystick_event :: call
                when AppEvent.User(user_event) => push_user :: remaining, user_event :: call
        self.events = remaining
        return matched

