    fn composition_started_events(edit self) -> List[WindowEvent]:
        let events = self.take_composition_started_events :: :: method
        let matched = List[WindowEvent] :: :: call
        repeat while !events.is_empty :: :: method:
            let event = events.remove :: 0 :: method
            select event:
                when WindowEvent.CompositionStarted(id = event_id) =>
                    let copied = build_composition_started_window_event :: event_id :: call
                    let restored = build_composition_started_window_event :: event_id :: call
                    matched.push :: copied :: method
                    push_window :: self.events, restored :: call
                when _ => ()
        return matched

    fn composition_updated_events(edit self) -> List[WindowEvent]:
        let events = self.take_composition_updated_events :: :: method
        let matched = List[WindowEvent] :: :: call
        repeat while !events.is_empty :: :: method:
            let event = events.remove :: 0 :: method
            select event:
                when WindowEvent.CompositionUpdated(id = event_id, text = text, cursor = cursor) =>
                    let copied_cursor = copy_optional_index :: cursor :: call
                    let copied = build_composition_updated_window_event :: event_id, text, copied_cursor :: call
                    let restored = build_composition_updated_window_event :: event_id, text, cursor :: call
                    matched.push :: copied :: method
                    push_window :: self.events, restored :: call
                when _ => ()
        return matched

