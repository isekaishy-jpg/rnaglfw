use std.{Clone, List, Option, Str}

use event.{AppEvent, AppEventBatch, WindowCompositionData, WindowEvent, WindowEventKind}
use window.WindowId

fn push_window(edit events: List[AppEvent], event: WindowEvent) -> Unit:
    let wrapped = AppEvent.Window :: event :: call
    events.push :: wrapped :: method

fn push_passthrough(edit events: List[AppEvent], event: AppEvent) -> Unit:
    events.push :: event :: method

fn build_composition_started_window_event(id: WindowId) -> WindowEvent:
    return WindowEvent.CompositionStarted :: :: call
        id = id

fn build_composition_updated_window_event(id: WindowId, read text: Str, cursor: Option[Index]) -> WindowEvent:
    let copied = text.clone :: :: method
    return WindowEvent.CompositionUpdated :: :: call
        id = id
        text = copied
        cursor = cursor

fn build_composition_committed_window_event(id: WindowId, read text: Str) -> WindowEvent:
    let copied = text.clone :: :: method
    return WindowEvent.CompositionCommitted :: :: call
        id = id
        text = copied

fn build_composition_ended_window_event(id: WindowId) -> WindowEvent:
    return WindowEvent.CompositionEnded :: :: call
        id = id

fn copy_optional_index(read value: Option[Index]) -> Option[Index]:
    select value:
        when Option.Some(index) => return Option.Some :: index :: call
        when Option.None => return Option.None

impl AppEventBatch:
    fn pop_composition_data(edit self) -> Option[WindowCompositionData]:
        let remaining = List[AppEvent] :: :: call
        let found: Option[WindowCompositionData] = Option.None
        repeat while !self.events.is_empty :: :: method:
            let event = self.events.remove :: 0 :: method
            select event:
                when AppEvent.Window(window_event) =>
                    select found:
                        when Option.None =>
                            select window_event:
                                when WindowEvent.CompositionUpdated(id = _, text = text, cursor = cursor) =>
                                    let value = WindowCompositionData :: :: call
                                        text = text
                                        cursor = cursor
                                    found = Option.Some :: value :: call
                                when _ => push_window :: remaining, window_event :: call
                        when Option.Some(_) => push_window :: remaining, window_event :: call
                when _ => push_passthrough :: remaining, event :: call
        self.events = remaining
        return found

    fn pop_composition_commit_text(edit self) -> Option[Str]:
        let remaining = List[AppEvent] :: :: call
        let found: Option[Str] = Option.None
        repeat while !self.events.is_empty :: :: method:
            let event = self.events.remove :: 0 :: method
            select event:
                when AppEvent.Window(window_event) =>
                    select found:
                        when Option.None =>
                            select window_event:
                                when WindowEvent.CompositionCommitted(id = _, text = text) => found = Option.Some :: text :: call
                                when _ => push_window :: remaining, window_event :: call
                        when Option.Some(_) => push_window :: remaining, window_event :: call
                when _ => push_passthrough :: remaining, event :: call
        self.events = remaining
        return found

    fn pop_composition_data_for(edit self, id: WindowId) -> Option[WindowCompositionData]:
        let remaining = List[AppEvent] :: :: call
        let found: Option[WindowCompositionData] = Option.None
        repeat while !self.events.is_empty :: :: method:
            let event = self.events.remove :: 0 :: method
            select event:
                when AppEvent.Window(window_event) =>
                    select found:
                        when Option.None =>
                            select window_event:
                                when WindowEvent.CompositionUpdated(id = event_id, text = text, cursor = cursor) =>
                                    select:
                                        when event_id == id =>
                                            let value = WindowCompositionData :: :: call
                                                text = text
                                                cursor = cursor
                                            found = Option.Some :: value :: call
                                        else =>
                                            let restored = WindowEvent.CompositionUpdated :: :: call
                                                id = event_id
                                                text = text
                                                cursor = cursor
                                            push_window :: remaining, restored :: call
                                when _ => push_window :: remaining, window_event :: call
                        when Option.Some(_) => push_window :: remaining, window_event :: call
                when _ => push_passthrough :: remaining, event :: call
        self.events = remaining
        return found

    fn pop_composition_commit_text_for(edit self, id: WindowId) -> Option[Str]:
        let remaining = List[AppEvent] :: :: call
        let found: Option[Str] = Option.None
        repeat while !self.events.is_empty :: :: method:
            let event = self.events.remove :: 0 :: method
            select event:
                when AppEvent.Window(window_event) =>
                    select found:
                        when Option.None =>
                            select window_event:
                                when WindowEvent.CompositionCommitted(id = event_id, text = text) =>
                                    select:
                                        when event_id == id => found = Option.Some :: text :: call
                                        else =>
                                            let restored = WindowEvent.CompositionCommitted :: :: call
                                                id = event_id
                                                text = text
                                            push_window :: remaining, restored :: call
                                when _ => push_window :: remaining, window_event :: call
                        when Option.Some(_) => push_window :: remaining, window_event :: call
                when _ => push_passthrough :: remaining, event :: call
        self.events = remaining
        return found

    fn pop_composition_started_event(edit self) -> Option[WindowEvent]:
        let remaining = List[AppEvent] :: :: call
        let found: Option[WindowEvent] = Option.None
        repeat while !self.events.is_empty :: :: method:
            let event = self.events.remove :: 0 :: method
            select event:
                when AppEvent.Window(window_event) =>
                    select found:
                        when Option.None =>
                            select window_event.kind :: :: method:
                                when WindowEventKind.CompositionStarted => found = Option.Some :: window_event :: call
                                else => push_window :: remaining, window_event :: call
                        when Option.Some(_) => push_window :: remaining, window_event :: call
                when _ => push_passthrough :: remaining, event :: call
        self.events = remaining
        return found

