    fn composition_data(edit self) -> List[WindowCompositionData]:
        let matched = List[WindowCompositionData] :: :: call
        let remaining = List[AppEvent] :: :: call
        repeat while !self.events.is_empty :: :: method:
            let event = self.events.remove :: 0 :: method
            select event:
                when AppEvent.Window(window_event) =>
                    select window_event:
                        when WindowEvent.CompositionUpdated(id = event_id, text = text, cursor = cursor) =>
                            let copied = text.clone :: :: method
                            let data_cursor = copy_optional_index :: cursor :: call
                            let data = WindowCompositionData :: :: call
                                text = copied
                                cursor = data_cursor
                            matched.push :: data :: method
                            let restored = build_composition_updated_window_event :: event_id, text, cursor :: call
                            push_window :: remaining, restored :: call
                        when _ => push_window :: remaining, window_event :: call
                when _ => push_passthrough :: remaining, event :: call
        self.events = remaining
        return matched

    fn composition_commit_texts(edit self) -> List[Str]:
        let matched = List[Str] :: :: call
        let remaining = List[AppEvent] :: :: call
        repeat while !self.events.is_empty :: :: method:
            let event = self.events.remove :: 0 :: method
            select event:
                when AppEvent.Window(window_event) =>
                    select window_event:
                        when WindowEvent.CompositionCommitted(id = id, text = text) =>
                            let copied = text.clone :: :: method
                            matched.push :: copied :: method
                            let restored = build_composition_committed_window_event :: id, text :: call
                            push_window :: remaining, restored :: call
                        when _ => push_window :: remaining, window_event :: call
                when _ => push_passthrough :: remaining, event :: call
        self.events = remaining
        return matched

    fn composition_data_for(edit self, id: WindowId) -> List[WindowCompositionData]:
