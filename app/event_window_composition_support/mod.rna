        self.events = remaining
        return events

    fn take_composition_data(edit self) -> List[WindowCompositionData]:
        let events = self.take_composition_updated_events :: :: method
        let data = List[WindowCompositionData] :: :: call
        repeat while !events.is_empty :: :: method:
            let event = events.remove :: 0 :: method
            select event.composition_data :: :: method:
                when Option.Some(value) => data.push :: value :: method
                when Option.None => ()
        return data

    fn take_composition_commit_texts(edit self) -> List[Str]:
        let events = self.take_composition_committed_events :: :: method
        let texts = List[Str] :: :: call
        repeat while !events.is_empty :: :: method:
            let event = events.remove :: 0 :: method
            select event.take_composition_commit_text :: :: method:
                when Option.Some(value) => texts.push :: value :: method
                when Option.None => ()
        return texts

    fn take_composition_data_for(edit self, id: WindowId) -> List[WindowCompositionData]:
        let data = List[WindowCompositionData] :: :: call
        let remaining = List[AppEvent] :: :: call
        repeat while !self.events.is_empty :: :: method:
            let event = self.events.remove :: 0 :: method
            select event:
                when AppEvent.Window(window_event) =>
                    select window_event:
                        when WindowEvent.CompositionUpdated(id = event_id, text = text, cursor = cursor) =>
                            select:
                                when event_id == id =>
                                    let copied = text.clone :: :: method
                                    let value = WindowCompositionData :: :: call
                                        text = copied
                                        cursor = cursor
                                    data.push :: value :: method
                                else =>
                                    let restored = build_composition_updated_window_event :: event_id, text, cursor :: call
                                    push_window :: remaining, restored :: call
                        when _ => push_window :: remaining, window_event :: call
                when _ => push_passthrough :: remaining, event :: call
        self.events = remaining
        return data

    fn take_composition_commit_texts_for(edit self, id: WindowId) -> List[Str]:
        let texts = List[Str] :: :: call
        let remaining = List[AppEvent] :: :: call
        repeat while !self.events.is_empty :: :: method:
            let event = self.events.remove :: 0 :: method
            select event:
                when AppEvent.Window(window_event) =>
                    select window_event:
                        when WindowEvent.CompositionCommitted(id = event_id, text = text) =>
                            select:
                                when event_id == id => texts.push :: text :: method
                                else =>
                                    let restored = build_composition_committed_window_event :: event_id, text :: call
                                    push_window :: remaining, restored :: call
                        when _ => push_window :: remaining, window_event :: call
                when _ => push_passthrough :: remaining, event :: call
        self.events = remaining
        return texts
