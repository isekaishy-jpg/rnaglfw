    fn pop_cursor_data_for(edit self, id: WindowId) -> Option[WindowCursorData]:
        let remaining = List[AppEvent] :: :: call
        let found: Option[WindowCursorData] = Option.None
        repeat while !self.events.is_empty :: :: method:
            let event = self.events.remove :: 0 :: method
            select event:
                when AppEvent.Window(window_event) =>
                    select found:
                        when Option.None =>
                            select window_event:
                                when WindowEvent.CursorMoved(id = event_id, x = x, y = y) =>
                                    select:
                                        when event_id == id =>
                                            let value = WindowCursorData :: :: call
                                                x = x
                                                y = y
                                            found = Option.Some :: value :: call
                                        else =>
                                            let restored = WindowEvent.CursorMoved :: :: call
                                                id = event_id
                                                x = x
                                                y = y
                                            push_window :: remaining, restored :: call
                                when _ => push_window :: remaining, window_event :: call
                        when Option.Some(_) => push_window :: remaining, window_event :: call
                when _ => push_passthrough :: remaining, event :: call
        self.events = remaining
        return found

