                    select found:
                        when Option.None =>
                            select window_event:
                                when WindowEvent.DroppedPaths(id = _, paths = paths) => found = Option.Some :: paths :: call
                                when _ => push_window :: remaining, window_event :: call
                        when Option.Some(_) => push_window :: remaining, window_event :: call
                when _ => push_passthrough :: remaining, event :: call
