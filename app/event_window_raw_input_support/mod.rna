                when _ => ()
        return matched

    fn raw_mouse_motion_data(edit self) -> List[WindowRawMouseMotionData]:
        let matched = List[WindowRawMouseMotionData] :: :: call
        let remaining = List[AppEvent] :: :: call
        repeat while !self.events.is_empty :: :: method:
            let event = self.events.remove :: 0 :: method
            select event:
                when AppEvent.Window(window_event) =>
                    select copy_window_raw_mouse_motion_data :: window_event :: call:
                        when Option.Some(data) => matched.push :: data :: method
                        when Option.None => ()
                    push_window :: remaining, window_event :: call
                when AppEvent.Monitor(monitor_event) => push_monitor :: remaining, monitor_event :: call
                when AppEvent.Joystick(joystick_event) => push_joystick :: remaining, joystick_event :: call
                when AppEvent.User(user_event) => push_user :: remaining, user_event :: call
        self.events = remaining
        return matched

