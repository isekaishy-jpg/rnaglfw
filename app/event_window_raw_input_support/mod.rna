use std.{List, Option}
use event.{AppEvent, AppEventBatch, JoystickEvent, MonitorEvent}
use event.{WindowEvent, WindowRawKeyData, WindowRawMouseButtonData, WindowRawMouseMotionData}
use event.WindowRawMouseWheelData
use event.UserEvent
use input.{RawKeyCode, ScanCode, input_action_from_raw, input_action_raw}
use input.{mouse_button_from_raw, mouse_button_raw}
use window.WindowId

fn push_window(edit events: List[AppEvent], window_event: WindowEvent) -> Unit:
    let wrapped = AppEvent.Window :: window_event :: call
    events.push :: wrapped :: method

fn push_monitor(edit events: List[AppEvent], monitor_event: MonitorEvent) -> Unit:
    let wrapped = AppEvent.Monitor :: monitor_event :: call
    events.push :: wrapped :: method

fn push_joystick(edit events: List[AppEvent], joystick_event: JoystickEvent) -> Unit:
    let wrapped = AppEvent.Joystick :: joystick_event :: call
    events.push :: wrapped :: method

fn push_user(edit events: List[AppEvent], user_event: UserEvent) -> Unit:
    let wrapped = AppEvent.User :: user_event :: call
    events.push :: wrapped :: method

fn build_raw_mouse_motion_window_event(id: WindowId, delta_x: CInt, delta_y: CInt) -> WindowEvent:
    return WindowEvent.RawMouseMotion :: :: call
        id = id
        delta_x = delta_x
        delta_y = delta_y

fn build_raw_mouse_button_changed_window_event(id: WindowId, raw_button: CInt, raw_action: CInt) -> WindowEvent:
    return WindowEvent.RawMouseButtonChanged :: :: call
        id = id
        button = mouse_button_from_raw :: raw_button :: call
        action = input_action_from_raw :: raw_action :: call

fn build_raw_mouse_wheel_window_event(id: WindowId, delta_x: CInt, delta_y: CInt) -> WindowEvent:
    return WindowEvent.RawMouseWheel :: :: call
        id = id
        delta_x = delta_x
        delta_y = delta_y

fn build_raw_key_changed_window_event(id: WindowId, raw_key: RawKeyCode, scancode: ScanCode, raw_action: CInt, extended: Bool) -> WindowEvent:
    return WindowEvent.RawKeyChanged :: :: call
        id = id
        raw_key = raw_key
        scancode = scancode
        action = input_action_from_raw :: raw_action :: call
        extended = extended

fn copy_window_raw_mouse_motion_data(read event: WindowEvent) -> Option[WindowRawMouseMotionData]:
    select event:
        when WindowEvent.RawMouseMotion(id = _, delta_x = delta_x, delta_y = delta_y) =>
            let data = WindowRawMouseMotionData :: :: call
                delta_x = delta_x
                delta_y = delta_y
            return Option.Some :: data :: call
        when _ => return Option.None

fn copy_window_raw_mouse_wheel_data(read event: WindowEvent) -> Option[WindowRawMouseWheelData]:
    select event:
        when WindowEvent.RawMouseWheel(id = _, delta_x = delta_x, delta_y = delta_y) =>
            let data = WindowRawMouseWheelData :: :: call
                delta_x = delta_x
                delta_y = delta_y
            return Option.Some :: data :: call
        when _ => return Option.None

impl AppEventBatch:
    fn raw_key_changed_events(edit self) -> List[WindowEvent]:
        let events = self.take_raw_key_changed_events :: :: method
        let matched = List[WindowEvent] :: :: call
        repeat while !events.is_empty :: :: method:
            let event = events.remove :: 0 :: method
            select event:
                when WindowEvent.RawKeyChanged(id = id, raw_key = raw_key, scancode = scancode, action = action, extended = extended) =>
                    let raw_action = input_action_raw :: action :: call
                    let copied = build_raw_key_changed_window_event :: id, raw_key, scancode, raw_action, extended :: call
                    let restored = build_raw_key_changed_window_event :: id, raw_key, scancode, raw_action, extended :: call
                    matched.push :: copied :: method
                    push_window :: self.events, restored :: call
                when _ => ()
        return matched

    fn raw_key_changed_events_for(edit self, id: WindowId) -> List[WindowEvent]:
        let events = self.take_raw_key_changed_events_for :: id :: method
        let matched = List[WindowEvent] :: :: call
        repeat while !events.is_empty :: :: method:
            let event = events.remove :: 0 :: method
            select event:
                when WindowEvent.RawKeyChanged(id = event_id, raw_key = raw_key, scancode = scancode, action = action, extended = extended) =>
                    let raw_action = input_action_raw :: action :: call
                    let copied = build_raw_key_changed_window_event :: event_id, raw_key, scancode, raw_action, extended :: call
                    let restored = build_raw_key_changed_window_event :: event_id, raw_key, scancode, raw_action, extended :: call
                    matched.push :: copied :: method
                    push_window :: self.events, restored :: call
                when _ => ()
        return matched

