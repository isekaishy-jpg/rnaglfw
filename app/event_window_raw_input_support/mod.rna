                        when WindowEvent.RawMouseButtonChanged(id = event_id, button = button, action = action) =>
                            let raw_button = mouse_button_raw :: button :: call
                            let raw_action = input_action_raw :: action :: call
                            let data = WindowRawMouseButtonData :: :: call
                                button = mouse_button_from_raw :: raw_button :: call
                                action = input_action_from_raw :: raw_action :: call
                            matched.push :: data :: method
                            let restored = build_raw_mouse_button_changed_window_event :: event_id, raw_button, raw_action :: call
