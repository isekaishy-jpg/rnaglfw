                        when _ => push_window :: remaining, window_event :: call
                when AppEvent.Monitor(monitor_event) => push_monitor :: remaining, monitor_event :: call
                when AppEvent.Joystick(joystick_event) => push_joystick :: remaining, joystick_event :: call
