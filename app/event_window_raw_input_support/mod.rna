                        when _ => push_window :: remaining, window_event :: call
                when AppEvent.Monitor(monitor_event) => push_monitor :: remaining, monitor_event :: call
                when AppEvent.Joystick(joystick_event) => push_joystick :: remaining, joystick_event :: call
                when AppEvent.User(user_event) => push_user :: remaining, user_event :: call
        self.events = remaining
        return events

    fn take_raw_mouse_motion_data(edit self) -> List[WindowRawMouseMotionData]:
        let events = self.take_raw_mouse_motion_events :: :: method
        let data = List[WindowRawMouseMotionData] :: :: call
        repeat while !events.is_empty :: :: method:
            let event = events.remove :: 0 :: method
            select event.raw_mouse_motion_data :: :: method:
                when Option.Some(value) => data.push :: value :: method
                when Option.None => ()
        return data

