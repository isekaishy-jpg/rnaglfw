                        when WindowEvent.RawKeyChanged(id = event_id, raw_key = raw_key, scancode = scancode, action = action, extended = extended) =>
                            let raw_action = input_action_raw :: action :: call
                            let data = WindowRawKeyData :: :: call
                                raw_key = raw_key
                                scancode = scancode
