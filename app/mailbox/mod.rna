    push_slot :: mailbox, slot :: call
    return

#export[name = "runa_app_window_drop_callback"]
extern["c"] fn drop_callback(window: *edit GlfwWindowRaw, count: CInt, paths: *read *read CChar) -> CVoid:
    let mailbox = mailbox_from_window :: window :: call
    select:
        when mailbox.is_null :: :: method => return
        else => ()
    let payload = copy_drop_payload :: count, paths :: call
    select:
        when payload.is_null :: :: method => return
        else => ()
    let slot = make_empty_slot :: :: call
    slot.kind = 17
    slot.a = count
    slot.p = payload
    push_slot :: mailbox, slot :: call
    return

pub(package) fn allocate_window_mailbox() -> Option[*edit WindowMailbox]:
    let heap: *edit CVoid = #unsafe GetProcessHeap :: :: call
    select:
        when heap.is_null :: :: method => return Option.None
        else =>
            let memory: *edit CVoid = #unsafe HeapAlloc :: heap, 0x00000008, 7184 :: call
            select:
                when memory.is_null :: :: method => return Option.None
                else =>
                    let mailbox = void_as_mailbox :: memory :: call
                    return Option.Some :: mailbox :: call

pub(package) fn free_window_mailbox(mailbox: *edit WindowMailbox) -> Unit:
    select:
        when mailbox.is_null :: :: method => return
        else =>
            let heap: *edit CVoid = #unsafe GetProcessHeap :: :: call
            select:
                when heap.is_null :: :: method => return
                else =>
                    let stored: WindowMailbox = #unsafe mailbox.load :: :: method
                    let slot_scan: CInt = 0
                    repeat while slot_scan < 128:
                        let Result.Ok(slot_index) = slot_scan as Maybe[Index] else => break
                        let kind: CInt = stored.kinds[slot_index]
                        let count: CInt = stored.as_[slot_index]
                        let payload: *edit CVoid = stored.ps[slot_index]
                        select:
                            when kind == 17 => free_drop_payload_heap :: heap, count, payload :: call
                            else => ()
                        slot_scan = slot_scan + 1
                    let memory = mailbox_as_void :: mailbox :: call
                    #unsafe HeapFree :: heap, 0, memory :: call
                    return

pub(package) fn attach_callbacks(read window: GlfwWindow, mailbox: *edit WindowMailbox) -> Unit:
    let user = mailbox_as_void :: mailbox :: call
    window.set_user_pointer :: user :: method
    let refresh_callback: Option[GlfwWindowRefreshCallback] = Option.Some :: window_refresh_callback :: call
    let pos_callback: Option[GlfwWindowPosCallback] = Option.Some :: window_pos_callback :: call
    let size_callback: Option[GlfwWindowSizeCallback] = Option.Some :: window_size_callback :: call
    let framebuffer_callback: Option[GlfwFramebufferSizeCallback] = Option.Some :: framebuffer_size_callback :: call
    let content_scale_changed: Option[GlfwWindowContentScaleCallback] = Option.Some :: content_scale_callback :: call
    let focus_changed: Option[GlfwWindowFocusCallback] = Option.Some :: focus_callback :: call
    let iconify_changed: Option[GlfwWindowIconifyCallback] = Option.Some :: iconify_callback :: call
    let maximize_changed: Option[GlfwWindowMaximizeCallback] = Option.Some :: maximize_callback :: call
    let cursor_entered: Option[GlfwCursorEnterCallback] = Option.Some :: cursor_enter_callback :: call
    let key_changed: Option[GlfwKeyCallback] = Option.Some :: key_callback :: call
    let character: Option[GlfwCharCallback] = Option.Some :: char_callback :: call
    let character_mods: Option[GlfwCharModsCallback] = Option.Some :: char_mods_callback :: call
    let mouse_button_changed: Option[GlfwMouseButtonCallback] = Option.Some :: mouse_button_callback :: call
    let cursor_moved: Option[GlfwCursorPosCallback] = Option.Some :: cursor_pos_callback :: call
    let scrolled: Option[GlfwScrollCallback] = Option.Some :: scroll_callback :: call
    let dropped: Option[GlfwDropCallback] = Option.Some :: drop_callback :: call
    window.set_refresh_callback :: refresh_callback :: method
    window.set_pos_callback :: pos_callback :: method
    window.set_size_callback :: size_callback :: method
    window.set_framebuffer_size_callback :: framebuffer_callback :: method
    window.set_content_scale_callback :: content_scale_changed :: method
    window.set_focus_callback :: focus_changed :: method
    window.set_iconify_callback :: iconify_changed :: method
    window.set_maximize_callback :: maximize_changed :: method
    window.set_cursor_enter_callback :: cursor_entered :: method
    window.set_key_callback :: key_changed :: method
    window.set_char_callback :: character :: method
    window.set_char_mods_callback :: character_mods :: method
    window.set_mouse_button_callback :: mouse_button_changed :: method
    window.set_cursor_pos_callback :: cursor_moved :: method
    window.set_scroll_callback :: scrolled :: method
    window.set_drop_callback :: dropped :: method
    return

pub(package) fn clear_user_pointer(read window: GlfwWindow) -> Unit:
    let user: *edit CVoid = null
    window.set_user_pointer :: user :: method
    return

pub(package) fn mailbox_overflowed(mailbox_ptr: *edit WindowMailbox) -> Bool:
    select:
        when mailbox_ptr.is_null :: :: method => return false
        else =>
            let mailbox: WindowMailbox = #unsafe mailbox_ptr.load :: :: method
            return cint_is_true :: mailbox.overflowed :: call

pub(package) fn drain_window_mailbox(id: WindowId, mailbox_ptr: *edit WindowMailbox, edit pending: List[AppEvent]) -> Unit:
    select:
        when mailbox_ptr.is_null :: :: method => return
        else =>
            let mailbox: WindowMailbox = #unsafe mailbox_ptr.load :: :: method
            repeat while mailbox.read_index != mailbox.write_index:
                let Result.Ok(slot_index) = cuint_to_index :: mailbox.read_index :: call else => return
                let kind: CInt = mailbox.kinds[slot_index]
                let a: CInt = mailbox.as_[slot_index]
                let b: CInt = mailbox.bs[slot_index]
                let c: CInt = mailbox.cs[slot_index]
                let d: CInt = mailbox.ds[slot_index]
                let u: CUInt = mailbox.us[slot_index]
                let fx: F32 = mailbox.fxs[slot_index]
                let fy: F32 = mailbox.fys[slot_index]
                let x: F64 = mailbox.xs[slot_index]
                let y: F64 = mailbox.ys[slot_index]
                let p: *edit CVoid = mailbox.ps[slot_index]
                select:
                    when kind == 1 =>
                        let event = WindowEvent.CloseRequested :: :: call
                            id = id
                        let wrapped = AppEvent.Window :: event :: call
                        pending.push :: wrapped :: method
                    when kind == 2 =>
                        let event = WindowEvent.Refreshed :: :: call
                            id = id
                        let wrapped = AppEvent.Window :: event :: call
                        pending.push :: wrapped :: method
                    when kind == 3 =>
                        let event = WindowEvent.Moved :: :: call
                            id = id
                            x = a
                            y = b
                        let wrapped = AppEvent.Window :: event :: call
                        pending.push :: wrapped :: method
                    when kind == 4 =>
                        let event = WindowEvent.Resized :: :: call
                            id = id
                            width = a
                            height = b
                        let wrapped = AppEvent.Window :: event :: call
                        pending.push :: wrapped :: method
                    when kind == 5 =>
                        let event = WindowEvent.FramebufferResized :: :: call
                            id = id
                            width = a
                            height = b
                        let wrapped = AppEvent.Window :: event :: call
                        pending.push :: wrapped :: method
                    when kind == 6 =>
                        let event = WindowEvent.ContentScaleChanged :: :: call
                            id = id
                            x = fx
                            y = fy
                        let wrapped = AppEvent.Window :: event :: call
                        pending.push :: wrapped :: method
                    when kind == 7 =>
                        let event = WindowEvent.FocusChanged :: :: call
                            id = id
                            focused = cint_is_true :: a :: call
                        let wrapped = AppEvent.Window :: event :: call
                        pending.push :: wrapped :: method
                    when kind == 8 =>
                        let event = WindowEvent.Iconified :: :: call
                            id = id
                            iconified = cint_is_true :: a :: call
                        let wrapped = AppEvent.Window :: event :: call
                        pending.push :: wrapped :: method
                    when kind == 9 =>
                        let event = WindowEvent.Maximized :: :: call
                            id = id
                            maximized = cint_is_true :: a :: call
                        let wrapped = AppEvent.Window :: event :: call
                        pending.push :: wrapped :: method
                    when kind == 10 =>
                        let event = WindowEvent.CursorEntered :: :: call
                            id = id
                            entered = cint_is_true :: a :: call
                        let wrapped = AppEvent.Window :: event :: call
                        pending.push :: wrapped :: method
                    when kind == 11 =>
                        let action = input_action_from_raw :: c :: call
                        let key = key_from_raw :: a :: call
                        let mods = modifiers_from_raw :: d :: call
                        let event = WindowEvent.KeyChanged :: :: call
                            id = id
                            key = key
                            scancode = b
                            action = action
                            mods = mods
                        let wrapped = AppEvent.Window :: event :: call
                        pending.push :: wrapped :: method
                    when kind == 12 =>
                        let event = WindowEvent.Character :: :: call
                            id = id
                            codepoint = u
                        let wrapped = AppEvent.Window :: event :: call
                        pending.push :: wrapped :: method
                    when kind == 13 =>
                        let mods = modifiers_from_raw :: a :: call
                        let event = WindowEvent.CharacterMods :: :: call
                            id = id
                            codepoint = u
                            mods = mods
                        let wrapped = AppEvent.Window :: event :: call
                        pending.push :: wrapped :: method
                    when kind == 14 =>
                        let button = mouse_button_from_raw :: a :: call
                        let action = input_action_from_raw :: b :: call
                        let mods = modifiers_from_raw :: c :: call
                        let event = WindowEvent.MouseButtonChanged :: :: call
                            id = id
                            button = button
                            action = action
                            mods = mods
                        let wrapped = AppEvent.Window :: event :: call
                        pending.push :: wrapped :: method
                    when kind == 15 =>
                        let event = WindowEvent.CursorMoved :: :: call
                            id = id
                            x = x
                            y = y
                        let wrapped = AppEvent.Window :: event :: call
                        pending.push :: wrapped :: method
                    when kind == 16 =>
                        let event = WindowEvent.Scrolled :: :: call
                            id = id
                            x = x
                            y = y
                        let wrapped = AppEvent.Window :: event :: call
                        pending.push :: wrapped :: method
                    when kind == 17 =>
                        let paths = take_dropped_paths :: a, p :: call
                        let event = WindowEvent.DroppedPaths :: :: call
                            id = id
                            paths = paths
                        let wrapped = AppEvent.Window :: event :: call
                        pending.push :: wrapped :: method
                    else => ()
                mailbox.kinds[slot_index] = 0
                mailbox.as_[slot_index] = 0
                mailbox.bs[slot_index] = 0
                mailbox.cs[slot_index] = 0
                mailbox.ds[slot_index] = 0
                mailbox.us[slot_index] = 0
                mailbox.fxs[slot_index] = 0.0
                mailbox.fys[slot_index] = 0.0
                mailbox.xs[slot_index] = 0.0
                mailbox.ys[slot_index] = 0.0
                mailbox.ps[slot_index] = null
                mailbox.read_index = next_slot :: mailbox.read_index :: call
            #unsafe mailbox_ptr.store :: mailbox :: method
            return
