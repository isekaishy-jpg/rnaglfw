pub const WINDOW_MAILBOX_CAPACITY: Index = 128
const POINTER_OFFSET_STEP: ISize = 1
type ReadDropPathPointer = *read CChar
type DropPathPointer = *edit CChar
type ReadUtf16UnitPointer = *read U16

struct SlotWrite:
    pub kind: CInt
    pub a: CInt
    pub b: CInt
    pub c: CInt
    pub d: CInt
    pub u: CUInt
    pub fx: F32
    pub fy: F32
    pub x: F64
    pub y: F64
    pub p: *edit CVoid

#repr[c]
pub(package) struct WindowMailbox:
    pub read_index: CUInt
    pub write_index: CUInt
    pub overflowed: CInt
    pub drag_drop_enabled: CInt
    pub theme_preference: CInt
    pub window_level_preference: CInt
    pub resize_increment_width: CInt
    pub resize_increment_height: CInt
    pub size_limit_min_width: CInt
    pub size_limit_min_height: CInt
    pub size_limit_max_width: CInt
    pub size_limit_max_height: CInt
    pub appearance_undecorated_shadow: CInt
    pub appearance_system_backdrop: CInt
    pub appearance_border_color: CUInt
    pub appearance_title_background_color: CUInt
    pub appearance_title_text_color: CUInt
    pub appearance_corner_preference: CInt
    pub taskbar_icon_handle: *edit CVoid
    pub kinds: [CInt; 128]
    pub as_: [CInt; 128]
    pub bs: [CInt; 128]
    pub cs: [CInt; 128]
    pub ds: [CInt; 128]
    pub us: [CUInt; 128]
    pub fxs: [F32; 128]
    pub fys: [F32; 128]
    pub xs: [F64; 128]
    pub ys: [F64; 128]
    pub ps: [*edit CVoid; 128]

#link[name = "kernel32"]
#unsafe
extern["system"] fn GetProcessHeap() -> *edit CVoid

#link[name = "kernel32"]
#unsafe
extern["system"] fn HeapAlloc(heap: *edit CVoid, flags: CUInt, bytes: CSize) -> *edit CVoid

#link[name = "kernel32"]
#unsafe
extern["system"] fn HeapFree(heap: *edit CVoid, flags: CUInt, memory: *edit CVoid) -> CInt

#link[name = "kernel32"]
#unsafe
extern["system"] fn WideCharToMultiByte(code_page: CUInt, flags: CUInt, source: *read U16, source_count: CInt, target: *edit CChar, target_count: CInt, default_char: *read CChar, used_default: *edit CInt) -> CInt

#link[name = "glfw3"]
#unsafe
extern["c"] fn glfwGetWindowUserPointer(window: *edit GlfwWindowRaw) -> *edit CVoid

fn next_slot(index: CUInt) -> CUInt:
    select:
        when index + 1 == 128 => return 0
        else => return index + 1

fn c_char_read_as_unsigned(pointer: *read CChar) -> *read CUnsignedChar:
    let address = #unsafe raw_pointer_address_read :: pointer :: call
    return #unsafe raw_pointer_from_address_read[CUnsignedChar] :: address :: call

fn c_char_edit_as_void(pointer: *edit CChar) -> *edit CVoid:
    let address = #unsafe raw_pointer_address_edit :: pointer :: call
    return #unsafe raw_pointer_from_address_edit[CVoid] :: address :: call

fn void_as_mailbox(pointer: *edit CVoid) -> *edit WindowMailbox:
    let address = #unsafe raw_pointer_address_edit :: pointer :: call
    return #unsafe raw_pointer_from_address_edit[WindowMailbox] :: address :: call

fn void_as_unsigned(pointer: *edit CVoid) -> *edit CUnsignedChar:
    let address = #unsafe raw_pointer_address_edit :: pointer :: call
    return #unsafe raw_pointer_from_address_edit[CUnsignedChar] :: address :: call

fn void_as_c_char(pointer: *edit CVoid) -> *edit CChar:
    let address = #unsafe raw_pointer_address_edit :: pointer :: call
    return #unsafe raw_pointer_from_address_edit[CChar] :: address :: call

fn void_as_drop_path_pointer(pointer: *edit CVoid) -> *edit DropPathPointer:
    let address = #unsafe raw_pointer_address_edit :: pointer :: call
    return #unsafe raw_pointer_from_address_edit[DropPathPointer] :: address :: call

fn void_as_utf16_read_pointer(pointer: *edit CVoid) -> *read U16:
    let address = #unsafe raw_pointer_address_edit :: pointer :: call
    return #unsafe raw_pointer_from_address_read[U16] :: address :: call

fn mailbox_as_void(pointer: *edit WindowMailbox) -> *edit CVoid:
    let address = #unsafe raw_pointer_address_edit :: pointer :: call
    return #unsafe raw_pointer_from_address_edit[CVoid] :: address :: call

fn mailbox_from_window(window: *edit GlfwWindowRaw) -> *edit WindowMailbox:
    let user: *edit CVoid = #unsafe glfwGetWindowUserPointer :: window :: call
    select:
        when user.is_null :: :: method =>
            let pointer: *edit WindowMailbox = null
            return pointer
        else => return void_as_mailbox :: user :: call

fn mailbox_window_size_limits(mailbox_ptr: *edit WindowMailbox) -> WindowSizeLimits:
    select:
        when mailbox_ptr.is_null :: :: method => return WindowSizeLimits :: :: call
            min_width = 0 - 1
            min_height = 0 - 1
            max_width = 0 - 1
            max_height = 0 - 1
        else =>
            let mailbox: WindowMailbox = #unsafe mailbox_ptr.load :: :: method
            return WindowSizeLimits :: :: call
                min_width = mailbox.size_limit_min_width
                min_height = mailbox.size_limit_min_height
                max_width = mailbox.size_limit_max_width
                max_height = mailbox.size_limit_max_height

fn set_mailbox_window_size_limits(mailbox_ptr: *edit WindowMailbox, read limits: WindowSizeLimits) -> Unit:
    select:
        when mailbox_ptr.is_null :: :: method => return
        else =>
            let mailbox: WindowMailbox = #unsafe mailbox_ptr.load :: :: method
            mailbox.size_limit_min_width = limits.min_width
            mailbox.size_limit_min_height = limits.min_height
            mailbox.size_limit_max_width = limits.max_width
            mailbox.size_limit_max_height = limits.max_height
            #unsafe mailbox_ptr.store :: mailbox :: method
            return

fn mailbox_has_pending_refresh(mailbox_ptr: *edit WindowMailbox) -> Bool:
    select:
        when mailbox_ptr.is_null :: :: method => return false
        else => ()
    let mailbox: WindowMailbox = #unsafe mailbox_ptr.load :: :: method
    let scan: CUInt = mailbox.read_index
    repeat while scan != mailbox.write_index:
        let Result.Ok(slot_index) = cuint_to_index :: scan :: call else => return false
        select:
            when mailbox.kinds[slot_index] == 2 => return true
            else => scan = next_slot :: scan :: call
    return false

fn input_path_slot_at(base: *read ReadDropPathPointer, index: CInt) -> *read ReadDropPathPointer:
    let slot: *read ReadDropPathPointer = base
    let scan: CInt = 0
    repeat while scan < index:
        slot = #unsafe slot.offset :: POINTER_OFFSET_STEP :: method
        scan = scan + 1
    return slot

fn copied_path_slot_at(base: *edit DropPathPointer, index: CInt) -> *edit DropPathPointer:
    let slot: *edit DropPathPointer = base
    let scan: CInt = 0
    repeat while scan < index:
        slot = #unsafe slot.offset :: POINTER_OFFSET_STEP :: method
        scan = scan + 1
    return slot

fn utf16_unit_slot_at(base: *read U16, index: CInt) -> *read U16:
    let slot: *read U16 = base
    let scan: CInt = 0
    repeat while scan < index:
        slot = #unsafe slot.offset :: POINTER_OFFSET_STEP :: method
        scan = scan + 1
    return slot

fn free_heap_string(heap: *edit CVoid, string: *edit CChar) -> Unit:
    select:
        when string.is_null :: :: method => return
        else =>
            let memory = c_char_edit_as_void :: string :: call
            #unsafe HeapFree :: heap, 0, memory :: call
            return

fn copy_heap_string(heap: *edit CVoid, source: *read CChar) -> *edit CChar:
    select:
        when source.is_null :: :: method =>
            let none: *edit CChar = null
            return none
        else => ()
    let read_ptr = c_char_read_as_unsigned :: source :: call
    let offset: ISize = 0
    let length: CSize = 0
    repeat:
        let current: *read CUnsignedChar = #unsafe read_ptr.offset :: offset :: method
        let raw: CUnsignedChar = #unsafe current.load :: :: method
        select:
            when raw == 0 => break
            else =>
                length = length + 1
                offset = offset + 1
    let bytes: CSize = length + 1
    let memory: *edit CVoid = #unsafe HeapAlloc :: heap, 0, bytes :: call
    select:
        when memory.is_null :: :: method =>
            let none: *edit CChar = null
            return none
        else => ()
    let write_ptr = void_as_unsigned :: memory :: call
    offset = 0
    repeat:
        let source_slot: *read CUnsignedChar = #unsafe read_ptr.offset :: offset :: method
        let raw: CUnsignedChar = #unsafe source_slot.load :: :: method
        let dest_slot: *edit CUnsignedChar = #unsafe write_ptr.offset :: offset :: method
        #unsafe dest_slot.store :: raw :: method
        select:
            when raw == 0 => break
            else => offset = offset + 1
    return void_as_c_char :: memory :: call

fn free_drop_payload_heap(heap: *edit CVoid, count: CInt, payload: *edit CVoid) -> Unit:
    select:
        when payload.is_null :: :: method => return
        else => ()
    let copied_paths = void_as_drop_path_pointer :: payload :: call
    let scan: CInt = 0
    repeat while scan < count:
        let slot: *edit DropPathPointer = copied_path_slot_at :: copied_paths, scan :: call
        let copied: DropPathPointer = #unsafe slot.load :: :: method
        free_heap_string :: heap, copied :: call
        let cleared: DropPathPointer = null
        #unsafe slot.store :: cleared :: method
        scan = scan + 1
    #unsafe HeapFree :: heap, 0, payload :: call
    return

fn free_drop_payload(count: CInt, payload: *edit CVoid) -> Unit:
    select:
        when payload.is_null :: :: method => return
        else => ()
    let heap: *edit CVoid = #unsafe GetProcessHeap :: :: call
    select:
        when heap.is_null :: :: method => return
        else => return free_drop_payload_heap :: heap, count, payload :: call

fn free_hovered_file_payload_heap(heap: *edit CVoid, payload: *edit CVoid) -> Unit:
    select:
        when payload.is_null :: :: method => return
        else => ()
    let copied = void_as_c_char :: payload :: call
    free_heap_string :: heap, copied :: call
    return

fn free_hovered_file_payload(payload: *edit CVoid) -> Unit:
    select:
        when payload.is_null :: :: method => return
        else => ()
    let heap: *edit CVoid = #unsafe GetProcessHeap :: :: call
    select:
        when heap.is_null :: :: method => return
        else => return free_hovered_file_payload_heap :: heap, payload :: call

fn copy_drop_payload(count: CInt, paths: *read *read CChar) -> *edit CVoid:
    select:
        when count <= 0 =>
            let none: *edit CVoid = null
            return none
        when paths.is_null :: :: method =>
            let none: *edit CVoid = null
            return none
        else => ()
    let heap: *edit CVoid = #unsafe GetProcessHeap :: :: call
    select:
        when heap.is_null :: :: method =>
            let none: *edit CVoid = null
            return none
        else => ()
    let Result.Ok(pointer_count) = count as Maybe[CSize] else =>
        let none: *edit CVoid = null
        return none
    let payload_bytes: CSize = pointer_count * 8
    let payload: *edit CVoid = #unsafe HeapAlloc :: heap, 0x00000008, payload_bytes :: call
    select:
        when payload.is_null :: :: method =>
            let none: *edit CVoid = null
            return none
        else => ()
    let copied_paths = void_as_drop_path_pointer :: payload :: call
    let scan: CInt = 0
    repeat while scan < count:
        let source_slot: *read ReadDropPathPointer = input_path_slot_at :: paths, scan :: call
        let source_path: ReadDropPathPointer = #unsafe source_slot.load :: :: method
        let copied: *edit CChar = copy_heap_string :: heap, source_path :: call
        select:
            when copied.is_null :: :: method =>
                free_drop_payload_heap :: heap, scan, payload :: call
                let none: *edit CVoid = null
                return none
            else => ()
        let copied_slot: *edit DropPathPointer = copied_path_slot_at :: copied_paths, scan :: call
        #unsafe copied_slot.store :: copied :: method
        scan = scan + 1
    return payload

fn take_dropped_paths(count: CInt, payload: *edit CVoid) -> List[Str]:
    let paths = List[Str] :: :: call
    select:
        when payload.is_null :: :: method => return paths
        else => ()
    let copied_paths = void_as_drop_path_pointer :: payload :: call
    let scan: CInt = 0
    repeat while scan < count:
        let slot: *edit DropPathPointer = copied_path_slot_at :: copied_paths, scan :: call
        let copied: DropPathPointer = #unsafe slot.load :: :: method
        select copy_edit_c_string :: copied :: call:
            when Result.Ok(path) => paths.push :: path :: method
            when Result.Err(_) => ()
        scan = scan + 1
    free_drop_payload :: count, payload :: call
    return paths

fn free_utf16_payload_heap(heap: *edit CVoid, payload: *edit CVoid) -> Unit:
    select:
        when payload.is_null :: :: method => return
        else =>
            let _ = #unsafe HeapFree :: heap, 0, payload :: call
            return

fn free_utf16_payload(payload: *edit CVoid) -> Unit:
    select:
        when payload.is_null :: :: method => return
        else => ()
    let heap: *edit CVoid = #unsafe GetProcessHeap :: :: call
    select:
        when heap.is_null :: :: method => return
        else => return free_utf16_payload_heap :: heap, payload :: call

fn copy_utf16_payload(count: CInt, units: *read U16) -> *edit CVoid:
    select:
        when count <= 0 =>
            let none: *edit CVoid = null
            return none
        when units.is_null :: :: method =>
            let none: *edit CVoid = null
            return none
        else => ()
    let heap: *edit CVoid = #unsafe GetProcessHeap :: :: call
    select:
        when heap.is_null :: :: method =>
            let none: *edit CVoid = null
            return none
        else => ()
    let Result.Ok(unit_count) = count as Maybe[CSize] else =>
        let none: *edit CVoid = null
        return none
    let payload_bytes: CSize = unit_count * 2
    let payload: *edit CVoid = #unsafe HeapAlloc :: heap, 0x00000008, payload_bytes :: call
    select:
        when payload.is_null :: :: method =>
            let none: *edit CVoid = null
            return none
        else => ()
    let copied_units = void_as_utf16_read_pointer :: payload :: call
    let scan: CInt = 0
    repeat while scan < count:
        let source_slot = utf16_unit_slot_at :: units, scan :: call
        let unit = #unsafe source_slot.load :: :: method
        let dest_slot = utf16_unit_slot_at :: copied_units, scan :: call
        let dest_address = #unsafe raw_pointer_address_read :: dest_slot :: call
        let dest_write = #unsafe raw_pointer_from_address_edit[U16] :: dest_address :: call
        #unsafe dest_write.store :: unit :: method
        scan = scan + 1
    return payload

fn take_utf16_text(count: CInt, payload: *edit CVoid) -> Option[Str]:
    select:
        when count <= 0 =>
            free_utf16_payload :: payload :: call
            return Option.Some :: "" :: call
        when payload.is_null :: :: method => return Option.None
        else => ()
    let units = void_as_utf16_read_pointer :: payload :: call
    let byte_count = #unsafe WideCharToMultiByte :: 65001, 0, units, count, null, 0, null, null :: call
    select:
        when byte_count <= 0 =>
            free_utf16_payload :: payload :: call
            return Option.None
        else => ()
    let heap: *edit CVoid = #unsafe GetProcessHeap :: :: call
    select:
        when heap.is_null :: :: method =>
            free_utf16_payload :: payload :: call
            return Option.None
        else => ()
    let Result.Ok(payload_bytes) = byte_count as Maybe[CSize] else =>
        free_utf16_payload :: payload :: call
        return Option.None
    let utf8_payload: *edit CVoid = #unsafe HeapAlloc :: heap, 0x00000008, payload_bytes :: call
    select:
        when utf8_payload.is_null :: :: method =>
            free_utf16_payload :: payload :: call
            return Option.None
        else => ()
    let utf8_chars = void_as_c_char :: utf8_payload :: call
    let written = #unsafe WideCharToMultiByte :: 65001, 0, units, count, utf8_chars, byte_count, null, null :: call
    select:
        when written <= 0 =>
            let _ = #unsafe HeapFree :: heap, 0, utf8_payload :: call
            free_utf16_payload :: payload :: call
            return Option.None
        else => ()
    let bytes = ByteBuffer :: :: call
    let utf8_units = void_as_unsigned :: utf8_payload :: call
    let Result.Ok(scan_limit) = written as Maybe[USize] else =>
        let _ = #unsafe HeapFree :: heap, 0, utf8_payload :: call
        free_utf16_payload :: payload :: call
        return Option.None
    let scan: USize = 0USize
    repeat while scan < scan_limit:
        let Result.Ok(offset) = scan as Maybe[ISize] else =>
            let _ = #unsafe HeapFree :: heap, 0, utf8_payload :: call
            free_utf16_payload :: payload :: call
            return Option.None
        let slot = #unsafe utf8_units.offset :: offset :: method
        let raw = #unsafe slot.load :: :: method
        let Result.Ok(byte) = raw as Maybe[U8] else =>
            let _ = #unsafe HeapFree :: heap, 0, utf8_payload :: call
            free_utf16_payload :: payload :: call
            return Option.None
        bytes.push :: byte :: method
        scan = scan + 1USize
    let _ = #unsafe HeapFree :: heap, 0, utf8_payload :: call
    free_utf16_payload :: payload :: call
    let frozen = bytes.freeze :: :: method
    select decode_utf8 :: frozen :: call:
        when Result.Ok(text) => return Option.Some :: text :: call
        when Result.Err(_) => return Option.None

fn free_slot_payload(read slot: SlotWrite) -> Unit:
    select:
        when slot.kind == 17 => free_drop_payload :: slot.a, slot.p :: call
        when slot.kind == 20 => free_utf16_payload :: slot.p :: call
        when slot.kind == 21 => free_utf16_payload :: slot.p :: call
        when slot.kind == 28 => free_hovered_file_payload :: slot.p :: call
        else => return

pub(package) fn push_window_theme_changed(mailbox_ptr: *edit WindowMailbox, read theme: Theme) -> Unit:
    let slot = make_empty_slot :: :: call
    slot.kind = 18
    slot.a = theme_raw :: theme :: call
    push_slot :: mailbox_ptr, slot :: call
    return

pub(package) fn push_window_raw_mouse_motion(mailbox_ptr: *edit WindowMailbox, delta_x: CInt, delta_y: CInt) -> Unit:
    let slot = make_empty_slot :: :: call
    slot.kind = 23
    slot.a = delta_x
    slot.b = delta_y
    push_slot :: mailbox_ptr, slot :: call
    return

pub(package) fn push_window_raw_key_changed(mailbox_ptr: *edit WindowMailbox, raw_key: RawKeyCode, scancode: ScanCode, read action: InputAction, extended: Bool) -> Unit:
    let slot = make_empty_slot :: :: call
    slot.kind = 24
    slot.a = raw_key
    slot.b = scancode
    slot.c = input_action_raw :: action :: call
    select:
        when extended => slot.d = 1
        else => slot.d = 0
    push_slot :: mailbox_ptr, slot :: call
    return

pub(package) fn push_window_raw_mouse_button_changed(mailbox_ptr: *edit WindowMailbox, raw_button: CInt, read action: InputAction) -> Unit:
    let slot = make_empty_slot :: :: call
    slot.kind = 25
    slot.a = raw_button
    slot.b = input_action_raw :: action :: call
    push_slot :: mailbox_ptr, slot :: call
    return

pub(package) fn push_window_raw_mouse_wheel(mailbox_ptr: *edit WindowMailbox, delta_x: CInt, delta_y: CInt) -> Unit:
    let slot = make_empty_slot :: :: call
    slot.kind = 26
    slot.a = delta_x
    slot.b = delta_y
    push_slot :: mailbox_ptr, slot :: call
    return

pub(package) fn push_window_touch(mailbox_ptr: *edit WindowMailbox, touch_id: CUInt, read phase: TouchPhase, x: F64, y: F64) -> Unit:
    let slot = make_empty_slot :: :: call
    slot.kind = 27
    slot.u = touch_id
    slot.a = touch_phase_raw :: phase :: call
    slot.x = x
    slot.y = y
    push_slot :: mailbox_ptr, slot :: call
    return

pub(package) fn push_window_dropped_paths_owned(mailbox_ptr: *edit WindowMailbox, count: CInt, payload: *edit CVoid) -> Unit:
    select:
        when payload.is_null :: :: method => return
        else => ()
    let slot = make_empty_slot :: :: call
    slot.kind = 17
    slot.a = count
    slot.p = payload
    push_slot :: mailbox_ptr, slot :: call
    return

pub(package) fn push_window_hovered_file_owned(mailbox_ptr: *edit WindowMailbox, payload: *edit CVoid) -> Unit:
    select:
        when payload.is_null :: :: method => return
        else => ()
    let slot = make_empty_slot :: :: call
    slot.kind = 28
    slot.p = payload
    push_slot :: mailbox_ptr, slot :: call
    return

pub(package) fn push_window_hovered_file_copy(mailbox_ptr: *edit WindowMailbox, path: *read CChar) -> Bool:
    let heap: *edit CVoid = #unsafe GetProcessHeap :: :: call
    select:
        when heap.is_null :: :: method => return false
        else => ()
    let copied = copy_heap_string :: heap, path :: call
    select:
        when copied.is_null :: :: method => return false
        else =>
            let payload = c_char_edit_as_void :: copied :: call
            push_window_hovered_file_owned :: mailbox_ptr, payload :: call
            return true

pub(package) fn push_window_hovered_file_cancelled(mailbox_ptr: *edit WindowMailbox) -> Unit:
    let slot = make_empty_slot :: :: call
    slot.kind = 29
    push_slot :: mailbox_ptr, slot :: call
    return

fn copied_modifiers(read mods: Modifiers) -> Modifiers:
    let raw = modifiers_raw :: mods :: call
    return modifiers_from_raw :: raw :: call

fn push_modifiers_changed_if_needed(id: WindowId, edit modifier_bits: CInt, read mods: Modifiers, edit pending: List[AppEvent]) -> Unit:
    let raw = modifiers_raw :: mods :: call
    select:
        when raw == modifier_bits => return
        else => ()
    modifier_bits = raw
    let event = WindowEvent.ModifiersChanged :: :: call
        id = id
        mods = copied_modifiers :: mods :: call
    let wrapped = AppEvent.Window :: event :: call
    pending.push :: wrapped :: method
    return

fn clear_modifiers_if_needed(id: WindowId, edit modifier_bits: CInt, edit pending: List[AppEvent]) -> Unit:
    select:
        when modifier_bits == 0 => return
        else => ()
    modifier_bits = 0
    let cleared = modifiers_from_raw :: 0 :: call
    let event = WindowEvent.ModifiersChanged :: :: call
        id = id
        mods = cleared
    let wrapped = AppEvent.Window :: event :: call
    pending.push :: wrapped :: method
    return

pub(package) fn push_window_composition_started(mailbox_ptr: *edit WindowMailbox) -> Unit:
    let slot = make_empty_slot :: :: call
    slot.kind = 19
    push_slot :: mailbox_ptr, slot :: call
    return

pub(package) fn push_window_composition_updated_utf16(mailbox_ptr: *edit WindowMailbox, count: CInt, cursor: CInt, units: *read U16) -> Unit:
    let slot = make_empty_slot :: :: call
    slot.kind = 20
    slot.a = count
    slot.b = cursor
    slot.p = copy_utf16_payload :: count, units :: call
    push_slot :: mailbox_ptr, slot :: call
    return

pub(package) fn push_window_composition_committed_utf16(mailbox_ptr: *edit WindowMailbox, count: CInt, units: *read U16) -> Unit:
    let slot = make_empty_slot :: :: call
    slot.kind = 21
    slot.a = count
    slot.p = copy_utf16_payload :: count, units :: call
    push_slot :: mailbox_ptr, slot :: call
    return

pub(package) fn push_window_composition_ended(mailbox_ptr: *edit WindowMailbox) -> Unit:
    let slot = make_empty_slot :: :: call
    slot.kind = 22
    push_slot :: mailbox_ptr, slot :: call
    return

fn push_slot(mailbox_ptr: *edit WindowMailbox, read slot: SlotWrite) -> Unit:
    select:
        when mailbox_ptr.is_null :: :: method =>
            free_slot_payload :: slot :: call
            return
        else =>
            let mailbox: WindowMailbox = #unsafe mailbox_ptr.load :: :: method
            let next: CUInt = next_slot :: mailbox.write_index :: call
            select:
                when next == mailbox.read_index =>
                    mailbox.overflowed = 1
                    #unsafe mailbox_ptr.store :: mailbox :: method
                    free_slot_payload :: slot :: call
                    return
                else =>
                    let Result.Ok(slot_index) = cuint_to_index :: mailbox.write_index :: call else =>
                        mailbox.overflowed = 1
                        #unsafe mailbox_ptr.store :: mailbox :: method
                        free_slot_payload :: slot :: call
                        return
                    mailbox.kinds[slot_index] = slot.kind
                    mailbox.as_[slot_index] = slot.a
                    mailbox.bs[slot_index] = slot.b
                    mailbox.cs[slot_index] = slot.c
                    mailbox.ds[slot_index] = slot.d
                    mailbox.us[slot_index] = slot.u
                    mailbox.fxs[slot_index] = slot.fx
                    mailbox.fys[slot_index] = slot.fy
                    mailbox.xs[slot_index] = slot.x
                    mailbox.ys[slot_index] = slot.y
                    mailbox.ps[slot_index] = slot.p
                    mailbox.write_index = next
                    #unsafe mailbox_ptr.store :: mailbox :: method
                    return

fn make_empty_slot() -> SlotWrite:
    return SlotWrite :: :: call
        kind = 0
        a = 0
        b = 0
        c = 0
        d = 0
        u = 0
        fx = 0.0
        fy = 0.0
        x = 0.0
        y = 0.0
        p = null

