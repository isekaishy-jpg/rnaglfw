use std.{List, Option, Result, Str}
use bridge.{cint_is_true, copy_edit_c_string, cuint_to_index}
use event.{AppEvent, WindowEvent}
use glfw.{GlfwCharCallback, GlfwCharModsCallback, GlfwCursorEnterCallback}
use glfw.{GlfwCursorPosCallback, GlfwFramebufferSizeCallback, GlfwKeyCallback}
use glfw.{GlfwDropCallback, GlfwMouseButtonCallback, GlfwScrollCallback}
use glfw.GlfwWindowContentScaleCallback
use glfw.{GlfwWindow, GlfwWindowRaw}
use glfw.{GlfwWindowFocusCallback, GlfwWindowIconifyCallback, GlfwWindowMaximizeCallback}
use glfw.{GlfwWindowPosCallback, GlfwWindowRefreshCallback, GlfwWindowSizeCallback}
use input.{input_action_from_raw, key_from_raw, modifiers_from_raw}
use input.mouse_button_from_raw
use window.WindowId

pub const WINDOW_MAILBOX_CAPACITY: Index = 128
const POINTER_OFFSET_STEP: ISize = 1
type ReadDropPathPointer = *read CChar
type DropPathPointer = *edit CChar

struct SlotWrite:
    pub kind: CInt
    pub a: CInt
    pub b: CInt
    pub c: CInt
    pub d: CInt
    pub u: CUInt
    pub fx: F32
    pub fy: F32
    pub x: F64
    pub y: F64
    pub p: *edit CVoid

#repr[c]
pub(package) struct WindowMailbox:
    pub read_index: CUInt
    pub write_index: CUInt
    pub overflowed: CInt
    pub kinds: [CInt; 128]
    pub as_: [CInt; 128]
    pub bs: [CInt; 128]
    pub cs: [CInt; 128]
    pub ds: [CInt; 128]
    pub us: [CUInt; 128]
    pub fxs: [F32; 128]
    pub fys: [F32; 128]
    pub xs: [F64; 128]
    pub ys: [F64; 128]
    pub ps: [*edit CVoid; 128]

#link[name = "kernel32"]
#unsafe
extern["system"] fn GetProcessHeap() -> *edit CVoid

#link[name = "kernel32"]
#unsafe
extern["system"] fn HeapAlloc(heap: *edit CVoid, flags: CUInt, bytes: CSize) -> *edit CVoid

#link[name = "kernel32"]
#unsafe
extern["system"] fn HeapFree(heap: *edit CVoid, flags: CUInt, memory: *edit CVoid) -> CInt

#link[name = "glfw3"]
#unsafe
extern["c"] fn glfwGetWindowUserPointer(window: *edit GlfwWindowRaw) -> *edit CVoid

fn next_slot(index: CUInt) -> CUInt:
    select:
        when index + 1 == 128 => return 0
        else => return index + 1

fn c_char_read_as_unsigned(pointer: *read CChar) -> *read CUnsignedChar:
    let address = #unsafe raw_pointer_address_read :: pointer :: call
    return #unsafe raw_pointer_from_address_read[CUnsignedChar] :: address :: call

fn c_char_edit_as_void(pointer: *edit CChar) -> *edit CVoid:
    let address = #unsafe raw_pointer_address_edit :: pointer :: call
    return #unsafe raw_pointer_from_address_edit[CVoid] :: address :: call

fn void_as_mailbox(pointer: *edit CVoid) -> *edit WindowMailbox:
    let address = #unsafe raw_pointer_address_edit :: pointer :: call
    return #unsafe raw_pointer_from_address_edit[WindowMailbox] :: address :: call

fn void_as_unsigned(pointer: *edit CVoid) -> *edit CUnsignedChar:
    let address = #unsafe raw_pointer_address_edit :: pointer :: call
    return #unsafe raw_pointer_from_address_edit[CUnsignedChar] :: address :: call

fn void_as_c_char(pointer: *edit CVoid) -> *edit CChar:
    let address = #unsafe raw_pointer_address_edit :: pointer :: call
    return #unsafe raw_pointer_from_address_edit[CChar] :: address :: call

fn void_as_drop_path_pointer(pointer: *edit CVoid) -> *edit DropPathPointer:
    let address = #unsafe raw_pointer_address_edit :: pointer :: call
    return #unsafe raw_pointer_from_address_edit[DropPathPointer] :: address :: call

fn mailbox_as_void(pointer: *edit WindowMailbox) -> *edit CVoid:
    let address = #unsafe raw_pointer_address_edit :: pointer :: call
    return #unsafe raw_pointer_from_address_edit[CVoid] :: address :: call

fn mailbox_from_window(window: *edit GlfwWindowRaw) -> *edit WindowMailbox:
    let user: *edit CVoid = #unsafe glfwGetWindowUserPointer :: window :: call
    select:
        when user.is_null :: :: method =>
            let pointer: *edit WindowMailbox = null
            return pointer
        else => return void_as_mailbox :: user :: call

fn input_path_slot_at(base: *read ReadDropPathPointer, index: CInt) -> *read ReadDropPathPointer:
    let slot: *read ReadDropPathPointer = base
    let scan: CInt = 0
    repeat while scan < index:
        slot = #unsafe slot.offset :: POINTER_OFFSET_STEP :: method
        scan = scan + 1
    return slot

fn copied_path_slot_at(base: *edit DropPathPointer, index: CInt) -> *edit DropPathPointer:
    let slot: *edit DropPathPointer = base
    let scan: CInt = 0
    repeat while scan < index:
        slot = #unsafe slot.offset :: POINTER_OFFSET_STEP :: method
        scan = scan + 1
    return slot

fn free_heap_string(heap: *edit CVoid, string: *edit CChar) -> Unit:
    select:
        when string.is_null :: :: method => return
        else =>
            let memory = c_char_edit_as_void :: string :: call
            #unsafe HeapFree :: heap, 0, memory :: call
            return

fn copy_heap_string(heap: *edit CVoid, source: *read CChar) -> *edit CChar:
    select:
        when source.is_null :: :: method =>
            let none: *edit CChar = null
            return none
        else => ()
    let read_ptr = c_char_read_as_unsigned :: source :: call
    let offset: ISize = 0
    let length: CSize = 0
    repeat:
        let current: *read CUnsignedChar = #unsafe read_ptr.offset :: offset :: method
        let raw: CUnsignedChar = #unsafe current.load :: :: method
        select:
            when raw == 0 => break
            else =>
                length = length + 1
                offset = offset + 1
    let bytes: CSize = length + 1
    let memory: *edit CVoid = #unsafe HeapAlloc :: heap, 0, bytes :: call
    select:
        when memory.is_null :: :: method =>
            let none: *edit CChar = null
            return none
        else => ()
    let write_ptr = void_as_unsigned :: memory :: call
    offset = 0
    repeat:
        let source_slot: *read CUnsignedChar = #unsafe read_ptr.offset :: offset :: method
        let raw: CUnsignedChar = #unsafe source_slot.load :: :: method
        let dest_slot: *edit CUnsignedChar = #unsafe write_ptr.offset :: offset :: method
        #unsafe dest_slot.store :: raw :: method
        select:
            when raw == 0 => break
            else => offset = offset + 1
    return void_as_c_char :: memory :: call

fn free_drop_payload_heap(heap: *edit CVoid, count: CInt, payload: *edit CVoid) -> Unit:
    select:
        when payload.is_null :: :: method => return
        else => ()
    let copied_paths = void_as_drop_path_pointer :: payload :: call
    let scan: CInt = 0
    repeat while scan < count:
        let slot: *edit DropPathPointer = copied_path_slot_at :: copied_paths, scan :: call
        let copied: DropPathPointer = #unsafe slot.load :: :: method
        free_heap_string :: heap, copied :: call
        let cleared: DropPathPointer = null
        #unsafe slot.store :: cleared :: method
        scan = scan + 1
    #unsafe HeapFree :: heap, 0, payload :: call
    return

fn free_drop_payload(count: CInt, payload: *edit CVoid) -> Unit:
    select:
        when payload.is_null :: :: method => return
        else => ()
    let heap: *edit CVoid = #unsafe GetProcessHeap :: :: call
    select:
        when heap.is_null :: :: method => return
        else => return free_drop_payload_heap :: heap, count, payload :: call

fn copy_drop_payload(count: CInt, paths: *read *read CChar) -> *edit CVoid:
    select:
        when count <= 0 =>
            let none: *edit CVoid = null
            return none
        when paths.is_null :: :: method =>
            let none: *edit CVoid = null
            return none
        else => ()
    let heap: *edit CVoid = #unsafe GetProcessHeap :: :: call
    select:
        when heap.is_null :: :: method =>
            let none: *edit CVoid = null
            return none
        else => ()
    let Result.Ok(pointer_count) = count as Maybe[CSize] else =>
        let none: *edit CVoid = null
        return none
    let payload_bytes: CSize = pointer_count * 8
    let payload: *edit CVoid = #unsafe HeapAlloc :: heap, 0x00000008, payload_bytes :: call
    select:
        when payload.is_null :: :: method =>
            let none: *edit CVoid = null
            return none
        else => ()
    let copied_paths = void_as_drop_path_pointer :: payload :: call
    let scan: CInt = 0
    repeat while scan < count:
        let source_slot: *read ReadDropPathPointer = input_path_slot_at :: paths, scan :: call
        let source_path: ReadDropPathPointer = #unsafe source_slot.load :: :: method
        let copied: *edit CChar = copy_heap_string :: heap, source_path :: call
        select:
            when copied.is_null :: :: method =>
                free_drop_payload_heap :: heap, scan, payload :: call
                let none: *edit CVoid = null
                return none
            else => ()
        let copied_slot: *edit DropPathPointer = copied_path_slot_at :: copied_paths, scan :: call
        #unsafe copied_slot.store :: copied :: method
        scan = scan + 1
    return payload

fn take_dropped_paths(count: CInt, payload: *edit CVoid) -> List[Str]:
    let paths = List[Str] :: :: call
    select:
        when payload.is_null :: :: method => return paths
        else => ()
    let copied_paths = void_as_drop_path_pointer :: payload :: call
    let scan: CInt = 0
    repeat while scan < count:
        let slot: *edit DropPathPointer = copied_path_slot_at :: copied_paths, scan :: call
        let copied: DropPathPointer = #unsafe slot.load :: :: method
        select copy_edit_c_string :: copied :: call:
            when Result.Ok(path) => paths.push :: path :: method
            when Result.Err(_) => ()
        scan = scan + 1
    free_drop_payload :: count, payload :: call
    return paths

fn free_slot_payload(read slot: SlotWrite) -> Unit:
    select:
        when slot.kind == 17 => free_drop_payload :: slot.a, slot.p :: call
        else => return

fn push_slot(mailbox_ptr: *edit WindowMailbox, read slot: SlotWrite) -> Unit:
    select:
        when mailbox_ptr.is_null :: :: method =>
            free_slot_payload :: slot :: call
            return
        else =>
            let mailbox: WindowMailbox = #unsafe mailbox_ptr.load :: :: method
            let next: CUInt = next_slot :: mailbox.write_index :: call
            select:
                when next == mailbox.read_index =>
                    mailbox.overflowed = 1
                    #unsafe mailbox_ptr.store :: mailbox :: method
                    free_slot_payload :: slot :: call
                    return
                else =>
                    let Result.Ok(slot_index) = cuint_to_index :: mailbox.write_index :: call else =>
                        mailbox.overflowed = 1
                        #unsafe mailbox_ptr.store :: mailbox :: method
                        free_slot_payload :: slot :: call
                        return
                    mailbox.kinds[slot_index] = slot.kind
                    mailbox.as_[slot_index] = slot.a
                    mailbox.bs[slot_index] = slot.b
                    mailbox.cs[slot_index] = slot.c
                    mailbox.ds[slot_index] = slot.d
                    mailbox.us[slot_index] = slot.u
                    mailbox.fxs[slot_index] = slot.fx
                    mailbox.fys[slot_index] = slot.fy
                    mailbox.xs[slot_index] = slot.x
                    mailbox.ys[slot_index] = slot.y
                    mailbox.ps[slot_index] = slot.p
                    mailbox.write_index = next
                    #unsafe mailbox_ptr.store :: mailbox :: method
                    return

fn make_empty_slot() -> SlotWrite:
    return SlotWrite :: :: call
        kind = 0
        a = 0
        b = 0
        c = 0
        d = 0
        u = 0
        fx = 0.0
        fy = 0.0
        x = 0.0
        y = 0.0
        p = null

#export[name = "runa_app_window_close_callback"]
extern["c"] fn window_close_callback(window: *edit GlfwWindowRaw) -> CVoid:
    let mailbox = mailbox_from_window :: window :: call
    let slot = make_empty_slot :: :: call
    slot.kind = 1
    push_slot :: mailbox, slot :: call
    return

