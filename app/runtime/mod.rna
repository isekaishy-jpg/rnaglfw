                        let snapshot = copy_window_snapshot :: self.windows[index] :: call
                        return Option.Some :: snapshot :: call
                    else => return Option.None
            when Option.None => return Option.None
    fn window(read self, id: WindowId) -> Option[WindowSnapshot]:
        select self.window_index :: id :: method:
            when Option.Some(index) =>
