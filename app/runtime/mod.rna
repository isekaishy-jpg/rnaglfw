pub enum ControlFlow:
    Poll
    Wait
    WaitTimeout:
        seconds: F64
    Exit
impl ControlFlow:
    fn exits(read self) -> Bool:
        select self:
            when ControlFlow.Exit => return true
            else => return false
    fn blocks(read self) -> Bool:
        select self:
            when ControlFlow.Poll => return false
            when ControlFlow.Exit => return false
            else => return true
pub trait AppHandler:
    fn started(edit self, edit app: App) -> Result[ControlFlow, AppError]:
        let _ = app
        return Result.Ok :: ControlFlow.Wait :: call
    fn about_to_wait(edit self, edit app: App) -> Result[ControlFlow, AppError]:
        let _ = app
        return Result.Ok :: ControlFlow.Wait :: call
    fn window_event(edit self, edit app: App, event: WindowEvent) -> Result[ControlFlow, AppError]:
        let _ = app
        let _ = event
        return Result.Ok :: ControlFlow.Wait :: call
    fn monitor_event(edit self, edit app: App, event: MonitorEvent) -> Result[ControlFlow, AppError]:
        let _ = app
        let _ = event
        return Result.Ok :: ControlFlow.Wait :: call
    fn joystick_event(edit self, edit app: App, event: JoystickEvent) -> Result[ControlFlow, AppError]:
        let _ = app
        let _ = event
        return Result.Ok :: ControlFlow.Wait :: call
    fn user_event(edit self, edit app: App, event: UserEvent) -> Result[ControlFlow, AppError]:
        let _ = app
        let _ = event
        return Result.Ok :: ControlFlow.Wait :: call
    fn idle(edit self, edit app: App) -> Result[ControlFlow, AppError]:
        let _ = app
        return Result.Ok :: ControlFlow.Wait :: call
    fn exiting(edit self, edit app: App) -> Unit:
        let _ = app
        return
pub enum AnglePlatformType:
    None
    OpenGl
    OpenGlEs
    D3D9
    D3D11
    Vulkan
    Metal
    Unknown(CInt)
pub enum WaylandLibdecorMode:
    Prefer
    Disable
    Unknown(CInt)
pub enum BoolOverride:
    Default
    Enabled
    Disabled
pub enum PlatformOverride:
    Default
    Selected(Platform)
pub enum AnglePlatformTypeOverride:
    Default
    Selected(AnglePlatformType)
pub enum WaylandLibdecorOverride:
    Default
    Selected(WaylandLibdecorMode)
pub struct AppInitConfig:
    pub joystick_hat_buttons: BoolOverride
    pub platform: PlatformOverride
    pub angle_platform_type: AnglePlatformTypeOverride
    pub cocoa_chdir_resources: BoolOverride
    pub cocoa_menubar: BoolOverride
    pub x11_xcb_vulkan_surface: BoolOverride
    pub wayland_libdecor: WaylandLibdecorOverride
pub fn angle_platform_type_from_raw(raw: CInt) -> AnglePlatformType:
    select:
        when raw == 0x00037001 => return AnglePlatformType.None
        when raw == 0x00037002 => return AnglePlatformType.OpenGl
        when raw == 0x00037003 => return AnglePlatformType.OpenGlEs
        when raw == 0x00037004 => return AnglePlatformType.D3D9
        when raw == 0x00037005 => return AnglePlatformType.D3D11
        when raw == 0x00037007 => return AnglePlatformType.Vulkan
        when raw == 0x00037008 => return AnglePlatformType.Metal
        else => return AnglePlatformType.Unknown :: raw :: call
pub fn angle_platform_type_raw(read platform_type: AnglePlatformType) -> CInt:
    select platform_type:
        when AnglePlatformType.None => return 0x00037001
        when AnglePlatformType.OpenGl => return 0x00037002
        when AnglePlatformType.OpenGlEs => return 0x00037003
        when AnglePlatformType.D3D9 => return 0x00037004
        when AnglePlatformType.D3D11 => return 0x00037005
        when AnglePlatformType.Vulkan => return 0x00037007
        when AnglePlatformType.Metal => return 0x00037008
        when AnglePlatformType.Unknown(raw) => return raw
    return 0x00037001
pub fn wayland_libdecor_mode_from_raw(raw: CInt) -> WaylandLibdecorMode:
    select:
        when raw == 0x00038001 => return WaylandLibdecorMode.Prefer
        when raw == 0x00038002 => return WaylandLibdecorMode.Disable
        else => return WaylandLibdecorMode.Unknown :: raw :: call
pub fn wayland_libdecor_mode_raw(read mode: WaylandLibdecorMode) -> CInt:
    select mode:
        when WaylandLibdecorMode.Prefer => return 0x00038001
        when WaylandLibdecorMode.Disable => return 0x00038002
        when WaylandLibdecorMode.Unknown(raw) => return raw
    return 0x00038001
pub fn app_init_config() -> AppInitConfig:
    let joystick_hat_buttons = BoolOverride.Default
    let platform = PlatformOverride.Default
    let angle_platform_type = AnglePlatformTypeOverride.Default
    let cocoa_chdir_resources = BoolOverride.Default
    let cocoa_menubar = BoolOverride.Default
    let x11_xcb_vulkan_surface = BoolOverride.Default
    let wayland_libdecor = WaylandLibdecorOverride.Default
    return AppInitConfig :: :: call
        joystick_hat_buttons = joystick_hat_buttons
        platform = platform
        angle_platform_type = angle_platform_type
        cocoa_chdir_resources = cocoa_chdir_resources
        cocoa_menubar = cocoa_menubar
        x11_xcb_vulkan_surface = x11_xcb_vulkan_surface
        wayland_libdecor = wayland_libdecor
pub fn app_init_config_with_joystick_hat_buttons(take config: AppInitConfig, enabled: Bool) -> AppInitConfig:
    config.set_joystick_hat_buttons :: enabled :: method
    return config
pub fn app_init_config_on_platform(take config: AppInitConfig, platform: Platform) -> AppInitConfig:
    config.set_platform :: platform :: method
    return config
pub fn app_init_config_with_angle_platform_type(take config: AppInitConfig, platform_type: AnglePlatformType) -> AppInitConfig:
    config.set_angle_platform_type :: platform_type :: method
    return config
pub fn app_init_config_with_cocoa_chdir_resources(take config: AppInitConfig, enabled: Bool) -> AppInitConfig:
    config.set_cocoa_chdir_resources :: enabled :: method
    return config
pub fn app_init_config_with_cocoa_menubar(take config: AppInitConfig, enabled: Bool) -> AppInitConfig:
    config.set_cocoa_menubar :: enabled :: method
    return config
pub fn app_init_config_with_x11_xcb_vulkan_surface(take config: AppInitConfig, enabled: Bool) -> AppInitConfig:
    config.set_x11_xcb_vulkan_surface :: enabled :: method
    return config
pub fn app_init_config_with_wayland_libdecor(take config: AppInitConfig, mode: WaylandLibdecorMode) -> AppInitConfig:
    config.set_wayland_libdecor :: mode :: method
    return config
pub fn win32_app_init_config() -> AppInitConfig:
    let config = app_init_config :: :: call
    return app_init_config_on_platform :: config, Platform.Win32 :: call
impl AppInitConfig:
    fn with_joystick_hat_buttons(take self, enabled: Bool) -> AppInitConfig:
        self.set_joystick_hat_buttons :: enabled :: method
        return self
    fn on_platform(take self, platform: Platform) -> AppInitConfig:
        self.set_platform :: platform :: method
        return self
    fn with_angle_platform_type(take self, platform_type: AnglePlatformType) -> AppInitConfig:
        self.set_angle_platform_type :: platform_type :: method
        return self
    fn with_cocoa_chdir_resources(take self, enabled: Bool) -> AppInitConfig:
        self.set_cocoa_chdir_resources :: enabled :: method
        return self
    fn with_cocoa_menubar(take self, enabled: Bool) -> AppInitConfig:
        self.set_cocoa_menubar :: enabled :: method
        return self
    fn with_x11_xcb_vulkan_surface(take self, enabled: Bool) -> AppInitConfig:
        self.set_x11_xcb_vulkan_surface :: enabled :: method
        return self
    fn with_wayland_libdecor(take self, mode: WaylandLibdecorMode) -> AppInitConfig:
        self.set_wayland_libdecor :: mode :: method
        return self
    fn without_joystick_hat_buttons_override(take self) -> AppInitConfig:
        self.clear_joystick_hat_buttons :: :: method
        return self
    fn without_platform_override(take self) -> AppInitConfig:
        self.clear_platform :: :: method
        return self
    fn without_angle_platform_type_override(take self) -> AppInitConfig:
        self.clear_angle_platform_type :: :: method
        return self
    fn without_cocoa_chdir_resources_override(take self) -> AppInitConfig:
        self.clear_cocoa_chdir_resources :: :: method
        return self
    fn without_cocoa_menubar_override(take self) -> AppInitConfig:
        self.clear_cocoa_menubar :: :: method
        return self
    fn without_x11_xcb_vulkan_surface_override(take self) -> AppInitConfig:
        self.clear_x11_xcb_vulkan_surface :: :: method
        return self
    fn without_wayland_libdecor_override(take self) -> AppInitConfig:
        self.clear_wayland_libdecor :: :: method
        return self
    fn set_joystick_hat_buttons(edit self, enabled: Bool) -> Unit:
        select:
            when enabled => self.joystick_hat_buttons = BoolOverride.Enabled
            else => self.joystick_hat_buttons = BoolOverride.Disabled
        return
    fn clear_joystick_hat_buttons(edit self) -> Unit:
        self.joystick_hat_buttons = BoolOverride.Default
        return
    fn set_platform(edit self, platform: Platform) -> Unit:
        self.platform = PlatformOverride.Selected :: platform :: call
        return
    fn clear_platform(edit self) -> Unit:
        self.platform = PlatformOverride.Default
        return
    fn set_angle_platform_type(edit self, platform_type: AnglePlatformType) -> Unit:
        self.angle_platform_type = AnglePlatformTypeOverride.Selected :: platform_type :: call
        return
    fn clear_angle_platform_type(edit self) -> Unit:
        self.angle_platform_type = AnglePlatformTypeOverride.Default
        return
    fn set_cocoa_chdir_resources(edit self, enabled: Bool) -> Unit:
        select:
            when enabled => self.cocoa_chdir_resources = BoolOverride.Enabled
            else => self.cocoa_chdir_resources = BoolOverride.Disabled
        return
    fn clear_cocoa_chdir_resources(edit self) -> Unit:
        self.cocoa_chdir_resources = BoolOverride.Default
        return
    fn set_cocoa_menubar(edit self, enabled: Bool) -> Unit:
        select:
            when enabled => self.cocoa_menubar = BoolOverride.Enabled
            else => self.cocoa_menubar = BoolOverride.Disabled
        return
    fn clear_cocoa_menubar(edit self) -> Unit:
        self.cocoa_menubar = BoolOverride.Default
        return
    fn set_x11_xcb_vulkan_surface(edit self, enabled: Bool) -> Unit:
        select:
            when enabled => self.x11_xcb_vulkan_surface = BoolOverride.Enabled
            else => self.x11_xcb_vulkan_surface = BoolOverride.Disabled
        return
    fn clear_x11_xcb_vulkan_surface(edit self) -> Unit:
        self.x11_xcb_vulkan_surface = BoolOverride.Default
        return
    fn set_wayland_libdecor(edit self, mode: WaylandLibdecorMode) -> Unit:
        self.wayland_libdecor = WaylandLibdecorOverride.Selected :: mode :: call
        return
    fn clear_wayland_libdecor(edit self) -> Unit:
        self.wayland_libdecor = WaylandLibdecorOverride.Default
        return
