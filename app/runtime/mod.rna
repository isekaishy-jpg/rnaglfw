impl WindowSnapshot:
    fn key_state(read self, read key: KeyCode) -> InputAction:
        return self.input.key_state :: key :: method
    fn key_pressed(read self, read key: KeyCode) -> Bool:
        return self.input.key_pressed :: key :: method
    fn key_down(read self, read key: KeyCode) -> Bool:
        return self.input.key_down :: key :: method
    fn key_repeating(read self, read key: KeyCode) -> Bool:
        return self.input.key_repeating :: key :: method
    fn mouse_button_state(read self, read button: MouseButton) -> InputAction:
        return self.input.mouse_button_state :: button :: method
    fn mouse_button_pressed(read self, read button: MouseButton) -> Bool:
        return self.input.mouse_button_pressed :: button :: method
    fn mouse_button_down(read self, read button: MouseButton) -> Bool:
        return self.input.mouse_button_down :: button :: method
impl MonitorSnapshot:
    fn available(read self) -> Bool:
        return self.available
    fn primary(read self) -> Bool:
        return self.primary
    fn fullscreen_spec(read self) -> Result[WindowMonitorSpec, WindowModeError]:
        select self.current_video_mode:
            when Option.Some(mode) =>
                let size = Size :: mode.width, mode.height :: call
                let spec = window_monitor_spec :: self.monitor, self.screen_pos, size, mode.refresh_rate :: call
                return Result.Ok :: spec :: call
            when Option.None => return Result.Err :: WindowModeError.MissingVideoMode :: call
    fn fullscreen_spec_with_video_mode(read self, read mode: VideoMode) -> Result[WindowMonitorSpec, WindowModeError]:
        let size = Size :: mode.width, mode.height :: call
        let spec = window_monitor_spec :: self.monitor, self.screen_pos, size, mode.refresh_rate :: call
        return Result.Ok :: spec :: call
    fn first_video_mode(read self) -> Option[VideoMode]:
        select:
            when self.video_modes.is_empty :: :: method => return Option.None
            else =>
                let mode = copy_video_mode :: self.video_modes[0] :: call
                return Option.Some :: mode :: call
    fn video_mode_at(read self, index: CInt) -> Option[VideoMode]:
        let Result.Ok(idx) = cint_to_index :: index :: call else => return Option.None
        select:
            when idx >= self.video_modes.count :: :: method => return Option.None
            else =>
                let mode = copy_video_mode :: self.video_modes[idx] :: call
                return Option.Some :: mode :: call
    fn video_mode_matching(read self, width: CInt, height: CInt, refresh_rate: CInt) -> Option[VideoMode]:
        let Result.Ok(count) = index_to_cint :: self.video_modes.count :: :: method :: call else => return Option.None
        let scan: CInt = 0
        repeat while scan < count:
            let Result.Ok(index) = cint_to_index :: scan :: call else => return Option.None
            let mode = copy_video_mode :: self.video_modes[index] :: call
            select:
                when mode.width == width && mode.height == height && mode.refresh_rate == refresh_rate =>
                    let copy = copy_video_mode :: mode :: call
                    return Option.Some :: copy :: call
                else => ()
            scan = scan + 1
        return Option.None
    fn video_mode_with_max_refresh(read self, width: CInt, height: CInt) -> Option[VideoMode]:
        let Result.Ok(count) = index_to_cint :: self.video_modes.count :: :: method :: call else => return Option.None
        let best_index: CInt = -1
        let best_refresh_rate: CInt = -1
        let scan: CInt = 0
        repeat while scan < count:
            let Result.Ok(index) = cint_to_index :: scan :: call else => return Option.None
            let mode = copy_video_mode :: self.video_modes[index] :: call
            select:
                when mode.width == width && mode.height == height =>
                    select:
                        when best_index < 0 || mode.refresh_rate > best_refresh_rate =>
                            best_index = scan
                            best_refresh_rate = mode.refresh_rate
                        else => ()
                else => ()
            scan = scan + 1
        select:
            when best_index >= 0 =>
                let Result.Ok(index) = cint_to_index :: best_index :: call else => return Option.None
                let mode = copy_video_mode :: self.video_modes[index] :: call
                return Option.Some :: mode :: call
            else => return Option.None
    fn supports_video_mode(read self, read mode: VideoMode) -> Bool:
        select self.video_mode_matching :: mode.width, mode.height, mode.refresh_rate :: method:
            when Option.Some(_) => return true
            when Option.None => return false
    fn has_gamma_ramp(read self) -> Bool:
        select self.gamma_ramp:
            when Option.Some(_) => return true
            when Option.None => return false
impl JoystickSnapshot:
    fn available(read self) -> Bool:
        return self.present
    fn axis_count(read self) -> Index:
        return self.axes.count :: :: method
    fn axis_at(read self, index: CInt) -> Option[F32]:
        let Result.Ok(idx) = cint_to_index :: index :: call else => return Option.None
        select:
            when idx >= self.axes.count :: :: method => return Option.None
            else => return Option.Some :: self.axes[idx] :: call
    fn button_count(read self) -> Index:
        return self.buttons.count :: :: method
    fn button_at(read self, index: CInt) -> Option[Bool]:
        let Result.Ok(idx) = cint_to_index :: index :: call else => return Option.None
        select:
            when idx >= self.buttons.count :: :: method => return Option.None
            else => return Option.Some :: self.buttons[idx] :: call
    fn hat_count(read self) -> Index:
        return self.hats.count :: :: method
    fn hat_at(read self, index: CInt) -> Option[HatState]:
        let Result.Ok(idx) = cint_to_index :: index :: call else => return Option.None
        select:
            when idx >= self.hats.count :: :: method => return Option.None
            else =>
                let hat = copy_hat_state :: self.hats[idx] :: call
                return Option.Some :: hat :: call
    fn has_gamepad_state(read self) -> Bool:
        select self.gamepad_state:
            when Option.Some(_) => return true
            when Option.None => return false
    fn gamepad_button_down(read self, button: GamepadButton) -> Bool:
        select self.gamepad_state:
            when Option.Some(state) => return state.button_down :: button :: method
            when Option.None => return false
    fn gamepad_axis(read self, axis: GamepadAxis) -> F32:
        select self.gamepad_state:
            when Option.Some(state) => return state.axis :: axis :: method
            when Option.None => return 0.0F32
fn apply_window_hint_string(hint: CInt, text: Str) -> Result[Unit, AppError]:
    select maybe_c_string :: text :: call:
        when Result.Ok(value) =>
            let pointer = value.as_ptr :: :: method
            glfw_window_hint_string :: hint, pointer :: call
            return Result.Ok :: () :: call
        when Result.Err(_) => return Result.Err :: AppError.InvalidWindowSpec :: call
fn invalid_win32_parent_window_spec(read spec: WindowSpec) -> Bool:
    select:
        when spec.win32_parent_window.is_null :: :: method => return false
        when !spec.win32_owner_window.is_null :: :: method => return true
        when !spec.win32_menu.is_null :: :: method => return true
        when !spec.monitor.is_null :: :: method => return true
        else => return false
fn same_point(read left: Point, read right: Point) -> Bool:
    return left.x == right.x && left.y == right.y
fn same_size(read left: Size, read right: Size) -> Bool:
    return left.width == right.width && left.height == right.height
fn same_scale(read left: Scale, read right: Scale) -> Bool:
    return left.x == right.x && left.y == right.y
fn same_cursor_pos(read left: CursorPos, read right: CursorPos) -> Bool:
    return left.x == right.x && left.y == right.y
fn copy_video_mode(read mode: VideoMode) -> VideoMode:
    return VideoMode :: :: call
        width = mode.width
        height = mode.height
        red_bits = mode.red_bits
        green_bits = mode.green_bits
        blue_bits = mode.blue_bits
        refresh_rate = mode.refresh_rate
fn copy_hat_state(read state: HatState) -> HatState:
    let raw = hat_state_raw :: state :: call
    let Result.Ok(value) = raw as Maybe[CUnsignedChar] else => return hat_state_from_raw :: 0 :: call
    return hat_state_from_raw :: value :: call
fn push_window_event(edit pending: List[AppEvent], event: WindowEvent) -> Unit:
    let wrapped = AppEvent.Window :: event :: call
    pending.push :: wrapped :: method
    return
fn push_monitor_event(edit pending: List[AppEvent], event: MonitorEvent) -> Unit:
    let wrapped = AppEvent.Monitor :: event :: call
    pending.push :: wrapped :: method
    return
fn push_joystick_event(edit pending: List[AppEvent], event: JoystickEvent) -> Unit:
    let wrapped = AppEvent.Joystick :: event :: call
    pending.push :: wrapped :: method
    return
fn push_user_event(edit pending: List[AppEvent], event: UserEvent) -> Unit:
    let wrapped = AppEvent.User :: event :: call
    pending.push :: wrapped :: method
    return
fn pending_pop_front(edit pending: List[AppEvent]) -> Option[AppEvent]:
    select:
        when pending.is_empty :: :: method => return Option.None
        else =>
            let event = pending.remove :: 0 :: method
            return Option.Some :: event :: call
fn drain_pending_events(edit pending: List[AppEvent]) -> List[AppEvent]:
    let events = List[AppEvent] :: :: call
    repeat:
        select pending_pop_front :: pending :: call:
            when Option.Some(event) =>
                events.push :: event :: method
                continue
            else => return events
fn snapshot_optional_text(present: Bool, text: Result[Str, TextDecodeError]) -> Result[Option[Str], TextDecodeError]:
    select:
        when !present => return Result.Ok :: Option.None :: call
        else =>
            select text:
                when Result.Ok(value) =>
                    let wrapped = Option.Some :: value :: call
                    return Result.Ok :: wrapped :: call
                when Result.Err(err) => return Result.Err :: err :: call
fn snapshot_optional_gamepad_text(present: Bool, gamepad: Bool, text: Result[Str, TextDecodeError]) -> Result[Option[Str], TextDecodeError]:
    select:
        when !present => return Result.Ok :: Option.None :: call
        when !gamepad => return Result.Ok :: Option.None :: call
        else =>
            select text:
                when Result.Ok(value) =>
                    let wrapped = Option.Some :: value :: call
                    return Result.Ok :: wrapped :: call
                when Result.Err(err) => return Result.Err :: err :: call
fn snapshot_axes(read joystick: Joystick, present: Bool) -> List[F32]:
    select:
        when present => return joystick.axes :: :: method
        else => return List[F32] :: :: call
fn snapshot_buttons(read joystick: Joystick, present: Bool) -> List[Bool]:
    select:
        when present => return joystick.buttons :: :: method
        else => return List[Bool] :: :: call
fn snapshot_hats(read joystick: Joystick, present: Bool) -> List[HatState]:
    select:
        when present => return joystick.hats :: :: method
        else => return List[HatState] :: :: call
fn snapshot_gamepad_state(read joystick: Joystick, present: Bool, gamepad: Bool) -> Option[GamepadState]:
    select:
        when present && gamepad => return joystick.gamepad_state :: :: method
        else => return Option.None
fn snapshot_current_context_window_id(read app: App) -> Option[WindowId]:
    select app.current_context_window :: :: method:
        when Result.Ok(window) => return Option.Some :: window.id :: call
        when Result.Err(_) => return Option.None
fn snapshot_primary_monitor_id(read app: App) -> Option[MonitorId]:
    select app.primary_monitor_id :: :: method:
        when Result.Ok(id) => return Option.Some :: id :: call
        when Result.Err(_) => return Option.None
fn clipboard_anchor_window(read app: App) -> Option[Window]:
    select app.current_context_window :: :: method:
        when Result.Ok(window) => return Option.Some :: window :: call
        when Result.Err(_) => ()
    select:
        when app.windows.is_empty :: :: method => return Option.None
        else =>
            let window = live_window_from_record :: app.windows[0] :: call
            return Option.Some :: window :: call
pub(package) fn joystick_snapshot_from_id(id: JoystickId) -> JoystickSnapshot:
    let joystick = joystick_from_id :: id :: call
    let present = joystick.present :: :: method
    let gamepad = joystick.gamepad :: :: method
    let raw_name_text = joystick.name_text :: :: method
    let raw_guid_text = joystick.guid_text :: :: method
    let raw_gamepad_name_text = joystick.gamepad_name_text :: :: method
    let name_text = snapshot_optional_text :: present, raw_name_text :: call
    let guid_text = snapshot_optional_text :: present, raw_guid_text :: call
    let gamepad_name_text = snapshot_optional_gamepad_text :: present, gamepad, raw_gamepad_name_text :: call
    let axis_count = joystick.axis_count :: :: method
    let button_count = joystick.button_count :: :: method
    let hat_count = joystick.hat_count :: :: method
    let axes = snapshot_axes :: joystick, present :: call
    let buttons = snapshot_buttons :: joystick, present :: call
    let hats = snapshot_hats :: joystick, present :: call
    let gamepad_state = snapshot_gamepad_state :: joystick, present, gamepad :: call
    return JoystickSnapshot :: :: call
        joystick = joystick
        name_text = name_text
        guid_text = guid_text
        gamepad_name_text = gamepad_name_text
        present = present
        gamepad = gamepad
        axis_count = axis_count
        button_count = button_count
        hat_count = hat_count
        axes = axes
        buttons = buttons
        hats = hats
        gamepad_state = gamepad_state
fn window_record(take window: Window, mailbox: *edit WindowMailbox, modifier_bits: CInt) -> WindowRecord:
    let raw_handle = glfw_window_raw_handle :: window.raw :: call
    let stored_raw = GlfwWindow :: raw_handle :: call
    let stored_id = window.id
    let stored_window = Window :: stored_raw, stored_id :: call
    let should_close = window.should_close :: :: method
    let pos = window.pos :: :: method
    let size = window.size :: :: method
    let framebuffer_size = window.framebuffer_size :: :: method
    let content_scale = window.content_scale :: :: method
    let focused = window.focused :: :: method
    let iconified = window.iconified :: :: method
    let maximized = window.maximized :: :: method
    let cursor_pos = window.cursor_pos :: :: method
    return WindowRecord :: :: call
        window = stored_window
        mailbox = mailbox
        modifier_bits = modifier_bits
        should_close = should_close
        pos = pos
        size = size
        framebuffer_size = framebuffer_size
        content_scale = content_scale
        focused = focused
        iconified = iconified
        maximized = maximized
        cursor_pos = cursor_pos
fn live_window_from_record(read record: WindowRecord) -> Window:
    let raw_handle = glfw_window_raw_handle :: record.window.raw :: call
    let raw_window = GlfwWindow :: raw_handle :: call
    let id = record.window.id
    return Window :: raw_window, id :: call
fn live_window_from_raw_handle(raw_handle: *edit GlfwWindowRaw, id: WindowId) -> Window:
    let raw_window = GlfwWindow :: raw_handle :: call
    return Window :: raw_window, id :: call
