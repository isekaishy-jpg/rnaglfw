    fn window(read self, id: WindowId) -> Result[Window, AppError]:
        let Option.Some(index) = find_window_index :: self, id :: call else => return Result.Err :: AppError.WindowNotFound :: call
        let raw_handle = glfw_window_raw_handle :: self.windows[index].window.raw :: call
        let window = live_window_from_raw_handle :: raw_handle, self.windows[index].window.id :: call
        return Result.Ok :: window :: call
    fn destroy_window_by_id(edit self, id: WindowId) -> Result[Unit, AppError]:
        return app_destroy_window_by_id :: self, id :: call
    fn destroy_window(edit self, take window: Window) -> Result[Unit, AppError]:
        return app_destroy_window_by_id :: self, window.id :: call
    fn close_all_windows(read self) -> Unit:
        let count = self.windows.count :: :: method
        let Result.Ok(limit) = index_to_cint :: count :: call else => return
        let scan: CInt = 0
        repeat while scan < limit:
            let Result.Ok(index) = cint_to_index :: scan :: call else => return
            let window = live_window_from_record :: self.windows[index] :: call
            window.close :: :: method
            scan = scan + 1
        return
    fn destroy_close_requested_windows(edit self) -> Index:
        let destroyed: CInt = 0
        let ids = close_requested_window_ids_from_records :: self :: call
        let count = ids.count :: :: method
        let Result.Ok(limit) = index_to_cint :: count :: call else => return 0
        let scan: CInt = 0
        repeat while scan < limit:
            let Result.Ok(index) = cint_to_index :: scan :: call else => return 0
            let id = ids[index]
            select app_destroy_window_by_id :: self, id :: call:
                when Result.Ok(_) => destroyed = destroyed + 1
                when Result.Err(_) => ()
            scan = scan + 1
        let Result.Ok(result) = destroyed as Maybe[Index] else => return 0
        return result
    fn destroy_all_windows(edit self) -> Index:
        let destroyed: CInt = 0
        repeat:
            select:
                when self.windows.is_empty :: :: method => break
                else =>
                    let _ = destroy_window_record_at :: self, 0 :: call
                    destroyed = destroyed + 1
        let Result.Ok(result) = destroyed as Maybe[Index] else => return 0
        return result
    fn post_empty_event(read self) -> Unit:
        glfw_post_empty_event :: :: call
        return
    fn post_user_event(edit self, id: UserEventId) -> Unit:
        let event = UserEvent.Signaled :: :: call
            id = id
        push_user_event :: self.pending, event :: call
        glfw_post_empty_event :: :: call
        return
    fn next_event(edit self) -> Option[AppEvent]:
        return pending_pop_front :: self.pending :: call
    fn next_window_event(edit self) -> Option[WindowEvent]:
        let batch = self.take_event_batch :: :: method
        let event = batch.pop_window :: :: method
        self.pending = batch.events
        return event
    fn next_monitor_event(edit self) -> Option[MonitorEvent]:
        let batch = self.take_event_batch :: :: method
        let event = batch.pop_monitor :: :: method
        self.pending = batch.events
        return event
    fn next_joystick_event(edit self) -> Option[JoystickEvent]:
        let batch = self.take_event_batch :: :: method
        let event = batch.pop_joystick :: :: method
        self.pending = batch.events
        return event
    fn next_user_event(edit self) -> Option[UserEvent]:
        let batch = self.take_event_batch :: :: method
        let event = batch.pop_user :: :: method
        self.pending = batch.events
        return event
    fn take_pending_events(edit self) -> List[AppEvent]:
        return drain_pending_events :: self.pending :: call
    fn take_event_batch(edit self) -> AppEventBatch:
        let events = self.take_pending_events :: :: method
        return split_app_events :: events :: call
    fn events_for(edit self, read flow: ControlFlow) -> List[AppEvent]:
        select flow:
            when ControlFlow.Poll => return self.poll_events :: :: method
            when ControlFlow.Wait => return self.wait_events :: :: method
            when ControlFlow.WaitTimeout(seconds = seconds) => return self.wait_timeout_events :: seconds :: method
            when ControlFlow.Exit => return List[AppEvent] :: :: call
    fn event_batch_for(edit self, read flow: ControlFlow) -> AppEventBatch:
        let events = self.events_for :: flow :: method
        return split_app_events :: events :: call
    fn pump_poll(edit self) -> Unit:
        glfw_poll_events :: :: call
        collect_window_events :: self :: call
        refresh_monitor_snapshot :: self, true :: call
        let previous_bits = self.joystick_state.bits_value :: :: method
        let next_bits = collect_joystick_bits :: previous_bits, true, self.pending :: call
        self.joystick_state.bits = next_bits
        return
    fn pump_wait(edit self) -> Unit:
        glfw_wait_events :: :: call
        collect_window_events :: self :: call
        refresh_monitor_snapshot :: self, true :: call
        let previous_bits = self.joystick_state.bits_value :: :: method
        let next_bits = collect_joystick_bits :: previous_bits, true, self.pending :: call
        self.joystick_state.bits = next_bits
        return
    fn pump_wait_timeout(edit self, timeout: F64) -> Unit:
        glfw_wait_events_timeout :: timeout :: call
        collect_window_events :: self :: call
        refresh_monitor_snapshot :: self, true :: call
        let previous_bits = self.joystick_state.bits_value :: :: method
        let next_bits = collect_joystick_bits :: previous_bits, true, self.pending :: call
        self.joystick_state.bits = next_bits
        return
    fn poll_events(edit self) -> List[AppEvent]:
        select:
            when self.has_pending_events :: :: method =>
                collect_window_events :: self :: call
                return self.take_pending_events :: :: method
            else => ()
        self.pump_poll :: :: method
        return self.take_pending_events :: :: method
    fn poll_event_batch(edit self) -> AppEventBatch:
        let events = self.poll_events :: :: method
        return split_app_events :: events :: call
    fn poll_window_event(edit self) -> Result[Option[WindowEvent], AppError]:
