        pos = window.pos :: :: method
        size = window.size :: :: method
        frame_size = frame_size
        framebuffer_size = window.framebuffer_size :: :: method
        content_scale = window.content_scale :: :: method
        focused = window.focused :: :: method
        iconified = window.iconified :: :: method
        maximized = window.maximized :: :: method
        cursor_pos = window.cursor_pos :: :: method
        client_api = client_api
        opengl_profile = opengl_profile
