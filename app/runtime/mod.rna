impl AppSnapshot:
    fn window_ids(read self) -> List[WindowId]:
        let ids = List[WindowId] :: :: call
        let count = self.windows.count :: :: method
        let Result.Ok(limit) = index_to_cint :: count :: call else => return ids
        let scan: CInt = 0
        repeat while scan < limit:
            let Result.Ok(index) = cint_to_index :: scan :: call else => return ids
            ids.push :: self.windows[index].window.id :: method
            scan = scan + 1
        return ids
    fn monitor_ids(read self) -> List[MonitorId]:
        let ids = List[MonitorId] :: :: call
        let count = self.monitors.count :: :: method
        let Result.Ok(limit) = index_to_cint :: count :: call else => return ids
        let scan: CInt = 0
        repeat while scan < limit:
            let Result.Ok(index) = cint_to_index :: scan :: call else => return ids
            ids.push :: self.monitors[index].id :: method
            scan = scan + 1
        return ids
    fn joystick_ids(read self) -> List[JoystickId]:
        let ids = List[JoystickId] :: :: call
        let count = self.joysticks.count :: :: method
        let Result.Ok(limit) = index_to_cint :: count :: call else => return ids
        let scan: CInt = 0
        repeat while scan < limit:
            let Result.Ok(index) = cint_to_index :: scan :: call else => return ids
            ids.push :: self.joysticks[index].joystick.id :: method
            scan = scan + 1
        return ids
    fn window_index(read self, id: WindowId) -> Option[Index]:
        let count = self.windows.count :: :: method
        let Result.Ok(limit) = index_to_cint :: count :: call else => return Option.None
        let scan: CInt = 0
        repeat while scan < limit:
            let Result.Ok(index) = cint_to_index :: scan :: call else => return Option.None
            select:
                when self.windows[index].window.id == id => return Option.Some :: index :: call
                else => ()
            scan = scan + 1
        return Option.None
    fn monitor_index(read self, id: MonitorId) -> Option[Index]:
        let count = self.monitors.count :: :: method
        let Result.Ok(limit) = index_to_cint :: count :: call else => return Option.None
        let scan: CInt = 0
        repeat while scan < limit:
            let Result.Ok(index) = cint_to_index :: scan :: call else => return Option.None
            select:
                when self.monitors[index].id == id => return Option.Some :: index :: call
                else => ()
            scan = scan + 1
        return Option.None
    fn joystick_index(read self, id: JoystickId) -> Option[Index]:
        let count = self.joysticks.count :: :: method
        let Result.Ok(limit) = index_to_cint :: count :: call else => return Option.None
        let scan: CInt = 0
        repeat while scan < limit:
            let Result.Ok(index) = cint_to_index :: scan :: call else => return Option.None
            select:
                when self.joysticks[index].joystick.id == id => return Option.Some :: index :: call
                else => ()
            scan = scan + 1
        return Option.None
    fn gamepad_index(read self, id: JoystickId) -> Option[Index]:
        let gamepad_index: CInt = 0
        let count = self.joysticks.count :: :: method
        let Result.Ok(limit) = index_to_cint :: count :: call else => return Option.None
        let scan: CInt = 0
        repeat while scan < limit:
            let Result.Ok(index) = cint_to_index :: scan :: call else => return Option.None
            select:
                when self.joysticks[index].gamepad =>
                    select:
                        when self.joysticks[index].joystick.id == id =>
                            let Result.Ok(result) = cint_to_index :: gamepad_index :: call else => return Option.None
                            return Option.Some :: result :: call
                        else => gamepad_index = gamepad_index + 1
                else => ()
            scan = scan + 1
        return Option.None
    fn has_window(read self, id: WindowId) -> Bool:
        select self.window_index :: id :: method:
            when Option.Some(_) => return true
            when Option.None => return false
    fn has_monitor(read self, id: MonitorId) -> Bool:
        select self.monitor_index :: id :: method:
            when Option.Some(_) => return true
            when Option.None => return false
    fn has_joystick(read self, id: JoystickId) -> Bool:
        select self.joystick_index :: id :: method:
            when Option.Some(_) => return true
            when Option.None => return false
    fn has_gamepad(read self, id: JoystickId) -> Bool:
        select self.joystick_index :: id :: method:
            when Option.Some(index) => return self.joysticks[index].gamepad
            when Option.None => return false
    fn gamepad_count(read self) -> Index:
        let total: CInt = 0
        let count = self.joysticks.count :: :: method
        let Result.Ok(limit) = index_to_cint :: count :: call else => return 0
        let scan: CInt = 0
        repeat while scan < limit:
            let Result.Ok(index) = cint_to_index :: scan :: call else => return 0
            select:
                when self.joysticks[index].gamepad => total = total + 1
                else => ()
            scan = scan + 1
        let Result.Ok(result) = cint_to_index :: total :: call else => return 0
        return result
    fn has_gamepads(read self) -> Bool:
        let count = self.joysticks.count :: :: method
        let Result.Ok(limit) = index_to_cint :: count :: call else => return false
        let scan: CInt = 0
        repeat while scan < limit:
            let Result.Ok(index) = cint_to_index :: scan :: call else => return false
            select:
                when self.joysticks[index].gamepad => return true
                else => ()
            scan = scan + 1
        return false
    fn gamepad_ids(read self) -> List[JoystickId]:
        let ids = List[JoystickId] :: :: call
        let count = self.joysticks.count :: :: method
        let Result.Ok(limit) = index_to_cint :: count :: call else => return ids
