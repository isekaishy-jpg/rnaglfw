pub(package) fn find_primary_monitor_record_index(read app: App) -> Result[Index, AppError]:
    let primary = glfw_primary_monitor :: :: call
    select:
        when primary.is_null :: :: method => return Result.Err :: AppError.PrimaryMonitorUnavailable :: call
        else => ()
    let Option.Some(index) = find_monitor_index_in_list :: app.monitors, primary :: call else => return Result.Err :: AppError.MonitorNotFound :: call
    return Result.Ok :: index :: call
pub(package) fn find_current_context_window_record_index(read app: App) -> Result[Index, AppError]:
    let current = glfw_get_current_context :: :: call
    select:
        when current.is_null :: :: method => return Result.Err :: AppError.NoCurrentContext :: call
        else => ()
    let current_raw = current.raw_handle :: :: method
    let count = app.windows.count :: :: method
    let Result.Ok(limit) = index_to_cint :: count :: call else => return Result.Err :: AppError.CurrentContextWindowNotTracked :: call
    let scan: CInt = 0
    repeat while scan < limit:
        let Result.Ok(index) = cint_to_index :: scan :: call else => return Result.Err :: AppError.CurrentContextWindowNotTracked :: call
        let raw_handle = glfw_window_raw_handle :: app.windows[index].window.raw :: call
        select:
            when raw_handle == current_raw => return Result.Ok :: index :: call
            else => ()
        scan = scan + 1
    return Result.Err :: AppError.CurrentContextWindowNotTracked :: call
fn apply_app_init_config(config: AppInitConfig) -> Unit:
    select config.joystick_hat_buttons:
        when BoolOverride.Enabled => glfw_init_hint_bool :: 0x00050001, true :: call
        when BoolOverride.Disabled => glfw_init_hint_bool :: 0x00050001, false :: call
        when BoolOverride.Default => ()
    select config.platform:
        when PlatformOverride.Selected(platform) =>
            let raw = runtime_platform_raw :: platform :: call
            glfw_init_hint :: 0x00050003, raw :: call
        when PlatformOverride.Default => ()
    select config.angle_platform_type:
        when AnglePlatformTypeOverride.Selected(platform_type) =>
            let raw = angle_platform_type_raw :: platform_type :: call
            glfw_init_hint :: 0x00050002, raw :: call
        when AnglePlatformTypeOverride.Default => ()
    select config.cocoa_chdir_resources:
        when BoolOverride.Enabled => glfw_init_hint_bool :: 0x00051001, true :: call
        when BoolOverride.Disabled => glfw_init_hint_bool :: 0x00051001, false :: call
        when BoolOverride.Default => ()
    select config.cocoa_menubar:
        when BoolOverride.Enabled => glfw_init_hint_bool :: 0x00051002, true :: call
        when BoolOverride.Disabled => glfw_init_hint_bool :: 0x00051002, false :: call
        when BoolOverride.Default => ()
    select config.x11_xcb_vulkan_surface:
        when BoolOverride.Enabled => glfw_init_hint_bool :: 0x00052001, true :: call
        when BoolOverride.Disabled => glfw_init_hint_bool :: 0x00052001, false :: call
        when BoolOverride.Default => ()
    select config.wayland_libdecor:
        when WaylandLibdecorOverride.Selected(mode) =>
            let raw = wayland_libdecor_mode_raw :: mode :: call
            glfw_init_hint :: 0x00053001, raw :: call
        when WaylandLibdecorOverride.Default => ()
    return
pub fn app_init() -> Result[App, AppError]:
    let config = app_init_config :: :: call
    return app_init_with :: config :: call
pub fn app_init_with(config: AppInitConfig) -> Result[App, AppError]:
    apply_app_init_config :: config :: call
    select:
        when glfw_init :: :: call =>
            select:
                when initialize_drag_drop_runtime :: :: call => ()
                else =>
                    glfw_terminate :: :: call
                    return Result.Err :: AppError.DragDropRuntimeInitFailed :: call
            let windows = List[WindowRecord] :: :: call
            let monitors = List[MonitorRecord] :: :: call
            let pending = List[AppEvent] :: :: call
            let joystick_bits = collect_joystick_bits :: 0, false, pending :: call
            let joystick_state = joystick_presence_state_with_bits :: joystick_bits :: call
            let app = App :: :: call
                live = true
                drag_drop_runtime_initialized = true
                next_window_id = WINDOW_ID_START
                next_monitor_id = MONITOR_ID_START
                joystick_state = joystick_state
                windows = windows
                monitors = monitors
                pending = pending
            refresh_monitor_snapshot :: app, false :: call
            return Result.Ok :: app :: call
        else => return Result.Err :: AppError.InitFailed :: call
