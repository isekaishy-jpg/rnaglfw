    fn window_close_requested(read self, id: WindowId) -> Bool:
        select self.window_index :: id :: method:
            when Option.Some(index) => return self.windows[index].should_close
            when Option.None => return false
    fn close_requested_windows(read self) -> List[WindowSnapshot]:
        let snapshots = List[WindowSnapshot] :: :: call
        let count = self.windows.count :: :: method
        let Result.Ok(limit) = index_to_cint :: count :: call else => return snapshots
        let scan: CInt = 0
