                    let snapshot = copy_window_snapshot :: self.windows[index] :: call
                    snapshots.push :: snapshot :: method
                else => ()
            scan = scan + 1
        return snapshots
    fn close_requested_window(read self, id: WindowId) -> Option[WindowSnapshot]:
        select self.window_index :: id :: method:
