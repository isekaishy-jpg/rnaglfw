    fn poll(edit self) -> Result[Option[AppEvent], AppError]:
        let queued = pending_pop_front :: self.pending :: call
        select queued:
            when Option.Some(event) =>
                let wrapped: Option[AppEvent] = Option.Some :: event :: call
                return Result.Ok :: wrapped :: call
            when Option.None =>
                self.pump_poll :: :: method
                let drained = pending_pop_front :: self.pending :: call
                return Result.Ok :: drained :: call
        let empty: Option[AppEvent] = Option.None
        return Result.Ok :: empty :: call
    fn wait(edit self) -> Result[Option[AppEvent], AppError]:
        let queued = pending_pop_front :: self.pending :: call
        select queued:
            when Option.Some(event) =>
                let wrapped: Option[AppEvent] = Option.Some :: event :: call
                return Result.Ok :: wrapped :: call
            when Option.None =>
