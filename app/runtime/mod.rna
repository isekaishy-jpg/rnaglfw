fn close_requested_window_count_from_records(read app: App) -> Index:
    let total: CInt = 0
    let count = app.windows.count :: :: method
    let Result.Ok(limit) = index_to_cint :: count :: call else => return 0
    let scan: CInt = 0
    repeat while scan < limit:
        let Result.Ok(index) = cint_to_index :: scan :: call else => return 0
        select:
            when app.windows[index].should_close => total = total + 1
            else => ()
        scan = scan + 1
    let Result.Ok(result) = total as Maybe[Index] else => return 0
    return result
fn close_requested_window_ids_from_records(read app: App) -> List[WindowId]:
    let ids = List[WindowId] :: :: call
    let count = app.windows.count :: :: method
    let Result.Ok(limit) = index_to_cint :: count :: call else => return ids
    let scan: CInt = 0
    repeat while scan < limit:
        let Result.Ok(index) = cint_to_index :: scan :: call else => return ids
        select:
            when app.windows[index].should_close => ids.push :: app.windows[index].window.id :: method
            else => ()
        scan = scan + 1
    return ids
fn close_requested_windows_from_records(read app: App) -> List[Window]:
    let windows = List[Window] :: :: call
    let count = app.windows.count :: :: method
    let Result.Ok(limit) = index_to_cint :: count :: call else => return windows
    let scan: CInt = 0
    repeat while scan < limit:
        let Result.Ok(index) = cint_to_index :: scan :: call else => return windows
        select:
            when app.windows[index].should_close =>
                let window = live_window_from_record :: app.windows[index] :: call
                windows.push :: window :: method
            else => ()
        scan = scan + 1
    return windows
fn copy_point(read point: Point) -> Point:
    return GlfwPoint :: point.x, point.y :: call
fn copy_size(read size: Size) -> Size:
    return GlfwSize :: size.width, size.height :: call
fn copy_scale(read scale: Scale) -> Scale:
    return GlfwScale :: scale.x, scale.y :: call
fn copy_cursor_pos(read pos: CursorPos) -> CursorPos:
    return GlfwCursorPos :: pos.x, pos.y :: call
fn destroy_window_record(edit pending: List[AppEvent], take record: WindowRecord) -> Unit:
    let _ = pending
    detach_window_platform_support :: record.window :: call
    clear_user_pointer :: record.window.raw :: call
    destroy_window_taskbar_icon :: record.mailbox :: call
    free_window_mailbox :: record.mailbox :: call
    record.window.destroy :: :: method
    return
fn destroy_window_record_at(edit app: App, index: Index) -> WindowId:
    let record = app.windows.remove :: index :: method
    let id = record.window.id
    let modifier_bits = record.modifier_bits
    drain_window_mailbox :: id, record.mailbox, modifier_bits, app.pending :: call
    destroy_window_record :: app.pending, record :: call
    let event = WindowEvent.Destroyed :: :: call
        id = id
    push_window_event :: app.pending, event :: call
    return id
fn create_raw_window_from_spec(take spec: WindowSpec) -> Result[RawWindowCreation, AppError]:
    select:
        when invalid_win32_parent_window_spec :: spec :: call =>
            return Result.Err :: AppError.InvalidWindowSpec :: call
        else => ()
    glfw_default_window_hints :: :: call
    glfw_window_hint_bool :: 0x00020004, false :: call
    glfw_window_hint_bool :: 0x00020003, spec.resizable :: call
    glfw_window_hint_bool :: 0x00020005, spec.decorated :: call
    glfw_window_hint_bool :: 0x00020001, false :: call
    glfw_window_hint_bool :: 0x00020006, spec.auto_iconify :: call
    glfw_window_hint_bool :: 0x00020007, spec.floating :: call
    glfw_window_hint_bool :: 0x00020008, spec.maximized :: call
    glfw_window_hint_bool :: 0x00020009, spec.center_cursor :: call
    glfw_window_hint_bool :: 0x0002000A, spec.transparent_framebuffer :: call
    glfw_window_hint_bool :: 0x0002000C, spec.focus_on_show :: call
    glfw_window_hint_bool :: 0x0002000D, spec.mouse_passthrough :: call
    glfw_window_hint_bool :: 0x0002200C, spec.scale_to_monitor :: call
    glfw_window_hint_bool :: 0x00025001, spec.win32_keyboard_menu :: call
    glfw_window_hint_bool :: 0x00025002, spec.win32_showdefault :: call
    glfw_window_hint_bool :: 0x00025004, spec.win32_no_redirection_bitmap :: call
    glfw_window_hint_bool :: 0x00025005, spec.win32_clip_children :: call
    glfw_set_win32_parent_window_hint :: spec.win32_parent_window :: call
    glfw_window_hint :: 0x0002000E, spec.x :: call
    glfw_window_hint :: 0x0002000F, spec.y :: call
    glfw_window_hint :: 0x00021001, spec.red_bits :: call
    glfw_window_hint :: 0x00021002, spec.green_bits :: call
    glfw_window_hint :: 0x00021003, spec.blue_bits :: call
    glfw_window_hint :: 0x00021004, spec.alpha_bits :: call
    glfw_window_hint :: 0x00021005, spec.depth_bits :: call
    glfw_window_hint :: 0x00021006, spec.stencil_bits :: call
    glfw_window_hint :: 0x0002100D, spec.samples :: call
    glfw_window_hint :: 0x0002100F, spec.refresh_rate :: call
    glfw_window_hint :: 0x00022002, spec.context_version_major :: call
    glfw_window_hint :: 0x00022003, spec.context_version_minor :: call
    let raw_opengl_profile = opengl_profile_raw :: spec.opengl_profile :: call
    let raw_context_creation_api = context_creation_api_raw :: spec.context_creation_api :: call
    glfw_window_hint :: 0x00022008, raw_opengl_profile :: call
    glfw_window_hint :: 0x0002200B, raw_context_creation_api :: call
    glfw_window_hint_bool :: 0x00022006, spec.opengl_forward_compat :: call
    glfw_window_hint_bool :: 0x00022007, spec.opengl_debug_context :: call
    glfw_window_hint_bool :: 0x0002200A, spec.context_no_error :: call
    glfw_window_hint_bool :: 0x0002100E, spec.srgb_capable :: call
    glfw_window_hint_bool :: 0x00021010, spec.doublebuffer :: call
    let raw_client_api = client_api_raw :: spec.client_api :: call
    select:
        when raw_client_api == 0 => glfw_window_hint_no_api :: :: call
        else => glfw_window_hint :: 0x00022001, raw_client_api :: call
    select spec.cocoa_frame_name:
        when Option.Some(name) =>
            select apply_window_hint_string :: 0x00023002, name :: call:
                when Result.Ok(_) => ()
                when Result.Err(err) => return Result.Err :: err :: call
        when Option.None => ()
    select spec.x11_class_name:
        when Option.Some(name) =>
            select apply_window_hint_string :: 0x00024001, name :: call:
                when Result.Ok(_) => ()
                when Result.Err(err) => return Result.Err :: err :: call
        when Option.None => ()
    select spec.x11_instance_name:
        when Option.Some(name) =>
            select apply_window_hint_string :: 0x00024002, name :: call:
                when Result.Ok(_) => ()
                when Result.Err(err) => return Result.Err :: err :: call
        when Option.None => ()
    select spec.win32_class_name:
        when Option.Some(name) =>
            select apply_window_hint_string :: 0x00025003, name :: call:
                when Result.Ok(_) => ()
                when Result.Err(err) => return Result.Err :: err :: call
        when Option.None => ()
    select spec.wayland_app_id:
        when Option.Some(name) =>
            select apply_window_hint_string :: 0x00026001, name :: call:
                when Result.Ok(_) => ()
                when Result.Err(err) => return Result.Err :: err :: call
        when Option.None => ()
    select either:
        when width: Result.Ok(width) <- index_to_cint :: spec.width :: call
        when height: Result.Ok(height) <- index_to_cint :: spec.height :: call
        when title: Result.Ok(title) <- maybe_c_string :: spec.title :: call =>
            let title_ptr = title.as_ptr :: :: method
            let raw_window = glfw_create_window_raw :: width, height, title_ptr, spec.monitor, spec.share :: call
            select:
                when raw_window.is_null :: :: method => return Result.Err :: AppError.WindowCreateFailed :: call
                else =>
                    let appearance_settings = WindowAppearanceSettings :: :: call
                        undecorated_shadow = spec.win32_undecorated_shadow
                        system_backdrop = spec.win32_system_backdrop
                        border_color = spec.win32_border_color
                        title_background_color = spec.win32_title_background_color
                        title_text_color = spec.win32_title_text_color
                        corner_preference = spec.win32_corner_preference
                    let created = RawWindowCreation :: :: call
                        raw_window = raw_window
                        window_icon = spec.icon
                        taskbar_icon = spec.win32_taskbar_icon
                        appearance_settings = appearance_settings
                    return Result.Ok :: created :: call

    with Result.Err(_):
        width => return Result.Err :: AppError.InvalidWindowSpec :: call
        height => return Result.Err :: AppError.InvalidWindowSpec :: call
        title => return Result.Err :: AppError.InvalidWindowSpec :: call

fn window_display_plan_from_spec(read spec: WindowSpec) -> WindowDisplayPlan:
    return WindowDisplayPlan :: :: call
        visible = spec.visible
        focused = spec.focused
        focus_on_show = spec.focus_on_show

fn apply_window_display_plan(read window: Window, read display_plan: WindowDisplayPlan) -> Unit:
    let initial_focus_on_show = false
    select:
        when display_plan.visible && display_plan.focused && display_plan.focus_on_show => initial_focus_on_show = true
        else => ()
    window.set_focus_on_show :: initial_focus_on_show :: method
    select:
        when display_plan.visible => window.show :: :: method
        else => ()
    window.set_focus_on_show :: display_plan.focus_on_show :: method
    select:
        when display_plan.visible && display_plan.focused && !display_plan.focus_on_show => window.focus :: :: method
        else => ()
    return

fn register_created_window(edit app: App, take window: Window, mailbox: *edit WindowMailbox) -> Unit:
    let id = window.id
    let record = window_record :: window, mailbox, 0 :: call
    app.windows.push :: record :: method
    let event = WindowEvent.Created :: :: call
        id = id
    push_window_event :: app.pending, event :: call
    return

fn apply_created_window_taskbar_icon(read window: Window, raw_window: GlfwWindow, mailbox: *edit WindowMailbox, take taskbar_icon: Option[RgbaImage]) -> Result[Unit, AppError]:
    select either:
        when image: Option.Some(image) <- taskbar_icon
        when applied: Result.Ok(_) <- window.set_taskbar_icon_image :: image :: method =>
            return Result.Ok :: () :: call

    with Option.None:
        image => return Result.Ok :: () :: call

    with Result.Err(error):
        applied =>
            detach_window_platform_support :: window :: call
            clear_user_pointer :: raw_window :: call
            destroy_window_taskbar_icon :: mailbox :: call
            free_window_mailbox :: mailbox :: call
            window.destroy :: :: method
            let failure = AppError.WindowTaskbarIconApplyFailed :: error :: call
            return Result.Err :: failure :: call

fn destroy_failed_created_window(read window: Window, mailbox: *edit WindowMailbox) -> Unit:
    detach_window_platform_support :: window :: call
    clear_user_pointer :: window.raw :: call
    destroy_window_taskbar_icon :: mailbox :: call
    free_window_mailbox :: mailbox :: call
    window.destroy :: :: method
    return

fn create_configured_window(edit app: App, take spec: WindowSpec) -> Result[Window, AppError]:
    let raw_window_level = window_level_raw :: spec.window_level :: call
    let resize_increment_width = spec.resize_increment_width
    let resize_increment_height = spec.resize_increment_height
    let win32_drag_and_drop = spec.win32_drag_and_drop
    let win32_clip_children = spec.win32_clip_children
    let win32_owner_window = spec.win32_owner_window
    let win32_menu = spec.win32_menu
    let win32_skip_taskbar = spec.win32_skip_taskbar
    select create_raw_window_from_spec :: spec :: call:
        when Result.Ok(raw_creation) =>
            let raw_window = raw_creation.raw_window
            let window_icon = raw_creation.window_icon
            let taskbar_icon = raw_creation.taskbar_icon
            let appearance_settings = raw_creation.appearance_settings
            let id = next_window_id :: app :: call
            let raw_handle = glfw_window_raw_handle :: raw_window :: call
            let stored_raw = GlfwWindow :: raw_handle :: call
            let window = window_from_glfw :: stored_raw, id :: call
            select window_icon:
                when Option.Some(image) => window.set_icon_image :: image :: method
                when Option.None => ()
            select allocate_window_mailbox :: :: call:
                when Option.Some(mailbox) =>
                    attach_callbacks :: raw_window, mailbox :: call
                    select attach_window_platform_support :: window, mailbox, win32_drag_and_drop :: call:
                        when Result.Ok(_) => ()
                        when Result.Err(err) => return Result.Err :: err :: call
                    let window_level = window_level_from_raw :: raw_window_level :: call
                    select window.set_window_level :: window_level :: method:
                        when Result.Ok(_) => ()
                        when Result.Err(_) =>
                            destroy_failed_created_window :: window, mailbox :: call
                            return Result.Err :: AppError.WindowLevelApplyFailed :: call
                    select:
                        when !win32_owner_window.is_null :: :: method =>
                            select set_window_owner_window :: window.raw, win32_owner_window :: call:
                                when Result.Ok(_) => ()
                                when Result.Err(_) =>
                                    destroy_failed_created_window :: window, mailbox :: call
                                    return Result.Err :: AppError.WindowOwnerApplyFailed :: call
                        else => ()
                    select:
                        when !win32_menu.is_null :: :: method =>
                            select set_window_menu :: window.raw, win32_menu :: call:
                                when Result.Ok(_) => ()
                                when Result.Err(_) =>
                                    destroy_failed_created_window :: window, mailbox :: call
                                    return Result.Err :: AppError.WindowMenuApplyFailed :: call
                        else => ()
                    select window.set_clip_children :: win32_clip_children :: method:
                        when Result.Ok(_) => ()
                        when Result.Err(_) =>
                            destroy_failed_created_window :: window, mailbox :: call
                            return Result.Err :: AppError.WindowClipChildrenApplyFailed :: call
                    select:
                        when resize_increment_width > 0 && resize_increment_height > 0 =>
                            let increments = Size :: resize_increment_width, resize_increment_height :: call
                            window.apply_resize_increments :: increments :: method
                        else => ()

                    select:
                        when win32_skip_taskbar =>
                            select window.set_skip_taskbar :: true :: method:
                                when Result.Ok(_) => ()
                                when Result.Err(_) =>
                                    destroy_failed_created_window :: window, mailbox :: call
                                    return Result.Err :: AppError.WindowSkipTaskbarApplyFailed :: call
                        else => ()
                    select apply_created_window_taskbar_icon :: window, raw_window, mailbox, taskbar_icon :: call:
                        when Result.Ok(_) => ()
                        when Result.Err(err) => return Result.Err :: err :: call
                    select apply_window_appearance :: window, appearance_settings :: call:
                        when Result.Ok(_) => ()
                        when Result.Err(error) =>
                            destroy_failed_created_window :: window, mailbox :: call
                            let failure = AppError.WindowAppearanceApplyFailed :: error :: call
                            return Result.Err :: failure :: call
                    register_created_window :: app, window, mailbox :: call
                    let return_window = live_window_from_raw_handle :: raw_handle, id :: call
                    return Result.Ok :: return_window :: call
                when Option.None =>
                    window.destroy :: :: method
                    return Result.Err :: AppError.MailboxAllocFailed :: call
        when Result.Err(err) => return Result.Err :: err :: call

pub fn app_create_window(edit app: App, take spec: WindowSpec) -> Result[Window, AppError]:
    let display_plan = window_display_plan_from_spec :: spec :: call
    select create_configured_window :: app, spec :: call:
        when Result.Ok(window) =>
            apply_window_display_plan :: window, display_plan :: call
            return Result.Ok :: window :: call
        when Result.Err(err) => return Result.Err :: err :: call

pub fn app_create_centered_window_on(edit app: App, take spec: WindowSpec, read monitor: Monitor) -> Result[Window, AppError]:
    let display_plan = window_display_plan_from_spec :: spec :: call
    select create_configured_window :: app, spec :: call:
        when Result.Ok(window) =>
            select:
                when !window.fullscreen :: :: method => window.center_on :: monitor :: method
                else => ()
            apply_window_display_plan :: window, display_plan :: call
            return Result.Ok :: window :: call
        when Result.Err(err) => return Result.Err :: err :: call
pub fn app_create_primary_centered_window(edit app: App, take spec: WindowSpec) -> Result[Window, AppError]:
    select app.primary_monitor :: :: method:
        when Result.Ok(monitor) => return app_create_centered_window_on :: app, spec, monitor :: call
        when Result.Err(err) => return Result.Err :: err :: call
pub fn app_destroy_window_by_id(edit app: App, id: WindowId) -> Result[Unit, AppError]:
    let Option.Some(index) = find_window_index :: app, id :: call else => return Result.Err :: AppError.WindowNotFound :: call
    let _ = destroy_window_record_at :: app, index :: call
    return Result.Ok :: () :: call
fn next_window_id(edit app: App) -> WindowId:
    let id = app.next_window_id
    app.next_window_id = app.next_window_id + WINDOW_ID_STEP
    return id
fn next_monitor_id(edit app: App) -> MonitorId:
    let id = app.next_monitor_id
    app.next_monitor_id = app.next_monitor_id + MONITOR_ID_STEP
    return id
pub(package) fn find_window_index(read app: App, id: WindowId) -> Option[Index]:
    let count = app.windows.count :: :: method
    let Result.Ok(limit) = index_to_cint :: count :: call else => return Option.None
    let scan: CInt = 0
    repeat while scan < limit:
        let Result.Ok(index) = cint_to_index :: scan :: call else => return Option.None
        select:
            when app.windows[index].window.id == id => return Option.Some :: index :: call
            else => scan = scan + 1
    return Option.None
fn find_monitor_index(read app: App, take monitor: Monitor) -> Option[Index]:
    let target_raw = glfw_monitor_raw_handle :: monitor :: call
    let count = app.monitors.count :: :: method
    let Result.Ok(limit) = index_to_cint :: count :: call else => return Option.None
    let scan: CInt = 0
    repeat while scan < limit:
        let Result.Ok(index) = cint_to_index :: scan :: call else => return Option.None
        select:
            when app.monitors[index].raw == target_raw => return Option.Some :: index :: call
            else => scan = scan + 1
    return Option.None
pub(package) fn find_monitor_record_index(read app: App, id: MonitorId) -> Option[Index]:
    let count = app.monitors.count :: :: method
    let Result.Ok(limit) = index_to_cint :: count :: call else => return Option.None
    let scan: CInt = 0
    repeat while scan < limit:
        let Result.Ok(index) = cint_to_index :: scan :: call else => return Option.None
        select:
            when app.monitors[index].id == id => return Option.Some :: index :: call
            else => scan = scan + 1
    return Option.None
fn joystick_presence_bit(jid: JoystickId) -> CUInt:
    select jid:
        when 0 => return 1
        when 1 => return 2
        when 2 => return 4
        when 3 => return 8
        when 4 => return 16
        when 5 => return 32
        when 6 => return 64
        when 7 => return 128
        when 8 => return 256
        when 9 => return 512
        when 10 => return 1024
        when 11 => return 2048
        when 12 => return 4096
        when 13 => return 8192
        when 14 => return 16384
        when 15 => return 32768
        else => return 0
pub(package) fn joystick_present_in_bits(bits: CUInt, jid: JoystickId) -> Bool:
    let bit = joystick_presence_bit :: jid :: call
    return (bits & bit) != 0
pub(package) fn joystick_id_in_range(jid: JoystickId) -> Bool:
    return jid >= 0 && jid < JOYSTICK_SLOT_LIMIT
fn joystick_presence_state() -> JoystickPresenceState:
    return JoystickPresenceState :: :: call
        bits = 0
        pad0 = 0
        pad1 = 0
        pad2 = 0
fn joystick_presence_state_with_bits(bits: CUInt) -> JoystickPresenceState:
    return JoystickPresenceState :: :: call
        bits = bits
        pad0 = 0
        pad1 = 0
        pad2 = 0
impl JoystickPresenceState:
    fn bits_value(read self) -> CUInt:
        return self.bits
    fn set_bits(edit self, bits: CUInt) -> Unit:
        self.bits = bits
        return
fn collect_joystick_bits(previous_bits: CUInt, emit_events: Bool, edit pending: List[AppEvent]) -> CUInt:
    let next_bits: CUInt = 0
    let jid: CInt = 0
    let bitmask: CUInt = 1
    repeat while jid < JOYSTICK_SLOT_LIMIT:
        let present = glfw_joystick_present :: jid :: call
        let was_present = (previous_bits & bitmask) != 0
        select:
            when present => next_bits = next_bits | bitmask
            else => ()
        select:
            when emit_events && present && !was_present =>
                let gamepad = glfw_joystick_is_gamepad :: jid :: call
                let event = JoystickEvent.Connected :: :: call
                    id = jid
                    gamepad = gamepad
                push_joystick_event :: pending, event :: call
            when emit_events && !present && was_present =>
                let event = JoystickEvent.Disconnected :: :: call
                    id = jid
                push_joystick_event :: pending, event :: call
            else => ()
        bitmask = bitmask + bitmask
        jid = jid + 1
    return next_bits
fn collect_window_events(edit app: App) -> Unit:
    let count = app.windows.count :: :: method
    let Result.Ok(limit) = index_to_cint :: count :: call else => return
    let scan: CInt = 0
    repeat while scan < limit:
        let Result.Ok(index) = cint_to_index :: scan :: call else => return
        let previous = app.windows.remove :: index :: method
        let previous_window = previous.window
        let previous_mailbox = previous.mailbox
        let previous_should_close = previous.should_close
        let modifier_bits = previous.modifier_bits
        drain_window_mailbox :: previous_window.id, previous_mailbox, modifier_bits, app.pending :: call
        let current = window_record :: previous_window, previous_mailbox, modifier_bits :: call
        select:
            when current.should_close && !previous_should_close =>
                let event = WindowEvent.CloseRequested :: :: call
                    id = current.window.id
                push_window_event :: app.pending, event :: call
            else => ()
        app.windows.insert :: index, current :: method
        scan = scan + 1
    return
fn refresh_monitor_snapshot(edit app: App, emit_events: Bool) -> Unit:
    let next_records = List[MonitorRecord] :: :: call
    let current = glfw_monitors :: :: call
    let total: CInt = current.count :: :: method
    let scan: CInt = 0
    repeat while scan < total:
        let monitor = current.raw_at :: scan :: method
        select:
            when monitor.is_null :: :: method =>
                scan = scan + 1
                continue
            else => ()
        let monitor_raw = glfw_monitor_raw_handle :: monitor :: call
        let lookup_monitor = GlfwMonitor :: monitor_raw :: call
        let record = MonitorRecord :: monitor_raw, MONITOR_ID_START :: call
        select find_monitor_index :: app, lookup_monitor :: call:
            when Option.Some(existing) =>
                let existing_raw = app.monitors[existing].raw
                let existing_id = app.monitors[existing].id
                record = MonitorRecord :: existing_raw, existing_id :: call
            when Option.None =>
                let id = next_monitor_id :: app :: call
                record = MonitorRecord :: monitor_raw, id :: call
                select:
                    when emit_events =>
                        let event = MonitorEvent.Connected :: :: call
                            id = id
                        push_monitor_event :: app.pending, event :: call
                    else => ()
        next_records.push :: record :: method
        scan = scan + 1
    let previous_count = app.monitors.count :: :: method
    let Result.Ok(previous_limit) = index_to_cint :: previous_count :: call else => return
    let previous_scan: CInt = 0
    repeat while previous_scan < previous_limit:
        let Result.Ok(previous_index) = cint_to_index :: previous_scan :: call else => return
        let still_present = false
        let previous_raw = app.monitors[previous_index].raw
        let previous_id = app.monitors[previous_index].id
        let previous_monitor = GlfwMonitor :: previous_raw :: call
        select find_monitor_index_in_list :: next_records, previous_monitor :: call:
            when Option.Some(_) => still_present = true
            when Option.None => still_present = false
        select:
            when emit_events && !still_present =>
                let event = MonitorEvent.Disconnected :: :: call
                    id = previous_id
                push_monitor_event :: app.pending, event :: call
            else => ()
        previous_scan = previous_scan + 1
    app.monitors = next_records
    return
fn find_monitor_index_in_list(read records: List[MonitorRecord], take monitor: Monitor) -> Option[Index]:
    let target_raw = glfw_monitor_raw_handle :: monitor :: call
    let count = records.count :: :: method
    let Result.Ok(limit) = index_to_cint :: count :: call else => return Option.None
    let scan: CInt = 0
    repeat while scan < limit:
        let Result.Ok(index) = cint_to_index :: scan :: call else => return Option.None
        select:
            when records[index].raw == target_raw => return Option.Some :: index :: call
            else => scan = scan + 1
    return Option.None
fn live_monitor_snapshot_from_record(read record: MonitorRecord) -> MonitorSnapshot:
    let monitor = GlfwMonitor :: record.raw :: call
    let name_text = monitor.name_text :: :: method
    let win32_names = monitor.win32_names :: :: method
    let available = monitor.available :: :: method
    let primary = monitor.primary :: :: method
    let screen_pos = monitor.screen_pos :: :: method
    let work_rect = monitor.work_rect :: :: method
    let physical_size_mm = monitor.physical_size_mm :: :: method
    let desktop_scale = monitor.desktop_scale :: :: method
    let current_video_mode = monitor.current_video_mode :: :: method
    let video_mode_count = monitor.video_mode_count :: :: method
