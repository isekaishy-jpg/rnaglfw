    fn current_context_window(read self) -> Result[Window, AppError]:
        select find_current_context_window_record_index :: self :: call:
            when Result.Ok(index) =>
                let raw_handle = glfw_window_raw_handle :: self.windows[index].window.raw :: call
                let window = live_window_from_raw_handle :: raw_handle, self.windows[index].window.id :: call
                return Result.Ok :: window :: call
            when Result.Err(err) => return Result.Err :: err :: call
    fn terminate(take self) -> Unit:
        let _ = self.destroy_all_windows :: :: method
        select:
            when self.drag_drop_runtime_initialized => uninitialize_drag_drop_runtime :: :: call
            else => ()
        glfw_terminate :: :: call
        return








