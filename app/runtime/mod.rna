        opengl_debug_context = opengl_debug_context
        context_no_error = context_no_error
        srgb_capable = srgb_capable
        doublebuffered = doublebuffered
        opacity = opacity
        cursor_mode = cursor_mode
        sticky_keys_enabled = sticky_keys_enabled
        sticky_mouse_buttons_enabled = sticky_mouse_buttons_enabled
        lock_key_mods_enabled = lock_key_mods_enabled
