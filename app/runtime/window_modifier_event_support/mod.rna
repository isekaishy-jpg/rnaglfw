        select:
            when self.has_pending_events :: :: method => ()
            else => self.pump_wait :: :: method
        return Result.Ok :: self.next_modifiers_changed_event_for :: id :: method :: call

    fn wait_timeout_next_modifiers_state(edit self, timeout: F64) -> Result[Option[Modifiers], AppError]:
        select:
            when self.has_pending_events :: :: method => ()
            else => self.pump_wait_timeout :: timeout :: method
        return Result.Ok :: self.next_modifiers_state :: :: method :: call

    fn wait_timeout_next_modifiers_state_for(edit self, id: WindowId, timeout: F64) -> Result[Option[Modifiers], AppError]:
        select:
            when self.has_pending_events :: :: method => ()
            else => self.pump_wait_timeout :: timeout :: method
        return Result.Ok :: self.next_modifiers_state_for :: id :: method :: call

    fn wait_timeout_next_modifiers_changed_event(edit self, timeout: F64) -> Result[Option[WindowEvent], AppError]:
        select:
            when self.has_pending_events :: :: method => ()
            else => self.pump_wait_timeout :: timeout :: method
        return Result.Ok :: self.next_modifiers_changed_event :: :: method :: call

    fn wait_timeout_next_modifiers_changed_event_for(edit self, id: WindowId, timeout: F64) -> Result[Option[WindowEvent], AppError]:
        select:
            when self.has_pending_events :: :: method => ()
            else => self.pump_wait_timeout :: timeout :: method
        return Result.Ok :: self.next_modifiers_changed_event_for :: id :: method :: call

    fn pending_modifiers_states(edit self) -> List[Modifiers]:
        let batch = self.take_event_batch :: :: method
        let states = batch.modifier_states :: :: method
        self.pending = batch.events
        return states

    fn pending_modifiers_states_for(edit self, id: WindowId) -> List[Modifiers]:
        let batch = self.take_event_batch :: :: method
