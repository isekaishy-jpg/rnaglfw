        let batch = self.wait_timeout_event_batch :: timeout :: method
        let states = batch.take_modifiers_states :: :: method
        self.pending = batch.events
        return states

    fn wait_timeout_modifiers_states_for(edit self, id: WindowId, timeout: F64) -> List[Modifiers]:
