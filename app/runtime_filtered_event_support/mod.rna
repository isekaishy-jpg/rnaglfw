    fn pending_created_window_ids(edit self) -> List[WindowId]:
        let ids = List[WindowId] :: :: call
        let remaining = List[AppEvent] :: :: call
        repeat while !self.pending.is_empty :: :: method:
            let event = self.pending.remove :: 0 :: method
            select event:
                when AppEvent.Window(window_event) =>
                    select window_event:
                        when WindowEvent.Created(id = id) => ids.push :: id :: method
                        when _ => ()
                    let wrapped = AppEvent.Window :: window_event :: call
                    remaining.push :: wrapped :: method
                when AppEvent.Monitor(monitor_event) =>
                    let wrapped = AppEvent.Monitor :: monitor_event :: call
                    remaining.push :: wrapped :: method
                when AppEvent.Joystick(joystick_event) =>
                    let wrapped = AppEvent.Joystick :: joystick_event :: call
                    remaining.push :: wrapped :: method
                when AppEvent.User(user_event) =>
                    let wrapped = AppEvent.User :: user_event :: call
                    remaining.push :: wrapped :: method
        self.pending = remaining
        return ids

