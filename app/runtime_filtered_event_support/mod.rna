use std.{List, Option, Result, Str}
use event.{AppEvent, JoystickEvent, JoystickId, MonitorEvent, MonitorId}
use event.{UserEvent, UserEventId, WindowCharacterData, WindowCharacterModsData}
use event.{WindowCursorData, WindowEvent, WindowKeyData, WindowMouseButtonData}
use event.{WindowMoveData, WindowScaleData, WindowScrollData, WindowSizeData}
use runtime.{App, AppError}
use window.{Theme, WindowId}

fn pending_pop_window_event_for(edit pending: List[AppEvent], id: WindowId) -> Option[WindowEvent]:
    let remaining = List[AppEvent] :: :: call
    let found: Option[WindowEvent] = Option.None
    let found_any = false
    repeat while !pending.is_empty :: :: method:
        let event = pending.remove :: 0 :: method
        select event:
            when AppEvent.Window(window_event) =>
                select:
                    when !found_any && window_event.window_id :: :: method == id =>
                        found = Option.Some :: window_event :: call
                        found_any = true
                    else =>
                        let wrapped = AppEvent.Window :: window_event :: call
                        remaining.push :: wrapped :: method
            when AppEvent.Monitor(monitor_event) =>
                let wrapped = AppEvent.Monitor :: monitor_event :: call
                remaining.push :: wrapped :: method
            when AppEvent.Joystick(joystick_event) =>
                let wrapped = AppEvent.Joystick :: joystick_event :: call
                remaining.push :: wrapped :: method
            when AppEvent.User(user_event) =>
                let wrapped = AppEvent.User :: user_event :: call
                remaining.push :: wrapped :: method
    pending = remaining
    return found

