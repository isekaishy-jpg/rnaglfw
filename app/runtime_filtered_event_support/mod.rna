use std.{List, Option, Result, Str}
use event.{AppEvent, AppEventBatch, AppEventKind, JoystickEvent, JoystickId, MonitorEvent, MonitorId}
use event.{UserEvent, UserEventId, WindowCharacterData, WindowCharacterModsData}
use event.{WindowCursorData, WindowEvent, WindowKeyData, WindowMouseButtonData}
use event.{WindowMoveData, WindowScaleData, WindowScrollData, WindowSizeData}
use runtime.{App, AppError}
use window.{Theme, WindowId}

fn batch_has_event_kind(read batch: AppEventBatch, kind: AppEventKind) -> Bool:
    let count = batch.events.count :: :: method
    let Result.Ok(limit) = count as Maybe[CInt] else => return false
    let scan: CInt = 0
    repeat while scan < limit:
        let Result.Ok(index) = scan as Maybe[Index] else => return false
        let event_kind = batch.events[index].kind :: :: method
        select kind:
            when AppEventKind.Window =>
                select event_kind:
                    when AppEventKind.Window => return true
                    when _ => ()
            when AppEventKind.Monitor =>
                select event_kind:
                    when AppEventKind.Monitor => return true
                    when _ => ()
            when AppEventKind.Joystick =>
                select event_kind:
                    when AppEventKind.Joystick => return true
                    when _ => ()
            when AppEventKind.User =>
                select event_kind:
                    when AppEventKind.User => return true
                    when _ => ()
        scan = scan + 1
    return false

impl App:
    fn pending_window_event_count(edit self) -> Index:
        let batch = self.take_event_batch :: :: method
        let count = batch.window_count :: :: method
        self.pending = batch.events
        return count

    fn pending_monitor_event_count(edit self) -> Index:
        let batch = self.take_event_batch :: :: method
        let count = batch.monitor_count :: :: method
