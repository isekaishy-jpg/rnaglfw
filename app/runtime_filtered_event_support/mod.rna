fn copy_monitor_event(read event: MonitorEvent) -> MonitorEvent:
    select event:
        when MonitorEvent.Connected(id = id) =>
            return MonitorEvent.Connected :: :: call
                id = id
        when MonitorEvent.Disconnected(id = id) =>
            return MonitorEvent.Disconnected :: :: call
                id = id

fn copy_joystick_event(read event: JoystickEvent) -> JoystickEvent:
    select event:
        when JoystickEvent.Connected(id = id, gamepad = gamepad) =>
            return JoystickEvent.Connected :: :: call
                id = id
                gamepad = gamepad
        when JoystickEvent.Disconnected(id = id) =>
            return JoystickEvent.Disconnected :: :: call
                id = id

fn copy_user_event(read event: UserEvent) -> UserEvent:
    select event:
        when UserEvent.Signaled(id = id) =>
            return UserEvent.Signaled :: :: call
                id = id

impl App:
    fn pending_window_event_count(edit self) -> Index:
        let batch = self.take_event_batch :: :: method
        let count = batch.window_count :: :: method
        self.pending = batch.events
        return count

    fn pending_monitor_event_count(edit self) -> Index:
        let batch = self.take_event_batch :: :: method
        let count = batch.monitor_count :: :: method
        self.pending = batch.events
        return count

    fn pending_joystick_event_count(edit self) -> Index:
        let batch = self.take_event_batch :: :: method
        let count = batch.joystick_count :: :: method
        self.pending = batch.events
        return count

    fn pending_user_event_count(edit self) -> Index:
        let batch = self.take_event_batch :: :: method
        let count = batch.user_count :: :: method
        self.pending = batch.events
        return count

    fn has_pending_window_events(edit self) -> Bool:
        return self.pending_window_event_count :: :: method != 0

    fn has_pending_monitor_events(edit self) -> Bool:
        return self.pending_monitor_event_count :: :: method != 0

    fn has_pending_joystick_events(edit self) -> Bool:
        return self.pending_joystick_event_count :: :: method != 0

    fn has_pending_user_events(edit self) -> Bool:
        return self.pending_user_event_count :: :: method != 0

    fn pending_window_events(edit self) -> List[WindowEvent]:
        let batch = self.take_event_batch :: :: method
        let events = batch.take_windows :: :: method
        self.pending = batch.events
        return events

    fn pending_monitor_events(edit self) -> List[MonitorEvent]:
        let events = List[MonitorEvent] :: :: call
        let remaining = List[AppEvent] :: :: call
        repeat while !self.pending.is_empty :: :: method:
            let event = self.pending.remove :: 0 :: method
            select event:
                when AppEvent.Window(window_event) =>
                    let wrapped = AppEvent.Window :: window_event :: call
                    remaining.push :: wrapped :: method
                when AppEvent.Monitor(monitor_event) =>
                    let copied = copy_monitor_event :: monitor_event :: call
                    events.push :: copied :: method
                    let wrapped = AppEvent.Monitor :: monitor_event :: call
                    remaining.push :: wrapped :: method
                when AppEvent.Joystick(joystick_event) =>
                    let wrapped = AppEvent.Joystick :: joystick_event :: call
                    remaining.push :: wrapped :: method
                when AppEvent.User(user_event) =>
                    let wrapped = AppEvent.User :: user_event :: call
                    remaining.push :: wrapped :: method
        self.pending = remaining
        return events

