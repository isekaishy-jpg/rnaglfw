    fn next_window_event_for(edit self, id: WindowId) -> Option[WindowEvent]:
        return pending_pop_window_event_for :: self.pending, id :: call

    fn next_monitor_event_for(edit self, id: MonitorId) -> Option[MonitorEvent]:
