impl App:
    fn next_created_window_event(edit self) -> Option[WindowEvent]:
        let batch = self.take_event_batch :: :: method
        let event = batch.pop_created_window_event :: :: method
        self.pending = batch.events
        return event

    fn next_destroyed_window_event(edit self) -> Option[WindowEvent]:
        let batch = self.take_event_batch :: :: method
        let event = batch.pop_destroyed_window_event :: :: method
