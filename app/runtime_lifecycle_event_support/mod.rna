use std.{List, Option, Result}
use event.{JoystickEvent, JoystickId, MonitorEvent, MonitorId, WindowEvent}
use runtime.{App, AppError, JoystickSnapshot, MonitorSnapshot, WindowSnapshot}
use joystick.Joystick
use window.{Monitor, Window}
use window.WindowId

fn windows_from_ids(read app: App, take ids: List[WindowId]) -> List[Window]:
    let windows = List[Window] :: :: call
    repeat while !ids.is_empty :: :: method:
        let id = ids.remove :: 0 :: method
        select app.window_option :: id :: method:
            when Option.Some(window) => windows.push :: window :: method
            when Option.None => ()
    return windows

fn window_snapshots_from_ids(read app: App, take ids: List[WindowId]) -> List[WindowSnapshot]:
    let snapshots = List[WindowSnapshot] :: :: call
    repeat while !ids.is_empty :: :: method:
        let id = ids.remove :: 0 :: method
        select app.window_snapshot_option :: id :: method:
            when Option.Some(snapshot) => snapshots.push :: snapshot :: method
            when Option.None => ()
    return snapshots

