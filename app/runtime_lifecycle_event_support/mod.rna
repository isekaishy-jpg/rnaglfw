    fn pending_created_windows(edit self) -> List[Window]:
        let ids = self.pending_created_window_ids :: :: method
        return windows_from_ids :: self, ids :: call

    fn pending_created_window_snapshots(edit self) -> List[WindowSnapshot]:
        let ids = self.pending_created_window_ids :: :: method
        return window_snapshots_from_ids :: self, ids :: call

