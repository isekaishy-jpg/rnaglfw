    fn poll_next_composition_data(edit self) -> Result[Option[WindowCompositionData], AppError]:
        select:
            when self.has_pending_events :: :: method => ()
            else => self.pump_poll :: :: method
        return Result.Ok :: self.next_composition_data :: :: method :: call

