use std.{List, Option, Result, Str}
use event.{WindowCompositionData, WindowEvent}
use runtime.{App, AppError}
use window.WindowId

impl App:
    fn next_composition_data(edit self) -> Option[WindowCompositionData]:
        let batch = self.take_event_batch :: :: method
        let data = batch.pop_composition_data :: :: method
        self.pending = batch.events
        return data

    fn next_composition_commit_text(edit self) -> Option[Str]:
        let batch = self.take_event_batch :: :: method
        let text = batch.pop_composition_commit_text :: :: method
        self.pending = batch.events
        return text

