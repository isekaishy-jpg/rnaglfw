    fn poll_next_hovered_file_path(edit self) -> Result[Option[Str], AppError]:
        select:
            when self.has_pending_events :: :: method => ()
            else => self.pump_poll :: :: method
        return Result.Ok :: self.next_hovered_file_path :: :: method :: call

