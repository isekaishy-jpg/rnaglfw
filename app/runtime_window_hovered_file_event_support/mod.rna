use std.{List, Option, Result, Str}
use event.WindowEvent
use runtime.{App, AppError}
use window.WindowId

impl App:
    fn next_hovered_file_path(edit self) -> Option[Str]:
        let batch = self.take_event_batch :: :: method
        let path = batch.pop_hovered_file_path :: :: method
        self.pending = batch.events
        return path

    fn next_hovered_file_path_for(edit self, id: WindowId) -> Option[Str]:
        let batch = self.take_event_batch :: :: method
        let path = batch.pop_hovered_file_path_for :: id :: method
        self.pending = batch.events
        return path

