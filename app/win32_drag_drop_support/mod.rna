use std.{Clone, Option, Result, Str}
use bridge.{TextDecodeError, maybe_c_string}
use glfw.{GlfwWindow, GlfwWindowRaw, glfw_window_raw_handle}
use mailbox.{WindowMailbox, push_window_dropped_paths_owned, push_window_hovered_file_cancelled}
use mailbox.{push_window_hovered_file_copy, push_window_hovered_file_owned}
use window.Win32HWnd

const S_OK: CInt = 0
const S_FALSE: CInt = 1
const E_NOINTERFACE: CInt = -2147467262
const CF_HDROP: CUShort = 15
const TYMED_HGLOBAL: CUInt = 1
const DVASPECT_CONTENT: CUInt = 1
const DROPEFFECT_NONE: CUInt = 0
const DROPEFFECT_COPY: CUInt = 1
const HEAP_ZERO_MEMORY: CUInt = 0x00000008
const DRAG_DROP_SUBCLASS_ID: USize = 0x44524F50USize
const POINTER_OFFSET_STEP: ISize = 1

type DropPathPointer = *edit CChar

#repr[c]
struct Win32Guid:
    pub data1: CUInt
    pub data2: CUShort
    pub data3: CUShort
    pub data4: [U8; 8]

#repr[c]
struct Win32PointL:
    pub x: CInt
    pub y: CInt

#repr[c]
struct FormatEtc:
    pub cf_format: CUShort
    pub ptd: *edit CVoid
    pub aspect: CUInt
    pub lindex: CInt
    pub tymed: CUInt

#repr[c]
struct StgMedium:
    pub tymed: CUInt
    pub handle: *edit CVoid
    pub p_unk_for_release: *edit CVoid

#repr[c]
struct DataObjectVTable:
    pub query_interface: extern["system"] fn(*edit CVoid, *read Win32Guid, *edit *edit CVoid) -> CInt
    pub add_ref: extern["system"] fn(*edit CVoid) -> CUInt
    pub release: extern["system"] fn(*edit CVoid) -> CUInt
    pub get_data: extern["system"] fn(*edit CVoid, *read FormatEtc, *edit StgMedium) -> CInt

#repr[c]
struct DataObject:
    pub vtable: *read DataObjectVTable

#repr[c]
struct DropTargetVTable:
    pub query_interface: extern["system"] fn(*edit CVoid, *read Win32Guid, *edit *edit CVoid) -> CInt
    pub add_ref: extern["system"] fn(*edit CVoid) -> CUInt
    pub release: extern["system"] fn(*edit CVoid) -> CUInt
    pub drag_enter: extern["system"] fn(*edit CVoid, *edit CVoid, CUInt, Win32PointL, *edit CUInt) -> CInt
    pub drag_over: extern["system"] fn(*edit CVoid, CUInt, Win32PointL, *edit CUInt) -> CInt
    pub drag_leave: extern["system"] fn(*edit CVoid) -> CInt
    pub drop: extern["system"] fn(*edit CVoid, *edit CVoid, CUInt, Win32PointL, *edit CUInt) -> CInt

#repr[c]
struct WindowDropTarget:
    pub vtable: *read DropTargetVTable
    pub owned_vtable: *edit DropTargetVTable
    pub mailbox: *edit WindowMailbox
    pub ref_count: CUInt
    pub hovering_files: CInt

struct OwnedDropPayload:
    pub count: CInt
    pub payload: *edit CVoid

