extern["system"] fn HeapFree(heap: *edit CVoid, flags: CUInt, memory: *edit CVoid) -> CInt

#link[name = "kernel32"]
#unsafe
extern["system"] fn WideCharToMultiByte(code_page: CUInt, flags: CUInt, source: *read U16, source_count: CInt, target: *edit CChar, target_count: CInt, default_char: *read CChar, used_default: *edit CInt) -> CInt

