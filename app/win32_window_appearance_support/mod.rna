    let raw = DWMWA_COLOR_DEFAULT
    select color:
        when Option.Some(value) => raw = colorref_from_rgba :: value :: call
        when Option.None => ()
    let Result.Ok(_) = apply_window_attribute_uint :: hwnd, DWMWA_TEXT_COLOR, raw, WindowAppearanceError.TitleTextColorUpdateFailed :: call else =>
        return Result.Err :: WindowAppearanceError.TitleTextColorUpdateFailed :: call
    let mailbox = window_mailbox :: window :: call
