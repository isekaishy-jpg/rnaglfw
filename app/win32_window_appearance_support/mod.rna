pub(package) fn current_window_corner_preference(read window: GlfwWindow) -> WindowCornerPreference:
    let mailbox = window_mailbox :: window :: call
    return mailbox_corner_preference :: mailbox :: call

pub(package) fn set_window_corner_preference(read window: GlfwWindow, read preference: WindowCornerPreference) -> Result[Unit, WindowAppearanceError]:
    let Result.Ok(hwnd) = window_handle :: window :: call else => return Result.Err :: WindowAppearanceError.NativeWindowUnavailable :: call
    let raw = window_corner_preference_raw :: preference :: call
    let Result.Ok(_) = apply_window_attribute_int :: hwnd, DWMWA_WINDOW_CORNER_PREFERENCE, raw, WindowAppearanceError.CornerPreferenceUpdateFailed :: call else =>
        return Result.Err :: WindowAppearanceError.CornerPreferenceUpdateFailed :: call
    let mailbox = window_mailbox :: window :: call
    set_mailbox_corner_preference :: mailbox, preference :: call
    return Result.Ok :: () :: call
