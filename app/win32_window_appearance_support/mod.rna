    let raw = DWMWA_COLOR_DEFAULT
    select color:
        when Option.Some(value) => raw = colorref_from_rgba :: value :: call
        when Option.None => ()
    let Result.Ok(_) = apply_window_attribute_uint :: hwnd, DWMWA_CAPTION_COLOR, raw, WindowAppearanceError.TitleBackgroundColorUpdateFailed :: call else =>
        return Result.Err :: WindowAppearanceError.TitleBackgroundColorUpdateFailed :: call
    let mailbox = window_mailbox :: window :: call
    set_mailbox_title_background_color :: mailbox, color :: call
    return Result.Ok :: () :: call

