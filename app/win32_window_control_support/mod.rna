use std.Result

use std.Option

use mailbox.WindowMailbox
use window.{Point, Size, UserAttentionType, WindowButtons, WindowControlError}
use window.{WindowLevel, WindowResizeDirection, Win32HMenu, Win32HWnd}
use window.{window_level_from_raw, window_level_raw}
use glfw.{GlfwPoint, GlfwWindow, GlfwWindowRaw, glfw_window_raw_handle}

const GWL_STYLE: CInt = 0 - 16
const GWL_EXSTYLE: CInt = 0 - 20
const GWLP_HWNDPARENT: CInt = 0 - 8
const GW_OWNER: CUInt = 4
const WS_MAXIMIZEBOX: ISize = 0x00010000
const WS_MINIMIZEBOX: ISize = 0x00020000
const WS_CLIPCHILDREN: ISize = 0x02000000
const WS_EX_TOOLWINDOW: ISize = 0x00000080
const WS_EX_APPWINDOW: ISize = 0x00040000
const WS_EX_NOREDIRECTIONBITMAP: ISize = 0x00200000
const MF_BYCOMMAND: CUInt = 0x00000000
const MF_ENABLED: CUInt = 0x00000000
const MF_GRAYED: CUInt = 0x00000001
const MF_DISABLED: CUInt = 0x00000002
const MENU_ERROR: CUInt = 0xFFFFFFFF
const SC_CLOSE: CUInt = 0xF060
const SC_MINIMIZE: CUInt = 0xF020
const SC_MAXIMIZE: CUInt = 0xF030
const FLASHW_STOP: CUInt = 0x00000000
const FLASHW_CAPTION: CUInt = 0x00000001
const FLASHW_TRAY: CUInt = 0x00000002
const FLASHW_ALL: CUInt = FLASHW_CAPTION | FLASHW_TRAY
const FLASHW_TIMERNOFG: CUInt = 0x0000000C
const WM_NULL: CUInt = 0x0000
const WM_SYSCOMMAND: CUInt = 0x0112
const TPM_RETURNCMD: CUInt = 0x0100
const SC_MOVE_BITS: USize = 0xF010USize
const SC_SIZE_BITS: USize = 0xF000USize
const HTCAPTION_BITS: USize = 0x0002USize
const HTLEFT_BITS: USize = 0x000AUSize
const HTRIGHT_BITS: USize = 0x000BUSize
const HTTOP_BITS: USize = 0x000CUSize
const HTTOPLEFT_BITS: USize = 0x000DUSize
const HTTOPRIGHT_BITS: USize = 0x000EUSize
const HTBOTTOM_BITS: USize = 0x000FUSize
const HTBOTTOMLEFT_BITS: USize = 0x0010USize
const HTBOTTOMRIGHT_BITS: USize = 0x0011USize
const SWP_NOSIZE: CUInt = 0x0001
const SWP_NOMOVE: CUInt = 0x0002
const SWP_NOZORDER: CUInt = 0x0004
const SWP_NOACTIVATE: CUInt = 0x0010
const SWP_FRAMECHANGED: CUInt = 0x0020
const DISABLED_MENU_MASK: CUInt = MF_GRAYED | MF_DISABLED
const WDA_NONE: CUInt = 0x00000000
const WDA_EXCLUDEFROMCAPTURE: CUInt = 0x00000011
const HWND_BOTTOM_ADDRESS: USize = 1USize
const WM_SIZING: CUInt = 0x0214
const WINDOW_CONTROL_SUBCLASS_ID: USize = 0x57434E54USize
const WMSZ_LEFT: USize = 1USize
const WMSZ_RIGHT: USize = 2USize
const WMSZ_TOP: USize = 3USize
const WMSZ_TOPLEFT: USize = 4USize
const WMSZ_TOPRIGHT: USize = 5USize
const WMSZ_BOTTOM: USize = 6USize
const WMSZ_BOTTOMLEFT: USize = 7USize
const WMSZ_BOTTOMRIGHT: USize = 8USize

