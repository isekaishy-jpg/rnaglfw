        let Result.Ok(raw_y0) = y0 as Maybe[CInt] else => return Result.Err :: RgbaImageError.SizeOutOfRange :: call
        let Result.Ok(raw_x1) = x1 as Maybe[CInt] else => return Result.Err :: RgbaImageError.SizeOutOfRange :: call
        let Result.Ok(raw_y1) = y1 as Maybe[CInt] else => return Result.Err :: RgbaImageError.SizeOutOfRange :: call
        let delta_x = rgba_abs_delta :: raw_x1 - raw_x0 :: call
        let delta_y = rgba_abs_delta :: raw_y1 - raw_y0 :: call
        let step_x = rgba_step_direction :: raw_x0, raw_x1 :: call
        let step_y = rgba_step_direction :: raw_y0, raw_y1 :: call
        let error = delta_x - delta_y
        let scan_x = raw_x0
        let scan_y = raw_y0
        let active = true
        repeat while active:
            let Result.Ok(plot_x) = scan_x as Maybe[Index] else => return Result.Err :: RgbaImageError.SizeOutOfRange :: call
            let Result.Ok(plot_y) = scan_y as Maybe[Index] else => return Result.Err :: RgbaImageError.SizeOutOfRange :: call
