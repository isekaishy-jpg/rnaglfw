fn cursor_mode_value(read mode: CursorMode) -> CInt:
    select mode:
        when CursorMode.Normal => return 0x00034001
        when CursorMode.Hidden => return 0x00034002
        when CursorMode.Disabled => return 0x00034003
        when CursorMode.Captured => return 0x00034004
    return 0x00034001
fn standard_cursor_value(cursor: StandardCursor) -> CInt:
    select cursor:
        when StandardCursor.Arrow => return 0x00036001
        when StandardCursor.IBeam => return 0x00036002
        when StandardCursor.Crosshair => return 0x00036003
        when StandardCursor.PointingHand => return 0x00036004
        when StandardCursor.ResizeEW => return 0x00036005
        when StandardCursor.ResizeNS => return 0x00036006
        when StandardCursor.ResizeNWSE => return 0x00036007
        when StandardCursor.ResizeNESW => return 0x00036008
        when StandardCursor.ResizeAll => return 0x00036009
        when StandardCursor.NotAllowed => return 0x0003600A
    return 0x00036001
pub fn create_standard_cursor(cursor: StandardCursor) -> Option[GlfwCursor]:
    let raw = standard_cursor_value :: cursor :: call
    return glfw_create_standard_cursor :: raw :: call
pub fn window_monitor_spec(monitor: Monitor, pos: Point, size: Size, refresh_rate: CInt) -> WindowMonitorSpec:
    return GlfwWindowMonitorSpec :: monitor, pos, size, refresh_rate :: call
pub fn fullscreen_window_spec(title: Str, read monitor: Monitor) -> Result[WindowSpec, WindowModeError]:
    select monitor.current_video_mode :: :: method:
        when Option.Some(mode) =>
            select either:
                when width: Result.Ok(width) <- mode.width as Maybe[Index]
                when height: Result.Ok(height) <- mode.height as Maybe[Index] =>
                    let spec = window_spec :: title, width, height :: call
                    let Result.Ok(_) = spec.fullscreen_using_current_video_mode :: monitor :: method else => return Result.Err :: WindowModeError.MissingVideoMode :: call
                    return Result.Ok :: spec :: call

            with Result.Err(_):
                width => return Result.Err :: WindowModeError.SizeOutOfRange :: call
                height => return Result.Err :: WindowModeError.SizeOutOfRange :: call
        when Option.None => return Result.Err :: WindowModeError.MissingVideoMode :: call
pub fn fullscreen_window_spec_with_video_mode(title: Str, read monitor: Monitor, read mode: VideoMode) -> Result[WindowSpec, WindowModeError]:
    let spec = window_spec :: title, 1, 1 :: call
    let Result.Ok(_) = spec.fullscreen_with_video_mode :: monitor, mode :: method else => return Result.Err :: WindowModeError.SizeOutOfRange :: call
    return Result.Ok :: spec :: call
pub(package) fn window_from_glfw(take raw: GlfwWindow, id: WindowId) -> Window:
    return Window :: raw, id :: call
pub(package) fn raw_window_id(read window: Window) -> WindowId:
    return window.id
impl WindowSpec:
    fn with_title(take self, take title: Str) -> WindowSpec:
        self.titled :: title :: method
        return self
    fn with_size(take self, width: Index, height: Index) -> WindowSpec:
        self.size :: width, height :: method
        return self
    fn with_fullscreen_using_current_video_mode(take self, read monitor: Monitor) -> Result[WindowSpec, WindowModeError]:
        select monitor.current_video_mode :: :: method:
            when Option.Some(mode) => return self.with_fullscreen_video_mode :: monitor, mode :: method
            when Option.None => return Result.Err :: WindowModeError.MissingVideoMode :: call
    fn with_fullscreen_video_mode(take self, read monitor: Monitor, read mode: VideoMode) -> Result[WindowSpec, WindowModeError]:
        select self.fullscreen_with_video_mode :: monitor, mode :: method:
            when Result.Ok(_) => return Result.Ok :: self :: call
            when Result.Err(error) => return Result.Err :: error :: call
