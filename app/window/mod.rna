    fn keyboard_snapshot(read self) -> KeyboardInputSnapshot:
        let keys_down = List[KeyCode] :: :: call
        let repeating_keys = List[KeyCode] :: :: call
        let raw_key = FIRST_KEY_RAW
        repeat while raw_key <= LAST_KEY_RAW:
            select known_key_code :: raw_key :: call:
                when Option.Some(key) =>
                    select self.key_state :: key :: method:
                        when InputAction.Press => keys_down.push :: key :: method
                        when InputAction.Repeat =>
                            keys_down.push :: key :: method
                            let repeat_key = key_from_raw :: raw_key :: call
                            repeating_keys.push :: repeat_key :: method
                        when _ => ()
                when Option.None => ()
            raw_key = raw_key + 1
        let sticky_keys_enabled = self.sticky_keys_enabled :: :: method
        let lock_key_mods_enabled = self.lock_key_mods_enabled :: :: method
        return KeyboardInputSnapshot :: :: call
            keys_down = keys_down
            repeating_keys = repeating_keys
            sticky_keys_enabled = sticky_keys_enabled
            lock_key_mods_enabled = lock_key_mods_enabled
    fn mouse_snapshot(read self) -> MouseInputSnapshot:
        let buttons_down = List[MouseButton] :: :: call
        let raw_button = FIRST_MOUSE_BUTTON_RAW
        repeat while raw_button <= LAST_MOUSE_BUTTON_RAW:
            let button = mouse_button_from_raw :: raw_button :: call
            select self.mouse_button_state :: button :: method:
