    fn set_outer_position(read self, x: CInt, y: CInt) -> Unit:
        let frame = self.frame_size :: :: method
        let inner_x = x + frame.left
        let inner_y = y + frame.top
        self.raw.set_pos :: inner_x, inner_y :: method
        return
    fn windowed_placement(read self) -> WindowPlacement:
        let pos = self.pos :: :: method
        let size = self.size :: :: method
