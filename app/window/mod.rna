            cursor_mode = cursor_mode
            sticky_mouse_buttons_enabled = sticky_mouse_buttons_enabled
            raw_mouse_motion_supported = raw_mouse_motion_supported
            raw_mouse_motion_enabled = raw_mouse_motion_enabled
