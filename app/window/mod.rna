    fn fullscreen_using_current_video_mode(edit self, read monitor: Monitor) -> Result[Unit, WindowModeError]:
        select monitor.current_video_mode :: :: method:
            when Option.Some(mode) =>
                select either:
                    when width: Result.Ok(width) <- mode.width as Maybe[Index]
                    when height: Result.Ok(height) <- mode.height as Maybe[Index] =>
                        self.width = width
                        self.height = height
                        self.refresh_rate = mode.refresh_rate
                        self.fullscreen_on :: monitor :: method
                        return Result.Ok :: () :: call

                with Result.Err(_):
                    width => return Result.Err :: WindowModeError.SizeOutOfRange :: call
                    height => return Result.Err :: WindowModeError.SizeOutOfRange :: call
            when Option.None => return Result.Err :: WindowModeError.MissingVideoMode :: call
    fn fullscreen_with_video_mode(edit self, read monitor: Monitor, read mode: VideoMode) -> Result[Unit, WindowModeError]:
        select either:
            when width: Result.Ok(width) <- mode.width as Maybe[Index]
            when height: Result.Ok(height) <- mode.height as Maybe[Index] =>
                self.width = width
                self.height = height
                self.refresh_rate = mode.refresh_rate
                self.fullscreen_on :: monitor :: method
                return Result.Ok :: () :: call

        with Result.Err(_):
            width => return Result.Err :: WindowModeError.SizeOutOfRange :: call
            height => return Result.Err :: WindowModeError.SizeOutOfRange :: call
