                when Option.Some(mode) =>
                    select:
                        when mode.width == width && mode.height == height && mode.refresh_rate == refresh_rate =>
                            return Option.Some :: mode :: call
                        else => ()
                when Option.None => ()
            scan = scan + 1
        return Option.None
    fn video_mode_with_max_refresh(read self, width: CInt, height: CInt) -> Option[VideoMode]:
        let modes = self.video_modes :: :: method
        let count = modes.count :: :: method
        let best_index: CInt = -1
        let best_refresh_rate: CInt = -1
        let scan: CInt = 0
        repeat while scan < count:
            select modes.at :: scan :: method:
                when Option.Some(mode) =>
                    select:
                        when mode.width == width && mode.height == height =>
                            select:
                                when best_index < 0 || mode.refresh_rate > best_refresh_rate =>
                                    best_index = scan
                                    best_refresh_rate = mode.refresh_rate
                                else => ()
                        else => ()
                when Option.None => ()
            scan = scan + 1
        select:
            when best_index >= 0 => return modes.at :: best_index :: method
            else => return Option.None
    fn supports_video_mode(read self, read mode: VideoMode) -> Bool:
        select self.video_mode_matching :: mode.width, mode.height, mode.refresh_rate :: method:
            when Option.Some(_) => return true
            when Option.None => return false
    fn gamma_ramp_snapshot(read self) -> Option[MonitorGammaRamp]:
        select self.gamma_ramp :: :: method:
            when Option.Some(ramp) =>
                let red = copy_gamma_channel :: ramp.red, ramp.size :: call
                let green = copy_gamma_channel :: ramp.green, ramp.size :: call
                let blue = copy_gamma_channel :: ramp.blue, ramp.size :: call
                let snapshot = MonitorGammaRamp :: red, green, blue :: call
                return Option.Some :: snapshot :: call
            when Option.None => return Option.None
    fn apply_gamma_ramp(read self, edit ramp: MonitorGammaRamp) -> Result[Unit, MonitorGammaRampError]:
        select ramp.raw_gamma_ramp :: :: method:
            when Result.Ok(raw_ramp) =>
                self.set_gamma_ramp :: raw_ramp :: method
                return Result.Ok :: () :: call
            when Result.Err(error) => return Result.Err :: error :: call
    fn apply_gamma(read self, gamma: F32) -> Unit:
        self.set_gamma :: gamma :: method
        return
impl MonitorGammaRamp:
    fn raw_gamma_ramp(edit self) -> Result[GlfwGammaRamp, MonitorGammaRampError]:
        select gamma_ramp_channel_count :: self :: call:
            when Result.Ok(size) =>
                let red_ptr: *edit CUShort = #unsafe &raw edit self.red[0]
                let green_ptr: *edit CUShort = #unsafe &raw edit self.green[0]
                let blue_ptr: *edit CUShort = #unsafe &raw edit self.blue[0]
                let raw = GlfwGammaRamp :: red_ptr, green_ptr, blue_ptr, size :: call
                return Result.Ok :: raw :: call
            when Result.Err(error) => return Result.Err :: error :: call
    fn size(read self) -> Index:
        return self.red.count :: :: method
    fn empty(read self) -> Bool:
        return self.red.is_empty :: :: method
