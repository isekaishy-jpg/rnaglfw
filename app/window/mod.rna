    fn set_icon_images(read self, edit images: List[RgbaImage]) -> Result[Unit, WindowIconError]:
        select:
            when images.is_empty :: :: method =>
                self.clear_icon :: :: method
                return Result.Ok :: () :: call
            else => ()
        let count = images.count :: :: method
        let Result.Ok(raw_count) = index_to_cint :: count :: call else => return Result.Err :: WindowIconError.CountOutOfRange :: call
        let raw_images = List[GlfwImage] :: :: call
        let scan: CInt = 0
        repeat while scan < raw_count:
            let Result.Ok(index) = scan as Maybe[Index] else => return Result.Err :: WindowIconError.CountOutOfRange :: call
            let image = images[index]
            let raw = image.raw_image_view :: :: method
            raw_images.push :: raw :: method
            scan = scan + 1
        let image_ptr: *read GlfwImage = #unsafe &raw read raw_images[0]
        self.raw.set_icon_array :: image_ptr, raw_count :: method
        return Result.Ok :: () :: call
