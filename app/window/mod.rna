const FIRST_KEY_RAW: CInt = 32
const LAST_KEY_RAW: CInt = 348
const FIRST_MOUSE_BUTTON_RAW: CInt = 0
const LAST_MOUSE_BUTTON_RAW: CInt = 7
fn gamma_channel_slot_at(base: *edit CUShort, index: CUInt) -> *edit CUShort:
    let slot: *edit CUShort = base
    let scan: CUInt = 0
    repeat while scan < index:
        slot = #unsafe slot.offset :: POINTER_OFFSET_STEP :: method
        scan = scan + 1
    return slot
fn copy_gamma_channel(base: *edit CUShort, count: CUInt) -> List[CUShort]:
    let values = List[CUShort] :: :: call
    select:
        when base.is_null :: :: method => return values
        else => ()
    let scan: CUInt = 0
    repeat while scan < count:
        let slot = gamma_channel_slot_at :: base, scan :: call
        let value: CUShort = #unsafe slot.load :: :: method
        values.push :: value :: method
        scan = scan + 1
    return values
fn gamma_ramp_channel_count(read ramp: MonitorGammaRamp) -> Result[CUInt, MonitorGammaRampError]:
    let red_count = ramp.red.count :: :: method
    let green_count = ramp.green.count :: :: method
    let blue_count = ramp.blue.count :: :: method
    select:
        when red_count == 0 => return Result.Err :: MonitorGammaRampError.Empty :: call
        when green_count != red_count => return Result.Err :: MonitorGammaRampError.ChannelLengthMismatch :: call
        when blue_count != red_count => return Result.Err :: MonitorGammaRampError.ChannelLengthMismatch :: call
        else => ()
    let Result.Ok(count) = red_count as Maybe[CUInt] else => return Result.Err :: MonitorGammaRampError.ChannelCountOutOfRange :: call
    return Result.Ok :: count :: call
fn known_key_code(raw: CInt) -> Option[KeyCode]:
    let key = key_from_raw :: raw :: call
    select key:
        when KeyCode.Unknown(_) => return Option.None
        when _ => return Option.Some :: key :: call
fn key_code_list_contains(read values: List[KeyCode], read key: KeyCode) -> Bool:
    let count = values.count :: :: method
    let Result.Ok(limit) = index_to_cint :: count :: call else => return false
    let target_raw = key_raw :: key :: call
    let scan: CInt = 0
    repeat while scan < limit:
        let Result.Ok(index) = scan as Maybe[Index] else => return false
        let current = values[index]
        let current_raw = key_raw :: current :: call
        select:
            when current_raw == target_raw => return true
            else => scan = scan + 1
    return false
fn mouse_button_list_contains(read values: List[MouseButton], read button: MouseButton) -> Bool:
    let count = values.count :: :: method
    let Result.Ok(limit) = index_to_cint :: count :: call else => return false
    let target_raw = mouse_button_raw :: button :: call
    let scan: CInt = 0
    repeat while scan < limit:
        let Result.Ok(index) = scan as Maybe[Index] else => return false
        let current = values[index]
        let current_raw = mouse_button_raw :: current :: call
        select:
            when current_raw == target_raw => return true
            else => scan = scan + 1
    return false
fn rgba_expected_byte_count(raw_width: CInt, raw_height: CInt) -> Result[Index, RgbaImageError]:
    let raw_pixel_count: CInt = raw_width * raw_height
    let raw_byte_count: CInt = raw_pixel_count * 4
    let Result.Ok(expected) = raw_byte_count as Maybe[Index] else => return Result.Err :: RgbaImageError.SizeOutOfRange :: call
    return Result.Ok :: expected :: call
fn rgba_checked_offset(read image: RgbaImage, x: Index, y: Index) -> Result[Index, RgbaImageError]:
    let Result.Ok(raw_x) = index_to_cint :: x :: call else => return Result.Err :: RgbaImageError.SizeOutOfRange :: call
    let Result.Ok(raw_y) = index_to_cint :: y :: call else => return Result.Err :: RgbaImageError.SizeOutOfRange :: call
    select:
        when raw_x >= image.width || raw_y >= image.height =>
            let error = RgbaImageError.CoordOutOfRange :: x, y, image.width, image.height :: call
            return Result.Err :: error :: call
        else => ()
    let raw_offset: CInt = ((raw_y * image.width) + raw_x) * 4
    let Result.Ok(offset) = raw_offset as Maybe[Index] else => return Result.Err :: RgbaImageError.SizeOutOfRange :: call
    return Result.Ok :: offset :: call
fn rgba_channel_index(offset: Index, delta: USize) -> Result[Index, RgbaImageError]:
    let Result.Ok(offset_wide) = offset as Maybe[USize] else => return Result.Err :: RgbaImageError.SizeOutOfRange :: call
    let target_wide: USize = offset_wide + delta
    let Result.Ok(target) = target_wide as Maybe[Index] else => return Result.Err :: RgbaImageError.SizeOutOfRange :: call
    return Result.Ok :: target :: call
fn rgba_checked_rect(read image: RgbaImage, x: Index, y: Index, width: Index, height: Index) -> Result[CheckedRgbaRect, RgbaImageError]:
    select:
        when width == 0 || height == 0 => return Result.Err :: RgbaImageError.RectZeroSize :: call
        else => ()
    let Result.Ok(raw_x) = index_to_cint :: x :: call else => return Result.Err :: RgbaImageError.SizeOutOfRange :: call
    let Result.Ok(raw_y) = index_to_cint :: y :: call else => return Result.Err :: RgbaImageError.SizeOutOfRange :: call
    let Result.Ok(raw_width) = index_to_cint :: width :: call else => return Result.Err :: RgbaImageError.SizeOutOfRange :: call
    let Result.Ok(raw_height) = index_to_cint :: height :: call else => return Result.Err :: RgbaImageError.SizeOutOfRange :: call
    select:
        when raw_x >= image.width || raw_y >= image.height =>
            let error = RgbaImageError.CoordOutOfRange :: x, y, image.width, image.height :: call
            return Result.Err :: error :: call
        else => ()
    let end_x: CInt = raw_x + raw_width - 1
    let end_y: CInt = raw_y + raw_height - 1
    select:
        when end_x >= image.width || end_y >= image.height =>
            let Result.Ok(last_x) = end_x as Maybe[Index] else => return Result.Err :: RgbaImageError.SizeOutOfRange :: call
            let Result.Ok(last_y) = end_y as Maybe[Index] else => return Result.Err :: RgbaImageError.SizeOutOfRange :: call
            let error = RgbaImageError.CoordOutOfRange :: last_x, last_y, image.width, image.height :: call
            return Result.Err :: error :: call
        else => ()
    let rect = CheckedRgbaRect :: raw_x, raw_y, raw_width, raw_height :: call
    return Result.Ok :: rect :: call
fn copy_rgba_bytes(read source: ByteBuffer) -> Result[ByteBuffer, RgbaImageError]:
    let count = source.byte_count :: :: method
    let copied = ByteBuffer :: :: call
    copied.reserve :: count :: method
    let Result.Ok(limit) = count as Maybe[USize] else => return Result.Err :: RgbaImageError.SizeOutOfRange :: call
    let scan: USize = 0USize
    repeat while scan < limit:
        let Result.Ok(index) = scan as Maybe[Index] else => return Result.Err :: RgbaImageError.SizeOutOfRange :: call
        let value = source[index]
        copied.push :: value :: method
        scan = scan + 1USize
    return Result.Ok :: copied :: call
pub fn rgba_image(width: Index, height: Index, take pixels: ByteBuffer) -> Result[RgbaImage, RgbaImageError]:
    select:
        when width == 0 => return Result.Err :: RgbaImageError.ZeroSize :: call
        when height == 0 => return Result.Err :: RgbaImageError.ZeroSize :: call
        else => ()
    let Result.Ok(raw_width) = index_to_cint :: width :: call else => return Result.Err :: RgbaImageError.SizeOutOfRange :: call
    let Result.Ok(raw_height) = index_to_cint :: height :: call else => return Result.Err :: RgbaImageError.SizeOutOfRange :: call
    let Result.Ok(expected) = rgba_expected_byte_count :: raw_width, raw_height :: call else => return Result.Err :: RgbaImageError.SizeOutOfRange :: call
    let actual = pixels.byte_count :: :: method
    select:
        when actual != expected => return Result.Err :: RgbaImageError.PixelCountMismatch :: call
        else => ()
    let image = RgbaImage :: :: call
        width = raw_width
        height = raw_height
        pixels = pixels
    return Result.Ok :: image :: call
pub fn rgba_color(red: U8, green: U8, blue: U8, alpha: U8) -> RgbaColor:
    return RgbaColor :: :: call
        red = red
        green = green
        blue = blue
        alpha = alpha
pub fn theme_from_raw(raw: CInt) -> Theme:
    select:
        when raw == 0 => return Theme.Dark
        else => return Theme.Light
pub fn theme_raw(read theme: Theme) -> CInt:
    select theme:
        when Theme.Light => return 1
        when Theme.Dark => return 0
    return 0
pub fn window_level_from_raw(raw: CInt) -> WindowLevel:
    select:
        when raw == 1 => return WindowLevel.AlwaysOnTop
        when raw == 2 => return WindowLevel.AlwaysOnBottom
        else => return WindowLevel.Normal
pub fn window_level_raw(read level: WindowLevel) -> CInt:
    select level:
        when WindowLevel.Normal => return 0
        when WindowLevel.AlwaysOnTop => return 1
        when WindowLevel.AlwaysOnBottom => return 2
    return 0
pub fn window_system_backdrop_from_raw(raw: CInt) -> WindowSystemBackdrop:
    select:
        when raw == 1 => return WindowSystemBackdrop.None
        when raw == 2 => return WindowSystemBackdrop.MainWindow
        when raw == 3 => return WindowSystemBackdrop.TransientWindow
        when raw == 4 => return WindowSystemBackdrop.TabbedWindow
        else => return WindowSystemBackdrop.Auto
pub fn window_system_backdrop_raw(read backdrop: WindowSystemBackdrop) -> CInt:
    select backdrop:
        when WindowSystemBackdrop.Auto => return 0
        when WindowSystemBackdrop.None => return 1
        when WindowSystemBackdrop.MainWindow => return 2
        when WindowSystemBackdrop.TransientWindow => return 3
        when WindowSystemBackdrop.TabbedWindow => return 4
    return 0
pub fn window_corner_preference_from_raw(raw: CInt) -> WindowCornerPreference:
    select:
        when raw == 1 => return WindowCornerPreference.DoNotRound
        when raw == 2 => return WindowCornerPreference.Round
        when raw == 3 => return WindowCornerPreference.RoundSmall
        else => return WindowCornerPreference.Default
pub fn window_corner_preference_raw(read preference: WindowCornerPreference) -> CInt:
    select preference:
        when WindowCornerPreference.Default => return 0
        when WindowCornerPreference.DoNotRound => return 1
        when WindowCornerPreference.Round => return 2
        when WindowCornerPreference.RoundSmall => return 3
    return 0
fn rgba_widen_channel(value: U8) -> Result[USize, RgbaImageError]:
    let Result.Ok(widened) = value as Maybe[USize] else => return Result.Err :: RgbaImageError.SizeOutOfRange :: call
    return Result.Ok :: widened :: call
fn rgba_narrow_channel(value: USize) -> Result[U8, RgbaImageError]:
    let Result.Ok(narrowed) = value as Maybe[U8] else => return Result.Err :: RgbaImageError.SizeOutOfRange :: call
    return Result.Ok :: narrowed :: call
fn rgba_blend_channel(dest: U8, source: U8, read factors: BlendFactors) -> Result[U8, RgbaImageError]:
    select:
        when factors.out_alpha == 0USize => return Result.Ok :: 0U8 :: call
        else => ()
    let Result.Ok(dest_wide) = rgba_widen_channel :: dest :: call else => return Result.Err :: RgbaImageError.SizeOutOfRange :: call
    let Result.Ok(source_wide) = rgba_widen_channel :: source :: call else => return Result.Err :: RgbaImageError.SizeOutOfRange :: call
    let source_premul: USize = source_wide * factors.source_alpha
    let dest_premul: USize = (dest_wide * factors.dest_alpha * factors.inv_source_alpha + 127USize) / 255USize
    let out_premul: USize = source_premul + dest_premul
    let out_value: USize = (out_premul + (factors.out_alpha / 2USize)) / factors.out_alpha
    return rgba_narrow_channel :: out_value :: call
fn rgba_abs_delta(value: CInt) -> CInt:
    select:
        when value < 0 => return 0 - value
        else => return value
    return value
fn rgba_step_direction(start: CInt, end: CInt) -> CInt:
    select:
        when start < end => return 1
        when start > end => return -1
        else => return 0
    return 0
pub fn rgba_blend_source_over(read dest: RgbaColor, read source: RgbaColor) -> Result[RgbaColor, RgbaImageError]:
    let Result.Ok(dest_alpha) = rgba_widen_channel :: dest.alpha :: call else => return Result.Err :: RgbaImageError.SizeOutOfRange :: call
    let Result.Ok(source_alpha) = rgba_widen_channel :: source.alpha :: call else => return Result.Err :: RgbaImageError.SizeOutOfRange :: call
    let inv_source_alpha: USize = 255USize - source_alpha
    let out_alpha_wide: USize = source_alpha + ((dest_alpha * inv_source_alpha + 127USize) / 255USize)
    let Result.Ok(out_alpha) = rgba_narrow_channel :: out_alpha_wide :: call else => return Result.Err :: RgbaImageError.SizeOutOfRange :: call
    let factors = BlendFactors :: dest_alpha, source_alpha, inv_source_alpha, out_alpha_wide :: call
    let Result.Ok(out_red) = rgba_blend_channel :: dest.red, source.red, factors :: call else =>
        return Result.Err :: RgbaImageError.SizeOutOfRange :: call
    let Result.Ok(out_green) = rgba_blend_channel :: dest.green, source.green, factors :: call else =>
        return Result.Err :: RgbaImageError.SizeOutOfRange :: call
    let Result.Ok(out_blue) = rgba_blend_channel :: dest.blue, source.blue, factors :: call else =>
        return Result.Err :: RgbaImageError.SizeOutOfRange :: call
    let color = rgba_color :: out_red, out_green, out_blue, out_alpha :: call
    return Result.Ok :: color :: call
pub fn monitor_gamma_ramp(take red: List[CUShort], take green: List[CUShort], take blue: List[CUShort]) -> Result[MonitorGammaRamp, MonitorGammaRampError]:
    let ramp = MonitorGammaRamp :: red, green, blue :: call
    select gamma_ramp_channel_count :: ramp :: call:
        when Result.Ok(_) => return Result.Ok :: ramp :: call
        when Result.Err(error) => return Result.Err :: error :: call
pub fn solid_rgba_image(width: Index, height: Index, read fill: RgbaColor) -> Result[RgbaImage, RgbaImageError]:
    select:
        when width == 0 => return Result.Err :: RgbaImageError.ZeroSize :: call
        when height == 0 => return Result.Err :: RgbaImageError.ZeroSize :: call
        else => ()
    let Result.Ok(raw_width) = index_to_cint :: width :: call else => return Result.Err :: RgbaImageError.SizeOutOfRange :: call
    let Result.Ok(raw_height) = index_to_cint :: height :: call else => return Result.Err :: RgbaImageError.SizeOutOfRange :: call
    let raw_pixel_count: CInt = raw_width * raw_height
    let Result.Ok(expected) = rgba_expected_byte_count :: raw_width, raw_height :: call else => return Result.Err :: RgbaImageError.SizeOutOfRange :: call
    let pixels = ByteBuffer :: :: call
    pixels.reserve :: expected :: method
    let scan: CInt = 0
    repeat while scan < raw_pixel_count:
        pixels.push :: fill.red :: method
        pixels.push :: fill.green :: method
        pixels.push :: fill.blue :: method
        pixels.push :: fill.alpha :: method
        scan = scan + 1
    return rgba_image :: width, height, pixels :: call
pub fn create_cursor_image(edit image: RgbaImage, xhot: CInt, yhot: CInt) -> Option[GlfwCursor]:
    let raw = image.raw_image :: :: method
    return glfw_create_cursor :: raw, xhot, yhot :: call
pub fn client_api_from_raw(raw: CInt) -> ClientApi:
    select:
        when raw == 0 => return ClientApi.None
        when raw == 0x00030001 => return ClientApi.OpenGl
        when raw == 0x00030002 => return ClientApi.OpenGlEs
        else => return ClientApi.Unknown :: raw :: call
pub fn client_api_raw(read api: ClientApi) -> CInt:
    select api:
        when ClientApi.None => return 0
        when ClientApi.OpenGl => return 0x00030001
        when ClientApi.OpenGlEs => return 0x00030002
        when ClientApi.Unknown(raw) => return raw
    return 0
pub fn opengl_profile_from_raw(raw: CInt) -> OpenGlProfile:
    select:
        when raw == 0 => return OpenGlProfile.Any
        when raw == 0x00032001 => return OpenGlProfile.Core
        when raw == 0x00032002 => return OpenGlProfile.Compat
        else => return OpenGlProfile.Unknown :: raw :: call
pub fn opengl_profile_raw(read profile: OpenGlProfile) -> CInt:
    select profile:
        when OpenGlProfile.Any => return 0
        when OpenGlProfile.Core => return 0x00032001
        when OpenGlProfile.Compat => return 0x00032002
        when OpenGlProfile.Unknown(raw) => return raw
    return 0
pub fn context_creation_api_from_raw(raw: CInt) -> ContextCreationApi:
    select:
        when raw == 0x00036001 => return ContextCreationApi.Native
        when raw == 0x00036002 => return ContextCreationApi.Egl
        when raw == 0x00036003 => return ContextCreationApi.OsMesa
        else => return ContextCreationApi.Unknown :: raw :: call
pub fn context_creation_api_raw(read api: ContextCreationApi) -> CInt:
    select api:
        when ContextCreationApi.Native => return 0x00036001
        when ContextCreationApi.Egl => return 0x00036002
        when ContextCreationApi.OsMesa => return 0x00036003
        when ContextCreationApi.Unknown(raw) => return raw
    return 0x00036001
pub fn cursor_mode_from_raw(raw: CInt) -> CursorMode:
    select:
        when raw == 0x00034001 => return CursorMode.Normal
        when raw == 0x00034002 => return CursorMode.Hidden
        when raw == 0x00034003 => return CursorMode.Disabled
        when raw == 0x00034004 => return CursorMode.Captured
        else => return CursorMode.Normal
pub fn cursor_mode_raw(read mode: CursorMode) -> CInt:
    return cursor_mode_value :: mode :: call
pub fn point(x: CInt, y: CInt) -> Point:
    return GlfwPoint :: x, y :: call
pub fn size(width: CInt, height: CInt) -> Size:
    return GlfwSize :: width, height :: call
pub fn rect(x: CInt, y: CInt, width: CInt, height: CInt) -> Rect:
    return GlfwRect :: x, y, width, height :: call
pub fn window_placement(pos: Point, size: Size) -> WindowPlacement:
    return WindowPlacement :: :: call
        pos = pos
        size = size
fn rect_right(read value: Rect) -> CInt:
    return value.x + value.width
fn rect_bottom(read value: Rect) -> CInt:
    return value.y + value.height
fn rect_center_x(read value: Rect) -> CInt:
    return value.x + value.width / 2
fn rect_center_y(read value: Rect) -> CInt:
    return value.y + value.height / 2
fn rect_intersection_area(read left: Rect, read right: Rect) -> CInt:
    let overlap_left = left.x
    select:
        when right.x > overlap_left => overlap_left = right.x
        else => ()
    let overlap_top = left.y
    select:
        when right.y > overlap_top => overlap_top = right.y
        else => ()
    let overlap_right = rect_right :: left :: call
    let right_right = rect_right :: right :: call
    select:
        when right_right < overlap_right => overlap_right = right_right
        else => ()
    let overlap_bottom = rect_bottom :: left :: call
    let right_bottom = rect_bottom :: right :: call
    select:
        when right_bottom < overlap_bottom => overlap_bottom = right_bottom
        else => ()
    select:
        when overlap_right <= overlap_left => return 0
        when overlap_bottom <= overlap_top => return 0
        else => return (overlap_right - overlap_left) * (overlap_bottom - overlap_top)
fn cint_to_i64(value: CInt) -> I64:
    let Result.Ok(widened) = value as Maybe[I64] else => return 0I64
    return widened
fn point_distance_squared(ax: CInt, ay: CInt, bx: CInt, by: CInt) -> I64:
    let dx = cint_to_i64 :: ax - bx :: call
    let dy = cint_to_i64 :: ay - by :: call
    return dx * dx + dy * dy
fn monitor_display_rect(read monitor: Monitor) -> Rect:
    let pos = monitor.screen_pos :: :: method
    select monitor.current_video_mode :: :: method:
        when Option.Some(mode) => return rect :: pos.x, pos.y, mode.width, mode.height :: call
        when Option.None => return monitor.work_rect :: :: method
fn current_monitor_for_window(read window: Window) -> Option[Monitor]:
    let placement = window.outer_placement :: :: method
    let window_rect = rect :: placement.pos.x, placement.pos.y, placement.size.width, placement.size.height :: call
    let window_center_x = rect_center_x :: window_rect :: call
    let window_center_y = rect_center_y :: window_rect :: call
    let monitors = glfw_monitors :: :: call
    let count = monitors.count :: :: method
    let best_monitor = glfw_monitor_none :: :: call
    let best_overlap: CInt = -1
    let best_distance: I64 = -1I64
    let scan: CInt = 0
    repeat while scan < count:
        let monitor = monitors.at :: scan :: method
        select:
            when !monitor.available :: :: method => ()
            else =>
                let display_rect = monitor_display_rect :: monitor :: call
                let overlap = rect_intersection_area :: window_rect, display_rect :: call
                let monitor_center_x = rect_center_x :: display_rect :: call
                let monitor_center_y = rect_center_y :: display_rect :: call
                let distance = point_distance_squared :: window_center_x, window_center_y, monitor_center_x, monitor_center_y :: call
                select:
                    when best_monitor.is_null :: :: method =>
                        best_monitor = monitor
                        best_overlap = overlap
                        best_distance = distance
                    when overlap > best_overlap =>
                        best_monitor = monitor
                        best_overlap = overlap
                        best_distance = distance
                    when overlap == best_overlap =>
                        select:
                            when best_overlap <= 0 && (best_distance < 0I64 || distance < best_distance) =>
                                best_monitor = monitor
                                best_overlap = overlap
                                best_distance = distance
                            else => ()
                    else => ()
        scan = scan + 1
    select:
        when best_monitor.is_null :: :: method => return Option.None
        else => return Option.Some :: best_monitor :: call
