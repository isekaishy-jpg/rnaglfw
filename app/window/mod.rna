const FIRST_KEY_RAW: CInt = 32
const LAST_KEY_RAW: CInt = 348
const FIRST_MOUSE_BUTTON_RAW: CInt = 0
const LAST_MOUSE_BUTTON_RAW: CInt = 7
fn known_key_code(raw: CInt) -> Option[KeyCode]:
    let key = key_from_raw :: raw :: call
    select key:
        when KeyCode.Unknown(_) => return Option.None
        when _ => return Option.Some :: key :: call
fn key_code_list_contains(read values: List[KeyCode], read key: KeyCode) -> Bool:
    let count = values.count :: :: method
    let Result.Ok(limit) = index_to_cint :: count :: call else => return false
    let target_raw = key_raw :: key :: call
    let scan: CInt = 0
    repeat while scan < limit:
        let Result.Ok(index) = scan as Maybe[Index] else => return false
        let current = values[index]
        let current_raw = key_raw :: current :: call
        select:
            when current_raw == target_raw => return true
            else => scan = scan + 1
    return false
fn mouse_button_list_contains(read values: List[MouseButton], read button: MouseButton) -> Bool:
    let count = values.count :: :: method
    let Result.Ok(limit) = index_to_cint :: count :: call else => return false
    let target_raw = mouse_button_raw :: button :: call
    let scan: CInt = 0
    repeat while scan < limit:
        let Result.Ok(index) = scan as Maybe[Index] else => return false
        let current = values[index]
        let current_raw = mouse_button_raw :: current :: call
        select:
            when current_raw == target_raw => return true
            else => scan = scan + 1
    return false
pub fn theme_from_raw(raw: CInt) -> Theme:
    select:
        when raw == 0 => return Theme.Dark
        else => return Theme.Light
pub fn theme_raw(read theme: Theme) -> CInt:
    select theme:
        when Theme.Light => return 1
        when Theme.Dark => return 0
    return 0
pub fn window_level_from_raw(raw: CInt) -> WindowLevel:
    select:
        when raw == 1 => return WindowLevel.AlwaysOnTop
        when raw == 2 => return WindowLevel.AlwaysOnBottom
        else => return WindowLevel.Normal
pub fn window_level_raw(read level: WindowLevel) -> CInt:
    select level:
        when WindowLevel.Normal => return 0
        when WindowLevel.AlwaysOnTop => return 1
        when WindowLevel.AlwaysOnBottom => return 2
    return 0
pub fn window_system_backdrop_from_raw(raw: CInt) -> WindowSystemBackdrop:
    select:
        when raw == 1 => return WindowSystemBackdrop.None
        when raw == 2 => return WindowSystemBackdrop.MainWindow
        when raw == 3 => return WindowSystemBackdrop.TransientWindow
        when raw == 4 => return WindowSystemBackdrop.TabbedWindow
        else => return WindowSystemBackdrop.Auto
pub fn window_system_backdrop_raw(read backdrop: WindowSystemBackdrop) -> CInt:
    select backdrop:
        when WindowSystemBackdrop.Auto => return 0
        when WindowSystemBackdrop.None => return 1
        when WindowSystemBackdrop.MainWindow => return 2
        when WindowSystemBackdrop.TransientWindow => return 3
        when WindowSystemBackdrop.TabbedWindow => return 4
    return 0
pub fn window_corner_preference_from_raw(raw: CInt) -> WindowCornerPreference:
    select:
        when raw == 1 => return WindowCornerPreference.DoNotRound
        when raw == 2 => return WindowCornerPreference.Round
        when raw == 3 => return WindowCornerPreference.RoundSmall
        else => return WindowCornerPreference.Default
pub fn window_corner_preference_raw(read preference: WindowCornerPreference) -> CInt:
    select preference:
        when WindowCornerPreference.Default => return 0
        when WindowCornerPreference.DoNotRound => return 1
        when WindowCornerPreference.Round => return 2
        when WindowCornerPreference.RoundSmall => return 3
    return 0
pub fn create_cursor_image(edit image: RgbaImage, xhot: CInt, yhot: CInt) -> Option[GlfwCursor]:
    let raw = image.raw_image :: :: method
    return glfw_create_cursor :: raw, xhot, yhot :: call
pub fn client_api_from_raw(raw: CInt) -> ClientApi:
    select:
        when raw == 0 => return ClientApi.None
        when raw == 0x00030001 => return ClientApi.OpenGl
        when raw == 0x00030002 => return ClientApi.OpenGlEs
        else => return ClientApi.Unknown :: raw :: call
pub fn client_api_raw(read api: ClientApi) -> CInt:
    select api:
        when ClientApi.None => return 0
        when ClientApi.OpenGl => return 0x00030001
        when ClientApi.OpenGlEs => return 0x00030002
        when ClientApi.Unknown(raw) => return raw
    return 0
pub fn opengl_profile_from_raw(raw: CInt) -> OpenGlProfile:
    select:
        when raw == 0 => return OpenGlProfile.Any
        when raw == 0x00032001 => return OpenGlProfile.Core
        when raw == 0x00032002 => return OpenGlProfile.Compat
        else => return OpenGlProfile.Unknown :: raw :: call
pub fn opengl_profile_raw(read profile: OpenGlProfile) -> CInt:
    select profile:
        when OpenGlProfile.Any => return 0
        when OpenGlProfile.Core => return 0x00032001
        when OpenGlProfile.Compat => return 0x00032002
        when OpenGlProfile.Unknown(raw) => return raw
    return 0
pub fn context_creation_api_from_raw(raw: CInt) -> ContextCreationApi:
    select:
        when raw == 0x00036001 => return ContextCreationApi.Native
        when raw == 0x00036002 => return ContextCreationApi.Egl
        when raw == 0x00036003 => return ContextCreationApi.OsMesa
        else => return ContextCreationApi.Unknown :: raw :: call
pub fn context_creation_api_raw(read api: ContextCreationApi) -> CInt:
    select api:
        when ContextCreationApi.Native => return 0x00036001
        when ContextCreationApi.Egl => return 0x00036002
        when ContextCreationApi.OsMesa => return 0x00036003
        when ContextCreationApi.Unknown(raw) => return raw
    return 0x00036001
pub fn cursor_mode_from_raw(raw: CInt) -> CursorMode:
    select:
        when raw == 0x00034001 => return CursorMode.Normal
        when raw == 0x00034002 => return CursorMode.Hidden
        when raw == 0x00034003 => return CursorMode.Disabled
        when raw == 0x00034004 => return CursorMode.Captured
        else => return CursorMode.Normal
pub fn cursor_grab_mode_from_cursor_mode(read mode: CursorMode) -> CursorGrabMode:
    select mode:
        when CursorMode.Captured => return CursorGrabMode.Confined
        when CursorMode.Disabled => return CursorGrabMode.Locked
        when _ => return CursorGrabMode.None
pub fn cursor_mode_raw(read mode: CursorMode) -> CInt:
    return cursor_mode_value :: mode :: call
pub fn point(x: CInt, y: CInt) -> Point:
    return GlfwPoint :: x, y :: call
pub fn size(width: CInt, height: CInt) -> Size:
    return GlfwSize :: width, height :: call
pub fn rect(x: CInt, y: CInt, width: CInt, height: CInt) -> Rect:
    return GlfwRect :: x, y, width, height :: call
pub fn window_placement(pos: Point, size: Size) -> WindowPlacement:
    return WindowPlacement :: :: call
        pos = pos
        size = size
pub fn window_buttons(close: Bool, minimize: Bool, maximize: Bool) -> WindowButtons:
    return WindowButtons :: :: call
        close = close
        minimize = minimize
        maximize = maximize
pub fn all_window_buttons() -> WindowButtons:
    return window_buttons :: true, true, true :: call
pub fn no_window_buttons() -> WindowButtons:
    return window_buttons :: false, false, false :: call
pub fn window_size_limits(read min: Size, read max: Size) -> WindowSizeLimits:
    return WindowSizeLimits :: :: call
        min_width = min.width
        min_height = min.height
        max_width = max.width
        max_height = max.height
pub fn window_min_size_limits(read min: Size) -> WindowSizeLimits:
    return WindowSizeLimits :: :: call
        min_width = min.width
        min_height = min.height
        max_width = 0 - 1
        max_height = 0 - 1
pub fn window_max_size_limits(read max: Size) -> WindowSizeLimits:
    return WindowSizeLimits :: :: call
        min_width = 0 - 1
        min_height = 0 - 1
        max_width = max.width
        max_height = max.height
pub fn window_no_size_limits() -> WindowSizeLimits:
    return WindowSizeLimits :: :: call
        min_width = 0 - 1
        min_height = 0 - 1
        max_width = 0 - 1
        max_height = 0 - 1

fn min_size_from_limits(read limits: WindowSizeLimits) -> Option[Size]:
    select:
        when limits.min_width < 0 => return Option.None
        when limits.min_height < 0 => return Option.None
        else =>
            let size = Size :: limits.min_width, limits.min_height :: call
            return Option.Some :: size :: call

fn max_size_from_limits(read limits: WindowSizeLimits) -> Option[Size]:
    select:
        when limits.max_width < 0 => return Option.None
        when limits.max_height < 0 => return Option.None
        else =>
            let size = Size :: limits.max_width, limits.max_height :: call
            return Option.Some :: size :: call
pub fn window_aspect_ratio(numerator: CInt, denominator: CInt) -> WindowAspectRatio:
    return WindowAspectRatio :: numerator, denominator :: call
pub fn window_aspect_ratio_from_size(read size: Size) -> WindowAspectRatio:
    return WindowAspectRatio :: size.width, size.height :: call
pub fn window_spec(title: Str, width: Index, height: Index) -> WindowSpec:
    let monitor: *edit GlfwMonitorRaw = null
    let share: *edit GlfwWindowRaw = null
    return WindowSpec :: :: call
        title = title
        width = width
        height = height
        x = 0 - 2147483647 - 1
        y = 0 - 2147483647 - 1
        monitor = monitor
        share = share
        visible = true
        resizable = true
        decorated = true
        focused = true
        auto_iconify = true
        floating = false
        maximized = false
        window_level = WindowLevel.Normal
        resize_increment_width = 0
        resize_increment_height = 0
        center_cursor = true
        transparent_framebuffer = false
        focus_on_show = true
        mouse_passthrough = false
        scale_to_monitor = true
        win32_drag_and_drop = true
        win32_clip_children = false
        win32_parent_window = null
        win32_owner_window = null
        win32_menu = null
        icon = Option.None
        win32_skip_taskbar = false
        win32_keyboard_menu = false
        win32_showdefault = false
        win32_no_redirection_bitmap = false
        win32_class_name = Option.None
        win32_taskbar_icon = Option.None
        win32_undecorated_shadow = false
        win32_system_backdrop = WindowSystemBackdrop.Auto
        win32_border_color = Option.None
        win32_title_background_color = Option.None
        win32_title_text_color = Option.None
        win32_corner_preference = WindowCornerPreference.Default
        cocoa_frame_name = Option.None
        x11_class_name = Option.None
        x11_instance_name = Option.None
        wayland_app_id = Option.None
        red_bits = 0 - 1
        green_bits = 0 - 1
        blue_bits = 0 - 1
        alpha_bits = 0 - 1
        depth_bits = 0 - 1
        stencil_bits = 0 - 1
        samples = 0 - 1
        refresh_rate = 0 - 1
        client_api = ClientApi.None
        context_version_major = 1
        context_version_minor = 0
        opengl_forward_compat = false
        opengl_debug_context = false
        opengl_profile = OpenGlProfile.Any
        context_creation_api = ContextCreationApi.Native
        context_no_error = false
        srgb_capable = false
        doublebuffer = true
