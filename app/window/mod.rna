    fn with_fullscreen_using_current_video_mode(take self, read monitor: Monitor) -> Result[WindowSpec, WindowModeError]:
        select monitor.current_video_mode :: :: method:
            when Option.Some(mode) => return self.with_fullscreen_video_mode :: monitor, mode :: method
            when Option.None => return Result.Err :: WindowModeError.MissingVideoMode :: call
    fn with_fullscreen_video_mode(take self, read monitor: Monitor, read mode: VideoMode) -> Result[WindowSpec, WindowModeError]:
        select self.fullscreen_with_video_mode :: monitor, mode :: method:
            when Result.Ok(_) => return Result.Ok :: self :: call
            when Result.Err(error) => return Result.Err :: error :: call
