    fn set_floating(edit self, floating: Bool) -> Unit:
        self.floating = floating
        select:
            when floating => self.window_level = WindowLevel.AlwaysOnTop
            else =>
                select self.window_level:
                    when WindowLevel.AlwaysOnTop => self.window_level = WindowLevel.Normal
                    else => ()
        return
