        let workarea = monitor.workarea :: :: method
        let size = self.size :: :: method
        let x = workarea.x + (workarea.width - size.width) / 2
        let y = workarea.y + (workarea.height - size.height) / 2
        self.raw.set_pos :: x, y :: method
        return
