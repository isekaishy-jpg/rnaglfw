impl KeyboardInputSnapshot:
    fn key_state(read self, read key: KeyCode) -> InputAction:
        select:
            when self.key_repeating :: key :: method => return InputAction.Repeat
            when self.key_down :: key :: method => return InputAction.Press
            else => return InputAction.Release
    fn key_pressed(read self, read key: KeyCode) -> Bool:
        select self.key_state :: key :: method:
            when InputAction.Release => return false
            when _ => return true
    fn key_down(read self, read key: KeyCode) -> Bool:
        return key_code_list_contains :: self.keys_down, key :: call
    fn key_repeating(read self, read key: KeyCode) -> Bool:
        return key_code_list_contains :: self.repeating_keys, key :: call
impl MouseInputSnapshot:
    fn button_state(read self, read button: MouseButton) -> InputAction:
        select:
            when self.button_down :: button :: method => return InputAction.Press
            else => return InputAction.Release
    fn button_pressed(read self, read button: MouseButton) -> Bool:
        return self.button_down :: button :: method
    fn button_down(read self, read button: MouseButton) -> Bool:
        return mouse_button_list_contains :: self.buttons_down, button :: call
impl WindowInputSnapshot:
    fn key_state(read self, read key: KeyCode) -> InputAction:
        return self.keyboard.key_state :: key :: method
    fn key_pressed(read self, read key: KeyCode) -> Bool:
        return self.keyboard.key_pressed :: key :: method
