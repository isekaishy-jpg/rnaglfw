use window.platform_win32.window_appearance_support.{set_window_border_color, set_window_corner_preference}
use window.platform_win32.window_appearance_support.{set_window_system_backdrop, set_window_title_background_color}
use window.platform_win32.window_appearance_support.{set_window_title_text_color, set_window_undecorated_shadow}
