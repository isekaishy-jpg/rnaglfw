use std.{Option, Result}

pub opaque type GlfwMonitorRaw
pub opaque type GlfwWindowRaw
pub opaque type GlfwCursorRaw

pub struct GlfwMonitor:
    pub(package) raw: *edit GlfwMonitorRaw

pub struct GlfwWindow:
    pub(package) raw: *edit GlfwWindowRaw

pub struct GlfwCursor:
    pub(package) raw: *edit GlfwCursorRaw

pub struct GlfwVersion:
    pub major: CInt
    pub minor: CInt
    pub revision: CInt

pub struct GlfwErrorReport:
    pub code: CInt
    pub description: *read CChar

pub struct GlfwCStringList:
    pub(package) base: *read *read CChar
    pub(package) count_value: CUInt

const POINTER_OFFSET_STEP: ISize = 1

impl GlfwVersion:
    fn major_number(read self) -> CInt:
        return self.major

    fn minor_number(read self) -> CInt:
        return self.minor

    fn revision_number(read self) -> CInt:
        return self.revision

impl GlfwErrorReport:
    fn code_value(read self) -> CInt:
        return self.code

    fn description_ptr(read self) -> *read CChar:
        return self.description

pub fn glfw_version_major(read version: GlfwVersion) -> CInt:
    return version.major

pub fn glfw_version_minor(read version: GlfwVersion) -> CInt:
    return version.minor

pub fn glfw_version_revision(read version: GlfwVersion) -> CInt:
    return version.revision

pub fn glfw_error_code(read report: GlfwErrorReport) -> CInt:
    return report.code

pub fn glfw_error_description(read report: GlfwErrorReport) -> *read CChar:
    return report.description

pub type GlfwGlProc = extern["c"] fn() -> CVoid
pub type GlfwVkProc = extern["c"] fn() -> CVoid
pub type GlfwAllocateCallback = extern["c"] fn(CSize, *edit CVoid) -> *edit CVoid
pub type GlfwReallocateCallback = extern["c"] fn(*edit CVoid, CSize, *edit CVoid) -> *edit CVoid
pub type GlfwDeallocateCallback = extern["c"] fn(*edit CVoid, *edit CVoid) -> CVoid
pub type GlfwErrorCallback = extern["c"] fn(CInt, *read CChar) -> CVoid

#repr[c]
pub struct GlfwAllocator:
    pub allocate: GlfwAllocateCallback
    pub reallocate: GlfwReallocateCallback
    pub deallocate: GlfwDeallocateCallback
    pub user: *edit CVoid

