use runa_app.{RgbaImage, rgba_color, solid_rgba_image}
use runa_app.size
use runa_app.{Size, window_aspect_ratio, window_aspect_ratio_from_size}
use runa_app.GlfwVkInstance
use runa_app.vulkan_window_spec
use runa_app.{window_max_size_limits, window_min_size_limits, window_no_size_limits}
use runa_app.window_size_limits
use runa_app.{vulkan_instance_proc_address, vulkan_required_instance_extensions}
use runa_app.vulkan_supported
use runa_app.window_spec
use runa_app.{window_spec_single_buffered, window_spec_with_color_bits}
use runa_app.{window_spec_with_cocoa_frame_name, window_spec_with_wayland_app_id}
use runa_app.{window_spec_with_client_api, window_spec_with_context_creation_api}
use runa_app.{window_spec_with_context_no_error, window_spec_with_depth_stencil_bits}
use runa_app.{window_spec_floating, window_spec_maximized, window_spec_unfocused}
use runa_app.{window_spec_with_multisampling, window_spec_with_opengl_forward_compat}
use runa_app.{window_spec_with_default_position, window_spec_with_mouse_passthrough}
use runa_app.window_spec_with_opengl_profile
use runa_app.window_spec_with_vulkan
use runa_app.{window_spec_with_default_refresh_rate, window_spec_with_refresh_rate}
use runa_app.{window_spec_with_position, window_spec_without_auto_iconify}
use runa_app.{window_spec_with_opengl_debug_context, window_spec_with_shared_context}
use runa_app.{window_spec_with_srgb, window_spec_without_center_cursor}
use runa_app.{window_spec_windowed, window_spec_without_cocoa_frame_name}
use runa_app.{window_spec_without_focus_on_show, window_spec_without_scale_to_monitor}
use runa_app.window_spec_without_win32_drag_and_drop
use runa_app.{window_spec_without_shared_context, window_spec_without_win32_class_name}
use runa_app.{window_spec_without_win32_menu, window_spec_without_win32_owner_window}
use runa_app.window_spec_without_win32_parent_window
use runa_app.{window_spec_with_win32_class_name, window_spec_with_win32_keyboard_menu}
use runa_app.{window_spec_with_win32_menu, window_spec_with_win32_no_redirection_bitmap}
use runa_app.{window_spec_with_win32_owner_window, window_spec_with_win32_parent_window}
use runa_app.window_spec_with_win32_showdefault
use runa_app.{win32_class_named_window_spec, win32_keyboard_menu_window_spec, win32_menu_window_spec, win32_no_redirection_bitmap_window_spec, win32_showdefault_window_spec}
use runa_app.{x11_class_named_window_spec, x11_instance_named_window_spec}
use runa_app.{window_spec_without_wayland_app_id, window_spec_without_x11_class_name}
use runa_app.window_spec_without_x11_instance_name
use runa_app.{window_spec_with_x11_class_name, window_spec_with_x11_instance_name}
use runa_app.{wayland_libdecor_mode_from_raw, wayland_libdecor_mode_raw}

fn main() -> I32:
    let helper_config = win32_app_init_config :: :: call
    select helper_config.platform:
        when PlatformOverride.Selected(Platform.Win32) => ()
        when _ => return 2
    let helper_config = app_init_config_with_joystick_hat_buttons :: helper_config, true :: call
    select helper_config.joystick_hat_buttons:
        when BoolOverride.Enabled => ()
        when _ => return 3
    let config = app_init_config :: :: call
    let config = config.on_platform :: Platform.Win32 :: method
    let config = config.with_joystick_hat_buttons :: true :: method
    let config = config.with_angle_platform_type :: AnglePlatformType.D3D11 :: method
    let config = config.with_cocoa_chdir_resources :: false :: method
    let config = config.with_cocoa_menubar :: false :: method
    let config = config.with_x11_xcb_vulkan_surface :: true :: method
    let config = config.with_wayland_libdecor :: WaylandLibdecorMode.Prefer :: method
    select config.platform:
        when PlatformOverride.Selected(Platform.Win32) => ()
        when _ => return 5
    select config.joystick_hat_buttons:
        when BoolOverride.Enabled => ()
        when _ => return 6
    select config.angle_platform_type:
        when AnglePlatformTypeOverride.Selected(AnglePlatformType.D3D11) => ()
        when _ => return 8
    select config.cocoa_chdir_resources:
        when BoolOverride.Disabled => ()
        when _ => return 9
    select config.cocoa_menubar:
        when BoolOverride.Disabled => ()
        when _ => return 10
    select config.x11_xcb_vulkan_surface:
        when BoolOverride.Enabled => ()
        when _ => return 11
    select config.wayland_libdecor:
        when WaylandLibdecorOverride.Selected(WaylandLibdecorMode.Prefer) => ()
        when _ => return 12
    let cleared_config = config.without_joystick_hat_buttons_override :: :: method
    let cleared_config = cleared_config.without_platform_override :: :: method
    let cleared_config = cleared_config.without_angle_platform_type_override :: :: method
    let cleared_config = cleared_config.without_cocoa_chdir_resources_override :: :: method
    let cleared_config = cleared_config.without_cocoa_menubar_override :: :: method
    let cleared_config = cleared_config.without_x11_xcb_vulkan_surface_override :: :: method
    let cleared_config = cleared_config.without_wayland_libdecor_override :: :: method
    select cleared_config.joystick_hat_buttons:
        when BoolOverride.Default => ()
        when _ => return 13
    select cleared_config.platform:
        when PlatformOverride.Default => ()
        when _ => return 14
    select cleared_config.angle_platform_type:
        when AnglePlatformTypeOverride.Default => ()
        when _ => return 15
    select cleared_config.cocoa_chdir_resources:
        when BoolOverride.Default => ()
        when _ => return 16
    select cleared_config.cocoa_menubar:
        when BoolOverride.Default => ()
        when _ => return 17
    select cleared_config.x11_xcb_vulkan_surface:
        when BoolOverride.Default => ()
        when _ => return 18
    select cleared_config.wayland_libdecor:
        when WaylandLibdecorOverride.Default => ()
        when _ => return 19
    let runtime_config = app_init_config :: :: call
    let runtime_config = runtime_config.on_platform :: Platform.Win32 :: method
    let runtime_config = runtime_config.with_joystick_hat_buttons :: true :: method
    select angle_platform_type_from_raw :: angle_platform_type_raw :: AnglePlatformType.D3D11 :: call :: call:
        when AnglePlatformType.D3D11 => ()
        when _ => return 20
    select wayland_libdecor_mode_from_raw :: wayland_libdecor_mode_raw :: WaylandLibdecorMode.Prefer :: call :: call:
        when WaylandLibdecorMode.Prefer => ()
        when _ => return 21
    let min_size = size :: 320, 240 :: call
    let max_size = size :: 1920, 1080 :: call
    let limits = window_size_limits :: min_size, max_size :: call
    select:
        when limits.min_width != 320 => return 22
        when limits.min_height != 240 => return 23
        when limits.max_width != 1920 => return 24
        when limits.max_height != 1080 => return 25
        else => ()
    let min_only_limits = window_min_size_limits :: min_size :: call
    select:
        when min_only_limits.min_width != 320 => return 26
        when min_only_limits.max_width != 0 - 1 => return 27
        else => ()
    let max_only_limits = window_max_size_limits :: max_size :: call
    select:
        when max_only_limits.min_width != 0 - 1 => return 28
        when max_only_limits.max_height != 1080 => return 29
        else => ()
    let no_limits = window_no_size_limits :: :: call
    select:
        when no_limits.min_width != 0 - 1 => return 30
        when no_limits.max_height != 0 - 1 => return 31
        else => ()
    let widescreen = window_aspect_ratio :: 16, 9 :: call
    select:
        when widescreen.numerator != 16 => return 32
        when widescreen.denominator != 9 => return 33
        else => ()
    let ratio_from_size = window_aspect_ratio_from_size :: max_size :: call
    select:
        when ratio_from_size.numerator != 1920 => return 34
        when ratio_from_size.denominator != 1080 => return 35
        else => ()
    select app_init_with :: runtime_config :: call:
        when Result.Ok(app) =>
            let version = app.version_info :: :: method
            select:
                when version.major < 3 =>
                    app.terminate :: :: method
                    return 101
                else => ()
            select app.version_string :: :: method:
                when Result.Ok(version_text) =>
                    select:
                        when version_text.is_empty :: :: method =>
                            app.terminate :: :: method
                            return 102
                        else => ()
                when Result.Err(_) =>
                    app.terminate :: :: method
                    return 103
            let current_platform = app.current_platform :: :: method
            select:
                when !app.platform_supported :: current_platform :: method =>
                    app.terminate :: :: method
                    return 104
                when !runtime_platform_supported :: current_platform :: call =>
                    app.terminate :: :: method
                    return 105
                else => ()
            select current_platform:
                when Platform.Win32 => ()
                when _ =>
                    app.terminate :: :: method
                    return 106
            select app.last_error :: :: method:
                when Result.Ok(Option.Some(_)) => ()
                when Result.Ok(Option.None) => ()
                when Result.Err(_) =>
                    app.terminate :: :: method
                    return 107
            let _ = app.timer_value :: :: method
            let frequency = app.timer_frequency :: :: method
            select:
                when frequency == 0U64 =>
                    app.terminate :: :: method
                    return 108
                else => ()
            app.set_time :: 0.0 :: method
            let elapsed = app.time :: :: method
            select:
                when elapsed < 0.0 =>
                    app.terminate :: :: method
                    return 109
                when elapsed > 2.0 =>
                    app.terminate :: :: method
                    return 110
                else => ()
            select app.clipboard_string :: :: method:
                when Result.Err(AppClipboardError.WindowUnavailable) => ()
                when _ =>
                    app.terminate :: :: method
                    return 111
            select app.set_clipboard_string :: "pre-window clipboard" :: method:
                when Result.Err(AppClipboardError.WindowUnavailable) => ()
                when _ =>
                    app.terminate :: :: method
                    return 112
            let spec = opengl_window_spec :: "runa_app smoke", 640, 480, 1, 0 :: call
            select spec.client_api:
                when ClientApi.OpenGl => ()
                when _ =>
                    app.terminate :: :: method
                    return 11
            select spec.opengl_profile:
                when OpenGlProfile.Any => ()
                when _ =>
                    app.terminate :: :: method
                    return 12
            select spec.context_creation_api:
                when ContextCreationApi.Native => ()
                when _ =>
                    app.terminate :: :: method
                    return 13
            let spec = window_spec_with_cocoa_frame_name :: spec, "runa-app-smoke-frame" :: call
            let spec = window_spec_with_x11_class_name :: spec, "runa-app-smoke" :: call
            let spec = window_spec_with_x11_instance_name :: spec, "runa-app-smoke-instance" :: call
            let spec = window_spec_with_wayland_app_id :: spec, "dev.runa.rnaglfw.app-smoke" :: call
            let es_spec = opengl_es_window_spec :: "es spec", 64, 64, 2, 0 :: call
            select es_spec.client_api:
                when ClientApi.OpenGlEs => ()
                when _ =>
                    app.terminate :: :: method
                    return 244
            select es_spec.context_creation_api:
                when ContextCreationApi.Native => ()
                when _ =>
                    app.terminate :: :: method
                    return 245
            let egl_spec = egl_opengl_window_spec :: "egl spec", 64, 64, 3, 3 :: call
            select egl_spec.client_api:
                when ClientApi.OpenGl => ()
                when _ =>
                    app.terminate :: :: method
                    return 246
            select egl_spec.context_creation_api:
                when ContextCreationApi.Egl => ()
                when _ =>
                    app.terminate :: :: method
                    return 247
            let egl_es_spec = egl_opengl_es_window_spec :: "egl es spec", 64, 64, 2, 0 :: call
            select egl_es_spec.client_api:
                when ClientApi.OpenGlEs => ()
                when _ =>
                    app.terminate :: :: method
                    return 248
            select egl_es_spec.context_creation_api:
                when ContextCreationApi.Egl => ()
                when _ =>
                    app.terminate :: :: method
                    return 249
            let osmesa_spec = osmesa_opengl_window_spec :: "osmesa spec", 64, 64, 3, 3 :: call
            select osmesa_spec.client_api:
                when ClientApi.OpenGl => ()
                when _ =>
                    app.terminate :: :: method
                    return 250
            select osmesa_spec.context_creation_api:
                when ContextCreationApi.OsMesa => ()
                when _ =>
                    app.terminate :: :: method
                    return 251
            let typed_client_api_spec = window_spec_with_client_api :: egl_spec, ClientApi.OpenGlEs :: call
            select typed_client_api_spec.client_api:
                when ClientApi.OpenGlEs => ()
                when _ =>
                    app.terminate :: :: method
                    return 252
            let typed_creation_api_spec = window_spec_with_context_creation_api :: typed_client_api_spec, ContextCreationApi.Egl :: call
            select typed_creation_api_spec.context_creation_api:
                when ContextCreationApi.Egl => ()
                when _ =>
                    app.terminate :: :: method
                    return 253
            let typed_profile_spec = window_spec_with_opengl_profile :: typed_creation_api_spec, OpenGlProfile.Core :: call
            select typed_profile_spec.opengl_profile:
                when OpenGlProfile.Core => ()
                when _ =>
                    app.terminate :: :: method
                    return 254
            let explicit_vulkan_spec = vulkan_window_spec :: "vulkan spec", 64, 64 :: call
            select explicit_vulkan_spec.client_api:
                when ClientApi.None => ()
                when _ =>
                    app.terminate :: :: method
                    return 265
            select explicit_vulkan_spec.context_creation_api:
                when ContextCreationApi.Native => ()
                when _ =>
                    app.terminate :: :: method
                    return 266
            let typed_vulkan_base = window_spec :: "typed vulkan", 64, 64 :: call
            let typed_vulkan_spec = window_spec_with_vulkan :: typed_vulkan_base :: call
            select typed_vulkan_spec.client_api:
                when ClientApi.None => ()
                when _ =>
                    app.terminate :: :: method
                    return 267
            let fluent_vulkan_base = opengl_window_spec :: "fluent vulkan", 64, 64, 3, 3 :: call
            let fluent_vulkan_spec = fluent_vulkan_base.with_vulkan :: :: method
            select fluent_vulkan_spec.client_api:
                when ClientApi.None => ()
                when _ =>
                    app.terminate :: :: method
                    return 268
            select fluent_vulkan_spec.opengl_profile:
                when OpenGlProfile.Any => ()
                when _ =>
                    app.terminate :: :: method
                    return 269
            let compat_spec = opengl_compat_window_spec :: "compat spec", 64, 64, 1, 0 :: call
            select compat_spec.opengl_profile:
                when OpenGlProfile.Compat => ()
                when _ =>
                    app.terminate :: :: method
                    return 14
            let hidden_mode = CursorMode.Hidden
            let hidden_mode_raw = cursor_mode_raw :: hidden_mode :: call
            select cursor_mode_from_raw :: hidden_mode_raw :: call:
                when CursorMode.Hidden => ()
                when _ =>
                    app.terminate :: :: method
                    return 15
            let debug_spec = opengl_debug_window_spec :: "debug spec", 64, 64, 1, 0 :: call
            select:
                when !debug_spec.opengl_debug_context =>
                    app.terminate :: :: method
                    return 18
                else => ()
            let srgb_spec = opengl_srgb_window_spec :: "srgb spec", 64, 64, 1, 0 :: call
            select:
                when !srgb_spec.srgb_capable =>
                    app.terminate :: :: method
                    return 19
                else => ()
            let debug_srgb_spec = opengl_debug_srgb_window_spec :: "debug srgb spec", 64, 64, 1, 0 :: call
            select:
                when !debug_srgb_spec.opengl_debug_context =>
                    app.terminate :: :: method
                    return 20
                when !debug_srgb_spec.srgb_capable =>
                    app.terminate :: :: method
                    return 21
                else => ()
            let core_debug_srgb_spec = opengl_core_debug_srgb_window_spec :: "core debug srgb spec", 64, 64, 1, 0 :: call
            select core_debug_srgb_spec.opengl_profile:
                when OpenGlProfile.Core => ()
                when _ =>
                    app.terminate :: :: method
                    return 212
            select:
                when !core_debug_srgb_spec.opengl_debug_context =>
                    app.terminate :: :: method
                    return 213
                when !core_debug_srgb_spec.srgb_capable =>
                    app.terminate :: :: method
                    return 214
                else => ()
            let compat_debug_srgb_spec = opengl_compat_debug_srgb_window_spec :: "compat debug srgb spec", 64, 64, 1, 0 :: call
            select compat_debug_srgb_spec.opengl_profile:
                when OpenGlProfile.Compat => ()
                when _ =>
                    app.terminate :: :: method
                    return 215
            select:
                when !compat_debug_srgb_spec.opengl_debug_context =>
                    app.terminate :: :: method
                    return 216
                when !compat_debug_srgb_spec.srgb_capable =>
                    app.terminate :: :: method
                    return 217
                else => ()
            let positioned_spec = positioned_window_spec :: "positioned spec", 64, 64, 123, 456 :: call
            select:
                when positioned_spec.x != 123 =>
                    app.terminate :: :: method
                    return 219
                when positioned_spec.y != 456 =>
                    app.terminate :: :: method
                    return 220
                else => ()
            let unfocused_spec = unfocused_window_spec :: "unfocused spec", 64, 64 :: call
            select:
                when unfocused_spec.focused =>
                    app.terminate :: :: method
                    return 221
                else => ()
            let floating_spec = floating_window_spec :: "floating spec", 64, 64 :: call
            select:
                when !floating_spec.floating =>
                    app.terminate :: :: method
                    return 222
                else => ()
            let maximized_spec = maximized_window_spec :: "maximized spec", 64, 64 :: call
            select:
                when !maximized_spec.maximized =>
                    app.terminate :: :: method
                    return 223
                else => ()
            let mouse_passthrough_spec = mouse_passthrough_window_spec :: "mouse passthrough spec", 64, 64 :: call
            select:
                when !mouse_passthrough_spec.mouse_passthrough =>
                    app.terminate :: :: method
                    return 224
                else => ()
            let keyboard_menu_spec = win32_keyboard_menu_window_spec :: "keyboard menu spec", 64, 64 :: call
            select:
                when !keyboard_menu_spec.win32_keyboard_menu =>
                    app.terminate :: :: method
                    return 225
                else => ()
            let showdefault_spec = win32_showdefault_window_spec :: "showdefault spec", 64, 64 :: call
            select:
                when !showdefault_spec.win32_showdefault =>
                    app.terminate :: :: method
                    return 226
                else => ()
            let fake_menu: Win32HMenu = #unsafe raw_pointer_from_address_edit[CVoid] :: 9USize :: call
            let menu_spec = win32_menu_window_spec :: "menu spec", 64, 64, fake_menu :: call
            select:
                when menu_spec.win32_menu != fake_menu =>
                    app.terminate :: :: method
                    return 241
                else => ()
            let win32_class_spec = win32_class_named_window_spec :: "win32 class spec", 64, 64, "rnaglfw-class" :: call
            select win32_class_spec.win32_class_name:
                when Option.Some(name) =>
                    select:
                        when name.is_empty :: :: method =>
                            app.terminate :: :: method
                            return 242
                        else => ()
                when Option.None =>
                    app.terminate :: :: method
                    return 243
            let cocoa_frame_spec = cocoa_frame_named_window_spec :: "cocoa frame spec", 64, 64, "rnaglfw-frame" :: call
            select cocoa_frame_spec.cocoa_frame_name:
                when Option.Some(name) =>
                    select:
                        when name.is_empty :: :: method =>
                            app.terminate :: :: method
                            return 227
                        else => ()
                when Option.None =>
                    app.terminate :: :: method
                    return 228
            let x11_class_spec = x11_class_named_window_spec :: "x11 class spec", 64, 64, "rnaglfw-class" :: call
            select x11_class_spec.x11_class_name:
                when Option.Some(name) =>
                    select:
                        when name.is_empty :: :: method =>
                            app.terminate :: :: method
                            return 229
                        else => ()
                when Option.None =>
                    app.terminate :: :: method
                    return 230
            let x11_instance_spec = x11_instance_named_window_spec :: "x11 instance spec", 64, 64, "rnaglfw-instance" :: call
            select x11_instance_spec.x11_instance_name:
                when Option.Some(name) =>
                    select:
                        when name.is_empty :: :: method =>
                            app.terminate :: :: method
                            return 231
                        else => ()
                when Option.None =>
                    app.terminate :: :: method
                    return 240
            let wayland_app_id_spec = wayland_app_id_window_spec :: "wayland app id spec", 64, 64, "dev.runa.rnaglfw.spec" :: call
            select wayland_app_id_spec.wayland_app_id:
                when Option.Some(app_id) =>
                    select:
                        when app_id.is_empty :: :: method =>
                            app.terminate :: :: method
                            return 241
                        else => ()
                when Option.None =>
                    app.terminate :: :: method
                    return 242
            let cleared_named_spec = window_spec :: "cleared named spec", 64, 64 :: call
            let cleared_named_spec = window_spec_with_cocoa_frame_name :: cleared_named_spec, "frame-name" :: call
            let cleared_named_spec = window_spec_with_x11_class_name :: cleared_named_spec, "class-name" :: call
            let cleared_named_spec = window_spec_with_x11_instance_name :: cleared_named_spec, "instance-name" :: call
            let cleared_named_spec = window_spec_with_wayland_app_id :: cleared_named_spec, "dev.runa.clear" :: call
            let cleared_named_spec = window_spec_without_cocoa_frame_name :: cleared_named_spec :: call
            let cleared_named_spec = window_spec_without_x11_class_name :: cleared_named_spec :: call
            let cleared_named_spec = window_spec_without_x11_instance_name :: cleared_named_spec :: call
            let cleared_named_spec = window_spec_without_wayland_app_id :: cleared_named_spec :: call
            select cleared_named_spec.cocoa_frame_name:
                when Option.None => ()
                when _ =>
                    app.terminate :: :: method
                    return 1140
            select cleared_named_spec.x11_class_name:
                when Option.None => ()
                when _ =>
                    app.terminate :: :: method
                    return 1141
            select cleared_named_spec.x11_instance_name:
                when Option.None => ()
                when _ =>
                    app.terminate :: :: method
                    return 1142
            select cleared_named_spec.wayland_app_id:
                when Option.None => ()
                when _ =>
                    app.terminate :: :: method
                    return 1143
            let multisample_base = opengl_window_spec :: "multisample base", 64, 64, 1, 0 :: call
            let multisample_spec = window_spec_with_multisampling :: multisample_base, 4 :: call
            select:
                when multisample_spec.samples != 4 =>
                    app.terminate :: :: method
                    return 22
