fn check_primary_monitor_snapshot(read primary_monitor_snapshot: MonitorSnapshot) -> I32:
    select:
        when !primary_monitor_snapshot.available :: :: method => return 457
        when !primary_monitor_snapshot.primary :: :: method => return 458
        else => ()
    select primary_monitor_snapshot.first_video_mode :: :: method:
        when Option.Some(first_mode) =>
            select:
                when !primary_monitor_snapshot.supports_video_mode :: first_mode :: method => return 459
                else => ()
        when Option.None =>
            select:
                when !primary_monitor_snapshot.video_modes.is_empty :: :: method => return 460
                else => ()
    let has_gamma_ramp = primary_monitor_snapshot.has_gamma_ramp :: :: method
    select primary_monitor_snapshot.gamma_ramp:
        when Option.Some(_) =>
            select:
                when !has_gamma_ramp => return 461
                else => ()
        when Option.None =>
            select:
                when has_gamma_ramp => return 462
                else => ()
    select primary_monitor_snapshot.current_video_mode:
        when Option.Some(current_mode) =>
            select:
                when !primary_monitor_snapshot.supports_video_mode :: current_mode :: method => return 463
                else => ()
            select primary_monitor_snapshot.video_mode_matching :: current_mode.width, current_mode.height, current_mode.refresh_rate :: method:
                when Option.Some(found_mode) =>
                    select:
                        when found_mode.width != current_mode.width => return 464
                        when found_mode.height != current_mode.height => return 465
                        when found_mode.refresh_rate != current_mode.refresh_rate => return 466
                        else => ()
                when Option.None => return 467
            select primary_monitor_snapshot.fullscreen_spec :: :: method:
                when Result.Ok(spec) =>
                    select:
                        when spec.pos.x != primary_monitor_snapshot.screen_pos.x => return 468
                        when spec.pos.y != primary_monitor_snapshot.screen_pos.y => return 469
                        when spec.size.width != current_mode.width => return 470
                        when spec.size.height != current_mode.height => return 471
                        when spec.refresh_rate != current_mode.refresh_rate => return 472
                        else => ()
                when Result.Err(_) => return 473
            select primary_monitor_snapshot.fullscreen_spec_with_video_mode :: current_mode :: method:
                when Result.Ok(spec) =>
                    select:
                        when spec.pos.x != primary_monitor_snapshot.screen_pos.x => return 474
                        when spec.pos.y != primary_monitor_snapshot.screen_pos.y => return 475
                        when spec.size.width != current_mode.width => return 476
                        when spec.size.height != current_mode.height => return 477
                        when spec.refresh_rate != current_mode.refresh_rate => return 478
                        else => ()
                when Result.Err(_) => return 479
        when Option.None =>
            select primary_monitor_snapshot.fullscreen_spec :: :: method:
                when Result.Ok(_) => return 480
                when Result.Err(_) => ()
    return 0

fn check_joystick_snapshot(read joystick_snapshot: JoystickSnapshot) -> I32:
    select:
        when !joystick_snapshot.available :: :: method => return 481
        when joystick_snapshot.axis_count :: :: method != joystick_snapshot.axes.count :: :: method => return 482
        when joystick_snapshot.button_count :: :: method != joystick_snapshot.buttons.count :: :: method => return 483
        when joystick_snapshot.hat_count :: :: method != joystick_snapshot.hats.count :: :: method => return 484
        else => ()
    select:
        when joystick_snapshot.axes.is_empty :: :: method =>
            select joystick_snapshot.axis_at :: 0 :: method:
                when Option.Some(_) => return 485
                when Option.None => ()
        else =>
            select joystick_snapshot.axis_at :: 0 :: method:
                when Option.Some(axis_value) =>
                    select:
                        when axis_value != joystick_snapshot.axes[0] => return 486
                        else => ()
                when Option.None => return 487
    select:
        when joystick_snapshot.buttons.is_empty :: :: method =>
            select joystick_snapshot.button_at :: 0 :: method:
                when Option.Some(_) => return 488
                when Option.None => ()
        else =>
            select joystick_snapshot.button_at :: 0 :: method:
                when Option.Some(button_value) =>
                    select:
                        when button_value != joystick_snapshot.buttons[0] => return 489
                        else => ()
                when Option.None => return 490
    select:
        when joystick_snapshot.hats.is_empty :: :: method =>
            select joystick_snapshot.hat_at :: 0 :: method:
                when Option.Some(_) => return 491
                when Option.None => ()
        else =>
            select joystick_snapshot.hat_at :: 0 :: method:
                when Option.Some(hat_value) =>
                    select:
                        when hat_value.up :: :: method != joystick_snapshot.hats[0].up :: :: method => return 492
                        when hat_value.right :: :: method != joystick_snapshot.hats[0].right :: :: method => return 493
                        when hat_value.down :: :: method != joystick_snapshot.hats[0].down :: :: method => return 494
                        when hat_value.left :: :: method != joystick_snapshot.hats[0].left :: :: method => return 495
                        else => ()
                when Option.None => return 496
    select joystick_snapshot.gamepad_state:
        when Option.Some(gamepad_state) =>
            select:
                when !joystick_snapshot.has_gamepad_state :: :: method => return 497
                when joystick_snapshot.gamepad_button_down :: GamepadButton.A :: method != gamepad_state.button_down :: GamepadButton.A :: method => return 498
                when joystick_snapshot.gamepad_button_up :: GamepadButton.A :: method != gamepad_state.button_up :: GamepadButton.A :: method => return 499
                when joystick_snapshot.gamepad_axis :: GamepadAxis.LeftX :: method != gamepad_state.axis :: GamepadAxis.LeftX :: method => return 500
                when joystick_snapshot.left_stick_x :: :: method != gamepad_state.left_stick_x :: :: method => return 501
                when joystick_snapshot.left_stick_y :: :: method != gamepad_state.left_stick_y :: :: method => return 502
                when joystick_snapshot.right_stick_x :: :: method != gamepad_state.right_stick_x :: :: method => return 503
                when joystick_snapshot.right_stick_y :: :: method != gamepad_state.right_stick_y :: :: method => return 504
                when joystick_snapshot.left_trigger :: :: method != gamepad_state.left_trigger :: :: method => return 505
                when joystick_snapshot.right_trigger :: :: method != gamepad_state.right_trigger :: :: method => return 506
                else => ()
        when Option.None =>
            select:
                when joystick_snapshot.has_gamepad_state :: :: method => return 507
                when joystick_snapshot.gamepad_button_down :: GamepadButton.A :: method => return 508
                when !joystick_snapshot.gamepad_button_up :: GamepadButton.A :: method => return 509
                when joystick_snapshot.gamepad_axis :: GamepadAxis.LeftX :: method != 0.0 => return 510
                when joystick_snapshot.left_stick_x :: :: method != 0.0 => return 511
                when joystick_snapshot.left_stick_y :: :: method != 0.0 => return 512
                when joystick_snapshot.right_stick_x :: :: method != 0.0 => return 513
                when joystick_snapshot.right_stick_y :: :: method != 0.0 => return 514
                when joystick_snapshot.left_trigger :: :: method != 0.0 => return 515
                when joystick_snapshot.right_trigger :: :: method != 0.0 => return 516
                else => ()
    return 0

fn check_snapshot_window_take(take snapshot: AppSnapshot, window_id: WindowId) -> I32:
    select snapshot.take_window :: window_id :: method:
        when Option.Some(window_snapshot) =>
            select:
                when window_snapshot.window.id != window_id => return 503
                when snapshot.has_window :: window_id :: method => return 504
                else => ()
        when Option.None => return 505
    return 0

fn check_snapshot_current_context_take(take snapshot: AppSnapshot) -> I32:
    select snapshot.take_current_context_window :: :: method:
        when Option.Some(_) => return 506
        when Option.None => return 0

fn check_snapshot_window_lookup(read snapshot: AppSnapshot, window_id: WindowId) -> I32:
    select snapshot.window :: window_id :: method:
        when Option.Some(window_snapshot) =>
            select:
                when window_snapshot.window.id != window_id => return 507
                else => ()
        when Option.None => return 508
    select snapshot.window :: window_id + 1000 :: method:
        when Option.Some(_) => return 509
        when Option.None => ()
    return 0

fn check_snapshot_current_context_lookup(read snapshot: AppSnapshot) -> I32:
    select snapshot.current_context_window :: :: method:
        when Option.Some(_) => return 510
        when Option.None => return 0

fn check_snapshot_primary_monitor_lookup(read snapshot: AppSnapshot) -> I32:
    select snapshot.primary_monitor_id:
        when Option.Some(primary_monitor_id) =>
            select snapshot.primary_monitor :: :: method:
                when Option.Some(monitor_snapshot) =>
                    select:
                        when monitor_snapshot.id != primary_monitor_id => return 511
                        else => ()
                when Option.None => return 512
            select snapshot.monitor :: primary_monitor_id :: method:
                when Option.Some(monitor_snapshot) =>
                    select:
                        when monitor_snapshot.id != primary_monitor_id => return 513
                        else => ()
                when Option.None => return 514
        when Option.None =>
            select snapshot.primary_monitor :: :: method:
                when Option.Some(_) => return 515
                when Option.None => ()
    return 0

fn check_snapshot_primary_monitor_take(take snapshot: AppSnapshot) -> I32:
    select snapshot.primary_monitor_id:
        when Option.Some(primary_monitor_id) =>
            select snapshot.take_primary_monitor :: :: method:
                when Option.Some(monitor_snapshot) =>
                    select:
                        when monitor_snapshot.id != primary_monitor_id => return 516
                        when snapshot.has_monitor :: primary_monitor_id :: method => return 517
                        else => ()
                when Option.None => return 518
        when Option.None =>
            select snapshot.take_primary_monitor :: :: method:
                when Option.Some(_) => return 519
                when Option.None => ()
    return 0

fn check_snapshot_joystick_take(take snapshot: AppSnapshot) -> I32:
    select:
        when snapshot.connected_joystick_count == 0 =>
            select snapshot.take_joystick :: 0 :: method:
                when Option.Some(_) => return 520
                when Option.None => ()
        else =>
            let joystick_id = snapshot.joysticks[0].joystick.id
            select snapshot.take_joystick :: joystick_id :: method:
                when Option.Some(found_snapshot) =>
                    select:
                        when found_snapshot.joystick.id != joystick_id => return 521
                        when snapshot.has_joystick :: joystick_id :: method => return 522
                        else => ()
                when Option.None => return 523
    return 0

fn check_snapshot_joystick_lookup(read snapshot: AppSnapshot) -> I32:
    select:
        when snapshot.connected_joystick_count == 0 =>
            select snapshot.joystick :: 0 :: method:
                when Option.Some(_) => return 549
                when Option.None => ()
        else =>
            let joystick_id = snapshot.joysticks[0].joystick.id
            select snapshot.joystick :: joystick_id :: method:
                when Option.Some(joystick_snapshot) =>
                    select:
                        when joystick_snapshot.joystick.id != joystick_id => return 550
                        else => ()
                when Option.None => return 551
    return 0

fn check_snapshot_id_lists(read snapshot: AppSnapshot, window_id: WindowId) -> I32:
    let window_ids = snapshot.window_ids :: :: method
    select:
        when window_ids.count :: :: method != 1 => return 524
        when window_ids.remove :: 0 :: method != window_id => return 525
        else => ()
    let monitor_ids = snapshot.monitor_ids :: :: method
    select:
        when monitor_ids.count :: :: method != snapshot.monitor_count => return 526
        when snapshot.monitor_count != 0 && monitor_ids.remove :: 0 :: method != snapshot.monitors[0].id => return 527
        else => ()
    let joystick_ids = snapshot.joystick_ids :: :: method
    select:
        when joystick_ids.count :: :: method != snapshot.connected_joystick_count => return 519
        when snapshot.connected_joystick_count != 0 && joystick_ids.remove :: 0 :: method != snapshot.joysticks[0].joystick.id => return 520
        else => ()
    let gamepad_ids = snapshot.gamepad_ids :: :: method
    let gamepad_count = snapshot.gamepad_count :: :: method
    select:
        when gamepad_ids.count :: :: method != gamepad_count => return 521
        when snapshot.has_gamepads :: :: method != (gamepad_count != 0) => return 522
        else => ()
    return 0

fn check_snapshot_gamepad_take(take snapshot: AppSnapshot) -> I32:
    let gamepad_ids = snapshot.gamepad_ids :: :: method
    select:
        when gamepad_ids.is_empty :: :: method =>
            select snapshot.take_gamepad :: 0 :: method:
                when Option.Some(_) => return 523
                when Option.None => ()
        else =>
            let gamepad_id = gamepad_ids.remove :: 0 :: method
            select snapshot.take_gamepad :: gamepad_id :: method:
                when Option.Some(gamepad_snapshot) =>
                    select:
                        when gamepad_snapshot.joystick.id != gamepad_id => return 524
                        when !gamepad_snapshot.gamepad => return 525
                        when snapshot.has_joystick :: gamepad_id :: method => return 526
                        else => ()
                when Option.None => return 527
    return 0

fn check_snapshot_gamepad_lookup(read snapshot: AppSnapshot) -> I32:
    let gamepad_ids = snapshot.gamepad_ids :: :: method
    let gamepad_snapshots = snapshot.gamepad_snapshots :: :: method
    select:
        when gamepad_ids.is_empty :: :: method =>
            select:
                when snapshot.has_gamepad :: 0 :: method => return 528
                else => ()
            select:
                when gamepad_snapshots.count :: :: method != 0 => return 556
                else => ()
            select snapshot.gamepad :: 0 :: method:
                when Option.Some(_) => return 552
                when Option.None => ()
            select snapshot.gamepad_index :: 0 :: method:
                when Option.Some(_) => return 529
                when Option.None => ()
        else =>
            let gamepad_id = gamepad_ids.remove :: 0 :: method
            select:
                when !snapshot.has_gamepad :: gamepad_id :: method => return 530
                when gamepad_snapshots.count :: :: method != snapshot.gamepad_count :: :: method => return 557
                when !gamepad_snapshots[0].gamepad => return 558
                when !snapshot.has_gamepad :: gamepad_snapshots[0].joystick.id :: method => return 559
                else => ()
            select snapshot.gamepad :: gamepad_id :: method:
                when Option.Some(gamepad_snapshot) =>
                    select:
                        when gamepad_snapshot.joystick.id != gamepad_id => return 553
                        when !gamepad_snapshot.gamepad => return 554
                        else => ()
                when Option.None => return 555
            select snapshot.gamepad_index :: gamepad_id :: method:
                when Option.Some(index) =>
                    select:
                        when gamepad_ids[index] != gamepad_id => return 531
                        when gamepad_snapshots[index].joystick.id != gamepad_id => return 532
                        when !gamepad_snapshots[index].gamepad => return 560
                        else => ()
                when Option.None => return 533
    return 0

fn check_snapshot_close_requested_views(take snapshot: AppSnapshot, window_id: WindowId) -> I32:
    let count_before = snapshot.close_requested_window_count :: :: method
    let ids_before = snapshot.close_requested_window_ids :: :: method
    let windows_before = snapshot.close_requested_windows :: :: method
    select:
        when count_before != 0 => return 532
        when snapshot.has_close_requested_windows :: :: method => return 533
        when snapshot.window_close_requested :: window_id :: method => return 543
        when ids_before.count :: :: method != 0 => return 534
        when windows_before.count :: :: method != 0 => return 535
        else => ()
    select snapshot.close_requested_window :: window_id :: method:
        when Option.Some(_) => return 544
        when Option.None => ()
    select snapshot.take_window :: window_id :: method:
        when Option.Some(window_snapshot) =>
            let closing_snapshot = window_snapshot
            closing_snapshot.should_close = true
            snapshot.windows.push :: closing_snapshot :: method
        when Option.None => return 536
    let count_after = snapshot.close_requested_window_count :: :: method
    let ids_after = snapshot.close_requested_window_ids :: :: method
    let windows_after = snapshot.close_requested_windows :: :: method
    select:
        when count_after != 1 => return 537
        when !snapshot.has_close_requested_windows :: :: method => return 538
        when !snapshot.window_close_requested :: window_id :: method => return 545
        when ids_after.count :: :: method != 1 => return 539
        when ids_after.remove :: 0 :: method != window_id => return 540
        when windows_after.count :: :: method != 1 => return 541
        when windows_after.remove :: 0 :: method.window.id != window_id => return 542
        else => ()
    select snapshot.close_requested_window :: window_id :: method:
        when Option.Some(closing_snapshot) =>
            select:
                when closing_snapshot.window.id != window_id => return 546
                when !closing_snapshot.should_close => return 547
                else => ()
        when Option.None => return 548
    return 0

fn main() -> I32:
    let report_status = check_vulkan_report_helpers :: :: call
    select:
        when report_status != 0 => return report_status
        else => ()
    let osmesa_status = check_osmesa_buffer_helpers :: :: call
    select:
        when osmesa_status != 0 => return osmesa_status
        else => ()
    let rgba_image_status = check_rgba_image_helpers :: :: call
    select:
        when rgba_image_status != 0 => return rgba_image_status
        else => ()
    let rgba_blend_status = check_rgba_blend_helpers :: :: call
    select:
        when rgba_blend_status != 0 => return rgba_blend_status
        else => ()
    let rgba_line_status = check_rgba_line_helpers :: :: call
    select:
        when rgba_line_status != 0 => return rgba_line_status
        else => ()
    let pixel_frame_status = check_vulkan_pixel_frame_helpers :: :: call
    select:
        when pixel_frame_status != 0 => return pixel_frame_status
        else => ()
    let pixel_frame_blend_status = check_vulkan_pixel_frame_blend_helpers :: :: call
    select:
        when pixel_frame_blend_status != 0 => return pixel_frame_blend_status
        else => ()
    let pixel_frame_line_status = check_vulkan_pixel_frame_line_helpers :: :: call
    select:
        when pixel_frame_line_status != 0 => return pixel_frame_line_status
        else => ()
    let config = app_init_config :: :: call
    let config = config.on_platform :: Platform.Win32 :: method
    let spec = vulkan_window_spec :: WINDOW_TITLE, 64, 64 :: call
    select app_init_hidden_vulkan_present_with :: config, WINDOW_TITLE, spec :: call:
        when Result.Ok(present_app) =>
            let window_id = present_app.window_id :: :: method
            let snapshot = present_app.snapshot :: :: method
            select:
                when !present_app.is_live :: :: method => return 136
                when !present_app.has_windows :: :: method => return 137
                when present_app.has_monitors :: :: method != (snapshot.monitor_count != 0) => return 138
                when present_app.has_joysticks :: :: method != (snapshot.connected_joystick_count != 0) => return 139
                when present_app.has_current_context_window :: :: method => return 140
                when snapshot.has_monitors :: :: method != (snapshot.monitor_count != 0) => return 141
                when snapshot.has_joysticks :: :: method != (snapshot.connected_joystick_count != 0) => return 142
                when snapshot.has_current_context_window :: :: method => return 143
                when present_app.window_count :: :: method != snapshot.window_count => return 138
                when !present_app.window_exists :: window_id :: method => return 144
                when present_app.monitor_count :: :: method != snapshot.monitor_count => return 145
                when present_app.connected_joystick_count :: :: method != snapshot.connected_joystick_count => return 146
                else => ()
            select present_app.current_context_window_option :: :: method:
                when Option.Some(_) => return 141
                when Option.None => ()
            select present_app.current_context_window_snapshot_option :: :: method:
                when Option.Some(_) => return 142
                when Option.None => ()
            let window_ids = present_app.window_ids :: :: method
            select:
                when window_ids.count :: :: method != 1 => return 142
                when window_ids.remove :: 0 :: method != window_id => return 143
                else => ()
            let live_windows = present_app.windows_snapshot :: :: method
            select:
                when live_windows.count :: :: method != 1 => return 144
                else => ()
            let live_window = live_windows.remove :: 0 :: method
            select:
                when live_window.id != window_id => return 145
                else => ()
            let window_snapshots = present_app.window_snapshots :: :: method
            select:
                when window_snapshots.count :: :: method != 1 => return 146
                else => ()
            let only_window_snapshot = window_snapshots.remove :: 0 :: method
            select:
                when only_window_snapshot.window.id != window_id => return 147
                else => ()
            let owned_window = present_app.window :: :: method
            select present_app.window_by_id_option :: window_id :: method:
                when Option.Some(optional_window) =>
                    select:
                        when optional_window.id != window_id => return 148
                        else => ()
                when Option.None => return 149
            select present_app.window_snapshot_by_id_option :: window_id :: method:
                when Option.Some(optional_window_snapshot) =>
                    select:
                        when optional_window_snapshot.window.id != window_id => return 150
                        else => ()
                when Option.None => return 151
            select:
                when present_app.wgl_context :: :: method != owned_window.wgl_context :: :: method => return 152
                when present_app.egl_context :: :: method != owned_window.egl_context :: :: method => return 153
                when present_app.egl_surface :: :: method != owned_window.egl_surface :: :: method => return 154
                when present_app.osmesa_context :: :: method != owned_window.osmesa_context :: :: method => return 155
                else => ()
            select present_app.osmesa_color_buffer :: :: method:
                when Option.Some(color_buffer) =>
                    select owned_window.osmesa_color_buffer :: :: method:
                        when Option.Some(window_color_buffer) =>
                            select:
                                when color_buffer.width :: :: method != window_color_buffer.width :: :: method => return 156
                                when color_buffer.height :: :: method != window_color_buffer.height :: :: method => return 157
                                when color_buffer.has_data :: :: method != window_color_buffer.has_data :: :: method => return 158
                                else => ()
                        when Option.None => return 159
                when Option.None =>
                    select owned_window.osmesa_color_buffer :: :: method:
                        when Option.Some(_) => return 160
                        when Option.None => ()
