pub fn check_vulkan_report_helpers() -> I32:
    let missing_extensions = List[Str] :: :: call
    let unsupported_window = VulkanWindowSupportReport :: :: call
        vulkan_supported = false
        required_instance_extensions = missing_extensions
    select:
        when unsupported_window.has_required_instance_extensions :: :: method => return 1
        when unsupported_window.required_extension_count :: :: method != 0 => return 2
        when unsupported_window.ready_for_surface_creation :: :: method => return 3
        else => ()
    let required_extensions = List[Str] :: :: call
    required_extensions.push :: "VK_KHR_surface" :: method
    let supported_window = VulkanWindowSupportReport :: :: call
        vulkan_supported = true
        required_instance_extensions = required_extensions
    select:
        when !supported_window.has_required_instance_extensions :: :: method => return 4
        when supported_window.required_extension_count :: :: method != 1 => return 5
        when !supported_window.ready_for_surface_creation :: :: method => return 6
        else => ()
    let no_surface_report = GlfwVkSurfaceCreateReport :: 0, 0U64 :: call
    select:
        when !no_surface_report.ok :: :: method => return 7
        when no_surface_report.has_surface :: :: method => return 8
        when no_surface_report.created :: :: method => return 9
        else => ()
    let failed_surface_report = GlfwVkSurfaceCreateReport :: 1, 1U64 :: call
    select:
        when failed_surface_report.ok :: :: method => return 10
        when !failed_surface_report.has_surface :: :: method => return 11
        when failed_surface_report.created :: :: method => return 12
        else => ()
    let created_surface_report = GlfwVkSurfaceCreateReport :: 0, 1U64 :: call
    select:
        when !created_surface_report.ok :: :: method => return 13
        when !created_surface_report.has_surface :: :: method => return 14
        when !created_surface_report.created :: :: method => return 15
        else => ()
    let unsupported_present = VulkanPresentReport :: :: call
        window_support = unsupported_window
        instance_provided = false
        physical_device_provided = false
        queuefamily = 0
        presentation_supported = Option.None
        surface_create_report = Option.None
        present_support_known_value = false
        surface_creation_attempted_value = false
        surface_created_value = false
    select:
        when unsupported_present.present_support_known :: :: method => return 16
        when unsupported_present.supports_presentation :: :: method => return 17
        when unsupported_present.surface_creation_attempted :: :: method => return 18
        when unsupported_present.surface_create_report_available :: :: method => return 19
        when unsupported_present.surface_created :: :: method => return 20
        when unsupported_present.surface_create_succeeded :: :: method => return 21
        when unsupported_present.ready_for_presenting :: :: method => return 22
        else => ()
    let ready_present = VulkanPresentReport :: :: call
        window_support = supported_window
        instance_provided = true
        physical_device_provided = true
        queuefamily = 0
        presentation_supported = Option.Some :: true :: call
        surface_create_report = Option.Some :: created_surface_report :: call
        present_support_known_value = true
        surface_creation_attempted_value = true
        surface_created_value = true
    select:
        when !ready_present.present_support_known :: :: method => return 23
        when !ready_present.supports_presentation :: :: method => return 24
        when !ready_present.surface_creation_attempted :: :: method => return 25
        when !ready_present.surface_create_report_available :: :: method => return 26
        when !ready_present.surface_created :: :: method => return 27
        when !ready_present.surface_create_succeeded :: :: method => return 28
        when !ready_present.ready_for_presenting :: :: method => return 29
        else => ()
    let inconsistent_extensions = List[Str] :: :: call
    inconsistent_extensions.push :: "VK_KHR_surface" :: method
    let inconsistent_window = VulkanWindowSupportReport :: :: call
        vulkan_supported = true
        required_instance_extensions = inconsistent_extensions
    let inconsistent_present = VulkanPresentReport :: :: call
        window_support = inconsistent_window
        instance_provided = true
        physical_device_provided = true
        queuefamily = 0
        presentation_supported = Option.Some :: true :: call
        surface_create_report = Option.Some :: failed_surface_report :: call
        present_support_known_value = true
        surface_creation_attempted_value = true
        surface_created_value = true
    select:
        when !inconsistent_present.surface_created :: :: method => return 30
        when inconsistent_present.surface_create_succeeded :: :: method => return 31
        when inconsistent_present.ready_for_presenting :: :: method => return 32
        else => ()
    return 0

pub fn check_osmesa_buffer_helpers() -> I32:
    let color_empty = GlfwOSMesaColorBuffer :: 4, 3, 0, null :: call
    select:
        when color_empty.width :: :: method != 4 => return 33
        when color_empty.height :: :: method != 3 => return 34
        when color_empty.has_data :: :: method => return 35
        else => ()
    select color_empty.pixel_count :: :: method:
        when Option.Some(pixel_count) =>
            select:
                when pixel_count != 12 => return 36
                else => ()
        when Option.None => return 37
    let depth_empty = GlfwOSMesaDepthBuffer :: 2, 5, 4, null :: call
    select:
        when depth_empty.width :: :: method != 2 => return 38
        when depth_empty.height :: :: method != 5 => return 39
        when depth_empty.has_data :: :: method => return 40
        else => ()
    select depth_empty.pixel_count :: :: method:
        when Option.Some(pixel_count) =>
            select:
                when pixel_count != 10 => return 41
                else => ()
        when Option.None => return 42
    select depth_empty.byte_count :: :: method:
        when Option.Some(byte_count) =>
            select:
                when byte_count != 40 => return 43
                else => ()
        when Option.None => return 44
    let invalid_color = GlfwOSMesaColorBuffer :: -1, 1, 0, null :: call
    select invalid_color.pixel_count :: :: method:
        when Option.Some(_) => return 45
        when Option.None => ()
    let invalid_depth = GlfwOSMesaDepthBuffer :: 1, 1, -1, null :: call
    select invalid_depth.byte_count :: :: method:
        when Option.Some(_) => return 46
        when Option.None => ()
    return 0

pub fn check_rgba_image_helpers() -> I32:
    let fill = rgba_color :: 8U8, 16U8, 24U8, 32U8 :: call
    select solid_rgba_image :: 3, 2, fill :: call:
        when Result.Ok(image) =>
            select:
                when image.width :: :: method != 3 => return 47
                when image.height :: :: method != 2 => return 48
                when image.byte_count :: :: method != 24 => return 49
                else => ()
            select image.width_index :: :: method:
                when Result.Ok(width_index) =>
                    select:
                        when width_index != 3 => return 85
                        else => ()
                when Result.Err(_) => return 86
            select image.height_index :: :: method:
                when Result.Ok(height_index) =>
                    select:
                        when height_index != 2 => return 87
                        else => ()
                when Result.Err(_) => return 88
            select image.pixel_count :: :: method:
                when Result.Ok(pixel_count) =>
                    select:
                        when pixel_count != 6 => return 89
                        else => ()
                when Result.Err(_) => return 90
            select image.pixel :: 0, 0 :: method:
                when Result.Ok(color) =>
                    select:
                        when color.red != 8U8 => return 50
                        when color.green != 16U8 => return 51
                        when color.blue != 24U8 => return 52
                        when color.alpha != 32U8 => return 53
                        else => ()
                when Result.Err(_) => return 54
            let accent = rgba_color :: 90U8, 80U8, 70U8, 60U8 :: call
            select image.set_pixel :: 2, 1, accent :: method:
                when Result.Ok(_) => ()
                when Result.Err(_) => return 55
            select image.pixel :: 2, 1 :: method:
                when Result.Ok(color) =>
                    select:
                        when color.red != 90U8 => return 56
                        when color.green != 80U8 => return 57
                        when color.blue != 70U8 => return 58
                        when color.alpha != 60U8 => return 59
                        else => ()
                when Result.Err(_) => return 60
            let rect_fill = rgba_color :: 4U8, 5U8, 6U8, 7U8 :: call
            select image.fill_rect :: 0, 0, 2, 1, rect_fill :: method:
                when Result.Ok(_) => ()
                when Result.Err(_) => return 61
            select image.pixel :: 1, 0 :: method:
                when Result.Ok(color) =>
                    select:
                        when color.red != 4U8 => return 62
                        when color.green != 5U8 => return 63
                        when color.blue != 6U8 => return 64
                        when color.alpha != 7U8 => return 65
                        else => ()
                when Result.Err(_) => return 66
            let hline_fill = rgba_color :: 11U8, 12U8, 13U8, 14U8 :: call
            select image.draw_hline :: 0, 1, 3, hline_fill :: method:
                when Result.Ok(_) => ()
                when Result.Err(_) => return 93
            select image.pixel :: 2, 1 :: method:
                when Result.Ok(color) =>
                    select:
                        when color.red != 11U8 => return 94
                        when color.green != 12U8 => return 95
                        when color.blue != 13U8 => return 96
                        when color.alpha != 14U8 => return 97
                        else => ()
                when Result.Err(_) => return 98
            let vline_fill = rgba_color :: 21U8, 22U8, 23U8, 24U8 :: call
            select image.draw_vline :: 2, 0, 2, vline_fill :: method:
                when Result.Ok(_) => ()
                when Result.Err(_) => return 99
            select image.pixel :: 2, 0 :: method:
                when Result.Ok(color) =>
                    select:
                        when color.red != 21U8 => return 100
                        when color.green != 22U8 => return 101
                        when color.blue != 23U8 => return 102
                        when color.alpha != 24U8 => return 103
                        else => ()
                when Result.Err(_) => return 104
            let stroke_fill = rgba_color :: 31U8, 32U8, 33U8, 34U8 :: call
            select image.stroke_rect :: 0, 0, 3, 2, stroke_fill :: method:
                when Result.Ok(_) => ()
                when Result.Err(_) => return 105
            select image.pixel :: 0, 0 :: method:
                when Result.Ok(color) =>
                    select:
                        when color.red != 31U8 => return 106
                        when color.green != 32U8 => return 107
                        when color.blue != 33U8 => return 108
                        when color.alpha != 34U8 => return 109
                        else => ()
                when Result.Err(_) => return 110
            let clear_fill = rgba_color :: 1U8, 2U8, 3U8, 4U8 :: call
            select image.clear :: clear_fill :: method:
                when Result.Ok(_) => ()
                when Result.Err(_) => return 67
            select image.pixel :: 0, 1 :: method:
                when Result.Ok(color) =>
                    select:
                        when color.red != 1U8 => return 68
                        when color.green != 2U8 => return 69
                        when color.blue != 3U8 => return 70
                        when color.alpha != 4U8 => return 71
                        else => ()
                when Result.Err(_) => return 72
            let blit_fill = rgba_color :: 40U8, 50U8, 60U8, 70U8 :: call
            select either:
                when source_image: Result.Ok(source_image) <- solid_rgba_image :: 2, 1, blit_fill :: call
                when blitted: Result.Ok(_) <- image.blit_image :: 1, 1, source_image :: method =>
                    ()

            with Result.Err(_):
                source_image => return 74
                blitted => return 73
            select image.pixel :: 2, 1 :: method:
                when Result.Ok(color) =>
                    select:
                        when color.red != 40U8 => return 75
                        when color.green != 50U8 => return 76
                        when color.blue != 60U8 => return 77
                        when color.alpha != 70U8 => return 78
                        else => ()
                when Result.Err(_) => return 79
            select image.pixel :: 3, 0 :: method:
                when Result.Ok(_) => return 80
                when Result.Err(_) => ()
            select image.fill_rect :: 0, 0, 0, 1, rect_fill :: method:
                when Result.Ok(_) => return 81
                when Result.Err(_) => ()
            select solid_rgba_image :: 2, 2, blit_fill :: call:
                when Result.Ok(source_image) =>
                    select image.blit_image :: 2, 1, source_image :: method:
                        when Result.Ok(_) => return 82
                        when Result.Err(_) => ()
                when Result.Err(_) => return 83
            select image.copy_pixels :: :: method:
                when Result.Ok(copied_pixels) =>
                    select:
                        when copied_pixels.byte_count :: :: method != image.byte_count :: :: method => return 91
                        else => ()
                when Result.Err(_) => return 92
            select image.copy_image :: :: method:
                when Result.Ok(copied_image) =>
                    select:
                        when copied_image.width :: :: method != image.width :: :: method => return 102
                        when copied_image.height :: :: method != image.height :: :: method => return 103
                        else => ()
                    select copied_image.pixel :: 2, 1 :: method:
                        when Result.Ok(color) =>
                            select:
                                when color.red != 40U8 => return 104
                                when color.green != 50U8 => return 105
                                when color.blue != 60U8 => return 106
                                when color.alpha != 70U8 => return 107
                                else => ()
                        when Result.Err(_) => return 108
                when Result.Err(_) => return 109
            select image.sub_image :: 1, 1, 2, 1 :: method:
                when Result.Ok(sub_image) =>
                    select:
                        when sub_image.width :: :: method != 2 => return 93
                        when sub_image.height :: :: method != 1 => return 94
                        else => ()
                    select sub_image.pixel :: 1, 0 :: method:
                        when Result.Ok(color) =>
                            select:
                                when color.red != 40U8 => return 95
                                when color.green != 50U8 => return 96
                                when color.blue != 60U8 => return 97
                                when color.alpha != 70U8 => return 98
                                else => ()
                        when Result.Err(_) => return 99
                when Result.Err(_) => return 100
            select image.sub_image :: 2, 1, 2, 1 :: method:
                when Result.Ok(_) => return 101
                when Result.Err(_) => ()
        when Result.Err(_) => return 84
    return 0

pub fn check_vulkan_pixel_frame_helpers() -> I32:
    let rgba_surface_format = VkSurfaceFormatKHR :: 43, 0 :: call
    let bgra_surface_format = VkSurfaceFormatKHR :: 50, 0 :: call
    select rgba_surface_format.surface_pixel_format :: :: method:
        when Result.Ok(format) =>
            select:
                when vulkan_pixel_format_code :: format :: call != 0 => return 600
                else => ()
        when Result.Err(_) => return 601
    select bgra_surface_format.surface_pixel_format :: :: method:
        when Result.Ok(format) =>
            select:
                when vulkan_pixel_format_code :: format :: call != 1 => return 602
                else => ()
        when Result.Err(_) => return 603
    let bgra_pixels = ByteBuffer :: :: call
    bgra_pixels.push :: 12U8 :: method
    bgra_pixels.push :: 24U8 :: method
    bgra_pixels.push :: 96U8 :: method
    bgra_pixels.push :: 255U8 :: method
    bgra_pixels.push :: 1U8 :: method
    bgra_pixels.push :: 2U8 :: method
    bgra_pixels.push :: 3U8 :: method
    bgra_pixels.push :: 4U8 :: method
    bgra_pixels.push :: 9U8 :: method
    bgra_pixels.push :: 9U8 :: method
    bgra_pixels.push :: 9U8 :: method
    bgra_pixels.push :: 9U8 :: method
    select vulkan_pixel_frame :: 2, 1, 12, VulkanPixelFormat.Bgra8, bgra_pixels :: call:
        when Result.Ok(frame) =>
            select:
                when frame.width :: :: method != 2 => return 604
                when frame.height :: :: method != 1 => return 605
                when frame.stride :: :: method != 12 => return 606
                when frame.byte_count :: :: method != 12 => return 607
                when frame.format_code :: :: method != 1 => return 608
                else => ()
            select frame.to_rgba_image :: :: method:
                when Result.Ok(image) =>
                    let image_pixels = image.take_pixels :: :: method
                    select:
                        when image_pixels.byte_count :: :: method != 8 => return 609
                        when image_pixels[0] != 96U8 => return 610
                        when image_pixels[1] != 24U8 => return 611
                        when image_pixels[2] != 12U8 => return 612
                        when image_pixels[3] != 255U8 => return 613
                        when image_pixels[4] != 3U8 => return 614
                        when image_pixels[5] != 2U8 => return 615
                        when image_pixels[6] != 1U8 => return 616
                        when image_pixels[7] != 4U8 => return 617
                        else => ()
                when Result.Err(_) => return 618
        when Result.Err(_) => return 619
    let rgbx_pixels = ByteBuffer :: :: call
    rgbx_pixels.push :: 5U8 :: method
    rgbx_pixels.push :: 6U8 :: method
    rgbx_pixels.push :: 7U8 :: method
    rgbx_pixels.push :: 0U8 :: method
    select either:
        when frame: Result.Ok(frame) <- vulkan_pixel_frame :: 1, 1, 4, VulkanPixelFormat.Rgbx8, rgbx_pixels :: call
        when image: Result.Ok(image) <- frame.to_rgba_image :: :: method =>
            let image_pixels = image.take_pixels :: :: method
            select:
                when image_pixels[0] != 5U8 => return 620
                when image_pixels[1] != 6U8 => return 621
                when image_pixels[2] != 7U8 => return 622
                when image_pixels[3] != 255U8 => return 623
                else => ()

    with Result.Err(_):
        frame => return 625
        image => return 624
    let bgrx_pixels = ByteBuffer :: :: call
    bgrx_pixels.push :: 40U8 :: method
    bgrx_pixels.push :: 30U8 :: method
    bgrx_pixels.push :: 20U8 :: method
    bgrx_pixels.push :: 0U8 :: method
    select either:
        when frame: Result.Ok(frame) <- vulkan_pixel_frame :: 1, 1, 4, VulkanPixelFormat.Bgrx8, bgrx_pixels :: call
        when surface_pixels: Result.Ok(surface_pixels) <- frame.to_surface_bytes :: rgba_surface_format :: method =>
            select:
                when surface_pixels[0] != 20U8 => return 626
                when surface_pixels[1] != 30U8 => return 627
                when surface_pixels[2] != 40U8 => return 628
                when surface_pixels[3] != 255U8 => return 629
                else => ()

    with Result.Err(_):
        frame => return 631
        surface_pixels => return 630
    let rgba_pixels = ByteBuffer :: :: call
    rgba_pixels.push :: 8U8 :: method
    rgba_pixels.push :: 16U8 :: method
    rgba_pixels.push :: 24U8 :: method
    rgba_pixels.push :: 32U8 :: method
    select either:
        when frame: Result.Ok(frame) <- vulkan_pixel_frame :: 1, 1, 4, VulkanPixelFormat.Rgba8, rgba_pixels :: call
        when surface_pixels: Result.Ok(surface_pixels) <- frame.to_surface_bytes :: bgra_surface_format :: method =>
            select:
                when surface_pixels[0] != 24U8 => return 632
                when surface_pixels[1] != 16U8 => return 633
                when surface_pixels[2] != 8U8 => return 634
                when surface_pixels[3] != 32U8 => return 635
                else => ()

    with Result.Err(_):
        frame => return 637
        surface_pixels => return 636
    let fill = RgbaColor :: 10U8, 20U8, 30U8, 40U8 :: call
    select vulkan_pixel_frame_with_color :: 2, 2, VulkanPixelFormat.Rgba8, fill :: call:
        when Result.Ok(frame) =>
            select:
                when frame.format_code :: :: method != 0 => return 657
                else => ()
            select frame.pixel_count :: :: method:
                when Result.Ok(pixel_count) =>
                    select:
                        when pixel_count != 4 => return 728
                        else => ()
                when Result.Err(_) => return 729
            select frame.pixel :: 0, 0 :: method:
                when Result.Ok(color) =>
                    select:
                        when color.red != 10U8 => return 638
                        when color.green != 20U8 => return 639
                        when color.blue != 30U8 => return 640
                        when color.alpha != 40U8 => return 641
                        else => ()
                when Result.Err(_) => return 642
            let accent = RgbaColor :: 90U8, 80U8, 70U8, 60U8 :: call
            select frame.set_pixel :: 1, 1, accent :: method:
                when Result.Ok(_) => ()
                when Result.Err(_) => return 643
            select frame.pixel :: 1, 1 :: method:
                when Result.Ok(color) =>
                    select:
                        when color.red != 90U8 => return 644
                        when color.green != 80U8 => return 645
                        when color.blue != 70U8 => return 646
                        when color.alpha != 60U8 => return 647
                        else => ()
                when Result.Err(_) => return 648
            let clear_fill = RgbaColor :: 1U8, 2U8, 3U8, 4U8 :: call
            select frame.clear :: clear_fill :: method:
                when Result.Ok(_) => ()
                when Result.Err(_) => return 649
            select frame.pixel :: 0, 1 :: method:
                when Result.Ok(color) =>
                    select:
                        when color.red != 1U8 => return 650
                        when color.green != 2U8 => return 651
                        when color.blue != 3U8 => return 652
                        when color.alpha != 4U8 => return 653
                        else => ()
                when Result.Err(_) => return 654
            let rect_fill = RgbaColor :: 14U8, 15U8, 16U8, 17U8 :: call
            select frame.fill_rect :: 0, 0, 2, 1, rect_fill :: method:
                when Result.Ok(_) => ()
                when Result.Err(_) => return 706
            select frame.pixel :: 1, 0 :: method:
                when Result.Ok(color) =>
                    select:
                        when color.red != 14U8 => return 707
                        when color.green != 15U8 => return 708
                        when color.blue != 16U8 => return 709
                        when color.alpha != 17U8 => return 710
                        else => ()
                when Result.Err(_) => return 711
            select frame.pixel :: 1, 1 :: method:
                when Result.Ok(color) =>
                    select:
                        when color.red != 1U8 => return 712
                        when color.green != 2U8 => return 713
                        when color.blue != 3U8 => return 714
                        when color.alpha != 4U8 => return 715
                        else => ()
                when Result.Err(_) => return 716
            select vulkan_pixel_frame_with_color :: 4, 4, VulkanPixelFormat.Rgba8, fill :: call:
                when Result.Ok(line_frame) =>
                    let hline_fill = RgbaColor :: 61U8, 62U8, 63U8, 64U8 :: call
                    select line_frame.draw_hline :: 0, 2, 4, hline_fill :: method:
                        when Result.Ok(_) => ()
                        when Result.Err(_) => return 774
                    select line_frame.pixel :: 3, 2 :: method:
                        when Result.Ok(color) =>
                            select:
                                when color.red != 61U8 => return 775
                                when color.green != 62U8 => return 776
                                when color.blue != 63U8 => return 777
                                when color.alpha != 64U8 => return 778
                                else => ()
                        when Result.Err(_) => return 779
                    let vline_fill = RgbaColor :: 71U8, 72U8, 73U8, 74U8 :: call
                    select line_frame.draw_vline :: 1, 0, 4, vline_fill :: method:
                        when Result.Ok(_) => ()
                        when Result.Err(_) => return 780
                    select line_frame.pixel :: 1, 3 :: method:
                        when Result.Ok(color) =>
                            select:
                                when color.red != 71U8 => return 781
                                when color.green != 72U8 => return 782
                                when color.blue != 73U8 => return 783
                                when color.alpha != 74U8 => return 784
                                else => ()
                        when Result.Err(_) => return 785
                    let stroke_fill = RgbaColor :: 81U8, 82U8, 83U8, 84U8 :: call
                    select line_frame.stroke_rect :: 0, 0, 4, 4, stroke_fill :: method:
                        when Result.Ok(_) => ()
                        when Result.Err(_) => return 786
                    select line_frame.pixel :: 0, 0 :: method:
                        when Result.Ok(color) =>
                            select:
                                when color.red != 81U8 => return 787
                                when color.green != 82U8 => return 788
                                when color.blue != 83U8 => return 789
                                when color.alpha != 84U8 => return 790
                                else => ()
                        when Result.Err(_) => return 791
                    select line_frame.pixel :: 2, 2 :: method:
                        when Result.Ok(color) =>
                            select:
                                when color.red != 61U8 => return 792
                                when color.green != 62U8 => return 793
                                when color.blue != 63U8 => return 794
                                when color.alpha != 64U8 => return 795
                                else => ()
                        when Result.Err(_) => return 796
                when Result.Err(_) => return 797
            let blit_fill = RgbaColor :: 21U8, 31U8, 41U8, 51U8 :: call
            select either:
                when source_frame: Result.Ok(source_frame) <- vulkan_pixel_frame_with_color :: 1, 1, VulkanPixelFormat.Bgra8, blit_fill :: call
                when blitted: Result.Ok(_) <- frame.blit_frame :: 1, 1, source_frame :: method =>
                    ()

            with Result.Err(_):
                source_frame => return 718
                blitted => return 717
            select frame.pixel :: 1, 1 :: method:
                when Result.Ok(color) =>
                    select:
                        when color.red != 21U8 => return 719
                        when color.green != 31U8 => return 720
                        when color.blue != 41U8 => return 721
                        when color.alpha != 51U8 => return 722
                        else => ()
                when Result.Err(_) => return 723
            select frame.fill_rect :: 0, 0, 0, 1, rect_fill :: method:
                when Result.Err(_) => ()
                when Result.Ok(_) => return 725
            select vulkan_pixel_frame_with_color :: 1, 1, VulkanPixelFormat.Rgba8, blit_fill :: call:
