    let no_redirection_spec = hidden_window_spec :: "window no redirection child", 60, 60 :: call
    let no_redirection_spec = no_redirection_spec.with_win32_no_redirection_bitmap :: :: method
    select present_app.create_window :: no_redirection_spec :: method:
        when Result.Ok(no_redirection_window) =>
            let no_redirection_id = no_redirection_window.id
            let no_redirection_created_ids = present_app.poll_created_window_ids :: :: method
            select:
                when no_redirection_created_ids.count :: :: method != 1 => return 3557
                when no_redirection_created_ids.remove :: 0 :: method != no_redirection_id => return 3558
                else => ()
            select no_redirection_window.no_redirection_bitmap :: :: method:
