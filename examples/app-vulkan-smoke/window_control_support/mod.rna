                        when !value => return 3559
                        else => ()
                when Result.Err(_) => return 3560
            select present_app.destroy_auxiliary_window :: no_redirection_window :: method:
                when Result.Ok(_) =>
                    let no_redirection_destroyed_ids = present_app.wait_timeout_destroyed_window_ids :: 0.1 :: method
                    select:
                        when no_redirection_destroyed_ids.count :: :: method != 1 => return 3561
                        when no_redirection_destroyed_ids.remove :: 0 :: method != no_redirection_id => return 3562
                        else => ()
                when Result.Err(_) => return 3563
        when Result.Err(_) => return 3564

    present_app.set_cursor_hittest :: initial_hittest :: method

    return 0





