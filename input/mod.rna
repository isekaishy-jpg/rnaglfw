use std.Option
use core.{GlfwCursor, GlfwCursorRaw, GlfwWindow, GlfwWindowRaw}
use core.glfw_cint_is_true
use window.GlfwImage

pub struct GlfwCursorPos:
    pub x: F64
    pub y: F64

impl GlfwCursorPos:
    fn x_value(read self) -> F64:
        return self.x

    fn y_value(read self) -> F64:
        return self.y

pub fn glfw_cursor_pos_x(read pos: GlfwCursorPos) -> F64:
    return pos.x

pub fn glfw_cursor_pos_y(read pos: GlfwCursorPos) -> F64:
    return pos.y

pub type GlfwCursorEnterCallback = extern["c"] fn(*edit GlfwWindowRaw, CInt) -> CVoid
pub type GlfwKeyCallback = extern["c"] fn(*edit GlfwWindowRaw, CInt, CInt, CInt, CInt) -> CVoid
pub type GlfwCharCallback = extern["c"] fn(*edit GlfwWindowRaw, CUInt) -> CVoid
pub type GlfwCharModsCallback = extern["c"] fn(*edit GlfwWindowRaw, CUInt, CInt) -> CVoid
pub type GlfwMouseButtonCallback = extern["c"] fn(*edit GlfwWindowRaw, CInt, CInt, CInt) -> CVoid
pub type GlfwCursorPosCallback = extern["c"] fn(*edit GlfwWindowRaw, F64, F64) -> CVoid
pub type GlfwScrollCallback = extern["c"] fn(*edit GlfwWindowRaw, F64, F64) -> CVoid
pub type GlfwDropCallback = extern["c"] fn(*edit GlfwWindowRaw, CInt, *read *read CChar) -> CVoid

