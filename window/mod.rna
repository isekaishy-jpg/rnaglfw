use std.Option
use core.{GlfwGlProc, GlfwMonitor, GlfwMonitorRaw, GlfwWindow, GlfwWindowRaw}
use core.{glfw_bool_to_cint, glfw_cint_is_true}

pub struct GlfwPoint:
    pub x: CInt
    pub y: CInt

pub struct GlfwSize:
    pub width: CInt
    pub height: CInt

pub struct GlfwScale:
    pub x: F32
    pub y: F32

pub struct GlfwRect:
    pub x: CInt
    pub y: CInt
    pub width: CInt
    pub height: CInt

pub struct GlfwFrameSize:
    pub left: CInt
    pub top: CInt
    pub right: CInt
    pub bottom: CInt

pub struct GlfwWindowMonitorSpec:
    pub monitor: GlfwMonitor
    pub pos: GlfwPoint
    pub size: GlfwSize
    pub refresh_rate: CInt

#repr[c]
pub struct GlfwImage:
    pub width: CInt
    pub height: CInt
    pub pixels: *edit CUnsignedChar

impl GlfwPoint:
    fn x_value(read self) -> CInt:
        return self.x

    fn y_value(read self) -> CInt:
        return self.y

impl GlfwSize:
    fn width_value(read self) -> CInt:
        return self.width

    fn height_value(read self) -> CInt:
        return self.height

impl GlfwScale:
    fn x_value(read self) -> F32:
        return self.x

    fn y_value(read self) -> F32:
        return self.y

impl GlfwRect:
    fn x_value(read self) -> CInt:
        return self.x

    fn y_value(read self) -> CInt:
        return self.y

    fn width_value(read self) -> CInt:
        return self.width

    fn height_value(read self) -> CInt:
        return self.height

impl GlfwFrameSize:
    fn left_value(read self) -> CInt:
        return self.left

    fn top_value(read self) -> CInt:
        return self.top

    fn right_value(read self) -> CInt:
        return self.right

    fn bottom_value(read self) -> CInt:
        return self.bottom

impl GlfwWindowMonitorSpec:
    fn refresh_rate_value(read self) -> CInt:
        return self.refresh_rate

impl GlfwImage:
    fn width_value(read self) -> CInt:
        return self.width

    fn height_value(read self) -> CInt:
        return self.height

    fn pixels_ptr(read self) -> *edit CUnsignedChar:
        return self.pixels

pub fn glfw_point_x(read point: GlfwPoint) -> CInt:
    return point.x

pub fn glfw_point_y(read point: GlfwPoint) -> CInt:
    return point.y

pub fn glfw_size_width(read size: GlfwSize) -> CInt:
    return size.width

pub fn glfw_size_height(read size: GlfwSize) -> CInt:
    return size.height

pub fn glfw_scale_x(read scale: GlfwScale) -> F32:
    return scale.x

pub fn glfw_scale_y(read scale: GlfwScale) -> F32:
    return scale.y

pub fn glfw_rect_x(read rect: GlfwRect) -> CInt:
    return rect.x

pub fn glfw_rect_y(read rect: GlfwRect) -> CInt:
    return rect.y

pub fn glfw_rect_width(read rect: GlfwRect) -> CInt:
    return rect.width

pub fn glfw_rect_height(read rect: GlfwRect) -> CInt:
    return rect.height

pub fn glfw_frame_size_left(read frame_size: GlfwFrameSize) -> CInt:
    return frame_size.left

pub fn glfw_frame_size_top(read frame_size: GlfwFrameSize) -> CInt:
    return frame_size.top

pub fn glfw_frame_size_right(read frame_size: GlfwFrameSize) -> CInt:
    return frame_size.right

pub fn glfw_frame_size_bottom(read frame_size: GlfwFrameSize) -> CInt:
    return frame_size.bottom

pub fn glfw_window_monitor_spec_refresh_rate(read spec: GlfwWindowMonitorSpec) -> CInt:
    return spec.refresh_rate

pub fn glfw_image_width(read image: GlfwImage) -> CInt:
    return image.width

pub fn glfw_image_height(read image: GlfwImage) -> CInt:
    return image.height

pub fn glfw_image_pixels(read image: GlfwImage) -> *edit CUnsignedChar:
    return image.pixels

pub type GlfwWindowPosCallback = extern["c"] fn(*edit GlfwWindowRaw, CInt, CInt) -> CVoid
pub type GlfwWindowSizeCallback = extern["c"] fn(*edit GlfwWindowRaw, CInt, CInt) -> CVoid
pub type GlfwWindowCloseCallback = extern["c"] fn(*edit GlfwWindowRaw) -> CVoid
pub type GlfwWindowRefreshCallback = extern["c"] fn(*edit GlfwWindowRaw) -> CVoid
pub type GlfwWindowFocusCallback = extern["c"] fn(*edit GlfwWindowRaw, CInt) -> CVoid
pub type GlfwWindowIconifyCallback = extern["c"] fn(*edit GlfwWindowRaw, CInt) -> CVoid
pub type GlfwWindowMaximizeCallback = extern["c"] fn(*edit GlfwWindowRaw, CInt) -> CVoid
pub type GlfwFramebufferSizeCallback = extern["c"] fn(*edit GlfwWindowRaw, CInt, CInt) -> CVoid
pub type GlfwWindowContentScaleCallback = extern["c"] fn(*edit GlfwWindowRaw, F32, F32) -> CVoid

