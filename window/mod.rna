pub fn glfw_default_window_hints() -> Unit:
    #unsafe glfwDefaultWindowHints :: :: call
    return

pub fn glfw_window_hint(hint: CInt, value: CInt) -> Unit:
    #unsafe glfwWindowHint :: hint, value :: call
    return

pub fn glfw_window_hint_bool(hint: CInt, value: Bool) -> Unit:
    let raw_value: CInt = glfw_bool_to_cint :: value :: call
    glfw_window_hint :: hint, raw_value :: call
    return

pub fn glfw_window_hint_string(hint: CInt, value: *read CChar) -> Unit:
    #unsafe glfwWindowHintString :: hint, value :: call
    return

pub fn glfw_window_hint_no_api() -> Unit:
    glfw_window_hint :: 0x00022001, 0 :: call
    return

pub fn glfw_create_window_raw(width: CInt, height: CInt, title: *read CChar, monitor: *edit GlfwMonitorRaw, share: *edit GlfwWindowRaw) -> GlfwWindow:
    let raw: *edit GlfwWindowRaw = #unsafe glfwCreateWindow :: width, height, title, monitor, share :: call
    return GlfwWindow :: raw :: call

pub fn glfw_create_window(width: CInt, height: CInt, title: *read CChar, read monitor: GlfwMonitor, read share: GlfwWindow) -> GlfwWindow:
    let monitor_raw: *edit GlfwMonitorRaw = monitor.raw
    let share_raw: *edit GlfwWindowRaw = share.raw
    return glfw_create_window_raw :: width, height, title, monitor_raw, share_raw :: call

pub fn glfw_get_current_context() -> GlfwWindow:
    let raw: *edit GlfwWindowRaw = #unsafe glfwGetCurrentContext :: :: call
    return GlfwWindow :: raw :: call

pub fn glfw_swap_interval(interval: CInt) -> Unit:
    #unsafe glfwSwapInterval :: interval :: call
    return

pub fn glfw_extension_supported(extension: *read CChar) -> Bool:
    let supported: CInt = #unsafe glfwExtensionSupported :: extension :: call
    return glfw_cint_is_true :: supported :: call

pub fn glfw_get_proc_address(procname: *read CChar) -> Option[GlfwGlProc]:
    return #unsafe glfwGetProcAddress :: procname :: call

impl GlfwWindow:
    fn destroy(take self) -> Unit:
        select:
            when self.raw.is_null :: :: method => return
            else =>
                #unsafe glfwDestroyWindow :: self.raw :: call
                return

    fn should_close(read self) -> Bool:
        let value: CInt = #unsafe glfwWindowShouldClose :: self.raw :: call
        return glfw_cint_is_true :: value :: call

    fn set_should_close(read self, value: Bool) -> Unit:
        let raw_value: CInt = glfw_bool_to_cint :: value :: call
        #unsafe glfwSetWindowShouldClose :: self.raw, raw_value :: call
        return

    fn title(read self) -> *read CChar:
        return #unsafe glfwGetWindowTitle :: self.raw :: call

    fn set_title(read self, title: *read CChar) -> Unit:
        #unsafe glfwSetWindowTitle :: self.raw, title :: call
        return

    fn set_icon_array(read self, images: *read GlfwImage, count: CInt) -> Unit:
        #unsafe glfwSetWindowIcon :: self.raw, count, images :: call
        return

    fn set_icon_single(read self, read image: GlfwImage) -> Unit:
        let image_ptr: *read GlfwImage = #unsafe &raw read image
        self.set_icon_array :: image_ptr, 1 :: method
        return

    fn pos(read self) -> GlfwPoint:
        let x: CInt = 0
        let y: CInt = 0
        let x_ptr: *edit CInt = #unsafe &raw edit x
        let y_ptr: *edit CInt = #unsafe &raw edit y
        #unsafe glfwGetWindowPos :: self.raw, x_ptr, y_ptr :: call
        return GlfwPoint :: x, y :: call

    fn set_pos(read self, x: CInt, y: CInt) -> Unit:
        #unsafe glfwSetWindowPos :: self.raw, x, y :: call
        return

    fn size(read self) -> GlfwSize:
        let width: CInt = 0
        let height: CInt = 0
        let width_ptr: *edit CInt = #unsafe &raw edit width
        let height_ptr: *edit CInt = #unsafe &raw edit height
        #unsafe glfwGetWindowSize :: self.raw, width_ptr, height_ptr :: call
        return GlfwSize :: width, height :: call

    fn set_size_limits(read self, min_width: CInt, min_height: CInt, max_width: CInt, max_height: CInt) -> Unit:
        #unsafe glfwSetWindowSizeLimits :: self.raw, min_width, min_height, max_width, max_height :: call
        return

    fn set_aspect_ratio(read self, numerator: CInt, denominator: CInt) -> Unit:
        #unsafe glfwSetWindowAspectRatio :: self.raw, numerator, denominator :: call
        return

    fn set_size(read self, width: CInt, height: CInt) -> Unit:
        #unsafe glfwSetWindowSize :: self.raw, width, height :: call
        return

    fn framebuffer_size(read self) -> GlfwSize:
        let width: CInt = 0
        let height: CInt = 0
        let width_ptr: *edit CInt = #unsafe &raw edit width
        let height_ptr: *edit CInt = #unsafe &raw edit height
        #unsafe glfwGetFramebufferSize :: self.raw, width_ptr, height_ptr :: call
        return GlfwSize :: width, height :: call

    fn frame_size(read self) -> GlfwFrameSize:
        let left: CInt = 0
        let top: CInt = 0
        let right: CInt = 0
        let bottom: CInt = 0
        let left_ptr: *edit CInt = #unsafe &raw edit left
        let top_ptr: *edit CInt = #unsafe &raw edit top
        let right_ptr: *edit CInt = #unsafe &raw edit right
        let bottom_ptr: *edit CInt = #unsafe &raw edit bottom
        #unsafe glfwGetWindowFrameSize :: self.raw, left_ptr, top_ptr, right_ptr, bottom_ptr :: call
        return GlfwFrameSize :: left, top, right, bottom :: call

    fn content_scale(read self) -> GlfwScale:
        let x: F32 = 0.0
        let y: F32 = 0.0
        let x_ptr: *edit F32 = #unsafe &raw edit x
        let y_ptr: *edit F32 = #unsafe &raw edit y
        #unsafe glfwGetWindowContentScale :: self.raw, x_ptr, y_ptr :: call
        return GlfwScale :: x, y :: call

    fn opacity(read self) -> F32:
        return #unsafe glfwGetWindowOpacity :: self.raw :: call

    fn set_opacity(read self, opacity: F32) -> Unit:
        #unsafe glfwSetWindowOpacity :: self.raw, opacity :: call
        return

    fn iconify(read self) -> Unit:
        #unsafe glfwIconifyWindow :: self.raw :: call
        return

    fn restore(read self) -> Unit:
        #unsafe glfwRestoreWindow :: self.raw :: call
        return

    fn maximize(read self) -> Unit:
        #unsafe glfwMaximizeWindow :: self.raw :: call
        return

    fn show(read self) -> Unit:
        #unsafe glfwShowWindow :: self.raw :: call
        return

    fn hide(read self) -> Unit:
        #unsafe glfwHideWindow :: self.raw :: call
        return

    fn focus(read self) -> Unit:
        #unsafe glfwFocusWindow :: self.raw :: call
        return

    fn request_attention(read self) -> Unit:
        #unsafe glfwRequestWindowAttention :: self.raw :: call
        return

    fn monitor(read self) -> GlfwMonitor:
        let raw: *edit GlfwMonitorRaw = #unsafe glfwGetWindowMonitor :: self.raw :: call
        return GlfwMonitor :: raw :: call

    fn set_monitor(read self, read spec: GlfwWindowMonitorSpec) -> Unit:
        #unsafe glfwSetWindowMonitor :: self.raw, spec.monitor.raw, spec.pos.x, spec.pos.y, spec.size.width, spec.size.height, spec.refresh_rate :: call
        return

    fn attrib(read self, attrib: CInt) -> CInt:
        return #unsafe glfwGetWindowAttrib :: self.raw, attrib :: call

    fn attrib_bool(read self, attrib: CInt) -> Bool:
        let value: CInt = self.attrib :: attrib :: method
        return glfw_cint_is_true :: value :: call

    fn set_attrib(read self, attrib: CInt, value: CInt) -> Unit:
        #unsafe glfwSetWindowAttrib :: self.raw, attrib, value :: call
        return

    fn set_attrib_bool(read self, attrib: CInt, value: Bool) -> Unit:
        let raw_value: CInt = glfw_bool_to_cint :: value :: call
        self.set_attrib :: attrib, raw_value :: method
        return

    fn set_user_pointer(read self, pointer: *edit CVoid) -> Unit:
        #unsafe glfwSetWindowUserPointer :: self.raw, pointer :: call
        return

    fn user_pointer(read self) -> *edit CVoid:
        return #unsafe glfwGetWindowUserPointer :: self.raw :: call

    fn set_pos_callback(read self, take callback: Option[GlfwWindowPosCallback]) -> Option[GlfwWindowPosCallback]:
        return #unsafe glfwSetWindowPosCallback :: self.raw, callback :: call

    fn set_size_callback(read self, take callback: Option[GlfwWindowSizeCallback]) -> Option[GlfwWindowSizeCallback]:
        return #unsafe glfwSetWindowSizeCallback :: self.raw, callback :: call

    fn set_close_callback(read self, take callback: Option[GlfwWindowCloseCallback]) -> Option[GlfwWindowCloseCallback]:
        return #unsafe glfwSetWindowCloseCallback :: self.raw, callback :: call

    fn set_refresh_callback(read self, take callback: Option[GlfwWindowRefreshCallback]) -> Option[GlfwWindowRefreshCallback]:
        return #unsafe glfwSetWindowRefreshCallback :: self.raw, callback :: call

    fn set_focus_callback(read self, take callback: Option[GlfwWindowFocusCallback]) -> Option[GlfwWindowFocusCallback]:
        return #unsafe glfwSetWindowFocusCallback :: self.raw, callback :: call

    fn set_iconify_callback(read self, take callback: Option[GlfwWindowIconifyCallback]) -> Option[GlfwWindowIconifyCallback]:
        return #unsafe glfwSetWindowIconifyCallback :: self.raw, callback :: call

    fn set_maximize_callback(read self, take callback: Option[GlfwWindowMaximizeCallback]) -> Option[GlfwWindowMaximizeCallback]:
        return #unsafe glfwSetWindowMaximizeCallback :: self.raw, callback :: call

    fn set_framebuffer_size_callback(read self, take callback: Option[GlfwFramebufferSizeCallback]) -> Option[GlfwFramebufferSizeCallback]:
        return #unsafe glfwSetFramebufferSizeCallback :: self.raw, callback :: call

    fn set_content_scale_callback(read self, take callback: Option[GlfwWindowContentScaleCallback]) -> Option[GlfwWindowContentScaleCallback]:
        return #unsafe glfwSetWindowContentScaleCallback :: self.raw, callback :: call

    fn make_context_current(read self) -> Unit:
        #unsafe glfwMakeContextCurrent :: self.raw :: call
        return

    fn swap_buffers(read self) -> Unit:
        #unsafe glfwSwapBuffers :: self.raw :: call
        return

pub fn glfw_image(width: CInt, height: CInt, pixels: *edit CUnsignedChar) -> GlfwImage:
    return GlfwImage :: width, height, pixels :: call
