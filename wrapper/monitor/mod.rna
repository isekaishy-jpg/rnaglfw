pub fn glfw_monitors() -> GlfwMonitorList:
    let count: CInt = 0
    let count_ptr: *edit CInt = #unsafe &raw edit count
    let base: *read *edit GlfwMonitorRaw = #unsafe glfwGetMonitors :: count_ptr :: call
    return GlfwMonitorList :: base, count :: call

pub fn glfw_primary_monitor() -> GlfwMonitor:
    let raw: *edit GlfwMonitorRaw = #unsafe glfwGetPrimaryMonitor :: :: call
    return GlfwMonitor :: raw :: call

pub fn glfw_set_monitor_callback(take callback: Option[GlfwMonitorCallback]) -> Option[GlfwMonitorCallback]:
    return #unsafe glfwSetMonitorCallback :: callback :: call

impl GlfwMonitor:
    fn pos(read self) -> GlfwPoint:
        let x: CInt = 0
        let y: CInt = 0
        let x_ptr: *edit CInt = #unsafe &raw edit x
        let y_ptr: *edit CInt = #unsafe &raw edit y
        #unsafe glfwGetMonitorPos :: self.raw, x_ptr, y_ptr :: call
        return GlfwPoint :: x, y :: call

    fn workarea(read self) -> GlfwRect:
        let x: CInt = 0
        let y: CInt = 0
        let width: CInt = 0
        let height: CInt = 0
        let x_ptr: *edit CInt = #unsafe &raw edit x
        let y_ptr: *edit CInt = #unsafe &raw edit y
        let width_ptr: *edit CInt = #unsafe &raw edit width
        let height_ptr: *edit CInt = #unsafe &raw edit height
        #unsafe glfwGetMonitorWorkarea :: self.raw, x_ptr, y_ptr, width_ptr, height_ptr :: call
        return GlfwRect :: x, y, width, height :: call

    fn physical_size(read self) -> GlfwSize:
        let width: CInt = 0
        let height: CInt = 0
        let width_ptr: *edit CInt = #unsafe &raw edit width
        let height_ptr: *edit CInt = #unsafe &raw edit height
        #unsafe glfwGetMonitorPhysicalSize :: self.raw, width_ptr, height_ptr :: call
        return GlfwSize :: width, height :: call

    fn content_scale(read self) -> GlfwScale:
        let x: F32 = 0.0
        let y: F32 = 0.0
        let x_ptr: *edit F32 = #unsafe &raw edit x
        let y_ptr: *edit F32 = #unsafe &raw edit y
        #unsafe glfwGetMonitorContentScale :: self.raw, x_ptr, y_ptr :: call
        return GlfwScale :: x, y :: call

    fn name(read self) -> *read CChar:
        return #unsafe glfwGetMonitorName :: self.raw :: call

    fn set_user_pointer(read self, pointer: *edit CVoid) -> Unit:
        #unsafe glfwSetMonitorUserPointer :: self.raw, pointer :: call
        return

    fn user_pointer(read self) -> *edit CVoid:
        return #unsafe glfwGetMonitorUserPointer :: self.raw :: call

    fn video_modes(read self) -> GlfwVideoModeList:
        let count: CInt = 0
        let count_ptr: *edit CInt = #unsafe &raw edit count
        let base: *read GlfwVideoMode = #unsafe glfwGetVideoModes :: self.raw, count_ptr :: call
        return GlfwVideoModeList :: base, count :: call

    fn video_mode(read self) -> Option[GlfwVideoMode]:
        let ptr: *read GlfwVideoMode = #unsafe glfwGetVideoMode :: self.raw :: call
        select:
            when ptr.is_null :: :: method => return Option.None
            else =>
                let mode: GlfwVideoMode = #unsafe ptr.load :: :: method
                return Option.Some :: mode :: call

    fn set_gamma(read self, gamma: F32) -> Unit:
        #unsafe glfwSetGamma :: self.raw, gamma :: call
        return

    fn gamma_ramp_ptr(read self) -> *read GlfwGammaRamp:
        return #unsafe glfwGetGammaRamp :: self.raw :: call

    fn gamma_ramp(read self) -> Option[GlfwGammaRamp]:
        let ptr: *read GlfwGammaRamp = self.gamma_ramp_ptr :: :: method
        select:
            when ptr.is_null :: :: method => return Option.None
            else =>
                let ramp: GlfwGammaRamp = #unsafe ptr.load :: :: method
                return Option.Some :: ramp :: call

    fn set_gamma_ramp(read self, read ramp: GlfwGammaRamp) -> Unit:
        let ramp_ptr: *read GlfwGammaRamp = #unsafe &raw read ramp
        #unsafe glfwSetGammaRamp :: self.raw, ramp_ptr :: call
        return

impl GlfwMonitorList:
    fn count(read self) -> CInt:
        return self.count_value

    fn raw_at(read self, index: CInt) -> GlfwMonitor:
        select:
            when self.base.is_null :: :: method => return glfw_monitor_none :: :: call
            when index < 0 => return glfw_monitor_none :: :: call
            when index >= self.count_value => return glfw_monitor_none :: :: call
            else =>
                let slot: *read *edit GlfwMonitorRaw = monitor_slot_at :: self.base, index :: call
                let raw: *edit GlfwMonitorRaw = #unsafe slot.load :: :: method
                return GlfwMonitor :: raw :: call

    fn at(read self, index: CInt) -> GlfwMonitor:
        return self.raw_at :: index :: method

    fn first(read self) -> GlfwMonitor:
        return self.at :: 0 :: method

impl GlfwVideoModeList:
    fn count(read self) -> CInt:
        return self.count_value

    fn raw_at(read self, index: CInt) -> GlfwVideoMode:
        let slot: *read GlfwVideoMode = video_mode_slot_at :: self.base, index :: call
        return #unsafe slot.load :: :: method

    fn at(read self, index: CInt) -> Option[GlfwVideoMode]:
        select:
            when self.base.is_null :: :: method => return Option.None
            when index < 0 => return Option.None
            when index >= self.count_value => return Option.None
            else =>
                let mode = self.raw_at :: index :: method
                return Option.Some :: mode :: call

    fn first(read self) -> Option[GlfwVideoMode]:
        return self.at :: 0 :: method
