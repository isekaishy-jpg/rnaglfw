use std.Option
use wrapper.core.{GlfwMonitor, GlfwMonitorRaw, glfw_monitor_none}
use wrapper.window.{GlfwPoint, GlfwRect, GlfwScale, GlfwSize}

pub struct GlfwMonitorList:
    pub(package) base: *read *edit GlfwMonitorRaw
    pub(package) count_value: CInt

pub struct GlfwVideoModeList:
    pub(package) base: *read GlfwVideoMode
    pub(package) count_value: CInt

const POINTER_OFFSET_STEP: ISize = 1

fn monitor_slot_at(base: *read *edit GlfwMonitorRaw, index: CInt) -> *read *edit GlfwMonitorRaw:
    let slot: *read *edit GlfwMonitorRaw = base
    let scan: CInt = 0
    repeat while scan < index:
        slot = #unsafe slot.offset :: POINTER_OFFSET_STEP :: method
        scan = scan + 1
    return slot

fn video_mode_slot_at(base: *read GlfwVideoMode, index: CInt) -> *read GlfwVideoMode:
    let slot: *read GlfwVideoMode = base
    let scan: CInt = 0
    repeat while scan < index:
        slot = #unsafe slot.offset :: POINTER_OFFSET_STEP :: method
        scan = scan + 1
    return slot

#repr[c]
pub struct GlfwVideoMode:
    pub width: CInt
    pub height: CInt
    pub red_bits: CInt
    pub green_bits: CInt
    pub blue_bits: CInt
    pub refresh_rate: CInt

#repr[c]
pub struct GlfwGammaRamp:
    pub red: *edit CUShort
    pub green: *edit CUShort
    pub blue: *edit CUShort
    pub size: CUInt

impl GlfwVideoMode:
    fn width_value(read self) -> CInt:
        return self.width

    fn height_value(read self) -> CInt:
        return self.height

    fn red_bits_value(read self) -> CInt:
        return self.red_bits

    fn green_bits_value(read self) -> CInt:
        return self.green_bits

    fn blue_bits_value(read self) -> CInt:
        return self.blue_bits

    fn refresh_rate_value(read self) -> CInt:
        return self.refresh_rate

impl GlfwGammaRamp:
    fn red_ptr(read self) -> *edit CUShort:
        return self.red

    fn green_ptr(read self) -> *edit CUShort:
        return self.green

    fn blue_ptr(read self) -> *edit CUShort:
        return self.blue

    fn size_value(read self) -> CUInt:
        return self.size

pub fn glfw_video_mode_width(read mode: GlfwVideoMode) -> CInt:
    return mode.width

pub fn glfw_video_mode_height(read mode: GlfwVideoMode) -> CInt:
    return mode.height

pub fn glfw_video_mode_red_bits(read mode: GlfwVideoMode) -> CInt:
    return mode.red_bits

pub fn glfw_video_mode_green_bits(read mode: GlfwVideoMode) -> CInt:
    return mode.green_bits

pub fn glfw_video_mode_blue_bits(read mode: GlfwVideoMode) -> CInt:
    return mode.blue_bits

pub fn glfw_video_mode_refresh_rate(read mode: GlfwVideoMode) -> CInt:
    return mode.refresh_rate

pub fn glfw_gamma_ramp_red(read ramp: GlfwGammaRamp) -> *edit CUShort:
    return ramp.red

pub fn glfw_gamma_ramp_green(read ramp: GlfwGammaRamp) -> *edit CUShort:
    return ramp.green

pub fn glfw_gamma_ramp_blue(read ramp: GlfwGammaRamp) -> *edit CUShort:
    return ramp.blue

pub fn glfw_gamma_ramp_size(read ramp: GlfwGammaRamp) -> CUInt:
    return ramp.size

pub type GlfwMonitorCallback = extern["c"] fn(*edit GlfwMonitorRaw, CInt) -> CVoid

