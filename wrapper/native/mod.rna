use std.Option
use wrapper.core.{GlfwMonitor, GlfwMonitorRaw, GlfwWindow, GlfwWindowRaw}
use wrapper.core.glfw_cint_is_true

pub type GlfwWin32HWnd = *edit CVoid
pub type GlfwWglContext = *edit CVoid
pub type GlfwEglDisplay = *edit CVoid
pub type GlfwEglContext = *edit CVoid
pub type GlfwEglSurface = *edit CVoid
pub type GlfwOsMesaContext = *edit CVoid

pub struct GlfwOSMesaColorBuffer:
    pub width: CInt
    pub height: CInt
    pub format: CInt
    pub buffer: *edit CVoid

pub struct GlfwOSMesaDepthBuffer:
    pub width: CInt
    pub height: CInt
    pub bytes_per_value: CInt
    pub buffer: *edit CVoid

impl GlfwOSMesaColorBuffer:
    fn width_value(read self) -> CInt:
        return self.width

    fn height_value(read self) -> CInt:
        return self.height

    fn format_value(read self) -> CInt:
        return self.format

    fn buffer_ptr(read self) -> *edit CVoid:
        return self.buffer

impl GlfwOSMesaDepthBuffer:
    fn width_value(read self) -> CInt:
        return self.width

    fn height_value(read self) -> CInt:
        return self.height

    fn bytes_per_value(read self) -> CInt:
        return self.bytes_per_value

    fn buffer_ptr(read self) -> *edit CVoid:
        return self.buffer

pub fn glfw_osmesa_color_buffer_width(read report: GlfwOSMesaColorBuffer) -> CInt:
    return report.width

pub fn glfw_osmesa_color_buffer_height(read report: GlfwOSMesaColorBuffer) -> CInt:
    return report.height

pub fn glfw_osmesa_color_buffer_format(read report: GlfwOSMesaColorBuffer) -> CInt:
    return report.format

pub fn glfw_osmesa_color_buffer_data(read report: GlfwOSMesaColorBuffer) -> *edit CVoid:
    return report.buffer

pub fn glfw_osmesa_depth_buffer_width(read report: GlfwOSMesaDepthBuffer) -> CInt:
    return report.width

pub fn glfw_osmesa_depth_buffer_height(read report: GlfwOSMesaDepthBuffer) -> CInt:
    return report.height

pub fn glfw_osmesa_depth_buffer_bytes_per_value(read report: GlfwOSMesaDepthBuffer) -> CInt:
    return report.bytes_per_value

pub fn glfw_osmesa_depth_buffer_data(read report: GlfwOSMesaDepthBuffer) -> *edit CVoid:
    return report.buffer

