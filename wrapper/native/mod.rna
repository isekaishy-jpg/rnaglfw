pub fn glfw_get_egl_display() -> GlfwEglDisplay:
    return #unsafe glfwGetEGLDisplay :: :: call

pub fn glfw_set_win32_parent_window_hint(parent: GlfwWin32HWnd) -> Unit:
    #unsafe glfwSetWin32ParentWindowHint :: parent :: call
    return

impl GlfwMonitor:
    fn win32_adapter_name(read self) -> *read CChar:
        return #unsafe glfwGetWin32Adapter :: self.raw :: call

    fn win32_monitor_name(read self) -> *read CChar:
        return #unsafe glfwGetWin32Monitor :: self.raw :: call

impl GlfwWindow:
    fn win32_window(read self) -> GlfwWin32HWnd:
        return #unsafe glfwGetWin32Window :: self.raw :: call

    fn win32_clip_children(read self) -> Bool:
        let enabled = #unsafe glfwGetWin32ClipChildren :: self.raw :: call
        return glfw_cint_is_true :: enabled :: call

    fn set_win32_clip_children(read self, enabled: Bool) -> Bool:
        let raw_enabled: CInt = 0
        select:
            when enabled => raw_enabled = 1
            else => ()
        let updated = #unsafe glfwSetWin32ClipChildren :: self.raw, raw_enabled :: call
        return glfw_cint_is_true :: updated :: call

    fn wgl_context(read self) -> GlfwWglContext:
        return #unsafe glfwGetWGLContext :: self.raw :: call

    fn egl_context(read self) -> GlfwEglContext:
        return #unsafe glfwGetEGLContext :: self.raw :: call

    fn egl_surface(read self) -> GlfwEglSurface:
        return #unsafe glfwGetEGLSurface :: self.raw :: call

    fn osmesa_color_buffer(read self) -> Option[GlfwOSMesaColorBuffer]:
        let width: CInt = 0
        let height: CInt = 0
        let format: CInt = 0
        let buffer: *edit CVoid = null
        let width_ptr: *edit CInt = #unsafe &raw edit width
        let height_ptr: *edit CInt = #unsafe &raw edit height
        let format_ptr: *edit CInt = #unsafe &raw edit format
        let buffer_ptr: *edit *edit CVoid = #unsafe &raw edit buffer
        let success: CInt = #unsafe glfwGetOSMesaColorBuffer :: self.raw, width_ptr, height_ptr, format_ptr, buffer_ptr :: call
        select:
            when glfw_cint_is_true :: success :: call =>
                let report = GlfwOSMesaColorBuffer :: width, height, format, buffer :: call
                return Option.Some :: report :: call
            else => return Option.None

    fn osmesa_depth_buffer(read self) -> Option[GlfwOSMesaDepthBuffer]:
        let width: CInt = 0
        let height: CInt = 0
        let bytes_per_value: CInt = 0
        let buffer: *edit CVoid = null
        let width_ptr: *edit CInt = #unsafe &raw edit width
        let height_ptr: *edit CInt = #unsafe &raw edit height
        let bytes_ptr: *edit CInt = #unsafe &raw edit bytes_per_value
        let buffer_ptr: *edit *edit CVoid = #unsafe &raw edit buffer
        let success: CInt = #unsafe glfwGetOSMesaDepthBuffer :: self.raw, width_ptr, height_ptr, bytes_ptr, buffer_ptr :: call
        select:
            when glfw_cint_is_true :: success :: call =>
                let report = GlfwOSMesaDepthBuffer :: width, height, bytes_per_value, buffer :: call
                return Option.Some :: report :: call
            else => return Option.None

    fn osmesa_context(read self) -> GlfwOsMesaContext:
        return #unsafe glfwGetOSMesaContext :: self.raw :: call
